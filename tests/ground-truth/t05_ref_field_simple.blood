// Test: returning &self.field from a method
struct Point {
    x: i32,
    y: i32,
}

impl Point {
    fn new(x: i32, y: i32) -> Point {
        Point { x: x, y: y }
    }

    fn get_x(self: &Self) -> &i32 {
        &self.x
    }

    fn get_y(self: &Self) -> &i32 {
        &self.y
    }
}

fn main() -> i32 {
    let p: Point = Point.new(42, 99);
    let xr: &i32 = p.get_x();
    let yr: &i32 = p.get_y();
    println_int(*xr);
    println_int(*yr);
    if *xr != 42 {
        return 1;
    }
    if *yr != 99 {
        return 2;
    }
    0
}
