// RUN: expect_exit 0
// Test: semicolons optional on all statements (SYN-06 Phase 1 + Phase 2)

fn test_let_if() -> i32 {
    let x = if true { 10 } else { 20 }
    x
}

fn test_let_match() -> i32 {
    let x = match 3 {
        1 => { 100 }
        2 => { 200 }
        _ => { 300 }
    }
    x
}

fn test_let_block() -> i32 {
    let x = {
        let a = 5;
        a * 2
    }
    x
}

fn test_let_loop() -> i32 {
    let mut n = 0;
    let x = for i in 0..5 {
        n = n + 1;
    }
    n
}

fn test_semi_still_works() -> i32 {
    let a = if true { 1 } else { 0 };
    let b = match a {
        0 => { 10 }
        _ => { 20 }
    };
    let c = { 30 };
    a + b + c
}

fn test_nested() -> i32 {
    let x = if true {
        let y = match 1 {
            1 => { 42 }
            _ => { 0 }
        }
        y
    } else {
        0
    }
    x
}

// Phase 2: semicolons optional on ALL let statements (not just block-like)
fn test_simple_let_no_semi() -> i32 {
    let x = 42
    let y = 10
    x + y
}

fn test_multiple_no_semi() -> i32 {
    let a = 1
    let b = 2
    let c = 3
    a + b + c
}

fn test_mixed_semi() -> i32 {
    let a = 10;
    let b = 20
    let c = 30;
    let d = 40
    a + b + c + d
}

fn main() -> i32 {
    let a = test_let_if()
    let b = test_let_match()
    let c = test_let_block()
    let d = test_let_loop()
    let e = test_semi_still_works()
    let f = test_nested()
    let g = test_simple_let_no_semi()
    let h = test_multiple_no_semi()
    let k = test_mixed_semi()

    if a != 10 { return 1 }
    if b != 300 { return 2 }
    if c != 10 { return 3 }
    if d != 5 { return 4 }
    if e != 51 { return 5 }
    if f != 42 { return 6 }
    if g != 52 { return 7 }
    if h != 6 { return 8 }
    if k != 100 { return 9 }
    0
}
