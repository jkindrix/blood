// COMPILE_FAIL: duplicate method name in impl block
// EXPECT: [E0214] the name `def351::get` is defined multiple times
// Test: two methods with the same name in impl block should fail
struct Foo {
    x: i32,
}

impl Foo {
    fn get(self) -> i32 { self.x }
    fn get(self) -> i32 { self.x + 1 }
}

fn main() -> i32 {
    0
}
