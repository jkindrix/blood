// Test: dispatch with no arguments beyond receiver
// EXPECT: default
// EXPECT: 42

struct Factory {}

impl Factory {
    fn create(self) -> i32 {
        println_str("default");
        0
    }
    fn create(self, x: i32) -> i32 {
        x
    }
}

fn main() -> i32 {
    let f: Factory = Factory {};
    f.create();
    println_int(f.create(42));
    0
}
