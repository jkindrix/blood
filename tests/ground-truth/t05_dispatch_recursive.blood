// Test: recursive function using dispatch (same method called recursively)
// EXPECT: 120

struct Math {}

impl Math {
    fn factorial(self, n: i32) -> i32 {
        if n <= 1 {
            1
        } else {
            n * self.factorial(n - 1)
        }
    }
}

fn main() -> i32 {
    let m: Math = Math {};
    println_int(m.factorial(5));
    0
}
