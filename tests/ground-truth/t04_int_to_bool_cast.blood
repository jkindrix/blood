// Test: integer to bool cast (0=false, nonzero=true)

fn main() -> i32 {
    // Zero should be false
    let a: bool = 0 as bool;
    // Nonzero should be true
    let b: bool = 42 as bool;
    let c: bool = 1 as bool;
    let d: bool = -1i32 as bool;

    // Verify false = 0, true = 1 when cast back
    let a_int: i32 = a as i32;
    let b_int: i32 = b as i32;
    let c_int: i32 = c as i32;
    let d_int: i32 = d as i32;

    // a=false(0), b=true(1), c=true(1), d=true(1) => sum = 3
    // Return 0 if all correct
    if a_int == 0 && b_int == 1 && c_int == 1 && d_int == 1 {
        0
    } else {
        1
    }
}
