// COMPILE_FAIL: performing undeclared effect (E0308)
// EXPECT: [E0308] function performs undeclared effects: Logger
// Test: performing an effect not listed in the function's effect row should fail
effect Logger {
    op log(msg: i32) -> ();
}

fn pure_function() -> i32 {
    perform Logger.log(42);
    0
}

fn main() -> i32 {
    0
}
