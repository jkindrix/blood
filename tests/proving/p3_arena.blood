// Program 3: arena — Use-after-free caught at dereference
// Pillar 1: Veracity (Generational References)
//
// Demonstrates:
// 1. Fat references ({ ptr, i32 }) carrying generation counters
// 2. Region blocks with implicit allocation
// 3. Region destruction increments generation (stale refs detectable)
// 4. Stale reference detection at dereference (gen mismatch → caught by handler)
// 5. Derived references (&entity.field propagates gen from source)
// 6. References surviving across function boundaries
// 7. Named regions with lifetime labels

// ============================================================
// Types
// ============================================================

struct Entity {
    x: i32,
    y: i32,
    health: i32,
}

// ============================================================
// StaleReference effect — built-in effect (ID 4100) that fires
// on gen-ref mismatch. User code can install a handler to catch it.
// ============================================================

effect StaleReference {
    op stale(expected: i32, actual: i32) -> ();
}

deep handler CatchStale for StaleReference {
    let mut caught: i32
    return(x) { caught }
    op stale(expected, actual) {
        caught = caught + 1;
        print_str("STALE CAUGHT: expected gen=");
        println_int(expected);
        resume(())
    }
}

// ============================================================
// Helper functions — refs cross function boundaries
// ============================================================

fn get_health(e: &Entity) -> i32 {
    e.health
}

fn get_x(e: &Entity) -> i32 {
    e.x
}

// ============================================================
// Part 1: Region allocation + field access through refs
// ============================================================

fn test_basic_region() -> i32 {
    let result: i32 = region {
        let entity: Entity = Entity { x: 10, y: 20, health: 100 };
        let h: i32 = get_health(&entity);
        print_str("health=");
        println_int(h);
        if h != 100 { return 1; }

        let ex: i32 = get_x(&entity);
        print_str("x=");
        println_int(ex);
        if ex != 10 { return 2; }
        0
    };
    result
}

// ============================================================
// Part 2: Cross-function reference survival
// ============================================================

fn read_through_ref(r: &Entity) -> i32 {
    let val: i32 = r.health;
    print_str("ref.health=");
    println_int(val);
    val
}

fn test_cross_function_ref() -> i32 {
    let result: i32 = region {
        let e: Entity = Entity { x: 5, y: 15, health: 200 };
        let r: &Entity = &e;
        let h: i32 = read_through_ref(r);
        if h != 200 { return 3; }
        0
    };
    result
}

// ============================================================
// Part 3: Multiple entities in same region
// ============================================================

fn test_multiple_entities() -> i32 {
    let result: i32 = region {
        let a: Entity = Entity { x: 1, y: 2, health: 10 };
        let b: Entity = Entity { x: 3, y: 4, health: 20 };
        let c: Entity = Entity { x: 5, y: 6, health: 30 };
        let sum: i32 = get_health(&a) + get_health(&b) + get_health(&c);
        print_str("sum=");
        println_int(sum);
        if sum != 60 { return 4; }
        0
    };
    result
}

// ============================================================
// Part 4: STALE REFERENCE DETECTION — the headline Pillar 1 feature
//
// A reference escapes its region via outer variable mutation.
// After region destruction, dereferencing it triggers the
// StaleReference effect, which our handler catches.
// ============================================================

fn test_stale_detection() -> i32 {
    let dummy: Entity = Entity { x: 0, y: 0, health: 0 };
    let mut stale: &Entity = &dummy;

    let stale_count: i32 = with CatchStale { caught: 0 } handle {
        // Create a region, take a reference, escape it via mutation
        region {
            let entity: Entity = Entity { x: 42, y: 99, health: 777 };
            stale = &entity;
            // Verify the reference works WHILE region is alive
            let h: i32 = stale.health;
            print_str("alive: health=");
            println_int(h);
        };
        // Region destroyed — stale's generation is now outdated

        // Dereference the stale reference — triggers StaleReference effect
        println_str("dereferencing stale ref...");
        let _val: i32 = (*stale).health;
        // If handler resumed, we continue here
        println_str("handler caught stale ref and resumed");
        0
    };

    print_str("stale catches=");
    println_int(stale_count);
    // Must have caught exactly 1 stale reference
    if stale_count != 1 { return 5; }
    0
}

// ============================================================
// Part 5: Derived references propagate generation
//
// Taking &entity.field should carry the same generation as &entity.
// If the entity's region is destroyed, the derived ref is also stale.
// ============================================================

fn read_field_ref(r: &Entity) -> i32 {
    // Access field through reference — gen propagates from source ref
    r.x + r.y
}

fn test_derived_refs() -> i32 {
    let result: i32 = region {
        let entity: Entity = Entity { x: 7, y: 13, health: 50 };
        let r: &Entity = &entity;
        // Derived access: r.x and r.y propagate gen from r
        let sum: i32 = read_field_ref(r);
        print_str("derived x+y=");
        println_int(sum);
        if sum != 20 { return 6; }
        0
    };
    result
}

// ============================================================
// Part 6: Named regions with lifetime labels
// ============================================================

fn test_named_regions() -> i32 {
    let result: i32 = region 'outer {
        let outer_entity: Entity = Entity { x: 100, y: 200, health: 300 };
        let oh: i32 = get_health(&outer_entity);
        print_str("outer.health=");
        println_int(oh);
        if oh != 300 { return 7; }
        0
    };
    result
}

// ============================================================
// Main
// ============================================================

fn main() -> i32 {
    println_str("=== Part 1: Basic region allocation ===");
    let r1: i32 = test_basic_region();
    if r1 != 0 { return r1; }

    println_str("=== Part 2: Cross-function reference ===");
    let r2: i32 = test_cross_function_ref();
    if r2 != 0 { return r2; }

    println_str("=== Part 3: Multiple entities ===");
    let r3: i32 = test_multiple_entities();
    if r3 != 0 { return r3; }

    println_str("=== Part 4: Stale reference detection ===");
    let r4: i32 = test_stale_detection();
    if r4 != 0 { return r4; }

    println_str("=== Part 5: Derived references ===");
    let r5: i32 = test_derived_refs();
    if r5 != 0 { return r5; }

    println_str("=== Part 6: Named regions ===");
    let r6: i32 = test_named_regions();
    if r6 != 0 { return r6; }

    println_str("=== All parts passed ===");
    0
}
