// Program 4: multidispatch -- Methods that specialize without inheritance
// Pillar 4: Extensibility (Multiple Dispatch)
//
// EXPECT: === Part 1: Circle+Screen specialized ===
// EXPECT: SPECIALIZED circle+screen r=5
// EXPECT: === Part 2: Rect+Printer specialized ===
// EXPECT: SPECIALIZED rect+printer w=4
// EXPECT: === Part 3: Tri+Screen specialized ===
// EXPECT: SPECIALIZED tri+screen b=3
// EXPECT: === Part 4: Generic fallback ===
// EXPECT: generic draw
// EXPECT: === Part 5: Retroactive extension ===
// EXPECT: generic draw
// EXPECT: === Part 6: Constraint specificity ===
// EXPECT: format(Printable+Measurable)
// EXPECT: format(Printable)
// EXPECT: === Part 7: Concrete vs constrained ===
// EXPECT: process(Circle) r=5
// EXPECT: process(Rect) w=4
// EXPECT: process(Shape)
// EXPECT: process(Shape)
// EXPECT: === Part 8: Where clauses ===
// EXPECT: === Part 9: Effect-row dispatch ===
// EXPECT: execute: pure
// EXPECT: execute: audited
// EXPECT: === Part 10: Cross-module dispatch ===
// EXPECT: process(Shape)
// EXPECT: pentagon area=18
// EXPECT: === All parts passed ===

// ============================================================
// Part 1: Traits — the dispatch interfaces
// ============================================================

trait Shape {
    fn area(self: &Self) -> i32;
}

trait Surface {
    fn dpi(self: &Self) -> i32;
}

// ============================================================
// Part 2: Concrete types + trait implementations
// ============================================================

struct Circle { radius: i32 }
struct Rectangle { width: i32, height: i32 }
struct Triangle { base: i32, height: i32 }

struct Screen { resolution: i32 }
struct Printer { model: i32 }

impl Shape for Circle {
    fn area(self: &Self) -> i32 { self.radius * self.radius * 3 }
}

impl Shape for Rectangle {
    fn area(self: &Self) -> i32 { self.width * self.height }
}

impl Shape for Triangle {
    fn area(self: &Self) -> i32 { self.base * self.height / 2 }
}

impl Surface for Screen {
    fn dpi(self: &Self) -> i32 { self.resolution }
}

impl Surface for Printer {
    fn dpi(self: &Self) -> i32 { self.model * 10 }
}

// ============================================================
// Part 3: Multi-argument dispatch with specialization
// ============================================================

struct Renderer {}

impl Renderer {
    /// Generic: any Shape + any Surface → returns 1
    fn draw<S: Shape, T: Surface>(self, shape: &S, surface: &T) -> i32 {
        println_str("generic draw");
        1
    }

    /// Specialized: Circle + Screen → returns 2
    fn draw(self, circle: &Circle, screen: &Screen) -> i32 {
        print_str("SPECIALIZED circle+screen r=");
        println_int(circle.radius);
        2
    }

    /// Specialized: Rectangle + Printer → returns 3
    fn draw(self, rect: &Rectangle, printer: &Printer) -> i32 {
        print_str("SPECIALIZED rect+printer w=");
        println_int(rect.width);
        3
    }

    /// Specialized: Triangle + Screen → returns 4
    fn draw(self, tri: &Triangle, screen: &Screen) -> i32 {
        print_str("SPECIALIZED tri+screen b=");
        println_int(tri.base);
        4
    }
}

// ============================================================
// Part 4: Constraint specificity (more bounds = more specific)
// ============================================================

trait Printable {
    fn tag(self: &Self) -> i32;
}

trait Measurable {
    fn size(self: &Self) -> i32;
}

impl Printable for Circle {
    fn tag(self: &Self) -> i32 { 100 }
}

impl Measurable for Circle {
    fn size(self: &Self) -> i32 { self.radius * 2 }
}

impl Printable for Rectangle {
    fn tag(self: &Self) -> i32 { 200 }
}

// Rectangle does NOT implement Measurable

struct Formatter {}

impl Formatter {
    /// One-constraint: T: Printable → returns 10
    fn format<T: Printable>(self, x: &T) -> i32 {
        println_str("format(Printable)");
        10
    }

    /// Two-constraint: T: Printable + Measurable → returns 20 (more specific)
    fn format<T: Printable + Measurable>(self, x: &T) -> i32 {
        println_str("format(Printable+Measurable)");
        20
    }
}

// ============================================================
// Part 5: Retroactive extension — add new type + impls
// ============================================================

struct Hexagon { side: i32 }

impl Shape for Hexagon {
    fn area(self: &Self) -> i32 {
        let s2: i32 = self.side * self.side;
        s2 * 2 + s2 / 2
    }
}

// Hexagon now dispatches through Renderer.draw<S,T> without modifying Renderer.

// ============================================================
// Part 6: Single-argument concrete vs constrained dispatch
// ============================================================

// ============================================================
// Part 8: Where clauses on dispatched methods
// ============================================================

fn describe<T>(x: &T) -> i32 where T: Shape + Printable {
    x.area() + x.tag()
}

fn describe_shape<T>(x: &T) -> i32 where T: Shape {
    x.area()
}

// ============================================================
// Part 9: Effect-row dispatch (methods selected by effect context)
// ============================================================

effect Audit {
    op log_op(tag: &str) -> ();
}

struct Worker {}

impl Worker {
    fn execute(self) -> i32 {
        println_str("execute: pure");
        1
    }

    fn execute(self) -> i32 / {Audit} {
        perform Audit.log_op("execute: audited");
        2
    }
}

deep handler AuditLog for Audit {
    return(x) { x }
    op log_op(tag) { println_str(tag); resume(()) }
}

// ============================================================
// Part 10: Cross-module dispatch
// ============================================================

mod p4_shapes_mod;
use p4_shapes_mod.Pentagon;
// Pentagon implements Shape in the module — dispatches through Processor.process<T: Shape>

struct Processor {}

impl Processor {
    /// Generic: any Shape → returns 100
    fn process<T: Shape>(self, x: &T) -> i32 {
        println_str("process(Shape)");
        100
    }

    /// Concrete: Circle → returns 200 (more specific than T: Shape)
    fn process(self, x: &Circle) -> i32 {
        print_str("process(Circle) r=");
        println_int(x.radius);
        200
    }

    /// Concrete: Rectangle → returns 300
    fn process(self, x: &Rectangle) -> i32 {
        print_str("process(Rect) w=");
        println_int(x.width);
        300
    }
}

// ============================================================
// Main
// ============================================================

fn main() -> i32 {
    let r: Renderer = Renderer {};
    let fmt: Formatter = Formatter {};
    let proc: Processor = Processor {};

    let circle: Circle = Circle { radius: 5 };
    let rect: Rectangle = Rectangle { width: 4, height: 6 };
    let tri: Triangle = Triangle { base: 3, height: 8 };
    let hex: Hexagon = Hexagon { side: 4 };
    let screen: Screen = Screen { resolution: 300 };
    let printer: Printer = Printer { model: 42 };

    // Part 1: Specialized multi-param dispatch
    println_str("=== Part 1: Circle+Screen specialized ===");
    let r1: i32 = r.draw(&circle, &screen);
    if r1 != 2 { print_str("FAIL r1="); println_int(r1); return 1; }

    // Part 2: Another specialization
    println_str("=== Part 2: Rect+Printer specialized ===");
    let r2: i32 = r.draw(&rect, &printer);
    if r2 != 3 { print_str("FAIL r2="); println_int(r2); return 2; }

    // Part 3: Tri+Screen specialization
    println_str("=== Part 3: Tri+Screen specialized ===");
    let r3: i32 = r.draw(&tri, &screen);
    if r3 != 4 { print_str("FAIL r3="); println_int(r3); return 3; }

    // Part 4: Generic fallback — no specialization for Circle+Printer
    println_str("=== Part 4: Generic fallback ===");
    let r4: i32 = r.draw(&circle, &printer);
    if r4 != 1 { print_str("FAIL r4="); println_int(r4); return 4; }

    // Part 5: Generic fallback — Hexagon (new type, no specialization)
    println_str("=== Part 5: Retroactive extension ===");
    let r5: i32 = r.draw(&hex, &screen);
    if r5 != 1 { print_str("FAIL r5="); println_int(r5); return 5; }

    // Part 6: Constraint specificity — more bounds wins
    println_str("=== Part 6: Constraint specificity ===");
    // Circle: Printable + Measurable → two-constraint wins (20)
    let f1: i32 = fmt.format(&circle);
    if f1 != 20 { print_str("FAIL f1="); println_int(f1); return 6; }

    // Rectangle: only Printable (NOT Measurable) → one-constraint wins (10)
    let f2: i32 = fmt.format(&rect);
    if f2 != 10 { print_str("FAIL f2="); println_int(f2); return 7; }

    // Part 7: Concrete vs constrained dispatch
    println_str("=== Part 7: Concrete vs constrained ===");
    // Circle → concrete process(Circle) = 200
    let p1: i32 = proc.process(&circle);
    if p1 != 200 { print_str("FAIL p1="); println_int(p1); return 8; }

    // Rectangle → concrete process(Rect) = 300
    let p2: i32 = proc.process(&rect);
    if p2 != 300 { print_str("FAIL p2="); println_int(p2); return 9; }

    // Triangle → generic process(Shape) = 100
    let p3: i32 = proc.process(&tri);
    if p3 != 100 { print_str("FAIL p3="); println_int(p3); return 10; }

    // Hexagon → generic process(Shape) = 100
    let p4: i32 = proc.process(&hex);
    if p4 != 100 { print_str("FAIL p4="); println_int(p4); return 11; }

    // Part 8: Where clauses
    println_str("=== Part 8: Where clauses ===");
    // Circle: Shape + Printable → describe works (area + tag = 75 + 100 = 175)
    let d1: i32 = describe(&circle);
    if d1 != 175 { print_str("FAIL d1="); println_int(d1); return 12; }
    // describe_shape (only Shape bound) works for any Shape
    let d2: i32 = describe_shape(&tri);
    if d2 != 12 { print_str("FAIL d2="); println_int(d2); return 13; }

    // Part 9: Effect-row dispatch
    println_str("=== Part 9: Effect-row dispatch ===");
    let w: Worker = Worker {};
    // Outside handler: selects pure overload
    let e1: i32 = w.execute();
    if e1 != 1 { print_str("FAIL e1="); println_int(e1); return 14; }
    // Inside handler: selects audited overload
    let e2: i32 = with AuditLog {} handle {
        w.execute()
    };
    if e2 != 2 { print_str("FAIL e2="); println_int(e2); return 15; }

    // Part 10: Cross-module dispatch
    println_str("=== Part 10: Cross-module dispatch ===");
    let pent: Pentagon = Pentagon { side: 3 };
    let p5: i32 = proc.process(&pent);
    if p5 != 100 { print_str("FAIL p5="); println_int(p5); return 16; }
    print_str("pentagon area=");
    println_int(pent.area());

    println_str("=== All parts passed ===");
    0
}
