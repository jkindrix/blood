// Program 7: actors -- Message-passing with memory safety
// Pillars: 3 (Effects) + 1 (Generational Refs) + 5 (Regions)
//
// EXPECT: === Part 1: Region actors + effects ===
// EXPECT: actor_a inbox=15
// EXPECT: actor_b inbox=50
// EXPECT: === Part 2: Cross-function refs in handler ===
// EXPECT: cross-fn inbox=350
// EXPECT: === Part 3: Three actors, one pool ===
// EXPECT: total=66
// EXPECT: === Part 4: Stale actor handle detection ===
// EXPECT: alive: inbox=42
// EXPECT: reading stale actor handle...
// EXPECT: STALE ACTOR: gen expected=42
// EXPECT: stale handle caught, resumed
// EXPECT: stale catches=1
// EXPECT: === Part 5: Handler state persistence ===
// EXPECT: pre-loaded a=105
// EXPECT: pre-loaded b=210
// EXPECT: === All parts passed ===

// ============================================================
// Types
// ============================================================

struct Actor {
    id: i32,
    inbox_count: i32,
}

// ============================================================
// Effects
// ============================================================

effect Send {
    op send_msg(target_id: i32, value: i32) -> ();
    op get_inbox(actor_id: i32) -> i32;
}

// Built-in effect (ID 4100) — fires on gen-ref mismatch at dereference
effect StaleReference {
    op stale(expected: i32, actual: i32) -> ();
}

// ============================================================
// Handlers
// ============================================================

deep handler MessageRouter for Send {
    let mut inbox_a: i32
    let mut inbox_b: i32
    let mut inbox_c: i32

    return(x) { x }

    op send_msg(target_id, value) {
        if target_id == 1 {
            inbox_a = inbox_a + value;
        } else if target_id == 2 {
            inbox_b = inbox_b + value;
        } else {
            inbox_c = inbox_c + value;
        }
        resume(())
    }

    op get_inbox(actor_id) {
        if actor_id == 1 {
            resume(inbox_a)
        } else if actor_id == 2 {
            resume(inbox_b)
        } else {
            resume(inbox_c)
        }
    }
}

deep handler CatchStale for StaleReference {
    let mut caught: i32
    return(x) { caught }
    op stale(expected, actual) {
        caught = caught + 1;
        print_str("STALE ACTOR: gen expected=");
        println_int(expected);
        resume(())
    }
}

// ============================================================
// Actor operations
// ============================================================

fn send_to(actor: &Actor, value: i32) / {Send} {
    perform Send.send_msg(actor.id, value);
}

fn check_inbox(actor: &Actor) -> i32 / {Send} {
    perform Send.get_inbox(actor.id)
}

// ============================================================
// Main
// ============================================================

fn main() -> i32 {
    // Part 1: Region-allocated actors + effect-based messaging
    println_str("=== Part 1: Region actors + effects ===");
    let r1: i32 = with MessageRouter { inbox_a: 0, inbox_b: 0, inbox_c: 0 } handle {
        region 'pool {
            let actor_a: Actor = Actor { id: 1, inbox_count: 0 };
            let actor_b: Actor = Actor { id: 2, inbox_count: 0 };

            send_to(&actor_a, 10);
            send_to(&actor_b, 20);
            send_to(&actor_a, 5);
            send_to(&actor_b, 30);

            let a_total: i32 = check_inbox(&actor_a);
            let b_total: i32 = check_inbox(&actor_b);
            print_str("actor_a inbox=");
            println_int(a_total);
            print_str("actor_b inbox=");
            println_int(b_total);
            if a_total != 15 { 0 - 1 } else if b_total != 50 { 0 - 2 } else { 0 }
        }
    };
    if r1 != 0 { return 1; }

    // Part 2: Cross-function ref survival inside handler
    println_str("=== Part 2: Cross-function refs in handler ===");
    let r2: i32 = with MessageRouter { inbox_a: 0, inbox_b: 0, inbox_c: 0 } handle {
        region {
            let actor: Actor = Actor { id: 1, inbox_count: 0 };
            let r: &Actor = &actor;
            send_to(r, 100);
            send_to(r, 200);
            send_to(r, 50);
            check_inbox(r)
        }
    };
    print_str("cross-fn inbox=");
    println_int(r2);
    if r2 != 350 { return 2; }

    // Part 3: Three actors, one pool
    println_str("=== Part 3: Three actors, one pool ===");
    let r3: i32 = with MessageRouter { inbox_a: 0, inbox_b: 0, inbox_c: 0 } handle {
        region 'pool {
            let a: Actor = Actor { id: 1, inbox_count: 0 };
            let b: Actor = Actor { id: 2, inbox_count: 0 };
            let c: Actor = Actor { id: 3, inbox_count: 0 };
            send_to(&a, 1);
            send_to(&b, 2);
            send_to(&c, 3);
            send_to(&a, 10);
            send_to(&b, 20);
            send_to(&c, 30);
            let total: i32 = check_inbox(&a) + check_inbox(&b) + check_inbox(&c);
            print_str("total=");
            println_int(total);
            if total != 66 { 0 - 1 } else { 0 }
        }
    };
    if r3 != 0 { return 3; }

    // Part 4: STALE ACTOR HANDLE DETECTION
    // Region destruction = actor teardown. After the region is destroyed,
    // the actor handle's generation is outdated. Dereferencing it triggers
    // the StaleReference effect, caught by our handler.
    println_str("=== Part 4: Stale actor handle detection ===");
    let dummy: Actor = Actor { id: 0, inbox_count: 0 };
    let mut stale_handle: &Actor = &dummy;

    let stale_count: i32 = with CatchStale { caught: 0 } handle {
        with MessageRouter { inbox_a: 0, inbox_b: 0, inbox_c: 0 } handle {
            region 'pool {
                let actor: Actor = Actor { id: 1, inbox_count: 0 };
                stale_handle = &actor;
                // Actor is alive — send works
                send_to(stale_handle, 42);
                let inbox: i32 = check_inbox(stale_handle);
                print_str("alive: inbox=");
                println_int(inbox);
            };
            // Region 'pool destroyed — actor freed, handle is stale

            // Attempt to read from stale actor handle
            println_str("reading stale actor handle...");
            let _id: i32 = (*stale_handle).id;
            // StaleReference effect caught by CatchStale handler
            println_str("stale handle caught, resumed");
            0
        }
    };
    print_str("stale catches=");
    println_int(stale_count);
    if stale_count != 1 { return 4; }

    // Part 5: Handler state persists across operations
    println_str("=== Part 5: Handler state persistence ===");
    let r5: i32 = with MessageRouter { inbox_a: 100, inbox_b: 200, inbox_c: 0 } handle {
        region {
            let a: Actor = Actor { id: 1, inbox_count: 0 };
            let b: Actor = Actor { id: 2, inbox_count: 0 };
            send_to(&a, 5);
            send_to(&b, 10);
            let at: i32 = check_inbox(&a);
            let bt: i32 = check_inbox(&b);
            print_str("pre-loaded a=");
            println_int(at);
            print_str("pre-loaded b=");
            println_int(bt);
            if at != 105 { 0 - 1 } else if bt != 210 { 0 - 2 } else { 0 }
        }
    };
    if r5 != 0 { return 5; }

    println_str("=== All parts passed ===");
    0
}
