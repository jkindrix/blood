// Module for P4 multidispatch: demonstrates cross-module dispatch.
// Shape trait is defined in the main file; this module provides a new type
// that implements it, proving retroactive conformance across module boundaries.

struct Pentagon { side: i32 }

impl Shape for Pentagon {
    fn area(self: &Self) -> i32 {
        // Approximate: 5 * s^2 * tan(54°) / 4 ≈ 1.72 * s^2 ≈ 2 * s^2 for integers
        self.side * self.side * 2
    }
}
