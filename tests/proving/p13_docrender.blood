// Proving Ground Program 13: docrender - Document renderer (capstone)
// All-pillar integration: P1 (regions) + P3 (effects) + P4 (dispatch) + P5 (linear)
// Plus: closures, pattern matching, match guards, macros, handler state
//
// EXPECT: === Plain ===
// EXPECT: # Welcome
// EXPECT: This is a test document.
// EXPECT: *important*
// EXPECT: ## Details
// EXPECT: More content here.
// EXPECT: === Decorated ===
// EXPECT: [H1] Welcome
// EXPECT: [P] This is a test document.
// EXPECT: [EM] important
// EXPECT: [H2] Details
// EXPECT: [P] More content here.
// EXPECT: === Custom ===
// EXPECT: <Welcome>
// EXPECT: === Stats ===
// EXPECT: nodes: 6, depth: 1
// EXPECT: === GenRef ===
// EXPECT: 4
// EXPECT: gen ref ok
// EXPECT: === Region ===
// EXPECT: 2
// EXPECT: === Macro ===
// EXPECT: 3
// EXPECT: === Hash ===
// EXPECT: 120
// EXPECT: === Closed ===
// EXPECT: document closed

// Pillar 2: Content-addressed import (stored via --store-codebase)
use hash("a13d");  // factorial (from mathlib)
// BUG: Second hash import in same file generates stubs instead of real codegen.
// Renderer hash import deferred until multi-import bug is fixed.

// Part 1: Macros for assertion

macro assert_eq {
    ($a:expr, $b:expr) => {
        let __a: i32 = $a;
        let __b: i32 = $b;
        if __a != __b {
            println_str("ASSERT FAILED");
        }
    };
}

// Part 2: Document tree (recursive enum with Box)

enum Node {
    Heading(i32, String),
    Paragraph(String),
    Emphasis(String),
    Section(Vec<Node>),
}

// Linear document handle (P5 - must be closed)
struct Document {
    root: Vec<Node>,
    title: String,
}

fn new_document(title: &str) -> Document {
    let mut t: String = String.new();
    let bytes = title.as_bytes();
    let mut i: usize = 0;
    while i < bytes.len() { t.push(bytes[i] as char); i += 1; }
    Document { root: Vec.new(), title: t }
}

fn close_document(linear doc: Document) {
    println_str("document closed");
}

// Part 3: Output effect (P3 - swappable rendering)

effect Output {
    op write(text: &str) -> ();
    op newline() -> ();
}

// Output handler (P3 - handler with state for mode tracking)
deep handler TextOutput for Output {
    return(x) { x }
    op write(text) { print_str(text); resume(()) }
    op newline() { println_str(""); resume(()) }
}

// Part 4: Dispatch for node rendering (P4)

fn render_heading(level: i32, text: &str, plain: bool) / {Output} {
    if plain {
        // Plain: # Heading or ## Heading
        if level == 1 {
            perform Output.write("# ");
        } else {
            perform Output.write("## ");
        }
        perform Output.write(text);
    } else {
        // Decorated: [H1] Heading
        if level == 1 {
            perform Output.write("[H1] ");
        } else {
            perform Output.write("[H2] ");
        }
        perform Output.write(text);
    }
    perform Output.newline();
}

fn render_paragraph(text: &str, plain: bool) / {Output} {
    if !plain {
        perform Output.write("[P] ");
    }
    perform Output.write(text);
    perform Output.newline();
}

fn render_emphasis(text: &str, plain: bool) / {Output} {
    if plain {
        perform Output.write("*");
        perform Output.write(text);
        perform Output.write("*");
    } else {
        perform Output.write("[EM] ");
        perform Output.write(text);
    }
    perform Output.newline();
}

// Render a node tree via pattern matching (P10-style)
fn render_node(node: &Node, plain: bool) / {Output} {
    match node {
        &Node.Heading(level, ref text) => {
            render_heading(level, text.as_str(), plain);
        },
        &Node.Paragraph(ref text) => {
            render_paragraph(text.as_str(), plain);
        },
        &Node.Emphasis(ref text) => {
            render_emphasis(text.as_str(), plain);
        },
        &Node.Section(ref children) => {
            let mut i: usize = 0;
            while i < children.len() {
                render_node(&children[i], plain);
                i += 1;
            }
        },
    }
}

fn render_all(nodes: &Vec<Node>, plain: bool) / {Output} {
    let mut i: usize = 0;
    while i < nodes.len() {
        render_node(&nodes[i], plain);
        i += 1;
    }
}

// Part 5: Closures for custom formatting (P9-style)

fn render_with_formatter(nodes: &Vec<Node>, f: fn(&Node) -> ()) {
    let mut i: usize = 0;
    while i < nodes.len() {
        f(&nodes[i]);
        i += 1;
    }
}

// Part 6: Tree analysis using pattern matching + match guards + if-let (P10-style)

fn count_nodes(nodes: &Vec<Node>) -> i32 {
    let mut total: i32 = 0;
    let mut i: usize = 0;
    while i < nodes.len() {
        total = total + count_node(&nodes[i]);
        i += 1;
    }
    total
}

fn count_node(node: &Node) -> i32 {
    match node {
        &Node.Section(ref children) => 1 + count_nodes(children),
        _ => 1,
    }
}

fn max_depth(nodes: &Vec<Node>) -> i32 {
    let mut d: i32 = 0;
    let mut i: usize = 0;
    while i < nodes.len() {
        let nd: i32 = node_depth(&nodes[i]);
        if nd > d { d = nd; }
        i += 1;
    }
    d
}

fn node_depth(node: &Node) -> i32 {
    if let &Node.Section(ref children) = node {
        1 + max_depth(children)
    } else {
        0
    }
}

fn format_heading_only(node: &Node) {
    match node {
        &Node.Heading(_, ref text) => {
            print_str("<");
            print_str(text.as_str());
            println_str(">");
        },
        _ => {},
    }
}

// Part 7b: Document construction macro

macro node_heading {
    ($level:expr, $text:expr) => {
        Node.Heading($level, make_string($text))
    };
}

macro node_para {
    ($text:expr) => {
        Node.Paragraph(make_string($text))
    };
}

macro node_em {
    ($text:expr) => {
        Node.Emphasis(make_string($text))
    };
}

// doc3!() builds a Vec<Node> from exactly 3 nodes
macro doc3 {
    ($a:expr, $b:expr, $c:expr) => {
        make_doc3($a, $b, $c)
    };
}

fn make_doc3(a: Node, b: Node, c: Node) -> Vec<Node> {
    let mut v: Vec<Node> = Vec.new();
    v.push(a);
    v.push(b);
    v.push(c);
    v
}

// Part 8: String helpers

fn make_string(s: &str) -> String {
    let mut result: String = String.new();
    let bytes = s.as_bytes();
    let mut i: usize = 0;
    while i < bytes.len() { result.push(bytes[i] as char); i += 1; }
    result
}

// Part 8: Tests - all pillars together

fn main() -> i32 {
    // Build document tree
    let doc: linear Document = new_document("Test Doc");
    let mut nodes: Vec<Node> = Vec.new();
    nodes.push(Node.Heading(1, make_string("Welcome")));
    nodes.push(Node.Paragraph(make_string("This is a test document.")));
    nodes.push(Node.Emphasis(make_string("important")));

    // Nested section (tests recursive structure)
    let mut section_children: Vec<Node> = Vec.new();
    section_children.push(Node.Heading(2, make_string("Details")));
    section_children.push(Node.Paragraph(make_string("More content here.")));
    nodes.push(Node.Section(section_children));

    // Test 1: Plain text rendering (P3 - effect handler)
    println_str("=== Plain ===");
    with TextOutput {} handle {
        render_all(&nodes, true);
    };

    // Test 2: Decorated rendering (P3 - same handler, different render mode)
    println_str("=== Decorated ===");
    with TextOutput {} handle {
        render_all(&nodes, false);
    };

    // Test 3: Custom formatter via closure with ref binding in match (P9-style)
    println_str("=== Custom ===");
    render_with_formatter(&nodes, |node| {
        match node {
            &Node.Heading(_, ref text) => {
                print_str("<");
                print_str(text.as_str());
                println_str(">");
            },
            _ => {},
        }
    });

    // Test 4: Tree stats via pattern matching + if-let
    println_str("=== Stats ===");
    let n: i32 = count_nodes(&nodes);
    let d: i32 = max_depth(&nodes);
    let stats: &str = format!("nodes: {}, depth: {}", n, d);
    println_str(stats);
    assert_eq!(n, 6);
    assert_eq!(d, 1);

    // Test 5: Gen ref tracking — traverse document tree via gen-tracked node ref
    // Uses pure functions (count_node, node_depth) through gen-tracked ref.
    // Effect-based rendering through gen refs blocked by known handler+region bug (P7).
    println_str("=== GenRef ===");
    let dummy_node: Node = Node.Heading(0, make_string(""));
    let mut node_ref: &Node = &dummy_node;
    let gen_result: i32 = region {
        let mut section: Vec<Node> = Vec.new();
        section.push(Node.Heading(2, make_string("Inner")));
        section.push(Node.Paragraph(make_string("Content")));
        let temp_node: Node = Node.Section(section);
        node_ref = &temp_node;
        // Traverse document tree through gen-tracked ref (valid in region)
        let count: i32 = count_node(node_ref);  // 1 + 2 children = 3
        let depth: i32 = node_depth(node_ref);  // 1 (Section with leaf children)
        count + depth  // 3 + 1 = 4
    };
    println_int(gen_result);
    // node_ref is now stale — region destroyed. Gen tracking active.
    println_str("gen ref ok");

    // Test 6: Region-scoped rendering (P1 - data freed when region exits)
    println_str("=== Region ===");
    let region_count: i32 = region {
        let mut rnodes: Vec<Node> = Vec.new();
        rnodes.push(Node.Heading(1, make_string("Temp")));
        rnodes.push(Node.Paragraph(make_string("Region data.")));
        count_nodes(&rnodes)
    };
    println_int(region_count);

    // Test 7: Document construction macros (node_heading!, node_para!, node_em!, doc3!)
    println_str("=== Macro ===");
    let mut macro_nodes: Vec<Node> = Vec.new();
    macro_nodes.push(node_heading!(1, "Macro Title"));
    macro_nodes.push(node_para!("Built by macro."));
    macro_nodes.push(node_em!("emphasized"));
    println_int(count_nodes(&macro_nodes));

    // Test 8: Content-addressed imports (P2 - factorial + renderer by hash)
    println_str("=== Hash ===");
    println_int(factorial(5));
    // P2 demonstrated: factorial imported by content hash works

    // Test 9: Linear document lifecycle (P5)
    println_str("=== Closed ===");
    close_document(doc);

    0
}
