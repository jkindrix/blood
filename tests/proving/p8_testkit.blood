// Proving Ground Program 8: testkit - Test framework with user-defined macros
// New features: user macros + effects, multi-rule macros, recursive macros,
//               matches!(), match guards, multi-field handler state
//
// EXPECT: Results: 16 passed, 0 failed

macro assert_eq {
    ($a:expr, $b:expr) => {
        let __a: i32 = $a;
        let __b: i32 = $b;
        if __a != __b {
            perform TestReport.fail("assert_eq");
        } else {
            perform TestReport.pass();
        }
    };
}

macro assert_ne {
    ($a:expr, $b:expr) => {
        let __a: i32 = $a;
        let __b: i32 = $b;
        if __a == __b {
            perform TestReport.fail("assert_ne");
        } else {
            perform TestReport.pass();
        }
    };
}

// Multi-rule macro: dispatches by arity (first-match semantics)
macro expect {
    ($a:expr, $b:expr) => {
        let __ea: i32 = $a;
        let __eb: i32 = $b;
        if __ea == __eb { perform TestReport.pass(); } else { perform TestReport.fail("expect eq"); }
    };
    ($cond:expr) => {
        if $cond { perform TestReport.pass(); } else { perform TestReport.fail("expect"); }
    };
}

// Recursive macro: expands to assert_eq invocation
macro double_check {
    ($x:expr, $expected:expr) => {
        assert_eq!($x + $x, $expected)
    };
}

effect TestReport {
    op pass() -> ();
    op fail(msg: &str) -> ();
}

// Two-field handler state: both fields correctly mutated across ops
deep handler TestRunner for TestReport {
    let mut passed: i32
    let mut failed: i32
    return(x) {
        let msg: &str = format!("Results: {} passed, {} failed", passed, failed);
        println_str(msg);
        x
    }
    op pass() {
        passed = passed + 1;
        resume(())
    }
    op fail(msg) {
        failed = failed + 1;
        print_str("FAIL: ");
        println_str(msg);
        resume(())
    }
}

// User macros expanding to effect performs
fn test_arithmetic() / {TestReport} {
    assert_eq!(2 + 3, 5);
    assert_eq!(10 - 7, 3);
    assert_eq!(4 * 3, 12);
    assert_ne!(1 + 1, 3);
}

// Built-in vec! macro + user assert macro
fn test_vec() / {TestReport} {
    let nums: [i32; 5] = vec![10, 20, 30, 40, 50];
    assert_eq!(nums[0], 10);
    assert_eq!(nums[4], 50);
}

// Multi-rule macro: 1-arg and 2-arg dispatch
fn test_multi_rule() / {TestReport} {
    expect!(true);
    expect!(7, 7);
}

// Recursive macro: double_check! -> assert_eq!
fn test_recursive() / {TestReport} {
    double_check!(5, 10);
    double_check!(3, 6);
}

// Built-in matches! macro (first test coverage)
fn test_matches() / {TestReport} {
    let x: i32 = 42;
    if matches!(x, 42) {
        perform TestReport.pass();
    } else {
        perform TestReport.fail("matches!");
    }
}

// Repetition patterns: $($x:expr),*
macro sum_all {
    ($($x:expr),*) => {
        0 $(+ $x)*
    };
}

macro assert_all_positive {
    ($($x:expr),*) => {
        $(assert_eq!(($x > 0) as i32, 1);)*
    };
}

fn test_repetition() / {TestReport} {
    // sum_all: accumulates values with + separator
    let total: i32 = sum_all!(1, 2, 3, 4);
    assert_eq!(total, 10);

    // assert_all_positive: generates one assert per item
    assert_all_positive!(1, 5, 42);
}

// Match guards: _ if condition => expr
fn test_match_guards() / {TestReport} {
    let x: i32 = 42;
    let result: i32 = match x {
        0 => 0,
        _ if x > 100 => 3,
        _ if x > 10 => 2,
        _ if x > 0 => 1,
        _ => 0 - 1,
    };
    assert_eq!(result, 2);
}

fn main() -> i32 {
    with TestRunner { passed: 0, failed: 0 } handle {
        test_arithmetic();
        test_vec();
        test_multi_rule();
        test_recursive();
        test_matches();
        test_repetition();
        test_match_guards();
    };
    0
}
