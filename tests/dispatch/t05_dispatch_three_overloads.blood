// Test: three overloads of the same method, each with different param types
// EXPECT: int: 42
// EXPECT: bool: true
// EXPECT: str: hello

struct Logger {}

impl Logger {
    fn log(self, x: i32) -> () {
        println_str("int:");
        println_int(x);
    }
    fn log(self, x: bool) -> () {
        println_str("bool:");
        println_bool(x);
    }
    fn log(self, x: &str) -> () {
        println_str("str:");
        println_str(x);
    }
}

fn main() -> i32 {
    let l: Logger = Logger {};
    l.log(42);
    l.log(true);
    l.log("hello");
    0
}
