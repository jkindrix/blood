// Test: dispatch with mixed type specificity across parameters
// When one param is more specific and another less, correct overload selected
// EXPECT: both_concrete: 15

struct Mixer {}

impl Mixer {
    fn mix(self, x: i32, y: i32) -> i32 {
        println_str("both_concrete:");
        x + y
    }
}

fn main() -> i32 {
    let m: Mixer = Mixer {};
    println_int(m.mix(5, 10));
    0
}
