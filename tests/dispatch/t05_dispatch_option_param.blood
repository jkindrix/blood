// Test: dispatch with Option parameter types
// EXPECT: some: 42
// EXPECT: none

struct Handler {}

impl Handler {
    fn process(self, x: i32) -> () {
        println_str("some:");
        println_int(x);
    }
    fn process(self, x: bool) -> () {
        println_str("none");
    }
}

fn main() -> i32 {
    let h: Handler = Handler {};
    h.process(42);
    h.process(false);
    0
}
