// Test: dispatch on methods with different arities
// EXPECT: one: 42
// EXPECT: two: 10

struct Container {}

impl Container {
    fn wrap(self, x: i32) -> i32 {
        println_str("one:");
        42
    }
    fn wrap(self, x: i32, y: i32) -> i32 {
        println_str("two:");
        10
    }
}

fn main() -> i32 {
    let b: Container = Container {};
    let a: i32 = b.wrap(1);
    println_int(a);
    let c: i32 = b.wrap(1, 2);
    println_int(c);
    0
}
