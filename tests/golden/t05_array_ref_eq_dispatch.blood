// Test: codegen dispatch of `==` and `!=` on `&[T; N]` types. S108
// closes the typeck-accepted ref-shape companion to S107's value-shape
// array eq. `try_emit_binop_array_ref_eq` derefs the `{ ptr, i32 }`
// fat ref to load the inner Array `[N x T]`, then routes through
// S107's existing `emit_array_eq_typed`. Pre-S108 this hit S104-B's
// fatal because the fat ref is a multi-field aggregate.
//
// EXPECT: ref_arr_eq_match: 1
// EXPECT: ref_arr_eq_mismatch_first: 0
// EXPECT: ref_arr_eq_mismatch_middle: 0
// EXPECT: ref_arr_eq_mismatch_last: 0
// EXPECT: ref_arr_ne_match: 0
// EXPECT: ref_arr_ne_mismatch: 1
// EXPECT: ref_u8_arr_eq_match: 1
// EXPECT: ref_u8_arr_eq_mismatch: 0
// EXPECT: ref_bool_arr_eq_match: 1
// EXPECT: ref_bool_arr_eq_mismatch: 0
// EXPECT: ref_single_elem_eq_match: 1
// EXPECT: ref_single_elem_eq_mismatch: 0
// EXPECT: ref_nested_arr_eq_match: 1
// EXPECT: ref_nested_arr_eq_mismatch_inner: 0
// EXPECT: ref_nested_arr_eq_mismatch_outer: 0
// EXPECT: ref_fn_param_eq_match: 1
// EXPECT: ref_fn_param_eq_mismatch: 0
mod std;

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn ref_arr3_arg_eq(a: &[i32; 3], b: &[i32; 3]) -> bool {
    a == b
}

fn main() -> i32 {
    let a1: [i32; 3] = [1, 2, 3];
    let a2: [i32; 3] = [1, 2, 3];
    let a3: [i32; 3] = [9, 2, 3];
    let a4: [i32; 3] = [1, 9, 3];
    let a5: [i32; 3] = [1, 2, 9];
    let ra1: &[i32; 3] = &a1;
    let ra2: &[i32; 3] = &a2;
    let ra3: &[i32; 3] = &a3;
    let ra4: &[i32; 3] = &a4;
    let ra5: &[i32; 3] = &a5;
    print_kv("ref_arr_eq_match", ra1 == ra2);
    print_kv("ref_arr_eq_mismatch_first", ra1 == ra3);
    print_kv("ref_arr_eq_mismatch_middle", ra1 == ra4);
    print_kv("ref_arr_eq_mismatch_last", ra1 == ra5);
    print_kv("ref_arr_ne_match", ra1 != ra2);
    print_kv("ref_arr_ne_mismatch", ra1 != ra3);

    let u1: [u8; 4] = [10u8, 20u8, 30u8, 40u8];
    let u2: [u8; 4] = [10u8, 20u8, 30u8, 40u8];
    let u3: [u8; 4] = [10u8, 20u8, 30u8, 99u8];
    let ru1: &[u8; 4] = &u1;
    let ru2: &[u8; 4] = &u2;
    let ru3: &[u8; 4] = &u3;
    print_kv("ref_u8_arr_eq_match", ru1 == ru2);
    print_kv("ref_u8_arr_eq_mismatch", ru1 == ru3);

    let b1: [bool; 3] = [true, false, true];
    let b2: [bool; 3] = [true, false, true];
    let b3: [bool; 3] = [true, true, true];
    let rb1: &[bool; 3] = &b1;
    let rb2: &[bool; 3] = &b2;
    let rb3: &[bool; 3] = &b3;
    print_kv("ref_bool_arr_eq_match", rb1 == rb2);
    print_kv("ref_bool_arr_eq_mismatch", rb1 == rb3);

    let s1: [i64; 1] = [42i64];
    let s2: [i64; 1] = [42i64];
    let s3: [i64; 1] = [99i64];
    let rs1: &[i64; 1] = &s1;
    let rs2: &[i64; 1] = &s2;
    let rs3: &[i64; 1] = &s3;
    print_kv("ref_single_elem_eq_match", rs1 == rs2);
    print_kv("ref_single_elem_eq_mismatch", rs1 == rs3);

    let n1: [[i32; 2]; 3] = [[1, 2], [3, 4], [5, 6]];
    let n2: [[i32; 2]; 3] = [[1, 2], [3, 4], [5, 6]];
    let n3: [[i32; 2]; 3] = [[1, 9], [3, 4], [5, 6]];
    let n4: [[i32; 2]; 3] = [[1, 2], [3, 4], [9, 6]];
    let rn1: &[[i32; 2]; 3] = &n1;
    let rn2: &[[i32; 2]; 3] = &n2;
    let rn3: &[[i32; 2]; 3] = &n3;
    let rn4: &[[i32; 2]; 3] = &n4;
    print_kv("ref_nested_arr_eq_match", rn1 == rn2);
    print_kv("ref_nested_arr_eq_mismatch_inner", rn1 == rn3);
    print_kv("ref_nested_arr_eq_mismatch_outer", rn1 == rn4);

    let p: [i32; 3] = [7, 8, 9];
    let q: [i32; 3] = [7, 8, 9];
    let r: [i32; 3] = [7, 8, 0];
    print_kv("ref_fn_param_eq_match", ref_arr3_arg_eq(&p, &q));
    print_kv("ref_fn_param_eq_mismatch", ref_arr3_arg_eq(&p, &r));

    0
}
