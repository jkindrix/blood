// Test: `Vec<T> == Vec<T>` and `&Vec<T> == &Vec<T>` (and !=) dispatch through
// `@str_eq` runtime. Pre-fix, the BinaryOp codegen treated the loaded Vec
// aggregate `{ ptr, i64, i64 }` as a generic struct, extracted field 0
// (data ptr), and emitted `icmp eq ptr` — silent miscompile because two
// distinct Vec heap allocations always have distinct data ptrs regardless
// of content. The `&Vec<T>` shape failed parallel: extracted field 0 of the
// outer fat ref `{ ptr, i32 }` (the alloca address) and pointer-compared.
// Closes the same root-cause family as S98 (`&str`), S99 (`String`),
// S100 (`&String`), S102 (`&[T]`), and S103-B (`& &String`); same runtime
// function, different LLVM layout. S103-C in the eq-family closure.
// EXPECT: i32_value_eq_match: 1
// EXPECT: i32_value_eq_mismatch: 0
// EXPECT: i32_value_ne_match: 0
// EXPECT: i32_value_ne_mismatch: 1
// EXPECT: u8_value_eq_match: 1
// EXPECT: u8_value_eq_mismatch: 0
// EXPECT: u64_value_eq_match: 1
// EXPECT: u64_value_eq_mismatch: 0
// EXPECT: empty_eq_empty: 1
// EXPECT: empty_eq_nonempty: 0
// EXPECT: ref_eq_match_inline: 1
// EXPECT: ref_eq_mismatch_inline: 0
// EXPECT: ref_eq_match_param: 1
// EXPECT: ref_ne_mismatch_param: 1

fn build_vec_i32(a: i32, b: i32, c: i32) -> Vec<i32> {
    let v = Vec.new();
    v.push(a);
    v.push(b);
    v.push(c);
    v
}

fn build_vec_u8(a: u8, b: u8, c: u8) -> Vec<u8> {
    let v = Vec.new();
    v.push(a);
    v.push(b);
    v.push(c);
    v
}

fn build_vec_u64(a: u64, b: u64, c: u64) -> Vec<u64> {
    let v = Vec.new();
    v.push(a);
    v.push(b);
    v.push(c);
    v
}

fn empty_vec_i32() -> Vec<i32> {
    let v = Vec.new();
    v
}

fn ref_eq_i32(a: &Vec<i32>, b: &Vec<i32>) -> bool {
    a == b
}

fn ref_ne_i32(a: &Vec<i32>, b: &Vec<i32>) -> bool {
    a != b
}

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn main() -> i32 {
    // i32 value-shape: distinct allocations, same content → must report match.
    let v_i32_a = build_vec_i32(1, 2, 3);
    let v_i32_b = build_vec_i32(1, 2, 3);
    let v_i32_c = build_vec_i32(1, 2, 4);
    print_kv("i32_value_eq_match", v_i32_a == v_i32_b);
    print_kv("i32_value_eq_mismatch", v_i32_a == v_i32_c);
    print_kv("i32_value_ne_match", v_i32_a != v_i32_b);
    print_kv("i32_value_ne_mismatch", v_i32_a != v_i32_c);

    // u8 element type — exercises the elem_size==1 short-circuit path
    // (no multiply needed; len IS the byte count directly).
    let v_u8_a = build_vec_u8(10u8, 20u8, 30u8);
    let v_u8_b = build_vec_u8(10u8, 20u8, 30u8);
    let v_u8_c = build_vec_u8(10u8, 20u8, 31u8);
    print_kv("u8_value_eq_match", v_u8_a == v_u8_b);
    print_kv("u8_value_eq_mismatch", v_u8_a == v_u8_c);

    // u64 element type — exercises the elem_size==8 multiply path
    // (byte_count = len * 8). Distinct allocations.
    let v_u64_a = build_vec_u64(100u64, 200u64, 300u64);
    let v_u64_b = build_vec_u64(100u64, 200u64, 300u64);
    let v_u64_c = build_vec_u64(100u64, 200u64, 301u64);
    print_kv("u64_value_eq_match", v_u64_a == v_u64_b);
    print_kv("u64_value_eq_mismatch", v_u64_a == v_u64_c);

    // Empty Vec equality. Both have len=0; data ptr is null or unallocated.
    // @str_eq's len-zero fast path must report match without dereffing data.
    let v_empty1 = empty_vec_i32();
    let v_empty2 = empty_vec_i32();
    print_kv("empty_eq_empty", v_empty1 == v_empty2);
    print_kv("empty_eq_nonempty", v_empty1 == v_i32_a);

    // &Vec<i32> ref shape, inline (no fn-parameter indirection). Exercises
    // the binop directly on `&Vec<T>` operands.
    let r_a: &Vec<i32> = &v_i32_a;
    let r_b: &Vec<i32> = &v_i32_b;
    let r_c: &Vec<i32> = &v_i32_c;
    print_kv("ref_eq_match_inline", r_a == r_b);
    print_kv("ref_eq_mismatch_inline", r_a == r_c);

    // &Vec<i32> ref shape via function parameter — the canonical wrapper
    // form. THE silent-miscompile case for ref shape, since distinct alloca
    // addresses for the same content otherwise always reported "differ".
    print_kv("ref_eq_match_param", ref_eq_i32(&v_i32_a, &v_i32_b));
    print_kv("ref_ne_mismatch_param", ref_ne_i32(&v_i32_a, &v_i32_c));

    0
}
