// Test: basic implicit semicolon insertion at line boundaries.
// Two expressions on separate lines without explicit semicolons
// should be treated as separate statements.
// EXPECT: 0

fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn main() -> i32 {
    let x: i32 = 10
    let y: i32 = 20
    let z: i32 = add(x, y)
    println_int(z - 30);
    z - 30
}
