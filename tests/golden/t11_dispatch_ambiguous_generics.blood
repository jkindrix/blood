// COMPILE_FAIL: ambiguous dispatch — incomparable constraint overloads
// EXPECT: [E0602] ambiguous dispatch
// Test: two generics with incomparable constraints — ambiguity detected
// SPEC: §3.7 — neither constraint subsumes the other, so dispatch is ambiguous

trait Numeric {
    fn value(self: &Self) -> i32;
}

trait Textual {
    fn label(self: &Self) -> i32;
}

struct Both {}

impl Numeric for Both {
    fn value(self: &Self) -> i32 { 1 }
}

impl Textual for Both {
    fn label(self: &Self) -> i32 { 2 }
}

struct Processor {}

impl Processor {
    fn run<T: Numeric>(self, x: T) -> i32 { 100 }
    fn run<T: Textual>(self, x: T) -> i32 { 200 }
}

fn main() -> i32 {
    let p: Processor = Processor {};
    let b: Both = Both {};
    // Ambiguous — Numeric and Textual are incomparable
    p.run(b) - 100
}
