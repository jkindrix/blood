// Test: two generics with incomparable constraints — ambiguity not detected
// SPEC: should be COMPILE_FAIL (ambiguous dispatch — neither constraint subsumes the other)
// ACTUAL: bootstrap selects first matching overload (first-match-wins)
// BUG: constraint-based ambiguity detection not implemented in bootstrap
// DIVERGENCE: first_gen may reject at HIR lowering (E0101 duplicate method)

trait Numeric {
    fn value(self: &Self) -> i32;
}

trait Textual {
    fn label(self: &Self) -> i32;
}

struct Both {}

impl Numeric for Both {
    fn value(self: &Self) -> i32 { 1 }
}

impl Textual for Both {
    fn label(self: &Self) -> i32 { 2 }
}

struct Processor {}

impl Processor {
    fn run<T: Numeric>(self, x: T) -> i32 { 100 }
    fn run<T: Textual>(self, x: T) -> i32 { 200 }
}

fn main() -> i32 {
    let p: Processor = Processor {};
    let b: Both = Both {};
    // SPEC: ambiguous — Numeric and Textual are incomparable
    // ACTUAL: selects first overload, returns 100
    p.run(b) - 100
}
