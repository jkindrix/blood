// COMPILE_FAIL: missing associated type in trait impl
// Test: impl of trait with associated type that is missing the type definition.
// EXPECT: E0233

trait MyIterator {
    type Item;
    fn next(self: &mut Self) -> Option<Self.Item>;
}

struct Empty {}

impl MyIterator for Empty {
    fn next(self: &mut Self) -> Option<i32> {
        Option.None
    }
}

fn main() -> i32 {
    0
}
