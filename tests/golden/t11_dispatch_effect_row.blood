// RUN: exit 0
// Test: effect-row dispatch — pure method vs effectful method
// SPEC: DISPATCH.md §7 — methods differing only in effect row are distinct overloads
// Pure method is more specific than effectful method (pure <: {IO}).
// Dispatch should prefer the pure overload when no effects are in scope.

effect IO {
    op print(msg: i32) -> ();
}

struct Service {}

impl Service {
    fn process(self: &Self, x: i32) -> i32 {
        x + 1
    }
    fn process(self: &Self, x: i32) -> i32 / {IO} {
        perform IO.print(x);
        x + 2
    }
}

fn main() -> i32 {
    let s: Service = Service {};
    let result: i32 = s.process(42);
    result - 43
}
