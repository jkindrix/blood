// Test: multi-caller `impl<T> Deref for Frozen<T>` from stdlib (S87+S88).
//
// Three different Frozen<T> instantiations (i32, bool, u64) all
// dispatch through the same delegation; per-T specialization picks
// the correct Target type per call site. Uses `*f` (unary auto-
// deref); S88 fixed the auto-deref Param-T substitution so each
// `*fX` returns Target with that fX's concrete T substituted in.
//
// EXPECT: 42
// EXPECT: 1
// EXPECT: 99
mod std;
use std.core.frozen.{Frozen, Freeze};
use std.ops.deref.Deref;

fn main() -> i32 {
    let fi: Frozen<i32> = Frozen.new(42);
    let fb: Frozen<bool> = Frozen.new(true);
    let fu: Frozen<u64> = Frozen.new(99u64);

    let vi: i32 = *fi;
    let vb: bool = *fb;
    let vu: u64 = *fu;

    println_int(vi);
    if vb { println_int(1); } else { println_int(0); }
    println_int(vu as i32);

    0
}
