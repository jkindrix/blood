// Test: &str.ends_with(&str) inline. S96.
// EXPECT: suffix: true
// EXPECT: not_suffix: false
// EXPECT: empty_needle: true
// EXPECT: full_match: true
// EXPECT: needle_too_long: false
// EXPECT: case_sensitive: false

fn main() -> i32 {
    let s: &str = "hello world";

    print("suffix: ");
    if s.ends_with("world") { println("true"); } else { println("false"); }

    print("not_suffix: ");
    if s.ends_with("hello") { println("true"); } else { println("false"); }

    print("empty_needle: ");
    if s.ends_with("") { println("true"); } else { println("false"); }

    print("full_match: ");
    if s.ends_with("hello world") { println("true"); } else { println("false"); }

    print("needle_too_long: ");
    if s.ends_with("ahello world") { println("true"); } else { println("false"); }

    print("case_sensitive: ");
    if s.ends_with("World") { println("true"); } else { println("false"); }
    0
}
