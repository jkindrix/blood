// RUN: expect_exit 0
// Test: fiber builtins are callable and link correctly (INFRA-02 Phase 1)
// This tests the builtin registration and FFI wiring, not full fiber semantics.
// EXPECT: 0

fn test_yield() -> i32 {
    // Yield should return without error
    __builtin_fiber_yield();
    0
}

fn test_current() -> i32 {
    // Current should return 0 (not in a fiber context)
    let id = __builtin_fiber_current();
    if id != 0u64 { return 1 }
    0
}

fn test_sleep() -> i32 {
    // Sleep for 1 millisecond (1_000_000 nanoseconds)
    __builtin_fiber_sleep(1000000u64);
    0
}

fn test_scheduler_init() -> i32 {
    // Initialize scheduler (no-op in Phase 1)
    __builtin_scheduler_init(0u64);
    0
}

fn test_spawn_join() -> i32 {
    // Spawn a fiber that returns 42, then join it
    // Note: Phase 1 uses OS threads as backing
    // For now just test that spawn/join don't crash
    // (fn ptr passing requires closure infrastructure)
    0
}

fn main() -> i32 {
    let a = test_scheduler_init()
    let b = test_yield()
    let c = test_current()
    let d = test_sleep()
    let e = test_spawn_join()

    if a != 0 { return 1 }
    if b != 0 { return 2 }
    if c != 0 { return 3 }
    if d != 0 { return 4 }
    if e != 0 { return 5 }
    println_int(0);
    0
}
