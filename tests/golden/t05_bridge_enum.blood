// Test: bridge enum declaration and variant matching (GAP 7A)
// EXPECT: red
// EXPECT: green
// EXPECT: blue

bridge "C" Colors {
    enum Color {
        Red,
        Green,
        Blue,
    }
}

fn color_name(c: Colors.Color) -> &str {
    match c {
        Colors.Color.Red => "red",
        Colors.Color.Green => "green",
        Colors.Color.Blue => "blue",
    }
}

fn main() -> i32 {
    println(color_name(Colors.Color.Red));
    println(color_name(Colors.Color.Green));
    println(color_name(Colors.Color.Blue));
    0
}
