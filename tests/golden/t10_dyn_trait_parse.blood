// Test: dyn Trait type syntax parsing
// Verifies that `dyn Trait` type syntax is accepted by the parser
// and type checker. Runtime dispatch through dyn Trait is not yet
// implemented (requires Phase 4 coercion and vtable dispatch).
// EXPECT: 36
// EXPECT: 10

trait Shape {
    fn area(&self) -> i32;
}

struct Square {
    side: i32,
}

impl Shape for Square {
    fn area(&self) -> i32 {
        self.side * self.side
    }
}

struct Rect {
    w: i32,
    h: i32,
}

impl Shape for Rect {
    fn area(&self) -> i32 {
        self.w * self.h
    }
}

fn main() -> i32 {
    let s: Square = Square { side: 6 };
    let a1: i32 = s.area();
    println_int(a1); // 36
    if a1 != 36 { return 1; }

    let r: Rect = Rect { w: 2, h: 5 };
    let a2: i32 = r.area();
    println_int(a2); // 10
    if a2 != 10 { return 2; }

    0
}
