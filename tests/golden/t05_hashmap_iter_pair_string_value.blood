// Test: HashMap<i32, String>.iter() correctly propagates the String value type
// through the for-tuple pattern. Pre-S89, the v sub-binding defaulted to i32,
// turning a 24-byte String store into a 4-byte alloca corruption — typically
// a segfault. (S89)
// EXPECT: 1 -> one
// EXPECT: 2 -> two

fn main() -> i32 {
    let mut m: HashMap<i32, String> = HashMap.new();
    m.insert(1, String.from("one"));
    m.insert(2, String.from("two"));

    let mut count: i32 = 0;
    while count < 2 {
        let target = count + 1;
        for (k, v) in m.iter() {
            if k == target {
                print_int(k);
                print(" -> ");
                println(v.as_str());
            }
        }
        count += 1;
    }

    0
}
