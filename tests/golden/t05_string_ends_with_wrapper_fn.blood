// Test: String.ends_with(&str) through a non-generic wrapper.
// EXPECT: w_hit: true
// EXPECT: w_miss: false

fn has_suffix(s: &String, suffix: &str) -> bool / pure {
    s.ends_with(suffix)
}

fn main() -> i32 {
    let s: String = String.from("foobar");

    print("w_hit: ");
    if has_suffix(&s, "bar") { println("true"); } else { println("false"); }

    print("w_miss: ");
    if has_suffix(&s, "foo") { println("true"); } else { println("false"); }
    0
}
