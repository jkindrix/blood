// COMPILE_FAIL: linear closure used twice
// EXPECT: [E0802] linear value
// Test: move closure capturing linear value creates a linear fn type
// Linear fn is callable, but using it twice violates linearity
fn main() -> i32 {
    let x: linear i32 = 42;
    let f = move || -> i32 { x };
    let a: i32 = f();
    let b: i32 = f();
    a + b
}
