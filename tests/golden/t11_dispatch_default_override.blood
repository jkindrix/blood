// Test: default trait method overridden in one impl but not another
// Override used for Custom, default for Default
// NOTE: bootstrap crashes on this (unsubstituted TyVarId) — known bootstrap bug

trait Greetable {
    fn greet(self: &Self) -> i32 {
        100
    }
}

struct Custom {}
struct Default {}

impl Greetable for Custom {
    fn greet(self: &Self) -> i32 {
        200
    }
}

impl Greetable for Default {}

fn main() -> i32 {
    let c: Custom = Custom {};
    let d: Default = Default {};
    let a: i32 = c.greet();
    let b: i32 = d.greet();
    a - 200 + b - 100
}
