// Test: trailing expression without semicolon is the block's value
// fn f() -> i32 { 42 } returns 42
// fn g() -> i32 { 42; 0 } returns 0 (42 is discarded by semicolon)
// EXPECT: 0
fn f() -> i32 {
    42
}

fn g() -> i32 {
    42;
    0
}

fn main() -> i32 {
    let a: i32 = f();
    let b: i32 = g();
    // f() should return 42, g() should return 0
    // a - 42 + b == 0 means both correct
    println_int(a - 42 + b);
    a - 42 + b
}
