// Test: method chain continuation — dot starting next line
// Per spec §5.2.1, '.' is a continuation token
// obj\n.method() should parse as obj.method()
// EXPECT: 0

struct Point {
    x: i32,
    y: i32,
}

impl Point {
    fn get_x(self: &Self) -> i32 {
        self.x
    }
}

fn main() -> i32 {
    let p: Point = Point { x: 42, y: 0 };
    let result: i32 = p
        .get_x();
    println_int(result - 42);
    result - 42
}
