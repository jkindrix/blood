// COMPILE_FAIL: no such field in pattern
// EXPECT: [E0213] no field `z` on type `Point`
// Test: struct pattern referencing nonexistent field should fail (E0213)
struct Point {
    x: i32,
    y: i32,
}

fn main() -> i32 {
    let p: Point = Point { x: 1, y: 2 };
    match p {
        Point { x, z } => x,
    }
}
