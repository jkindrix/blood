// Test: &str.starts_with(&str) inline. S96.
// EXPECT: prefix: true
// EXPECT: not_prefix: false
// EXPECT: empty_needle: true
// EXPECT: full_match: true
// EXPECT: needle_too_long: false
// EXPECT: case_sensitive: false

fn main() -> i32 {
    let s: &str = "hello world";

    print("prefix: ");
    if s.starts_with("hello") { println("true"); } else { println("false"); }

    print("not_prefix: ");
    if s.starts_with("world") { println("true"); } else { println("false"); }

    print("empty_needle: ");
    if s.starts_with("") { println("true"); } else { println("false"); }

    print("full_match: ");
    if s.starts_with("hello world") { println("true"); } else { println("false"); }

    print("needle_too_long: ");
    if s.starts_with("hello world!!") { println("true"); } else { println("false"); }

    print("case_sensitive: ");
    if s.starts_with("Hello") { println("true"); } else { println("false"); }
    0
}
