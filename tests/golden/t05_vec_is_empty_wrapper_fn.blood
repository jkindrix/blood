// Test: Vec.is_empty through a non-generic wrapper function. Closes S94.
// Wrapper-call shapes auto-ref the &Vec<T> parameter into &&Vec<T> in MIR;
// `emit_operand_as_ptr` strips both ref layers down to the bare ptr the
// runtime expects. Without the dedicated emitter, the wrapper path was
// equally accidental — same i1 vs i32 mismatch as inline.
// EXPECT: w_empty: true
// EXPECT: w_one: false
// EXPECT: w_after_pop: true

fn vec_empty(v: &Vec<i32>) -> bool / pure {
    v.is_empty()
}

fn main() -> i32 {
    let mut v: Vec<i32> = Vec.new();
    print("w_empty: ");
    if vec_empty(&v) { println("true"); } else { println("false"); }

    v.push(7);
    print("w_one: ");
    if vec_empty(&v) { println("true"); } else { println("false"); }

    let _ = v.pop();
    print("w_after_pop: ");
    if vec_empty(&v) { println("true"); } else { println("false"); }
    0
}
