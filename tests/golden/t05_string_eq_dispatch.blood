// Test: `String == String` and `String != String` dispatch through `@str_eq`
// runtime. Pre-fix, the BinaryOp codegen treated String's `{ ptr, i64, i64 }`
// LLVM layout as an aggregate, extracted the first field (heap data ptr), and
// emitted `icmp eq ptr` — silent miscompile because two distinct String
// allocations always have different heap pointers regardless of content.
// Closes the same root-cause family as S98's `&str == &str` fix; same runtime
// function, different LLVM layout (3-field aggregate, view-extract first 2).
// EXPECT: heap_eq_heap_match: 1
// EXPECT: heap_eq_heap_mismatch: 0
// EXPECT: heap_ne_heap_match: 0
// EXPECT: heap_ne_heap_mismatch: 1
// EXPECT: empty_eq_empty: 1
// EXPECT: empty_eq_nonempty: 0
// EXPECT: empty_ne_empty: 0
// EXPECT: empty_ne_nonempty: 1
// EXPECT: mutated_eq_built: 1
// EXPECT: mutated_eq_other: 0

fn build_string(text: &str) -> String {
    let s = String.new();
    s.push_str(text);
    s
}

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn main() -> i32 {
    // Pattern A: heap-built vs heap-built, same content. THE silent-miscompile
    // case — distinct heap allocations have distinct data ptrs even when bytes
    // match, so the default extract-first-field path always reports "differ".
    let s_hello1 = build_string("hello");
    let s_hello2 = build_string("hello");
    print_kv("heap_eq_heap_match", s_hello1 == s_hello2);

    // Pattern B: heap-built vs heap-built, different content.
    let s_world = build_string("world");
    print_kv("heap_eq_heap_mismatch", s_hello1 == s_world);

    // Pattern C: != flip of A and B.
    print_kv("heap_ne_heap_match", s_hello1 != s_hello2);
    print_kv("heap_ne_heap_mismatch", s_hello1 != s_world);

    // Pattern D: empty-String equality. Both Strings have len=0; the data ptr
    // may be heap-allocated (depending on String.new() impl) but content is
    // empty, so byte comparison must report equal.
    let s_empty1 = build_string("");
    let s_empty2 = build_string("");
    print_kv("empty_eq_empty", s_empty1 == s_empty2);
    print_kv("empty_eq_nonempty", s_empty1 == s_hello1);

    // Pattern E: != flip of D.
    print_kv("empty_ne_empty", s_empty1 != s_empty2);
    print_kv("empty_ne_nonempty", s_empty1 != s_hello1);

    // Pattern F: a String mutated via push_str (potentially through realloc)
    // compared to a String built from the equivalent literal in one shot.
    // Exercises the data-ptr-after-realloc path.
    let mut s_grow = build_string("hel");
    s_grow.push_str("lo");
    let s_full = build_string("hello");
    print_kv("mutated_eq_built", s_grow == s_full);
    print_kv("mutated_eq_other", s_grow == s_world);

    0
}
