// Test: Vec.remove inline in main. Closes S93 — pre-S93 the runtime symbol
// `@vec_remove` was not declared and llc failed with `use of undefined value`.
// S93 adds the runtime function (out-param ABI to dodge backlog #30) plus
// `emit_vec_remove_call` which passes the destination as the out-pointer,
// matching the runtime signature `void @vec_remove(ptr v, i64 idx, i64
// elem_size, ptr out)`.
// EXPECT: removed: 20
// EXPECT: len: 3
// EXPECT: v[0]: 10
// EXPECT: v[1]: 30
// EXPECT: v[2]: 40
// EXPECT: head: 10
// EXPECT: len2: 2

fn main() -> i32 {
    let mut v: Vec<i32> = Vec.new();
    v.push(10);
    v.push(20);
    v.push(30);
    v.push(40);

    let mid: i32 = v.remove(1);
    print("removed: "); println_int(mid);
    print("len: "); println_int(v.len() as i32);

    print("v[0]: ");
    match v.get(0) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("v[1]: ");
    match v.get(1) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("v[2]: ");
    match v.get(2) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }

    let head: i32 = v.remove(0);
    print("head: "); println_int(head);
    print("len2: "); println_int(v.len() as i32);
    0
}
