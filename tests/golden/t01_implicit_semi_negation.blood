// Test: minus at start of new line after non-continuation token
// is treated as a new statement (negation), not subtraction.
// `a\n-b` = two statements, NOT `a - b`.

fn main() -> i32 {
    let a: i32 = 5;
    let b: i32 = a
    -a
    // b == 5 (the `let b = a` ended at the line boundary)
    // `-a` is a separate expression statement (discarded)
    b - 5
}
