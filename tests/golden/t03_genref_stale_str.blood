// Test: stale &str detection via region-aware String allocation.
// String data buffer is allocated in the active region. After region
// destroy, the &str from as_str() carries a stale gen. Call-site
// validation at print() detects the mismatch and panics.
// EXPECT_EXIT: nonzero

fn main() -> i32 {
    let mut r: &str = "";
    region {
        let mut s: String = String.new();
        s.push_str("hello from region");
        r = s.as_str();
        print(r);
        print_newline();
    }
    // Region destroyed — r is stale &str
    print(r);
    0
}
