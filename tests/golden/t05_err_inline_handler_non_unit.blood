// COMPILE_FAIL: E0215
// EXPECT: inline handler (try...with) for effect op with non-unit return type
// B1 audit (S44): inline handlers route every perform through blood_perform
// (direct-call) with a multishot-identity continuation rather than through
// blood_perform_ntr + libmprompt. For non-unit-return ops the handler's
// post-resume value silently replaces the op's natural return value, so the
// rest of the with-body runs with the wrong value (e.g., under real NTR
// semantics the body sees resume's arg; under the identity-continuation path
// it sees the handler's whole-body result). Reject at typecheck until B1a
// extends mprompt registration to inline closures.

effect Get {
    op get() -> i32;
}

fn main() -> i32 {
    let r: i32 = try {
        let x = perform Get.get();
        x * 2
    } with {
        Get.get() => {
            let v = resume(5);
            v + 100
        }
    };
    println_int(r);
    0
}
