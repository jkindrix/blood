// Test: binary operator continuation across line boundary
// Per spec §5.2.1: '+ b' on next line should continue the expression
// a\n+ b should parse as a + b
// EXPECT: 0

fn main() -> i32 {
    let a: i32 = 10;
    let b: i32 = 20;
    let c: i32 = 12;
    let result: i32 = a
        + b
        + c;
    println_int(result - 42);
    result - 42
}
