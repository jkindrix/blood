// Test: Finally clause runs on abnormal exit (handler does NOT resume)
// Verifies: finally clause executes even when handler aborts via non-resume
// EXPECT: 1
// EXPECT: 99
// EXPECT: -1

effect Cancel {
    op check_cancelled() -> i32;
}

deep handler AlwaysCancel for Cancel {
    return(x) { x }
    finally {
        println_int(99);
    }
    op check_cancelled() {
        -1
    }
}

fn cancellable_work() -> i32 / {Cancel} {
    println_int(1);
    perform Cancel.check_cancelled();
    println_int(2);
    42
}

fn main() -> i32 {
    let result: i32 = with AlwaysCancel {} handle {
        cancellable_work()
    };
    println_int(result);
    if result != -1 {
        return 1;
    }
    0
}
