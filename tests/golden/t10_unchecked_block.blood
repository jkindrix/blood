// Test unchecked block parsing, execution, and bounds check elision.
// EXPECT: 42
// EXPECT: H
// EXPECT: unchecked_ok

fn main() -> i32 {
    let x: i32 = 10;
    let y: i32 = 32;

    // Basic unchecked block — should parse and execute body
    let result: i32 = unchecked(overflow) {
        x + y
    };
    println_int(result);
    if result != 42 { return 1; }

    // Bounds check elision — string indexing without bounds check
    let s: &str = "Hello";
    let ch: char = unchecked(bounds) {
        s[0]
    };
    println_char(ch);
    if ch != 'H' { return 2; }

    // Multiple checks
    let result2: i32 = unchecked(bounds, overflow) {
        result
    };

    // Nested unchecked
    let result3: i32 = unchecked(generation) {
        unchecked(overflow) {
            result2
        }
    };

    // Conditional mode — when = "release" should be transparent in debug mode
    let result4: i32 = unchecked(overflow, when = "release") {
        x + y
    };
    if result4 != 42 { return 3; }

    println_str("unchecked_ok");
    0
}
