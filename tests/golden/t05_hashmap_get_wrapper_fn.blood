// Test: HashMap.get / contains_key / insert through a non-generic wrapper
// function. Closes S90 — pre-S90 the codegen at extract_hashmap_sizes
// peeled only one layer of `&` from the operand's HIR type. For the
// receiver inside `fn lookup(m: &HashMap<i32, i32>, ...)` MIR produced
// `&&HashMap<i32, i32>` (auto-ref of the already-`&` parameter under a
// `&self` method); the single peel left `&HashMap<i32, i32>` (not an
// Adt), so get_adt_args returned None and the builtin fell back to
// hashmap_default_sizes() (ks=8, vs=8). The runtime then hashed 8 bytes
// of the 4-byte i32 key (next 4 bytes were stack garbage), so lookups
// never matched the inserts done at concrete sites. S90 makes the
// receiver-type peel walk all Ref/Ptr layers via unwrap_all_refs_id.
// EXPECT: len: 2
// EXPECT: get 1: 100
// EXPECT: get 2: 200
// EXPECT: contains 1: true
// EXPECT: contains 3: false
// EXPECT: get_after_remove 1: NONE

fn put(m: &mut HashMap<i32, i32>, k: i32, v: i32) -> () / pure {
    m.insert(k, v);
}

fn lookup(m: &HashMap<i32, i32>, k: i32) -> i32 / pure {
    match m.get(&k) {
        Option.Some(v) => v,
        Option.None => -1,
    }
}

fn has_key(m: &HashMap<i32, i32>, k: i32) -> bool / pure {
    m.contains_key(&k)
}

fn drop_key(m: &mut HashMap<i32, i32>, k: i32) -> () / pure {
    match m.remove(&k) {
        Option.Some(_) => {}
        Option.None => {}
    }
}

fn main() -> i32 {
    let mut m: HashMap<i32, i32> = HashMap.new();
    put(&mut m, 1, 100);
    put(&mut m, 2, 200);

    print("len: ");
    println_int(m.len() as i32);

    print("get 1: ");
    println_int(lookup(&m, 1));
    print("get 2: ");
    println_int(lookup(&m, 2));

    print("contains 1: ");
    if has_key(&m, 1) { println("true"); } else { println("false"); }
    print("contains 3: ");
    if has_key(&m, 3) { println("true"); } else { println("false"); }

    drop_key(&mut m, 1);
    print("get_after_remove 1: ");
    match m.get(&1) {
        Option.Some(v) => println_int(v),
        Option.None => println("NONE"),
    }
    0
}
