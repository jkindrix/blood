// Test: basic generational reference creation and dereference
// EXPECT: 42
// EXPECT: 100
// EXPECT_EXIT: nonzero
// FIXME(E3-BUG-1): should exit 0; bare `fn main()` returns last RAX value as exit code.
// C wrapper emits `%ret = call i32 @blood_main()` but `blood_main` is `define void`
// when source has no `-> i32` return type. See BUGS_OPEN.md "E3-BUG-1".

fn main() {
    let x: i32 = 42;
    let r: &i32 = &x;
    let v1: i32 = *r;
    println_int(v1);

    let y: i32 = 100;
    let s: &i32 = &y;
    let v2: i32 = *s;
    println_int(v2);
}
