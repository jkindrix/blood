// COMPILE_FAIL: ambiguous dispatch — cross-parameter incomparable specificity
// EXPECT: ambiguous dispatch
// Test: fn route<T>(x: T, y: i32) vs fn route<T>(x: i32, y: T) — call with (i32, i32)
// SPEC: §3.7 — neither is uniformly more specific across all parameters

struct Router {}

impl Router {
    fn route<T>(self, x: T, y: i32) -> i32 { 1 }
    fn route<T>(self, x: i32, y: T) -> i32 { 2 }
}

fn main() -> i32 {
    let r: Router = Router {};
    // Ambiguous — neither overload is uniformly more specific
    r.route(42, 42) - 1
}
