// Test: T.Item associated type projection in generic function signatures
// EXPECT: 42
trait Container {
    type Item;
    fn get(self: &Self) -> Self.Item;
}

struct IntBox {
    value: i32,
}

impl Container for IntBox {
    type Item = i32;
    fn get(self: &Self) -> i32 {
        self.value
    }
}

fn extract<T: Container>(c: &T) -> T.Item {
    c.get()
}

fn main() -> i32 {
    let b = IntBox { value: 42 };
    let result: i32 = extract(&b);
    println_int(result);
    if result != 42 { return 1; }
    0
}
