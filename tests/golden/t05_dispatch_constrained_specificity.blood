// RUN: exit 0
// Test: more-constrained generic vs less-constrained generic dispatch
// method<T: Display>(x: T) vs method<T: Display + Debug>(x: T)
// SPEC: DISPATCH.md §3.7 — more-constrained method wins

trait Display {
    fn display(self: &Self) -> i32;
}

trait Debug {
    fn debug(self: &Self) -> i32;
}

struct MyType {}

impl Display for MyType {
    fn display(self: &Self) -> i32 { 1 }
}

impl Debug for MyType {
    fn debug(self: &Self) -> i32 { 2 }
}

struct Dispatcher {}

impl Dispatcher {
    fn process<T: Display>(self: &Self, x: T) -> i32 {
        100
    }
    fn process<T: Display + Debug>(self: &Self, x: T) -> i32 {
        200
    }
}

fn main() -> i32 {
    let d: Dispatcher = Dispatcher {};
    let m: MyType = MyType {};
    let result: i32 = d.process(m);
    // More-constrained wins: Display + Debug > Display
    result - 200
}
