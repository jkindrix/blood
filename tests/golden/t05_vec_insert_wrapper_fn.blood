// Test: Vec.insert through a non-generic wrapper function. Closes S93.
// Verifies elem_size derivation from args[2] (the element) for wrapper calls,
// and exercises the realloc path: pushing then inserting many elements forces
// vec_ensure_cap to grow the buffer; the runtime re-fetches `data` after
// growth so the trailing-shift memmove targets the new allocation.
// EXPECT: a: 1
// EXPECT: b: 99
// EXPECT: c: 2
// EXPECT: d: 3
// EXPECT: post_grow_first: 0
// EXPECT: post_grow_last: 9

fn put_at(v: &mut Vec<i32>, idx: usize, elem: i32) / pure {
    v.insert(idx, elem);
}

fn main() -> i32 {
    let mut v: Vec<i32> = Vec.new();
    v.push(1);
    v.push(2);
    v.push(3);

    // Insert 99 at index 1: [1, 99, 2, 3].
    put_at(&mut v, 1, 99);
    print("a: ");
    match v.get(0) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("b: ");
    match v.get(1) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("c: ");
    match v.get(2) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("d: ");
    match v.get(3) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }

    // Force realloc by inserting many elements at the front. Initial cap
    // grows from 4 → 8 → ...; check first/last after the dust settles.
    let mut g: Vec<i32> = Vec.new();
    for i in 0..10 {
        put_at(&mut g, 0, 9 - i);
    }
    // After inserting 9..=0 at index 0 in turn, g is [0, 1, 2, ..., 9].
    print("post_grow_first: ");
    match g.get(0) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("post_grow_last: ");
    match g.get(9) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    0
}
