// Test: String.contains(&str) through a non-generic wrapper function.
// EXPECT: w_hit: true
// EXPECT: w_miss: false

fn has(haystack: &String, needle: &str) -> bool / pure {
    haystack.contains(needle)
}

fn main() -> i32 {
    let s: String = String.from("the quick brown fox");

    print("w_hit: ");
    if has(&s, "quick") { println("true"); } else { println("false"); }

    print("w_miss: ");
    if has(&s, "slow") { println("true"); } else { println("false"); }
    0
}
