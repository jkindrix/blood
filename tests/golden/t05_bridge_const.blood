// Test: bridge constant declaration and usage (GAP 7A)
// EXPECT: -1
// EXPECT: 42

bridge "C" Constants {
    const EOF: i32 = -1;
    const ANSWER: i32 = 42;
}

fn main() -> i32 {
    let eof: i32 = Constants.EOF;
    let answer: i32 = Constants.ANSWER;
    println_int(eof);
    println_int(answer);
    if eof != -1 { return 1; }
    if answer != 42 { return 2; }
    0
}
