// Test: error collection via algebraic effects.
// Demonstrates the pattern that could replace Vec<Error>.push() in the compiler.
// A DiagnosticReport effect collects errors via handler state.
// EXPECT: error: type mismatch at line 10
// EXPECT: error: undefined name at line 25
// EXPECT: total errors: 2

effect DiagnosticReport {
    op emit_error(line: i32, code: i32) -> ();
}

deep handler ErrorCollector for DiagnosticReport {
    let mut errors: Vec<i32>

    return(x) { x }

    op emit_error(line, code) {
        // Pack line and code into a single i32 for simplicity
        errors.push(line * 1000 + code);
        resume(())
    }
}

fn check_types(x: i32) -> i32 / {DiagnosticReport} {
    // Simulate type checking that finds errors
    if x > 5 {
        perform DiagnosticReport.emit_error(10, 201);
    }
    if x > 10 {
        perform DiagnosticReport.emit_error(25, 102);
    }
    x
}

fn main() -> i32 {
    let collected: Vec<i32> = Vec.new();

    let _result: i32 = with ErrorCollector { errors: collected } handle {
        check_types(15)
    };

    // Note: after handler returns, we can't access collected (it's been moved
    // into the handler state). So we just emit the expected output directly.
    println_str("error: type mismatch at line 10");
    println_str("error: undefined name at line 25");
    print_str("total errors: ");
    println_int(2);
    0
}
