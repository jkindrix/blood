// Test: `& &String == & &String` and `& &String != & &String` dispatch
// through `@str_eq` runtime. Pre-fix, the dispatch chain only handled the
// single-Ref-layer `&String` case (S100), so two-layer refs fell through to
// the default BinaryOp path. That path extracts field 0 of the outer
// `{ ptr, i32 }` (which addresses the inner ref's alloca) and pointer-
// compares — wrong because two distinct inner refs always live at different
// alloca addresses regardless of the underlying String content.
// Closes the same root-cause family as S98 (`&str`), S99 (`String`), S100
// (`&String`), and S102 (`&[T]`); same runtime function, same view shape,
// one more deref step at the front. S103-B in the eq-family closure.
// EXPECT: heap_eq_match_param: 1
// EXPECT: heap_eq_mismatch_param: 0
// EXPECT: heap_ne_match_param: 0
// EXPECT: heap_ne_mismatch_param: 1
// EXPECT: inline_eq_match: 1
// EXPECT: inline_eq_mismatch: 0
// EXPECT: empty_eq_empty: 1
// EXPECT: empty_eq_nonempty: 0
// EXPECT: mutated_eq_built: 1
// EXPECT: mutated_eq_other: 0

fn build_string(text: &str) -> String {
    let s = String.new();
    s.push_str(text);
    s
}

fn rref_eq(a: & &String, b: & &String) -> bool {
    a == b
}

fn rref_ne(a: & &String, b: & &String) -> bool {
    a != b
}

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn main() -> i32 {
    // Pattern A: heap-built vs heap-built, same content, function-parameter
    // shape. THE silent-miscompile case — distinct inner-ref allocas have
    // distinct addresses even when the underlying String content matches,
    // so the default path always reports "differ".
    let s_hello1 = build_string("hello");
    let s_hello2 = build_string("hello");
    let r_hello1: &String = &s_hello1;
    let r_hello2: &String = &s_hello2;
    print_kv("heap_eq_match_param", rref_eq(&r_hello1, &r_hello2));

    // Pattern B: heap-built vs heap-built, different content via fn param.
    let s_world = build_string("world");
    let r_world: &String = &s_world;
    print_kv("heap_eq_mismatch_param", rref_eq(&r_hello1, &r_world));

    // Pattern C: != flip of A and B.
    print_kv("heap_ne_match_param", rref_ne(&r_hello1, &r_hello2));
    print_kv("heap_ne_mismatch_param", rref_ne(&r_hello1, &r_world));

    // Pattern D: inline shape with no fn-parameter indirection. Exercises
    // the binop directly on `& &String` operands without crossing a function
    // boundary.
    let rr1: & &String = &r_hello1;
    let rr2: & &String = &r_hello2;
    print_kv("inline_eq_match", rr1 == rr2);
    let rr3: & &String = &r_world;
    print_kv("inline_eq_mismatch", rr1 == rr3);

    // Pattern E: empty-String equality through two ref layers. Both have
    // len=0; data ptr depends on String.new() impl, but content-equality
    // must report match.
    let s_empty1 = build_string("");
    let s_empty2 = build_string("");
    let r_empty1: &String = &s_empty1;
    let r_empty2: &String = &s_empty2;
    print_kv("empty_eq_empty", rref_eq(&r_empty1, &r_empty2));
    print_kv("empty_eq_nonempty", rref_eq(&r_empty1, &r_hello1));

    // Pattern F: a String mutated via push_str (potentially through realloc)
    // compared to one built from the equivalent literal in one shot. The
    // mutation may move the data ptr; the two-layer deref must still resolve
    // to the post-realloc data ptr.
    let mut s_grow = build_string("hel");
    s_grow.push_str("lo");
    let s_full = build_string("hello");
    let r_grow: &String = &s_grow;
    let r_full: &String = &s_full;
    print_kv("mutated_eq_built", rref_eq(&r_grow, &r_full));
    print_kv("mutated_eq_other", rref_eq(&r_grow, &r_world));

    0
}
