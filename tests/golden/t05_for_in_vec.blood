// Test: for-in loop over &Vec<i32> — desugars to index-based loop.
// EXPECT: 10_20_30_sum:60

fn main() -> i32 {
    let mut v: Vec<i32> = Vec.new();
    v.push(10);
    v.push(20);
    v.push(30);

    let mut sum: i32 = 0;
    for item in &v {
        print_int(item);
        print("_");
        sum = sum + item;
    }
    print("sum:");
    println_int(sum);
    if sum != 60 { return 1; }
    0
}
