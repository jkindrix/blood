// Test: String.starts_with(&str) through a non-generic wrapper.
// EXPECT: w_hit: true
// EXPECT: w_miss: false

fn has_prefix(s: &String, prefix: &str) -> bool / pure {
    s.starts_with(prefix)
}

fn main() -> i32 {
    let s: String = String.from("foobar");

    print("w_hit: ");
    if has_prefix(&s, "foo") { println("true"); } else { println("false"); }

    print("w_miss: ");
    if has_prefix(&s, "bar") { println("true"); } else { println("false"); }
    0
}
