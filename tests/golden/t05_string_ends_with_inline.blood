// Test: String.ends_with(&str) inline. Closes S94's String audit.
// EXPECT: hit: true
// EXPECT: miss: false
// EXPECT: empty_suffix: true
// EXPECT: too_long: false
// EXPECT: exact: true

fn main() -> i32 {
    let s: String = String.from("hello world");

    print("hit: ");
    if s.ends_with("world") { println("true"); } else { println("false"); }

    print("miss: ");
    if s.ends_with("hello") { println("true"); } else { println("false"); }

    print("empty_suffix: ");
    if s.ends_with("") { println("true"); } else { println("false"); }

    print("too_long: ");
    if s.ends_with("hello world!") { println("true"); } else { println("false"); }

    print("exact: ");
    if s.ends_with("hello world") { println("true"); } else { println("false"); }
    0
}
