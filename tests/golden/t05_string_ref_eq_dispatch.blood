// Test: `&String == &String` and `&String != &String` dispatch through
// `@str_eq` runtime. Pre-fix, the BinaryOp codegen treated the loaded fat ref
// `{ ptr, i32 }` as an aggregate, extracted the first field (alloca address),
// and emitted `icmp eq ptr` — silent miscompile because two distinct String
// allocations always live at different addresses regardless of content.
// Closes the same root-cause family as S98 (`&str`) and S99 (`String`); same
// runtime function, different LLVM layout (single-deref through ref + view
// extract, vs S99's direct extract).
// EXPECT: heap_eq_match_param: 1
// EXPECT: heap_eq_mismatch_param: 0
// EXPECT: heap_ne_match_param: 0
// EXPECT: heap_ne_mismatch_param: 1
// EXPECT: inline_eq_match: 1
// EXPECT: inline_eq_mismatch: 0
// EXPECT: empty_eq_empty: 1
// EXPECT: empty_eq_nonempty: 0
// EXPECT: mutated_eq_built: 1
// EXPECT: mutated_eq_other: 0

fn build_string(text: &str) -> String {
    let s = String.new();
    s.push_str(text);
    s
}

fn ref_eq(a: &String, b: &String) -> bool {
    a == b
}

fn ref_ne(a: &String, b: &String) -> bool {
    a != b
}

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn main() -> i32 {
    // Pattern A: heap-built vs heap-built, same content, function-parameter
    // shape. THE silent-miscompile case — distinct heap allocations have
    // distinct alloca addresses even when content matches, so the default
    // extract-first-field-of-fat-ref path always reports "differ".
    let s_hello1 = build_string("hello");
    let s_hello2 = build_string("hello");
    print_kv("heap_eq_match_param", ref_eq(&s_hello1, &s_hello2));

    // Pattern B: heap-built vs heap-built, different content via fn param.
    let s_world = build_string("world");
    print_kv("heap_eq_mismatch_param", ref_eq(&s_hello1, &s_world));

    // Pattern C: != flip of A and B.
    print_kv("heap_ne_match_param", ref_ne(&s_hello1, &s_hello2));
    print_kv("heap_ne_mismatch_param", ref_ne(&s_hello1, &s_world));

    // Pattern D: &local references in the inline shape (no fn-parameter
    // indirection). Exercises the `let r = &s; r == r2` path where MIR
    // sees `Operand::Copy(_r)` of a `&String`-typed local.
    let r1: &String = &s_hello1;
    let r2: &String = &s_hello2;
    print_kv("inline_eq_match", r1 == r2);
    let r3: &String = &s_world;
    print_kv("inline_eq_mismatch", r1 == r3);

    // Pattern E: empty-String equality. Both have len=0; data ptr depends
    // on String.new() impl, but content-equality must report match.
    let s_empty1 = build_string("");
    let s_empty2 = build_string("");
    print_kv("empty_eq_empty", ref_eq(&s_empty1, &s_empty2));
    print_kv("empty_eq_nonempty", ref_eq(&s_empty1, &s_hello1));

    // Pattern F: a String mutated via push_str (potentially through realloc)
    // compared to a String built from the equivalent literal in one shot.
    // Exercises the data-ptr-after-realloc path through the &String deref.
    let mut s_grow = build_string("hel");
    s_grow.push_str("lo");
    let s_full = build_string("hello");
    print_kv("mutated_eq_built", ref_eq(&s_grow, &s_full));
    print_kv("mutated_eq_other", ref_eq(&s_grow, &s_world));

    0
}
