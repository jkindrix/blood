// Test: `&[T] == &[T]` and `&[T] != &[T]` dispatch through `@str_eq`
// runtime. Pre-fix, the BinaryOp codegen treated the loaded slice ref
// `{ ptr, i64 }` as an aggregate, extracted the first field (data ptr),
// and emitted `icmp eq ptr` — silent miscompile because two distinct
// slice allocations always live at different addresses regardless of
// content. Closes the same root-cause family as S98 (`&str`),
// S99 (`String`), and S100 (`&String`); same runtime function, different
// LLVM-layout semantics (count * elem_size to convert element count to
// byte count).
//
// Coverage:
//   - `&[u8]` (elem_size = 1, no multiplier) — Patterns A/B/C/D
//   - `&[i32]` (elem_size = 4, multiplier path) — Patterns E/F/G
//   - `&[u64]` (elem_size = 8) — Pattern H
//   - Empty-slice equality — Pattern I
//   - `&[u8]` matching `String.as_bytes()` content from distinct buffers —
//     Pattern J (the bug's natural use case)
//
// EXPECT: u8_eq_match: 1
// EXPECT: u8_eq_mismatch: 0
// EXPECT: u8_ne_match: 0
// EXPECT: u8_ne_mismatch: 1
// EXPECT: i32_eq_match: 1
// EXPECT: i32_eq_mismatch: 0
// EXPECT: i32_ne_match: 0
// EXPECT: i32_eq_param_match: 1
// EXPECT: u64_eq_match: 1
// EXPECT: u64_eq_mismatch: 0
// EXPECT: empty_eq_empty: 1
// EXPECT: empty_eq_nonempty: 0
// EXPECT: u8_diff_buf_same_content: 1

fn slice_eq_u8(a: &[u8], b: &[u8]) -> bool {
    a == b
}

fn slice_ne_u8(a: &[u8], b: &[u8]) -> bool {
    a != b
}

fn slice_eq_i32(a: &[i32], b: &[i32]) -> bool {
    a == b
}

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn main() -> i32 {
    // Pattern A/B: &[u8] equality through fn parameter — the silent-miscompile
    // case. Two distinct array allocations with the same content must compare
    // equal.
    let a: [u8; 3] = [1u8, 2u8, 3u8];
    let b: [u8; 3] = [1u8, 2u8, 3u8];
    let c: [u8; 3] = [1u8, 2u8, 4u8];
    print_kv("u8_eq_match", slice_eq_u8(&a, &b));
    print_kv("u8_eq_mismatch", slice_eq_u8(&a, &c));

    // Pattern C/D: != flip of A and B.
    print_kv("u8_ne_match", slice_ne_u8(&a, &b));
    print_kv("u8_ne_mismatch", slice_ne_u8(&a, &c));

    // Pattern E/F: &[i32] inline equality (elem_size = 4, exercises the
    // multiplier path). Inline `sxa == sxb` shape — MIR sees Operand::Copy
    // of `&[i32]`-typed locals.
    let xa: [i32; 3] = [10, 20, 30];
    let xb: [i32; 3] = [10, 20, 30];
    let xc: [i32; 3] = [10, 20, 99];
    let sxa: &[i32] = &xa;
    let sxb: &[i32] = &xb;
    let sxc: &[i32] = &xc;
    print_kv("i32_eq_match", sxa == sxb);
    print_kv("i32_eq_mismatch", sxa == sxc);
    print_kv("i32_ne_match", sxa != sxb);

    // Pattern G: &[i32] equality through fn parameter (the param-shape we
    // already covered for &[u8]). Confirms multiplier-path works through
    // the wrapper-call shape too.
    print_kv("i32_eq_param_match", slice_eq_i32(&xa, &xb));

    // Pattern H: &[u64] (elem_size = 8 — the maximum primitive).
    let ya: [u64; 2] = [0xDEADBEEFu64, 0xCAFEBABEu64];
    let yb: [u64; 2] = [0xDEADBEEFu64, 0xCAFEBABEu64];
    let yc: [u64; 2] = [0xDEADBEEFu64, 0u64];
    let sya: &[u64] = &ya;
    let syb: &[u64] = &yb;
    let syc: &[u64] = &yc;
    print_kv("u64_eq_match", sya == syb);
    print_kv("u64_eq_mismatch", sya == syc);

    // Pattern I: empty-slice equality. Both have len=0; data ptr depends
    // on array storage, but content-equality must report match.
    let e1: [u8; 0] = [];
    let e2: [u8; 0] = [];
    let se1: &[u8] = &e1;
    let se2: &[u8] = &e2;
    let sa_ref: &[u8] = &a;
    print_kv("empty_eq_empty", se1 == se2);
    print_kv("empty_eq_nonempty", se1 == sa_ref);

    // Pattern J: distinct allocations, same content — same-content arrays
    // built independently from literals, compared as `&[u8]`. Validates that
    // the byte-comparison path correctly returns true for identical content
    // across different storage. (Pattern A also covers this for &[u8] but
    // J makes the intent explicit by naming the buffers differently.)
    let buf1: [u8; 5] = [104u8, 101u8, 108u8, 108u8, 111u8]; // "hello"
    let buf2: [u8; 5] = [104u8, 101u8, 108u8, 108u8, 111u8];
    print_kv("u8_diff_buf_same_content", slice_eq_u8(&buf1, &buf2));

    0
}
