// COMPILE_FAIL: trait with Self return type is not object-safe
// EXPECT: E0901
// Test: Self in return position prevents dyn Trait usage

trait Clonable {
    fn clone_self(self: &Self) -> Self;
}

struct Foo {}

impl Clonable for Foo {
    fn clone_self(self: &Self) -> Self { Foo {} }
}

fn main() -> i32 {
    let f: Foo = Foo {};
    let d: &dyn Clonable = &f as &dyn Clonable;
    0
}
