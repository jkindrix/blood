// Test: multi-caller `impl<T: Debug> Debug for Frozen<T>` (S79).
//
// Calls `.fmt()` on three different Frozen<T> instantiations
// (i32, bool, u64). Verifies Option F's per-caller specialization
// for the Debug delegation — each formats its inner T via the
// concrete `impl Debug for <T>`.
//
// EXPECT: Frozen(42)
// EXPECT: Frozen(true)
// EXPECT: Frozen(99)
mod std;
use std.core.frozen.{Frozen, Freeze};
use std.traits.debug.Debug;

fn main() -> i32 {
    let fi: Frozen<i32> = Frozen.new(42);
    let fb: Frozen<bool> = Frozen.new(true);
    let fu: Frozen<u64> = Frozen.new(99u64);

    println_str(fi.fmt().as_str());
    println_str(fb.fmt().as_str());
    println_str(fu.fmt().as_str());

    0
}
