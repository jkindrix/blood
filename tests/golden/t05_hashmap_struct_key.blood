// Test: HashMap with a user-defined struct key (closes C2-STRUCT-KEY).
//
// Previously, `HashMap<Point, i32>` where Point is a non-String user ADT
// would route through the runtime's `hash_string_key` fast path (kk=1)
// and segfault on the first insert. C3 Phase C Step 2 (S65) adds a new
// codegen path: when the key is a user ADT, emit per-K hash/eq wrapper
// functions that delegate to the user's `impl Hash for K` and
// `impl PartialEq for K`, and route the HashMap call to the `_fn`
// runtime variants added in S64 (Phase C Step 1).
//
// This golden exercises:
//   - insert / get / contains_key / remove on HashMap<Point, i32>
//   - user `impl Hash for Point { fn hash }` composing two i32 field hashes
//     via the Hash trait's `fn hash(&self, &mut u64)` signature
//   - user `impl PartialEq for Point { fn eq }` doing field-wise comparison
//     (byte-level comparison would also produce the same result for this
//     pure-data struct, but we exercise the real call path to validate the
//     eq wrapper is invoked during collision probing)
//
// EXPECT: insert: 42
// EXPECT: insert: 99
// EXPECT: get p1: 42
// EXPECT: get p2: 99
// EXPECT: contains p1: true
// EXPECT: contains p3: false
// EXPECT: len: 2
// EXPECT: removed p1
// EXPECT: len after: 1
// EXPECT: get p1 after: NONE
mod std;
use std.traits.hash.Hash;

struct Point {
    x: i32,
    y: i32,
}

impl Hash for Point {
    fn hash(self: &Self, state: &mut u64) {
        self.x.hash(state);
        self.y.hash(state);
    }
}

trait PartialEq {
    fn eq(self: &Self, other: &Self) -> bool;
}

impl PartialEq for Point {
    fn eq(self: &Self, other: &Self) -> bool {
        self.x == other.x && self.y == other.y
    }
}

fn main() -> i32 {
    let mut map: HashMap<Point, i32> = HashMap.new();

    let p1 = Point { x: 1, y: 2 };
    let p2 = Point { x: 3, y: 4 };
    let p3 = Point { x: 5, y: 6 };

    print("insert: ");
    println_int(42);
    map.insert(p1, 42);

    print("insert: ");
    println_int(99);
    let p2_ins = Point { x: 3, y: 4 };
    map.insert(p2_ins, 99);

    let q1 = Point { x: 1, y: 2 };
    match map.get(&q1) {
        Option.Some(v) => { print("get p1: "); println_int(v); }
        Option.None => { println("get p1: NONE"); }
    }

    let q2 = Point { x: 3, y: 4 };
    match map.get(&q2) {
        Option.Some(v) => { print("get p2: "); println_int(v); }
        Option.None => { println("get p2: NONE"); }
    }

    let q3 = Point { x: 1, y: 2 };
    if map.contains_key(&q3) {
        println("contains p1: true");
    } else {
        println("contains p1: false");
    }

    let q4 = Point { x: 5, y: 6 };
    if map.contains_key(&q4) {
        println("contains p3: true");
    } else {
        println("contains p3: false");
    }

    print("len: ");
    println_int(map.len() as i32);

    let q5 = Point { x: 1, y: 2 };
    match map.remove(&q5) {
        Option.Some(_) => { println("removed p1"); }
        Option.None => { println("remove failed"); }
    }

    print("len after: ");
    println_int(map.len() as i32);

    let q6 = Point { x: 1, y: 2 };
    match map.get(&q6) {
        Option.Some(v) => { print("get p1 after: "); println_int(v); }
        Option.None => { println("get p1 after: NONE"); }
    }

    0
}
