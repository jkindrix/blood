// GAP 1D exploit: primitive ref escapes through identity function call.
// BC-01 and codegen E0503 only check direct Ref→return chains.
// Passing &local through a function call launders the reference.
//
// FIXED: ArgEscape primitives are no longer demoted to Stack. The local
// x gets region allocation (gen-tracked), so the value 42 is preserved
// safely even after the function returns. The use-after-free is prevented.
// EXPECT: 42

fn identity_ref(r: &i32) -> &i32 {
    r
}

fn make_ref() -> &i32 {
    let x: i32 = 42;
    identity_ref(&x)
}

fn clobber() -> i32 {
    let a: i32 = 111111;
    let b: i32 = 222222;
    let c: i32 = 333333;
    let d: i32 = 444444;
    a + b + c + d
}

fn main() -> i32 {
    let r: &i32 = make_ref();
    let _: i32 = clobber();
    let val: i32 = *r;
    println_int(val);
    0
}
