// Test: for-in over Vec of enum values
// EXPECT: 1_2_3_

enum Color {
    Red,
    Green,
    Blue,
}

fn color_id(c: &Color) -> i32 {
    match c {
        &Color.Red => 1,
        &Color.Green => 2,
        &Color.Blue => 3,
    }
}

fn main() -> i32 {
    let mut colors: Vec<Color> = Vec.new();
    colors.push(Color.Red);
    colors.push(Color.Green);
    colors.push(Color.Blue);

    for c in &colors {
        let id: i32 = color_id(c);
        print_int(id);
        print("_");
    }
    0
}
