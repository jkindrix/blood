// Test: Frozen<T> basic usage — wrap a Freeze type, access via get()
//
// A1 Phase 3c (S75): uses stdlib Frozen + Freeze instead of local
// redeclaration. Exercises the common `mod std; use std.core.frozen.*`
// import pattern.
//
// EXPECT: 42
// EXPECT: 100
mod std;
use std.core.frozen.{Frozen, Freeze};

fn main() -> i32 {
    // Create a frozen i32
    let f: Frozen<i32> = Frozen.new(42);

    // Access via get()
    let v: &i32 = f.get();
    println_int(*v);
    if *v != 42 {
        return 1;
    }

    // Create another frozen value
    let f2: Frozen<i32> = Frozen.new(100);
    let v2: &i32 = f2.get();
    println_int(*v2);
    if *v2 != 100 {
        return 2;
    }

    0
}
