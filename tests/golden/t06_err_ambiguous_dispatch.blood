// COMPILE_FAIL: E0214
// EXPECT: E0243
// Test: definition-time dispatch ambiguity detection (DIS-04)

struct Foo {}

impl Foo {
    fn process(self: &Self, x: i32) -> i32 {
        x
    }
}

impl Foo {
    fn process(self: &Self, x: i32) -> i32 {
        x + 1
    }
}

fn main() -> i32 {
    let f = Foo {};
    f.process(1)
}
