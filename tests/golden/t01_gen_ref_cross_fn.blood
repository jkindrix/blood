// Test: generational reference passed across function boundaries
// EXPECT: 77
// EXPECT: 33
// EXPECT_EXIT: nonzero
// FIXME(E3-BUG-1): should exit 0; bare `fn main()` returns last RAX value as exit code.
// See BUGS_OPEN.md "E3-BUG-1".

fn read_ref(r: &i32) -> i32 {
    *r
}

fn main() {
    let a: i32 = 77;
    let result: i32 = read_ref(&a);
    println_int(result);

    let b: i32 = 33;
    let result2: i32 = read_ref(&b);
    println_int(result2);
}
