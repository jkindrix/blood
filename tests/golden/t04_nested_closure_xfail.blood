// XFAIL: Nested closure inside another closure — inner closure body is
// not compiled, leaving a dangling `@blood_closure_XXX` reference in
// the emitted IR. Tracked as S-7 in .tmp/AUDIT_2026-04-07.md.
//
// The outer closure is compiled normally, but the inner one
// (referenced only via the outer closure's body) is missed by the
// closure worklist in codegen. Fix requires tracing closure
// collection from MIR lowering through the codegen driver.
//
// Simple closure in a function body: WORKS.
// Closure captured and passed to a function: WORKS.
// Closure nested inside another closure's body: FAILS (this test).

// EXPECT: 30

fn apply_twice(f: fn() -> i32) -> i32 {
    f() + f()
}

fn main() -> i32 {
    let base: i32 = 5;
    // Outer closure contains a nested closure definition
    let outer = || -> i32 {
        let inner = || -> i32 { base * 3 };
        inner()
    };
    let result: i32 = apply_twice(outer);
    if result == 30 { return 0; }
    1
}
