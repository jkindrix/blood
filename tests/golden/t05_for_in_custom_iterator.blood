// COMPILE_FAIL: for-in on custom iterator type (blocked on single-file mode typeck)
// EXPECT: type mismatch
// NOTE: Known limitation — single-file mode doesn't fully register impls,
// so the custom iterator detection in infer_for_iter returns None.
// The streaming mode (selfhost compilation) works correctly.

struct Counter {
    current: i32,
    max: i32,
}

impl Counter {
    fn new(max: i32) -> Counter {
        Counter { current: 0, max: max }
    }

    fn next(self: &mut Counter) -> Option<i32> {
        if self.current < self.max {
            let val = self.current;
            self.current = self.current + 1;
            Option.Some(val)
        } else {
            Option.None
        }
    }
}

fn main() -> i32 {
    let mut counter = Counter.new(5);
    let mut sum: i32 = 0;
    for x in counter {
        sum = sum + x;
    }
    // 0 + 1 + 2 + 3 + 4 = 10
    println_int(sum);
    0
}
