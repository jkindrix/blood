// A1 Phase 3a (GAP-2): `Frozen.new(heap_t)` deep-freezes the inner heap
// buffers via the MIR intrinsic dispatch path.
//
// Background: Blood erases impl-level type parameters at codegen, so the
// generic body of `impl<T> Frozen<T>.new(value: T)` would see T → i64 and
// truncate any T > 8 bytes (String, Wrapper{s:String}, etc.) at the Call
// boundary, then call `blood_freeze_fields` with a zero-entry layout
// descriptor (the body's T is Infer, no field info known).
//
// Fix (S60): HIR lowering captures Frozen.new's DefId during lower_assoc_fn;
// MIR lowering's `lower_call_expr` rewrites Calls to that DefId as inline
// `Rvalue.Aggregate(Adt(frozen_def_id, 0, [T]))`, bypassing the generic body.
// Codegen's ADT aggregate path (already used by the inline `Frozen { value: w }`
// shape — Phase 2's `t05_frozen_deep_string.blood`) then handles persist +
// freeze + freeze_fields with the concrete T from the call site.
//
// A1 Phase 3c (S75): migrated to stdlib Frozen.new. The intrinsic dispatch
// now captures stdlib's DefId via Phase 1a.5 root-scope injection.
//
// EXPECT: 1

mod std;
use std.core.frozen.{Frozen, Freeze};

bridge "C" Rt {
    fn blood_is_frozen(ptr: *mut u8) -> bool;
}

impl Freeze for String {}

struct Wrapper { s: String }
impl Freeze for Wrapper {}

fn main() -> i32 {
    let mut s0: String = String.new();
    s0.push_str("hello");
    let w: Wrapper = Wrapper { s: s0 };
    // Route through stdlib Frozen.new (generic). The MIR intrinsic dispatch
    // rewrites this Call to inline ADT Aggregate, matching the deep-freeze
    // semantics of inline `Frozen { value: w }` (t05_frozen_deep_string.blood).
    let f: Frozen<Wrapper> = Frozen.new(w);
    @unsafe {
        let s_ref: &String = &f.value.s;
        let s_addr: usize = (s_ref as *const String) as usize;
        let data_addr: i64 = ptr_read_i64(s_addr as u64);
        let data_ptr: *mut u8 = (data_addr as usize) as *mut u8;
        let is_frozen: bool = Rt.blood_is_frozen(data_ptr);
        if is_frozen { println_int(1); } else { println_int(0); }
    }
    0
}
