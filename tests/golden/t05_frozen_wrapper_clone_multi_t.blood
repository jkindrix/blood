// Test: same wrapper called with three different concrete T values
// (S85 / Option G-structural).
//
// Verifies the chained mono path produces per-T specializations: each
// call to `copy_inner(&Frozen<X>)` must mono `copy_inner$T<X>` AND
// emit a secondary MonoRequest for `Frozen<X>::clone`. Three distinct
// (T, fn_name) pairs → three primary + three secondary monos. The
// dedup loop in compile_monomorphized_bodies ensures no double-emit.
//
// EXPECT: 42
// EXPECT: 1
// EXPECT: 99

mod std;
use std.core.frozen.{Frozen, Freeze};
use std.traits.clone.Clone;

fn copy_inner<T: Clone>(a: &Frozen<T>) -> Frozen<T> {
    a.clone()
}

fn main() -> i32 {
    let fi: Frozen<i32> = Frozen.new(42);
    let fb: Frozen<bool> = Frozen.new(true);
    let fu: Frozen<u64> = Frozen.new(99u64);

    let ci: Frozen<i32> = copy_inner(&fi);
    let cb: Frozen<bool> = copy_inner(&fb);
    let cu: Frozen<u64> = copy_inner(&fu);

    println_int(*ci.get());
    if *cb.get() { println_int(1); } else { println_int(0); }
    let u: u64 = *cu.get();
    println_int(u as i32);

    0
}
