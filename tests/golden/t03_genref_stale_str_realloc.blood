// Canary: &str from String.as_str() uses gen=0 (untracked).
//
// String data buffer gen tracking via blood_lazy_register_gen was removed
// from the string_as_str codegen path because it caused thousands of false
// positive stale ref panics per compilation. Root cause: effect handler
// snapshot validation checks ALL gen-tracked allocas at every perform site,
// including dead &str temporaries whose backing String buffers were freed
// by ensure_cap during normal growth. Until snapshot liveness analysis can
// exclude dead references, &str from as_str() is intentionally untracked.
//
// This test verifies the compiler does NOT panic on stale &str references.
// The &str points to freed memory after the String grows, but gen=0 means
// validation is skipped. We do NOT read through the stale reference (that
// would be reading freed memory).
//
// EXPECT: ok

fn main() -> i32 {
    let mut _stale: &str = "";
    region {
        let mut s: String = String.new();
        s.push_str("hi");
        _stale = s.as_str();         // gen=0 (untracked)
        s.push_str("abcdefghijklmnopqrstuvwxyz"); // triggers realloc
    }
    // _stale now points to freed memory, but we don't read it.
    // The important thing is that no stale ref panic was triggered.
    println("ok");
    0
}
