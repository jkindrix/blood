// Canary: &str from String.as_str() now has lazily-registered gen (A3).
// String reallocation invalidates the old buffer's gen via blood_free_simple,
// so the stale &str would fail validation if dereferenced. This test
// deliberately does NOT deref the stale ref — verifying that the realloc
// path itself does not produce a spurious panic from snapshot validation
// or any other code path. See t03_genref_stale_str_deref.blood for the
// companion that verifies TRUE positive detection on deref.
//
// EXPECT: ok

fn main() -> i32 {
    let mut _stale: &str = "";
    region {
        let mut s: String = String.new();
        s.push_str("hi");
        _stale = s.as_str();         // gen=0 (untracked)
        s.push_str("abcdefghijklmnopqrstuvwxyz"); // triggers realloc
    }
    // _stale now points to freed memory, but we don't read it.
    // The important thing is that no stale ref panic was triggered.
    println("ok");
    0
}
