// Test: codegen dispatch of `==` and `!=` on Array `[T; N]` types.
// S107 closes the case where the default codegen path's aggregate
// guard checks `{` not `[`, so an unrouted Array Eq/Ne reached
// `icmp eq [N x T]` and llc rejected with "icmp requires integer
// operands". `try_emit_binop_array_eq` emits per-index extractvalue
// + recursive dispatch + AND-chain. Empty arrays compare vacuously
// equal.
//
// EXPECT: arr_eq_match: 1
// EXPECT: arr_eq_mismatch_first: 0
// EXPECT: arr_eq_mismatch_middle: 0
// EXPECT: arr_eq_mismatch_last: 0
// EXPECT: arr_ne_match: 0
// EXPECT: arr_ne_mismatch: 1
// EXPECT: u8_arr_eq_match: 1
// EXPECT: u8_arr_eq_mismatch: 0
// EXPECT: bool_arr_eq_match: 1
// EXPECT: bool_arr_eq_mismatch: 0
// EXPECT: single_elem_eq_match: 1
// EXPECT: single_elem_eq_mismatch: 0
// EXPECT: nested_arr_eq_match: 1
// EXPECT: nested_arr_eq_mismatch_inner: 0
// EXPECT: nested_arr_eq_mismatch_outer: 0
// EXPECT: fn_param_eq_match: 1
// EXPECT: fn_param_eq_mismatch: 0
mod std;

fn bool_to_int(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn print_kv(label: &str, v: bool) {
    print_str(label);
    print_str(": ");
    println_int(bool_to_int(v));
}

fn arr3_arg_eq(a: [i32; 3], b: [i32; 3]) -> bool {
    a == b
}

fn main() -> i32 {
    let a1: [i32; 3] = [1, 2, 3];
    let a2: [i32; 3] = [1, 2, 3];
    let a3: [i32; 3] = [9, 2, 3];
    let a4: [i32; 3] = [1, 9, 3];
    let a5: [i32; 3] = [1, 2, 9];
    print_kv("arr_eq_match", a1 == a2);
    print_kv("arr_eq_mismatch_first", a1 == a3);
    print_kv("arr_eq_mismatch_middle", a1 == a4);
    print_kv("arr_eq_mismatch_last", a1 == a5);
    print_kv("arr_ne_match", a1 != a2);
    print_kv("arr_ne_mismatch", a1 != a3);

    let u1: [u8; 4] = [10u8, 20u8, 30u8, 40u8];
    let u2: [u8; 4] = [10u8, 20u8, 30u8, 40u8];
    let u3: [u8; 4] = [10u8, 20u8, 30u8, 99u8];
    print_kv("u8_arr_eq_match", u1 == u2);
    print_kv("u8_arr_eq_mismatch", u1 == u3);

    let b1: [bool; 3] = [true, false, true];
    let b2: [bool; 3] = [true, false, true];
    let b3: [bool; 3] = [true, true, true];
    print_kv("bool_arr_eq_match", b1 == b2);
    print_kv("bool_arr_eq_mismatch", b1 == b3);

    let s1: [i64; 1] = [42i64];
    let s2: [i64; 1] = [42i64];
    let s3: [i64; 1] = [99i64];
    print_kv("single_elem_eq_match", s1 == s2);
    print_kv("single_elem_eq_mismatch", s1 == s3);

    let n1: [[i32; 2]; 3] = [[1, 2], [3, 4], [5, 6]];
    let n2: [[i32; 2]; 3] = [[1, 2], [3, 4], [5, 6]];
    let n3: [[i32; 2]; 3] = [[1, 9], [3, 4], [5, 6]];
    let n4: [[i32; 2]; 3] = [[1, 2], [3, 4], [9, 6]];
    print_kv("nested_arr_eq_match", n1 == n2);
    print_kv("nested_arr_eq_mismatch_inner", n1 == n3);
    print_kv("nested_arr_eq_mismatch_outer", n1 == n4);

    let p: [i32; 3] = [7, 8, 9];
    let q: [i32; 3] = [7, 8, 9];
    let r: [i32; 3] = [7, 8, 0];
    print_kv("fn_param_eq_match", arr3_arg_eq(p, q));
    print_kv("fn_param_eq_mismatch", arr3_arg_eq(p, r));

    0
}
