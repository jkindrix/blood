// COMPILE_FAIL: E0222
// EXPECT: linear value captured in deep handler body
effect Ask {
    op ask() -> i32;
}

fn main() -> i32 {
    let x: linear i32 = 42;
    let result: i32 = try {
        let a: i32 = perform Ask.ask();
        a
    } with {
        Ask.ask() => {
            let v: i32 = x;
            resume(v);
        }
    };
    result
}
