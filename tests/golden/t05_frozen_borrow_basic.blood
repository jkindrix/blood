// Test: stdlib `impl<T> Borrow<T> for Frozen<T>` (S87).
//
// `f.borrow()` on `f: Frozen<i32>` dispatches to the Borrow trait
// delegation, which returns `&self.value` (i.e. `&i32`).
//
// EXPECT: 42
mod std;
use std.core.frozen.{Frozen, Freeze};
use std.traits.borrow.Borrow;

fn main() -> i32 {
    let f: Frozen<i32> = Frozen.new(42);
    let r: &i32 = f.borrow();
    println_int(*r);

    0
}
