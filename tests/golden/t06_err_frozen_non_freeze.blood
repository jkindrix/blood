// COMPILE_FAIL: `freeze<T: Freeze>` wrapper rejects non-Freeze type
// EXPECT: type does not implement trait
//
// A1 Phase 3c (S75): migrated to stdlib Frozen + Freeze. The `T: Freeze`
// bound on the user function binds to stdlib's Freeze trait (injected
// into root scope by `inject_stdlib_frozen_into_root`).

mod std;
use std.core.frozen.{Frozen, Freeze};

fn freeze<T: Freeze>(val: T) -> Frozen<T> {
    Frozen { value: val }
}

fn main() -> i32 {
    let mut x: i32 = 42;
    let r: &mut i32 = &mut x;
    let f: Frozen<&mut i32> = freeze(r);
    0
}
