// Test: stale reference to region-allocated data panics on dereference.
// The struct is allocated inside the region (deferred allocation at
// RegionEnter). After region destroy, dereferencing the stale reference
// triggers a generation check failure.
// EXPECT_EXIT: nonzero

struct Pair {
    a: i32,
    b: i32,
}

fn main() -> i32 {
    let dummy: Pair = Pair { a: 0, b: 0 };
    let mut r: &Pair = &dummy;
    region {
        let p: Pair = Pair { a: 42, b: 99 };
        r = &p;
    }
    // Region destroyed — r is stale
    println_int((*r).a);
    0
}
