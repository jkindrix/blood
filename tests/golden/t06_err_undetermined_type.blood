// COMPILE_FAIL: undetermined type variable
// EXPECT: cannot infer type
// Test: generic function with undetermined return type should fail
// fn phantom<T, U>(x: T) -> U has no way to determine U from context

fn phantom<T, U>(x: T) -> U {
    x
}

fn main() -> i32 {
    let result = phantom(42);
    0
}
