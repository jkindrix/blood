// Test: HashMap<K, V>.values() iteration via for-in
// EXPECT: count: 3
// EXPECT: sum: 600
// EXPECT: string key count: 2
// EXPECT: string key sum: 30

fn main() -> i32 {
    let mut map: HashMap<i32, i32> = HashMap.new();
    map.insert(10, 100);
    map.insert(20, 200);
    map.insert(30, 300);

    // for-in iteration over values
    let mut count: i32 = 0;
    let mut sum: i32 = 0;
    for val in map.values() {
        count += 1;
        sum += val;
    }
    print("count: ");
    println_int(count);
    print("sum: ");
    println_int(sum);

    // String key HashMap — verify key_kind=1 path works for iteration
    let mut smap: HashMap<String, i32> = HashMap.new();
    smap.insert(make_str("hello"), 10);
    smap.insert(make_str("world"), 20);

    let mut scount: i32 = 0;
    let mut ssum: i32 = 0;
    for val in smap.values() {
        scount += 1;
        ssum += val;
    }
    print("string key count: ");
    println_int(scount);
    print("string key sum: ");
    println_int(ssum);

    0
}

fn make_str(s: &str) -> String {
    let mut r = String.new();
    r.push_str(s);
    r
}
