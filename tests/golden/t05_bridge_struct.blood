// Test: bridge struct declaration and field access (GAP 7A)
// EXPECT: 10
// EXPECT: 20

bridge "C" Geom {
    struct Point {
        x: i32,
        y: i32,
    }
}

fn main() -> i32 {
    let p: Geom.Point = Geom.Point { x: 10, y: 20 };
    println_int(p.x);
    println_int(p.y);
    if p.x != 10 { return 1; }
    if p.y != 20 { return 2; }
    0
}
