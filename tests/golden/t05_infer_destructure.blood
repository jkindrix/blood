// Test: type inference through tuple/struct destructuring
// Types of destructured bindings should be inferred correctly

struct Pair {
    first: i32,
    second: bool,
}

fn make_pair() -> Pair {
    Pair { first: 42, second: true }
}

fn main() -> i32 {
    let p: Pair = make_pair();
    let a: i32 = p.first;
    let b: bool = p.second;
    if b {
        a - 42
    } else {
        1
    }
}
