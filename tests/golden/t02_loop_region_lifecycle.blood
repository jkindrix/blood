// Test: reference from previous loop iteration's region is stale.
// Each iteration creates a new region, allocates data, and destroys it.
// A reference saved from iteration 0 must not be valid in iteration 1.
// EXPECT_EXIT: nonzero

struct Data {
    value: i32,
}

fn main() -> i32 {
    let dummy: Data = Data { value: 0 };
    let mut saved: &Data = &dummy;
    let mut i: i32 = 0;
    while i < 2 {
        region {
            let d: Data = Data { value: i + 100 };
            if i == 0 {
                saved = &d;
            }
            if i == 1 {
                // Iteration 1: saved points to iteration 0's destroyed region
                println_int((*saved).value);
            }
        }
        i += 1;
    }
    0
}
