// Test: array indexing within bounds works correctly
fn main() -> i32 {
    let arr: [i32; 3] = [10, 20, 30];
    let i: i32 = 0;
    let a: i32 = arr[i];
    let j: i32 = 1;
    let b: i32 = arr[j];
    let k: i32 = 2;
    let c: i32 = arr[k];
    // 10 + 20 + 30 = 60
    println_int(a + b + c);
    0
}
// EXPECT: 60
