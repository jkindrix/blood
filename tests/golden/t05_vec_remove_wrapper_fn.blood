// Test: Vec.remove through a non-generic wrapper function. Closes S93.
// Verifies that wrapper-call shapes (where MIR auto-refs `&mut Vec<T>` into
// `&&mut Vec<T>`) still resolve the correct elem_size via
// `extract_vec_element_size_id` (S91 unwrap_all_refs_id helper).
// EXPECT: a: 100
// EXPECT: b: 200
// EXPECT: c: 300
// EXPECT: removed: 200
// EXPECT: tail_len: 2

fn pop_at(v: &mut Vec<i32>, idx: usize) -> i32 / pure {
    v.remove(idx)
}

fn main() -> i32 {
    let mut v: Vec<i32> = Vec.new();
    v.push(100);
    v.push(200);
    v.push(300);

    print("a: ");
    match v.get(0) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("b: ");
    match v.get(1) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }
    print("c: ");
    match v.get(2) { Option.Some(x) => println_int(*x), Option.None => println("NONE"), }

    let r: i32 = pop_at(&mut v, 1);
    print("removed: "); println_int(r);
    print("tail_len: "); println_int(v.len() as i32);
    0
}
