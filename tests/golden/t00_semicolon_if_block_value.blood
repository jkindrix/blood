// Test: if/else as trailing expression returns the selected branch value
// When if/else is the last expression in a block without semicolon,
// its value becomes the block's value
// EXPECT: 0
fn choose(cond: bool) -> i32 {
    if cond {
        10
    } else {
        20
    }
}

fn main() -> i32 {
    let a: i32 = choose(true);
    let b: i32 = choose(false);
    // a should be 10, b should be 20
    // a - 10 + b - 20 == 0 means both correct
    println_int(a - 10 + b - 20);
    a - 10 + b - 20
}
