// Test: Frozen<T> as type-level immutability wrapper
//
// A1 Phase 3c (S75): uses stdlib Frozen. `Point` has all-primitive fields
// so the compiler's `type_is_freeze` structural walk (typeck.blood) auto-
// derives Freeze — no explicit `impl Freeze for Point {}` required.
//
// EXPECT: 42
// EXPECT: 99

mod std;
use std.core.frozen.Frozen;

struct Point { x: i32, y: i32 }

fn use_frozen(f: &Frozen<Point>) -> i32 {
    let r: &Point = f.get();
    r.x + r.y
}

fn main() -> i32 {
    let p: Point = Point { x: 42, y: 99 };
    let f: Frozen<Point> = Frozen.new(p);
    println_int(f.get().x);
    println_int(f.get().y);
    let total: i32 = use_frozen(&f);
    if total != 141 { return 1; }
    0
}
