// f32 / f64: NaN-aware partial_cmp returns None when either operand
// is NaN. lt/le/gt/ge return false in that case (matching IEEE 754
// behavior of the primitive `<` / `<=` / `>` / `>=` operators).
impl PartialOrd for f32 {
    fn partial_cmp(self: &Self, other: &Self) -> Option<Ordering> / pure {
        if *self < *other { Some(Ordering.Less) }
        else if *self > *other { Some(Ordering.Greater) }
        else if *self == *other { Some(Ordering.Equal) }
        else { None }
    }
    fn lt(self: &Self, other: &Self) -> bool / pure { *self < *other }
    fn le(self: &Self, other: &Self) -> bool / pure { *self <= *other }
    fn gt(self: &Self, other: &Self) -> bool / pure { *self > *other }
    fn ge(self: &Self, other: &Self) -> bool / pure { *self >= *other }
}

impl PartialOrd for f64 {
    fn partial_cmp(self: &Self, other: &Self) -> Option<Ordering> / pure {
        if *self < *other { Some(Ordering.Less) }
        else if *self > *other { Some(Ordering.Greater) }
        else if *self == *other { Some(Ordering.Equal) }
        else { None }
    }
    fn lt(self: &Self, other: &Self) -> bool / pure { *self < *other }
    fn le(self: &Self, other: &Self) -> bool / pure { *self <= *other }
    fn gt(self: &Self, other: &Self) -> bool / pure { *self > *other }
    fn ge(self: &Self, other: &Self) -> bool / pure { *self >= *other }
}

// ============================================================
// Ord impls for primitive types
//
// f32 and f64 are intentionally absent: NaN incomparability rules
// out a total ordering.
// ============================================================

impl Ord for bool {
    fn cmp(self: &Self, other: &Self) -> Ordering / pure {
        if *self == *other {
            Ordering.Equal
        } else if !*self {
            Ordering.Less
        } else {
            Ordering.Greater
        }
    }
}

impl Ord for char {
    fn cmp(self: &Self, other: &Self) -> Ordering / pure {
        if *self < *other { Ordering.Less }
        else if *self > *other { Ordering.Greater }
        else { Ordering.Equal }
    }
}

impl Ord for i8 {
    fn cmp(self: &Self, other: &Self) -> Ordering / pure {
        if *self < *other { Ordering.Less }
        else if *self > *other { Ordering.Greater }
        else { Ordering.Equal }
    }
}

impl Ord for i16 {
    fn cmp(self: &Self, other: &Self) -> Ordering / pure {
        if *self < *other { Ordering.Less }
