// reflexivity guarantee Eq requires.
// ============================================================

impl Eq for bool {}
impl Eq for char {}
impl Eq for i8 {}
impl Eq for i16 {}
impl Eq for i32 {}
impl Eq for i64 {}
impl Eq for isize {}
impl Eq for u8 {}
impl Eq for u16 {}
impl Eq for u32 {}
impl Eq for u64 {}
impl Eq for usize {}
impl Eq for str {}
impl Eq for String {}

// ============================================================
// Ordering enum (S82)
//
// Result of an ordering comparison. The three variants describe
// how `self` relates to `other`: `Less` means `self < other`,
// `Equal` means `self == other`, `Greater` means `self > other`.
// ============================================================

/// Result of a comparison between two values.
pub enum Ordering {
    /// `self < other`
    Less,
    /// `self == other`
    Equal,
    /// `self > other`
    Greater,
}

impl Ordering {
    /// Returns true if the ordering is `Less`.
    pub fn is_lt(self: &Self) -> bool / pure {
        match *self {
            Ordering.Less => true,
            Ordering.Equal => false,
            Ordering.Greater => false,
        }
    }

    /// Returns true if the ordering is `Equal`.
    pub fn is_eq(self: &Self) -> bool / pure {
        match *self {
            Ordering.Less => false,
            Ordering.Equal => true,
            Ordering.Greater => false,
        }
    }

    /// Returns true if the ordering is `Greater`.
    pub fn is_gt(self: &Self) -> bool / pure {
        match *self {
            Ordering.Less => false,
            Ordering.Equal => false,
            Ordering.Greater => true,
        }
    }

    /// Returns true if the ordering is `Less` or `Equal`.
    pub fn is_le(self: &Self) -> bool / pure {
        match *self {
            Ordering.Less => true,
            Ordering.Equal => true,
            Ordering.Greater => false,
        }
    }

    /// Returns true if the ordering is `Greater` or `Equal`.
    pub fn is_ge(self: &Self) -> bool / pure {
        match *self {
            Ordering.Less => false,
            Ordering.Equal => true,
            Ordering.Greater => true,
        }
    }

    /// Returns true if the ordering is not `Equal`.
    pub fn is_ne(self: &Self) -> bool / pure {
        match *self {
            Ordering.Less => true,
            Ordering.Equal => false,
            Ordering.Greater => true,
        }
    }

    /// Reverses the ordering: `Less` ↔ `Greater`, `Equal` unchanged.
    pub fn reverse(self: &Self) -> Ordering / pure {
        match *self {
            Ordering.Less => Ordering.Greater,
            Ordering.Equal => Ordering.Equal,
            Ordering.Greater => Ordering.Less,
        }
    }

    /// Chains two orderings: returns `self` unless `Equal`, in which
    /// case returns `other`. Used to break ties in lexicographic
    /// comparison: `a.cmp(&b).then(c.cmp(&d))`.
    pub fn then(self: &Self, other: Ordering) -> Ordering / pure {
        match *self {
            Ordering.Equal => other,
            Ordering.Less => Ordering.Less,
            Ordering.Greater => Ordering.Greater,
        }
    }
}

// ============================================================
// PartialOrd / Ord traits (S82, S83 supertrait pair)
//
// Mirrors Rust's `core::cmp::{PartialOrd, Ord}` with one adjustment:
// `PartialOrd` does NOT carry a default `Rhs = Self` parameter (Blood
// does not yet support default type parameters). `Ord` extends both
// `Eq` and `PartialOrd` per Rust convention; the spec narrowly requires
// `Ord: Eq`, but every Ord type is by construction also PartialOrd.
// ============================================================

/// Trait for partial-ordering comparisons.
///
/// `partial_cmp` returns `Some(Ordering::*)` for comparable values
/// and `None` for incomparable ones (e.g. `f32::NaN`). Default
/// bodies for `lt` / `le` / `gt` / `ge` derive their result from
/// `partial_cmp`; primitive impls override them to avoid a tag
/// branch in the hot path.
pub trait PartialOrd: PartialEq {
    /// Returns the ordering of `self` and `other` if comparable.
    fn partial_cmp(self: &Self, other: &Self) -> Option<Ordering> / pure;

    /// Returns true if `self < other`.
    fn lt(self: &Self, other: &Self) -> bool / pure {
        match self.partial_cmp(other) {
            Some(o) => o.is_lt(),
            None => false,
        }
    }

    /// Returns true if `self <= other`.
    fn le(self: &Self, other: &Self) -> bool / pure {
        match self.partial_cmp(other) {
            Some(o) => o.is_le(),
            None => false,
        }
    }

    /// Returns true if `self > other`.
    fn gt(self: &Self, other: &Self) -> bool / pure {
        match self.partial_cmp(other) {
            Some(o) => o.is_gt(),
            None => false,
        }
    }

    /// Returns true if `self >= other`.
    fn ge(self: &Self, other: &Self) -> bool / pure {
        match self.partial_cmp(other) {
            Some(o) => o.is_ge(),
            None => false,
        }
    }
}

/// Trait for total-ordering comparisons.
///
/// Every pair of values yields a definite `Ordering`. `Eq` and
/// `PartialOrd` both extend `PartialEq`, so the supertrait closure
/// reaches `PartialEq` via two paths — the dispatch ambiguity check
/// dedups same-method-via-two-paths, so the diamond is harmless.
pub trait Ord: Eq + PartialOrd {
    /// Returns the ordering of `self` and `other`.
    fn cmp(self: &Self, other: &Self) -> Ordering / pure;
}

// ============================================================
// PartialOrd impls for primitive types
//
// Each impl provides direct `<` / `<=` / `>` / `>=` bodies in
// addition to `partial_cmp`, matching the explicit-eq/ne pattern
// used by `PartialEq` above.
// ============================================================

impl PartialOrd for bool {
    fn partial_cmp(self: &Self, other: &Self) -> Option<Ordering> / pure {
        if *self == *other {
            Some(Ordering.Equal)
        } else if !*self {
            Some(Ordering.Less)
        } else {
            Some(Ordering.Greater)
        }
    }
    fn lt(self: &Self, other: &Self) -> bool / pure { !*self && *other }
    fn le(self: &Self, other: &Self) -> bool / pure { !*self || *other }
    fn gt(self: &Self, other: &Self) -> bool / pure { *self && !*other }
    fn ge(self: &Self, other: &Self) -> bool / pure { *self || !*other }
}

impl PartialOrd for char {
    fn partial_cmp(self: &Self, other: &Self) -> Option<Ordering> / pure {
        if *self < *other {
            Some(Ordering.Less)
        } else if *self > *other {
            Some(Ordering.Greater)
        } else {
            Some(Ordering.Equal)
        }
    }
    fn lt(self: &Self, other: &Self) -> bool / pure { *self < *other }
    fn le(self: &Self, other: &Self) -> bool / pure { *self <= *other }
    fn gt(self: &Self, other: &Self) -> bool / pure { *self > *other }
    fn ge(self: &Self, other: &Self) -> bool / pure { *self >= *other }
}

impl PartialOrd for i8 {
    fn partial_cmp(self: &Self, other: &Self) -> Option<Ordering> / pure {
        if *self < *other { Some(Ordering.Less) }
        else if *self > *other { Some(Ordering.Greater) }
        else { Some(Ordering.Equal) }
    }
    fn lt(self: &Self, other: &Self) -> bool / pure { *self < *other }
    fn le(self: &Self, other: &Self) -> bool / pure { *self <= *other }
    fn gt(self: &Self, other: &Self) -> bool / pure { *self > *other }
    fn ge(self: &Self, other: &Self) -> bool / pure { *self >= *other }
}

