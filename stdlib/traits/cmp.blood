// Blood Standard Library - Comparison Traits
//
// Traits for comparing values for equality and ordering:
//   - `PartialEq` / `Eq`        (S81)
//   - `PartialOrd` / `Ord` and `Ordering`  (S82)
//
// The eventual `min` / `max` / `minmax` free functions in the prototype
// are deferred — they take `T` by value, exercising the consuming-self +
// value-return calling convention which is currently miscompiled for
// non-primitive receivers (S78 residual). Users can call `.cmp(...)`
// directly and dispatch on the returned `Ordering` until that ABI is
// fixed.

/// Trait for partial equality comparisons.
///
/// Implementors provide `eq`, which tests two values for equality.
/// A default `ne` body negates `eq`; every primitive impl below also
/// provides an explicit `ne` body using the primitive `!=` operator
/// so the common path compiles to a single LLVM `icmp ne` instead of
/// an `icmp eq` + `xor`.
///
/// PartialEq does NOT require reflexivity. `f32`/`f64` implement
/// PartialEq but NOT Eq because `NaN != NaN`.
pub trait PartialEq {
    /// Returns true if `self` is equal to `other`.
    fn eq(self: &Self, other: &Self) -> bool / pure;

    /// Returns true if `self` is not equal to `other`.
    ///
    /// The default body returns `!self.eq(other)`. Primitive impls
    /// override this with the direct `!=` operator for efficiency.
    fn ne(self: &Self, other: &Self) -> bool / pure {
        !self.eq(other)
    }
}

/// Marker trait indicating that equality is reflexive, symmetric,
/// and transitive.
///
/// A type implementing `Eq` promises that `a == a` always holds and
/// that equality defines an equivalence relation. This is required
/// for types used as HashMap keys: the runtime relies on reflexivity
/// to find a value it has just stored.
///
/// Floating-point types intentionally do NOT implement Eq because
/// NaN is unequal to itself.
pub trait Eq: PartialEq {}

// ============================================================
// PartialEq impls for primitive types
//
// Each body reduces to a single LLVM `icmp` / `fcmp` via the primitive
// `==` / `!=` operators (see mir_lower_util.blood + codegen_expr.blood:
// MirBinOp.Eq → icmp eq / fcmp oeq, MirBinOp.Ne → icmp ne / fcmp one).
// ============================================================

impl PartialEq for bool {
    fn eq(self: &Self, other: &Self) -> bool / pure { *self == *other }
    fn ne(self: &Self, other: &Self) -> bool / pure { *self != *other }
}

impl PartialEq for char {
    fn eq(self: &Self, other: &Self) -> bool / pure { *self == *other }
    fn ne(self: &Self, other: &Self) -> bool / pure { *self != *other }
}

