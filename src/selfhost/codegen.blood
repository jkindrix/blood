module blood.codegen;

// Blood Self-Hosted Compiler - Code Generator
//
// This module provides the main entry point for generating LLVM IR from MIR.
// It coordinates the generation of function bodies, declarations, and
// produces complete LLVM modules as text.

mod common;
mod hir_def;
mod hir_ty;
mod hir_item;
mod hir_lower_ctx;
mod mir_def;
mod mir_types;
mod mir_stmt;
mod mir_term;
mod mir_body;
mod codegen_types;
mod codegen_ctx;
mod codegen_emit;
mod codegen_expr;
mod codegen_stmt;
mod codegen_term;
mod codegen_body_fn;
mod mir_escape;
mod mir_ntr_scope;
mod mir_liveness;
mod hashmap;
mod type_intern;
mod codegen_size;
mod interner;

// ============================================================
// Perf diagnostics (Rev 4 instrumentation — permanent)
// ============================================================
// Sub-phase timers accumulated across all generate_function_with_ctx
// calls. Read via pub getters below and printed by main.codegen_pass2.
//
// @unsafe safety note: all `@unsafe { CODEGEN_T_* }` blocks in this file
// access these module-level `static mut` counters. Under parallel codegen
// (4 workers), racing ++ may lose updates. Safety:
//   1. u64 reads/writes are single-instruction on x86-64 — no torn values.
//   2. Lost updates produce imprecise --mem-profile reports, never wrong code.
//   3. No pointers dereferenced; races cannot cause memory unsafety.
static mut CODEGEN_T_SETUP_MS: u64 = 0;       // clear, debug, begin, params, ret, register, header
static mut CODEGEN_T_ESCAPE_MS: u64 = 0;      // mir_escape.analyze_escapes + persist scan + overrides
static mut CODEGEN_T_ALLOCAS_MS: u64 = 0;     // emit_allocas_with_escapes + emit_arg_stores
static mut CODEGEN_T_BLOCKS_MS: u64 = 0;      // basic block emission loop
static mut CODEGEN_T_FOOTER_MS: u64 = 0;      // fn footer, clone result, end

pub fn codegen_t_setup_ms() -> u64 { @unsafe { CODEGEN_T_SETUP_MS } }
pub fn codegen_t_escape_ms() -> u64 { @unsafe { CODEGEN_T_ESCAPE_MS } }
pub fn codegen_t_allocas_ms() -> u64 { @unsafe { CODEGEN_T_ALLOCAS_MS } }
pub fn codegen_t_blocks_ms() -> u64 { @unsafe { CODEGEN_T_BLOCKS_MS } }
pub fn codegen_t_footer_ms() -> u64 { @unsafe { CODEGEN_T_FOOTER_MS } }

// ============================================================
// Module Generation
// ============================================================

/// Result of code generation for a complete module.
pub struct CodegenResult {
    /// The generated LLVM IR as a string.
    pub llvm_ir: String,
    /// Structured errors collected during codegen.
    pub errors: Vec<codegen_ctx.CodegenError>,
    /// Any warnings generated during codegen.
    pub warnings: Vec<String>,
    /// Whether codegen was successful.
    pub success: bool,
}

impl CodegenResult {
    /// Creates a successful result with no errors.
    pub fn ok(llvm_ir: String) -> CodegenResult {
        CodegenResult {
            llvm_ir: llvm_ir,
            errors: Vec.new(),
            warnings: Vec.new(),
            success: true,
        }
    }

    /// Creates a successful result that carries non-fatal errors/warnings from codegen.
    pub fn ok_with_diagnostics(
        llvm_ir: String,
        errors: Vec<codegen_ctx.CodegenError>,
        warnings: Vec<String>,
    ) -> CodegenResult {
        CodegenResult {
            llvm_ir: llvm_ir,
            errors: errors,
            warnings: warnings,
            success: true,
        }
    }

    /// Creates a failed result with a single error message.
    pub fn error(msg: String) -> CodegenResult {
        let mut errors = Vec.new();
        errors.push(codegen_ctx.CodegenError.new(
            codegen_ctx.CodegenErrorKind.InternalError,
            msg,
        ));
        CodegenResult {
            llvm_ir: String.new(),
            errors: errors,
            warnings: Vec.new(),
            success: false,
        }
    }

    /// Returns true if there are any errors.
    pub fn has_errors(self: &CodegenResult) -> bool {
        self.errors.len() > 0
    }
}

/// Generates LLVM IR for a module with multiple functions.
pub fn generate_module(
    module_name: &str,
    functions: &Vec<(String, mir_body.MirBody)>,
    intern: &interner.StringInterner,
) -> CodegenResult {
    // Empty items list and no remaps for backward compatibility
    let empty_items: Vec<hir_lower_ctx.ItemEntry> = Vec.new();
    let empty_remaps: Vec<common.DefaultMethodRemap> = Vec.new();
    generate_module_with_items(module_name, functions, &empty_items, &empty_remaps, intern)
}

/// Finds call remapping entries for a given default method DefId.
fn find_call_remaps(
    remaps: &Vec<common.DefaultMethodRemap>,
    def_id: u32,
) -> Vec<common.CallRemapEntry> {
    let mut result: Vec<common.CallRemapEntry> = Vec.new();
    for i in 0usize..remaps.len() {
        if remaps[i].body_def_id == def_id {
            for j in 0usize..remaps[i].call_remaps.len() {
                result.push(common.CallRemapEntry.new(
                    remaps[i].call_remaps[j].from_def_id,
                    remaps[i].call_remaps[j].to_def_id,
                ));
            }
            return result;
        }
    }
    result
}

/// Generates LLVM IR for a module with multiple functions and ADT item info.
pub fn generate_module_with_items(
    module_name: &str,
    functions: &Vec<(String, mir_body.MirBody)>,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    default_method_remaps: &Vec<common.DefaultMethodRemap>,
    intern: &interner.StringInterner,
) -> CodegenResult {
    let mut output = String.new();

    // Build the DefId to name mapping for all functions
    let mut def_names: Vec<codegen_ctx.DefNameEntry> = Vec.new();
    for idx in 0usize..functions.len() {
        let (ref name, ref body) = functions[idx];
        def_names.push(codegen_ctx.DefNameEntry.new(
            body.def_id.index,
            name.clone(),
        ));
    }

    // Create the shared codegen context with def names
    let mut ctx = codegen_ctx.CodegenCtx.new();
    for entry in &def_names {
        ctx.register_def_name(entry.def_id, entry.name.clone());
    }

    // Populate ADT registry from HIR items
    populate_adt_registry(&mut ctx, items);

    // Generate vtables for dyn Trait dispatch (must be after ADT registry and def names)
    generate_vtables(&mut ctx, intern, items);

    // Module header
    output.push_str("; ModuleID = '");
    output.push_str(module_name);
    output.push_str("'\n");
    output.push_str("source_filename = \"");
    output.push_str(module_name);
    output.push_str(".blood\"\n");
    output.push_str("target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128\"\n");
    output.push_str("target triple = \"x86_64-unknown-linux-gnu\"\n");
    output.push_str("\n");

    // Intrinsic and runtime declarations — must come BEFORE function definitions
    // so that `declare @foo` followed by `define @foo` is valid LLVM IR
    // (the reverse order — define then declare — is a redefinition error).
    let main_unit = main_returns_unit(items);
    let decls = intrinsic_declarations(main_unit);
    output.push_str(decls.as_str());

    // Generate each function using the shared context.
    //
    // DEDUP GUARD: skip duplicate function definitions (keep the first one
    // with each mangled name). This is a LOUD safety net, not a silent
    // workaround. When mangling is correct, monomorphizations have unique
    // names and this branch never fires. When it DOES fire, the compiler
    // has a real bug — either duplicate DefIds producing the same mangled
    // name (a mangling bug) or the same DefId being queued for codegen
    // twice (a driver bug). Emitting both would produce invalid LLVM IR
    // (multiple definitions of the same symbol). Emitting one silently
    // could mask the bug. So: skip + warn to stderr.
    let mut generated_set = hashmap.HashMapU64U32.with_capacity(functions.len());
    let mut skip_count: usize = 0;
    for i in 0usize..functions.len() {
        let (ref name, ref body) = functions[i];
        let name_hash = hashmap.hash_str(name.as_str());
        let already_generated = match generated_set.get(name_hash) {
            Option.Some(_) => true,
            Option.None => false,
        };
        if !already_generated {
            ctx.call_remaps = find_call_remaps(default_method_remaps, body.def_id.index);
            let fn_ir = generate_function_with_ctx(&mut ctx, body, name.as_str(), 0, 1);
            output.push_str(fn_ir.as_str());
            ctx.call_remaps = Vec.new();
            generated_set.insert(name_hash, 1);
        } else {
            skip_count += 1;
            // Emit LOUDLY to stderr — this is a compiler bug, not a
            // no-op. The IR comment remains for debuggability.
            eprint_str("warning: codegen dropped duplicate definition of @");
            eprint_str(name.as_str());
            eprintln_str(" — this is a mangling or driver bug; please report");
            output.push_str("; DUPLICATE SKIPPED (bug): @");
            output.push_str(name.as_str());
            output.push_str("\n");
        }
    }
    if skip_count > 0 {
        eprint_str("warning: codegen skipped ");
        let skip_str = codegen_types.format_u64(skip_count as u64);
        eprint_str(skip_str.as_str());
        eprintln_str(" duplicate function definitions; the compiler should not produce duplicates");
        output.push_str("; TOTAL DUPLICATES SKIPPED: ");
        output.push_str(skip_str.as_str());
        output.push_str("\n");
    }

    // Emit fn pointer wrapper functions collected during codegen
    for wrapper in &ctx.fn_ptr_wrapper_defs {
        output.push_str(wrapper.as_str());
    }

    // Emit vtable global constants
    for vtable in &ctx.vtable_defs {
        output.push_str(vtable.as_str());
    }

    // Emit VFT metadata as comments (P2-9: hash-to-function mapping)
    for vi in 0usize..ctx.vtable_name_entries.len() {
        let vne = &ctx.vtable_name_entries[vi];
        output.push_str("; VFT ");
        output.push_str(vne.vtable_name.as_str());
        output.push_str(" trait=");
        output.push_str(codegen_types.format_u64(vne.trait_def_id as u64).as_str());
        output.push_str(" type=");
        output.push_str(codegen_types.format_u64(vne.type_def_id as u64).as_str());
        output.push_str("\n");
    }

    // Append string constants from the context
    ctx.emit_string_constants();
    // Populate Frozen<T> layout descriptors before emit (GAP-2 A1 Phase 2
    // deep-freeze metadata: walks inner-type fields into { offset, kind,
    // inner_layout, elem_size } entries). Idempotent.
    populate_all_layouts(ctx);
    ctx.emit_layout_descriptors();
    output.push_str(ctx.output.as_str());

    // Drain accumulated errors and warnings from the context
    let errors = ctx.take_errors();
    let warnings = ctx.take_warnings();
    if errors.len() > 0 || warnings.len() > 0 {
        CodegenResult.ok_with_diagnostics(output, errors, warnings)
    } else {
        CodegenResult.ok(output)
    }
}

/// Generates LLVM IR for a function with access to def names table.
/// Legacy function for backward compatibility.
pub fn generate_function_with_defs(
    body: &mir_body.MirBody,
    fn_name: &str,
    def_names: &Vec<codegen_ctx.DefNameEntry>,
) -> String {
    let mut ctx = codegen_ctx.CodegenCtx.new();

    // Register all def names in the context
    for i in 0usize..def_names.len() {
        ctx.register_def_name(def_names[i].def_id, def_names[i].name.clone());
    }

    generate_function_with_ctx(&mut ctx, body, fn_name, 0, 1)
}

/// Generates LLVM IR for a single function using a shared codegen context.
pub fn generate_function_with_ctx(
    ctx: &mut codegen_ctx.CodegenCtx,
    body: &mir_body.MirBody,
    fn_name: &str,
    module_index: u32,
    module_count: u32,
) -> String {
    let t_setup_start = blood_clock_millis();
    // Reset per-function state but keep global state (def_names, adt_registry, string_table)
    ctx.clear_locals();
    ctx.output = String.new();
    // Set up DWARF debug info for this function (source file + line)
    ctx.setup_debug_function(fn_name, body.span.line, module_index, module_count);
    ctx.begin_function(common.make_string(fn_name));

    // Record the DefId of the function being emitted so statement emitters
    // that reference module-level LLVM symbols derived from it (e.g.,
    // PushHandler's mprompt path referencing @body_fn_<fn_id>_<pb_idx> and
    // %env_ty_<fn_id>_<pb_idx>) can reconstruct those names without threading
    // `body` through. Matches the convention used by codegen_body_fn.
    ctx.current_fn_def_id = body.def_id.index;

    // 3d: decide whether Resume terminators in this body should compile
    // to the libmprompt blood_resume path. Named handler op bodies for
    // an mprompt-eligible effect route through mp_resume; every other
    // body falls through to the simple store-back + ret i64 sequence.
    //
    // That fallthrough is correct for TR handler ops. It is ALSO what
    // inline handler op closures (closures with is_handler_op=true) take,
    // because they are never registered in handler_op_body_effect_hash —
    // and consequently every perform against them is routed through
    // blood_perform (direct-call) with a multishot-identity continuation
    // rather than through blood_perform_ntr + mp_prompt_enter. That
    // identity-continuation collapse produces the correct observable
    // result only when the effect op returns unit `()` — i.e., when the
    // handler's post-resume value is irrelevant because there is nothing
    // to return. For non-unit ops the inline path miscompiles (B1 audit,
    // S44; empirical tests in .tmp/b1_audit/). typeck_expr.blood now
    // rejects inline handlers for non-unit-return ops with a pointer to
    // this limitation. Tracked as B1a in the backlog.
    ctx.current_handler_op_uses_mprompt_resume = if ctx.is_handler_op {
        match ctx.handler_op_body_effect(body.def_id.index) {
            Option.Some(eid) => ctx.is_mprompt_eligible_effect(eid),
            Option.None => false,
        }
    } else {
        false
    };

    // NTR handler scope pre-scan — populate ctx.ntr_scopes for the current function.
    // mir_ntr_scope.analyze_ntr_scopes reports ALL handler scopes (TR and NTR); we
    // filter to NTR-only here via handler_needs_abort so downstream emission
    // (sub-tasks 4–6) only sees scopes that actually need the mprompt path.
    // Run early — BEFORE the function header — so env struct type
    // declarations can be emitted at module scope ahead of the function's
    // alloca/GEP uses. LLVM requires the base of GEP/alloca to be a sized
    // type; named type forward references across the function boundary
    // have been observed to fail on llc-18.
    ctx.ntr_scopes = Vec.new();
    let ntr_result = mir_ntr_scope.analyze_ntr_scopes(body);
    for nsi in 0usize..ntr_result.scopes.len() {
        let scope = &ntr_result.scopes[nsi];
        // Filter: only populate scope data for NTR handlers. Every NTR
        // handler is mprompt-eligible after S42's gate flip, so the second
        // check (is_mprompt_eligible_effect) is now tautological with
        // handler_needs_abort — it stays as defense-in-depth in case the
        // classification rules change.
        //
        // Named scopes key on handler_id and consult lookup_handler_effect
        // to find the effect's NTR classification. Inline scopes (B1a-1b)
        // key on effect_id directly because `handler_id == effect_id` —
        // there is no named handler DefId to look up. Today no inline
        // handler's effect is classified NTR, so `scope_eligible` is
        // always false for inline and the branch is dead code; B1a-1b's
        // classification walker will flip this once it lands.
        let scope_eligible = if scope.is_inline {
            ctx.is_non_tail_resumptive_effect(scope.handler_id.index)
        } else {
            ctx.handler_needs_abort(scope.handler_id.index)
        };
        if !scope_eligible {
            continue;
        }
        let effect_id_for_mprompt: u32 = if scope.is_inline {
            scope.handler_id.index
        } else {
            match ctx.lookup_handler_effect(scope.handler_id.index) {
                Option.Some(eid) => eid,
                Option.None => {
                    // Named scope without a handler→effect mapping is
                    // malformed; skip defensively.
                    continue;
                }
            }
        };
        if !ctx.is_mprompt_eligible_effect(effect_id_for_mprompt) {
            continue;
        }
        let mut body_blocks_copy: Vec<mir_def.BasicBlockId> = Vec.with_capacity(scope.body_blocks.len());
        for bbi in 0usize..scope.body_blocks.len() {
            body_blocks_copy.push(mir_def.BasicBlockId { index: scope.body_blocks[bbi].index });
        }
        let mut captures_copy: Vec<mir_def.MirLocalId> = Vec.with_capacity(scope.captures.len());
        for ci in 0usize..scope.captures.len() {
            captures_copy.push(mir_def.MirLocalId { index: scope.captures[ci].index });
        }
        let inline_dest_copy = match &scope.inline_dest {
            &Option.Some(ref p) => Option.Some(p.clone()),
            &Option.None => Option.None,
        };
        ctx.ntr_scopes.push(mir_ntr_scope.NtrScope {
            handler_id: hir_def.DefId { index: scope.handler_id.index },
            is_inline: scope.is_inline,
            push_block: mir_def.BasicBlockId { index: scope.push_block.index },
            pop_block: mir_def.BasicBlockId { index: scope.pop_block.index },
            body_blocks: body_blocks_copy,
            captures: captures_copy,
            body_result_local: scope.body_result_local,
            pop_pre_stmt_count: scope.pop_pre_stmt_count,
            after_block: mir_def.BasicBlockId { index: scope.after_block.index },
            inline_dest: inline_dest_copy,
        });
    }

    // Emit env struct type declarations for each NTR scope at module scope,
    // ahead of the function header. Matches the layout produced by
    // codegen_body_fn.append_env_type_decl so PushHandler's alloca/GEP and
    // body_fn's env unpack reference the same shape.
    //
    // Layout (sub-task 3f): for each capture i we reserve TWO pointer slots
    // at indices 2*i (base alloca ptr) and 2*i+1 (gen alloca ptr). The gen
    // slot is NULL for non-gen-tracked captures and holds `&_<N>_gen` for
    // region/persistent-allocated captures. Slot 2*N holds the normal_flag
    // alloca ptr. Total field count = 2*N + 1.
    let ntr_scope_count_pre = ctx.ntr_scopes.len();
    if ntr_scope_count_pre > 0 {
        let fn_def_id = ctx.current_fn_def_id;
        for si in 0usize..ntr_scope_count_pre {
            let push_idx = ctx.ntr_scopes[si].push_block.index;
            let cap_count = ctx.ntr_scopes[si].captures.len();
            ctx.write("%env_ty_");
            ctx.write(codegen_types.format_u64(fn_def_id as u64).as_str());
            ctx.write("_");
            ctx.write(codegen_types.format_u64(push_idx as u64).as_str());
            ctx.write(" = type { ");
            let field_count = cap_count * 2 + 1;
            for fi in 0usize..field_count {
                if fi > 0 {
                    ctx.write(", ");
                }
                ctx.write("ptr");
            }
            ctx.write(" }\n");
        }
        ctx.write("\n");
    }

    // Build parameter list (skip first local which is return place)
    // For handler op bodies with multiple state fields, skip the state field
    // locals (2..1+state_count) — they are loaded from the state pointer, not passed as args.
    let mut params: Vec<(String, String)> = Vec.new();
    let mut arg_idx: usize = 0;
    let mut p: usize = 1; // Start at 1 to skip return place
    let param_end: usize = 1usize + (body.param_count as usize);
    while p < param_end && p < body.locals.len() {
        let local = &body.locals[p];
        let local_id = mir_def.MirLocalId.new(p as u32);
        // Skip handler state field locals — they're accessed via GEP into state ptr
        if ctx.is_handler_state_field(local_id) {
            p += 1;
            continue;
        }
        // Handler op state local: arg type is ptr (state pointer from wrapper)
        let ty = if ctx.is_handler_state_ptr(local_id) {
            common.make_string("ptr")
        } else {
            codegen_size.type_to_llvm_with_ctx_id(ctx, local.ty)
        };
        let mut arg_name = common.make_string("%arg");
        let idx_str = codegen_types.format_u64(arg_idx as u64);
        arg_name.push_str(idx_str.as_str());
        params.push((ty, arg_name));
        arg_idx += 1;
        p += 1;
    }

    // Get return type (local _0)
    // Normalize {} (empty struct / unit) to void for LLVM function signatures
    let ret_ty_raw = if body.locals.len() > 0 {
        codegen_size.type_to_llvm_with_ctx_id(ctx, body.locals[0].ty)
    } else {
        common.make_string("void")
    };
    let ret_ty = if ctx.is_handler_op {
        // Handler op body functions always return i64 — the wrapper widens anyway,
        // and this allows Resume codegen to return i64 values uniformly
        // (continuation results, widened resume values, etc.)
        common.make_string("i64")
    } else if is_empty_struct_type(ret_ty_raw.as_str()) {
        common.make_string("void")
    } else {
        ret_ty_raw
    };

    // Handler op bodies get an extra i64 %__cont parameter for continuation access.
    // This allows Resume codegen to call blood_continuation_resume_with_regions
    // and continue execution with post-resume code (non-tail-resumptive handlers).
    if ctx.is_handler_op {
        params.push((common.make_string("i64"), common.make_string("%__cont")));
    }

    // Store function signature for generic call fixup at call sites
    let mut sig_param_types: Vec<String> = Vec.new();
    for sp in 0usize..params.len() {
        sig_param_types.push(params[sp].0.clone());
    }
    ctx.register_fn_signature(body.def_id.index, sig_param_types, ret_ty.clone());

    // Emit function header
    ctx.emit_fn_header(fn_name, &params, ret_ty.as_str());

    // Emit entry label
    ctx.write("entry:\n");

    @unsafe { CODEGEN_T_SETUP_MS += blood_clock_millis() - t_setup_start; }
    let t_escape_start = blood_clock_millis();

    // Run escape analysis to determine allocation tiers
    let mut escape_result = mir_escape.analyze_escapes(body);

    // Mark persist() call destinations as GlobalEscape (Persistent tier).
    // This ensures the alloca phase allocates them as pointer-to-persistent-buffer.
    for pbi in 0usize..body.basic_blocks.len() {
        let pbb = &body.basic_blocks[pbi];
        match &pbb.terminator {
            &Option.Some(ref term) => {
                match &term.kind {
                    &mir_term.TerminatorKind.Call { ref func, args: _, ref destination, target: _, unwind: _ } => {
                        match func {
                            &mir_types.Operand.Constant(ref constant) => {
                                match &constant.kind {
                                    &mir_types.ConstantKind.FnDef(ref def_id) => {
                                        match ctx.lookup_def_name(def_id.index) {
                                            Option.Some(name) => {
                                                if string_eq_str(name.as_str(), "persist") {
                                                    escape_result.mark_global_escape(destination.local);
                                                }
                                            }
                                            Option.None => {}
                                        }
                                    }
                                    _ => {}
                                }
                            }
                            _ => {}
                        }
                    }
                    _ => {}
                }
            }
            &Option.None => {}
        }
    }

    // Apply @heap/@stack allocation directive overrides
    escape_result.apply_alloc_overrides(body);

    @unsafe { CODEGEN_T_ESCAPE_MS += blood_clock_millis() - t_escape_start; }
    let t_allocas_start = blood_clock_millis();

    // Emit allocas with escape-aware allocation decisions
    codegen_stmt.emit_allocas_with_escapes(ctx, body, &escape_result);

    // Store effect-escaped locals for snapshot validation during Perform codegen
    ctx.effect_captured_locals.clear();
    for eci in 0usize..escape_result.local_states.len() {
        let local_id = mir_def.MirLocalId { index: eci as u32 };
        if escape_result.needs_effect_snapshot(local_id) {
            ctx.effect_captured_locals.push(eci as u32);
        }
    }

    // Store arguments into allocas
    codegen_stmt.emit_arg_stores(ctx, body);

    // Clear handler capture state from previous compilations
    ctx.handler_capture_locals.clear();
    ctx.handler_capture_tys.clear();

    // For closure bodies with captures, load captured values from env struct
    if body.capture_locals.len() > 0 {
        emit_capture_loads(ctx, body);
    }

    @unsafe { CODEGEN_T_ALLOCAS_MS += blood_clock_millis() - t_allocas_start; }
    let t_blocks_start = blood_clock_millis();

    // Emit basic blocks into a separate buffer so we can collect deferred
    // entry-block allocas (e.g., handler state shadows) before the branch.
    if body.basic_blocks.len() > 0 {
        let saved_output = ctx.output;
        ctx.output = String.new();

        // Compute backward liveness for snapshot filtering at Perform sites.
        ctx.perform_liveness = mir_liveness.compute_liveness(body);
        ctx.perform_liveness_locals = body.locals.len() as u32;

        for block_idx in 0usize..body.basic_blocks.len() {
            let block_id = mir_def.BasicBlockId.new(block_idx as u32);
            // Skip blocks that live inside SOME NTR scope's body (other
            // than as that scope's own push/pop): they belong inside an
            // extracted body function. The outer function keeps only the
            // outermost scope's push_block and pop_block plus blocks not
            // contained by any scope. For nested scopes, the inner
            // scope's push/pop blocks are owned by the enclosing scope's
            // body_fn (which handles their mprompt setup/teardown), not
            // by the outer function.
            if ctx.ntr_block_is_strictly_contained(block_id) {
                continue;
            }
            codegen_term.emit_basic_block(ctx, block_id, &body.basic_blocks[block_idx]);
        }

        let blocks_ir = ctx.output;
        ctx.output = saved_output;

        // Emit deferred allocas (collected during basic block codegen) into the entry block.
        // Clone the vec to avoid borrow conflict with ctx.write().
        let deferred = ctx.deferred_entry_allocas;
        ctx.deferred_entry_allocas = Vec.new();
        for alloca_ir in &deferred {
            ctx.write(alloca_ir.as_str());
        }

        // Branch to first basic block
        let first_label = ctx.block_label_cg(mir_def.BasicBlockId.new(0));
        ctx.indent();
        ctx.emit_br_cg(&first_label);
        ctx.dedent();

        // Append basic block IR
        ctx.write(blocks_ir.as_str());
    } else {
        ctx.indent();
        ctx.emit_unreachable();
        ctx.dedent();
    }

    @unsafe { CODEGEN_T_BLOCKS_MS += blood_clock_millis() - t_blocks_start; }
    let t_footer_start = blood_clock_millis();

    ctx.emit_fn_footer();
    ctx.end_function();

    // Emit one body function per NTR scope (sub-task 4 vertical slice).
    // Append each body_fn's IR to ctx.output after the outer function's
    // footer so the module contains the outer function first, then every
    // body function. Body functions are currently DEAD until sub-task 5
    // rewrites PushHandler to call `blood_prompt_enter(prompt, body_fn, env)`.
    //
    // Each iteration clones scope data into an owned NtrScope so the
    // shared borrow of ctx.ntr_scopes ends before emit_body_fn takes ctx
    // mutably — the resulting body_fn emission freely reads ctx.ntr_scopes
    // again through the intercepts in local_cg / block_label_cg.
    let ntr_scope_count = ctx.ntr_scopes.len();
    for si in 0usize..ntr_scope_count {
        let scope_copy = ctx.ntr_scopes[si].clone_deep();
        let body_fn_ir = codegen_body_fn.emit_body_fn(ctx, body, &scope_copy, si as u32);
        ctx.write(body_fn_ir.as_str());
    }

    // Extract and return the function IR
    let result = ctx.output.clone();
    ctx.output = String.new();

    @unsafe { CODEGEN_T_FOOTER_MS += blood_clock_millis() - t_footer_start; }

    result
}

/// Emits loads for captured variables from the env struct pointer at closure body start.
///
/// Closure body layout:
///   Local 0: return value
///   Local 1: env_ptr (first parameter, ptr type)
///   Locals 2..1+num_user_params: explicit closure parameters
///   Locals (1+param_count)..(1+param_count+capture_count): capture locals
///
/// The env struct has the same layout as the capture operands in the
/// AggregateKind.Closure aggregate that constructed this closure.
fn emit_capture_loads(
    ctx: &mut codegen_ctx.CodegenCtx,
    body: &mir_body.MirBody,
) {
    // For handler op bodies, the state struct stores POINTERS to parent allocas.
    // For closures, it stores VALUES directly. Detect via is_handler_op.
    let is_ptr_captures = ctx.is_handler_op;

    // Build env struct LLVM type from capture types
    let mut env_llvm = common.make_string("{ ");
    for ti in 0usize..body.capture_tys.len() {
        if ti > 0 {
            env_llvm.push_str(", ");
        }
        if is_ptr_captures {
            env_llvm.push_str("ptr");
        } else {
            let cap_ty_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, body.capture_tys[ti]);
            env_llvm.push_str(cap_ty_llvm.as_str());
        }
    }
    env_llvm.push_str(" }");

    // Load env_ptr from local 1's alloca
    let env_load = ctx.fresh_temp_cg();
    let local1_name = ctx.local_cg(mir_def.MirLocalId.new(1));
    ctx.write("    ");
    ctx.write_cgname(&env_load);
    ctx.write(" = load ptr, ptr ");
    ctx.write_cgname(&local1_name);
    ctx.write(", align 8\n");

    // For each capture, GEP into env struct and load value into the capture local's alloca
    let mut ci: usize = 0;
    while ci < body.capture_locals.len() && ci < body.capture_tys.len() {
        let cap_ty_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, body.capture_tys[ci]);
        let local_idx = body.capture_locals[ci];

        // GEP to get pointer to this capture in the env struct
        let field_ptr = ctx.fresh_temp_cg();
        ctx.write("    ");
        ctx.write_cgname(&field_ptr);
        ctx.write(" = getelementptr ");
        ctx.write_string(&env_llvm);
        ctx.write(", ptr ");
        ctx.write_cgname(&env_load);
        ctx.write(", i32 0, i32 ");
        ctx.write(codegen_types.format_u64(ci as u64).as_str());
        ctx.write("\n");

        if is_ptr_captures {
            // Handler op: state struct holds ptr to parent alloca.
            // Load the pointer, then load the value through it.
            let parent_ptr = ctx.fresh_temp_cg();
            ctx.write("    ");
            ctx.write_cgname(&parent_ptr);
            ctx.write(" = load ptr, ptr ");
            ctx.write_cgname(&field_ptr);
            ctx.write(", align 8\n");

            let cap_val = ctx.fresh_temp_cg();
            ctx.write("    ");
            ctx.write_cgname(&cap_val);
            ctx.write(" = load ");
            ctx.write_string(&cap_ty_llvm);
            ctx.write(", ptr ");
            ctx.write_cgname(&parent_ptr);
            ctx.write(", align 8\n");

            // Store into the capture local's alloca
            let cap_local = ctx.local_cg(mir_def.MirLocalId.new(local_idx));
            ctx.write("    store ");
            ctx.write_string(&cap_ty_llvm);
            ctx.write(" ");
            ctx.write_cgname(&cap_val);
            ctx.write(", ptr ");
            ctx.write_cgname(&cap_local);
            ctx.write(", align 8\n");
        } else {
            // Closure: state struct holds values directly
            let cap_val = ctx.fresh_temp_cg();
            ctx.write("    ");
            ctx.write_cgname(&cap_val);
            ctx.write(" = load ");
            ctx.write_string(&cap_ty_llvm);
            ctx.write(", ptr ");
            ctx.write_cgname(&field_ptr);
            ctx.write(", align 8\n");

            // Store into the capture local's alloca
            let cap_local = ctx.local_cg(mir_def.MirLocalId.new(local_idx));
            ctx.write("    store ");
            ctx.write_string(&cap_ty_llvm);
            ctx.write(" ");
            ctx.write_cgname(&cap_val);
            ctx.write(", ptr ");
            ctx.write_cgname(&cap_local);
            ctx.write(", align 8\n");
        }

        ci += 1;
    }

    // For handler op bodies: record capture info on ctx so Resume codegen
    // can emit store-back (write local values back through parent pointers).
    if is_ptr_captures {
        for ri in 0usize..body.capture_locals.len() {
            ctx.handler_capture_locals.push(body.capture_locals[ri]);
            ctx.handler_capture_tys.push(body.capture_tys[ri]);
        }
    }
}

// ============================================================
// ADT Registry Population
// ============================================================

/// Populates the ADT registry from HIR items.
/// Uses a two-pass approach: first register all ADTs with placeholder field types,
/// then rebuild layouts using the now-populated registry for correct nested ADT types.
pub fn populate_adt_registry(
    ctx: &mut codegen_ctx.CodegenCtx,
    items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    // Pass 1: Register all ADTs with basic (possibly ptr) field types.
    // This ensures all ADT def_ids are known before resolving nested types.
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Struct(ref struct_def) => {
                let layout = build_struct_layout_basic(entry.def_id.index, struct_def);
                ctx.register_struct(layout);
            }
            &hir_item.ItemKind.Enum(ref enum_def) => {
                let layout = build_enum_layout_with_ctx(ctx, entry.def_id.index, enum_def);
                ctx.register_enum(layout);
            }
            &hir_item.ItemKind.Fn(_) => {}
            &hir_item.ItemKind.TypeAlias(_) => {}
            &hir_item.ItemKind.Const(_) => {}
            &hir_item.ItemKind.Static(_) => {}
            &hir_item.ItemKind.Trait(_) => {}
            &hir_item.ItemKind.Effect(_) => {}
            &hir_item.ItemKind.Handler(ref handler_def) => {
                let layout = build_handler_enum_layout(ctx, entry.def_id.index, handler_def);
                ctx.register_enum(layout);
            }
            &hir_item.ItemKind.Module(_) => {}
            &hir_item.ItemKind.Impl(_) => {}
            &hir_item.ItemKind.Macro(_) => {}
            &hir_item.ItemKind.Foreign(_) => {}
        }
    }

    // Pass 2+: Rebuild struct and enum layouts using context-aware type resolution.
    // Each pass resolves one more level of nesting. Since lookup_struct/lookup_enum and
    // adt_llvm_type scan from the end, new entries override old ones.
    //
    // Within each pass, items are processed in def_id order. When a struct S appears
    // before enum E in the items list, S uses E's value from the PREVIOUS pass. This
    // means S is always one pass behind E. To ensure all types converge:
    // - Run passes until no layout changes (fixpoint), then one extra pass so that
    //   structs pick up the final enum values from the convergence pass.
    // - Maximum 12 passes as a safety bound (handles nesting depth up to ~6).
    let mut pass: u32 = 0;
    let mut stable_count: u32 = 0;
    while pass < 12 && stable_count < 2 {
        let mut changed: bool = false;
        for j in 0usize..items.len() {
            let entry = &items[j];
            match &entry.item.kind {
                &hir_item.ItemKind.Struct(ref struct_def) => {
                    let layout = build_struct_layout_with_ctx(ctx, entry.def_id.index, struct_def);
                    // Check if this layout differs from the last registered one
                    let old_type = ctx.adt_llvm_type(entry.def_id.index);
                    if !string_eq_str(old_type.as_str(), layout.llvm_type.as_str()) {
                        changed = true;
                    }
                    ctx.register_struct(layout);
                }
                &hir_item.ItemKind.Enum(ref enum_def) => {
                    let layout = build_enum_layout_with_ctx(ctx, entry.def_id.index, enum_def);
                    let old_type = ctx.adt_llvm_type(entry.def_id.index);
                    if !string_eq_str(old_type.as_str(), layout.llvm_type.as_str()) {
                        changed = true;
                    }
                    ctx.register_enum(layout);
                }
                _ => {}
            }
        }
        if changed {
            stable_count = 0;
        } else {
            stable_count += 1;
        }
        pass += 1;
    }
}

/// Registers synthetic StructLayouts for builtin ADT types (Vec, String, HashMap, Box).
/// These types are not in the HIR items list but need to be in the ADT registry so that
/// user-defined structs containing these types resolve to the correct LLVM layout
/// (e.g., `{ ptr, i64, i64 }` instead of `ptr`).
pub fn register_builtin_adts(
    ctx: &mut codegen_ctx.CodegenCtx,
    builtin_vec_def: &Option<hir_def.DefId>,
    builtin_string_def: &Option<hir_def.DefId>,
    builtin_hashmap_def: &Option<hir_def.DefId>,
    builtin_box_def: &Option<hir_def.DefId>,
    builtin_option_def: &Option<hir_def.DefId>,
    builtin_result_def: &Option<hir_def.DefId>,
) {
    // Vec<T> = { ptr, i64, i64 } (data pointer, length, capacity)
    match builtin_vec_def {
        &Option.Some(ref def_id) => {
            let layout = make_builtin_struct_layout(def_id.index, "{ ptr, i64, i64 }");
            ctx.register_struct(layout);
        }
        &Option.None => {}
    }
    // String = { ptr, i64, i64 } (same as Vec<u8>)
    match builtin_string_def {
        &Option.Some(ref def_id) => {
            let layout = make_builtin_struct_layout(def_id.index, "{ ptr, i64, i64 }");
            ctx.register_struct(layout);
        }
        &Option.None => {}
    }
    // HashMap<K,V> = { ptr, i64, i64 } (runtime representation)
    match builtin_hashmap_def {
        &Option.Some(ref def_id) => {
            let layout = make_builtin_struct_layout(def_id.index, "{ ptr, i64, i64 }");
            ctx.register_struct(layout);
        }
        &Option.None => {}
    }
    // Box<T> = ptr (single heap pointer)
    match builtin_box_def {
        &Option.Some(ref def_id) => {
            let layout = make_builtin_struct_layout(def_id.index, "ptr");
            ctx.register_struct(layout);
        }
        &Option.None => {}
    }
    // Option<T> = { i32, [1 x i64] } — discriminant i32, generic payload
    // Variant 0 = None (no payload), Variant 1 = Some(T) (one field)
    match builtin_option_def {
        &Option.Some(ref def_id) => {
            let layout = make_builtin_enum_layout(def_id.index, 2, true);
            ctx.register_enum(layout);
        }
        &Option.None => {}
    }
    // Result<T, E> = { i32, [1 x i64] } — discriminant i32, generic payload
    // Variant 0 = Ok(T) (one field), Variant 1 = Err(E) (one field)
    match builtin_result_def {
        &Option.Some(ref def_id) => {
            let layout = make_builtin_enum_layout(def_id.index, 2, false);
            ctx.register_enum(layout);
        }
        &Option.None => {}
    }
}

/// Creates a synthetic StructLayout for a builtin type with the given LLVM type string.
fn make_builtin_struct_layout(def_id: u32, llvm_type_str: &str) -> codegen_ctx.StructLayout {
    codegen_ctx.StructLayout {
        def_id: def_id,
        fields: Vec.new(),
        llvm_type: common.make_string(llvm_type_str),
        is_packed: false,
        align: 0,
        is_union: false,
    }
}

/// Creates a synthetic EnumLayout for a builtin enum (Option or Result).
/// Generic enums use i64 as the payload slot size (sufficient for pointers and i64 values).
/// `num_variants` is the number of variants (2 for Option, 2 for Result).
/// `first_is_unit` indicates whether variant 0 has no payload (true for Option.None).
fn make_builtin_enum_layout(def_id: u32, num_variants: u32, first_is_unit: bool) -> codegen_ctx.EnumLayout {
    let mut variants: Vec<codegen_ctx.VariantLayout> = Vec.new();
    for vi in 0u32..num_variants {
        let fields: Vec<codegen_ctx.AdtFieldInfo> = Vec.new();
        let payload_ty = if first_is_unit && vi == 0 {
            common.make_string("{}")
        } else {
            common.make_string("{ i64 }")
        };
        variants.push(codegen_ctx.VariantLayout {
            variant_idx: vi,
            fields: fields,
            payload_llvm_type: payload_ty,
        });
    }
    codegen_ctx.EnumLayout {
        def_id: def_id,
        discriminant_type: common.make_string("i32"),
        variants: variants,
        llvm_type: common.make_string("{ i32, [1 x i64] }"),
        max_payload_size: 8,
    }
}

// ============================================================
// Frozen<T> Layout Population (GAP-2 A1 Phase 2)
// ============================================================

/// Populates field entries for the layout descriptor keyed on `ty_id_idx`.
/// Safe to call multiple times — idempotent via `populated` flag. Also safe
/// to call on types with no registered descriptor (no-op). Recursive cycles
/// (Box<Self>, mutual recursion) terminate because the descriptor's
/// `populated` flag is set before walking fields, and `add_layout_descriptor`
/// returns the existing label for already-registered types.
pub fn populate_layout_entries(ctx: &mut codegen_ctx.CodegenCtx, ty_id_idx: u32) {
    let desc_idx = match ctx.layout_by_ty_id.get(ty_id_idx as u64) {
        Option.Some(i) => i,
        Option.None => { return; }
    };
    if ctx.layout_table[desc_idx as usize].populated {
        return;
    }
    // Mark populated BEFORE walking to break cycles.
    ctx.layout_table[desc_idx as usize].populated = true;

    let entries = compute_layout_entries(ctx, ty_id_idx);
    ctx.layout_table[desc_idx as usize].num_entries = entries.len() as u32;
    ctx.layout_table[desc_idx as usize].entries = entries;
}

/// Walks an inner type's heap-owning fields and produces a Vec<LayoutEntry>
/// describing them. Returns an empty vec when the type has no heap-owning
/// subparts (all primitives, plain struct with primitive fields only, etc.).
fn compute_layout_entries(ctx: &mut codegen_ctx.CodegenCtx, ty_id_idx: u32) -> Vec<codegen_ctx.LayoutEntry> {
    let mut entries: Vec<codegen_ctx.LayoutEntry> = Vec.new();
    let ty_id = type_intern.TyId.new(ty_id_idx);
    let kind = type_intern.type_interner().get(ty_id);
    match kind {
        &type_intern.InternedTypeKind.Adt { def_id, args } => {
            // Top-level T may itself be a heap-owning builtin (String / Vec<U> /
            // Box<U>) — in that case, emit a single entry at offset 0 so the
            // walker freezes the buffer/pointee of the persisted T.
            if ctx.string_def_id != 0 && def_id.index == ctx.string_def_id {
                entries.push(codegen_ctx.LayoutEntry {
                    offset: 0,
                    kind: 1,
                    inner_label: String.new(),
                    element_size: 0,
                });
                return entries;
            }
            if ctx.vec_def_id != 0 && def_id.index == ctx.vec_def_id {
                let interner = type_intern.type_interner();
                let arg_len = interner.ty_list_len(args);
                let (elem_label, elem_size) = if arg_len > 0 {
                    let elem_id = interner.get_ty_list_element(args, 0);
                    let elem_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, elem_id);
                    let sz = codegen_size.llvm_type_size(elem_llvm.as_str());
                    let lbl = maybe_layout_label_for_heap_owning(ctx, elem_id.index);
                    (lbl, sz)
                } else {
                    (String.new(), 0u64)
                };
                entries.push(codegen_ctx.LayoutEntry {
                    offset: 0,
                    kind: 2,
                    inner_label: elem_label,
                    element_size: elem_size,
                });
                return entries;
            }
            if ctx.box_def_id != 0 && def_id.index == ctx.box_def_id {
                let interner = type_intern.type_interner();
                let arg_len = interner.ty_list_len(args);
                let inner_label = if arg_len > 0 {
                    let inner_id = interner.get_ty_list_element(args, 0);
                    maybe_layout_label_for_heap_owning(ctx, inner_id.index)
                } else {
                    String.new()
                };
                entries.push(codegen_ctx.LayoutEntry {
                    offset: 0,
                    kind: 3,
                    inner_label: inner_label,
                    element_size: 0,
                });
                return entries;
            }
            // Builtin Option<T> / Result<T, E> (A1 Phase 3b, GAP-2): emit a
            // single kind=5 entry at offset 0 pointing to a variant table if
            // any variant's payload has heap-owning subparts.
            if (ctx.option_def_id != 0 && def_id.index == ctx.option_def_id)
                || (ctx.result_def_id != 0 && def_id.index == ctx.result_def_id) {
                let vt_label = build_builtin_enum_variant_table(ctx, ty_id_idx, def_id.index, args);
                if vt_label.len() > 0 {
                    entries.push(codegen_ctx.LayoutEntry {
                        offset: 0,
                        kind: 5,
                        inner_label: vt_label,
                        element_size: 0,
                    });
                }
                return entries;
            }
            // User-defined struct: walk its fields via the ADT registry.
            walk_struct_fields_into(ctx, def_id.index, &mut entries, 0u32);
        }
        _ => {
            // Primitives / refs / tuples / functions / user-defined enums:
            // no heap traversal. User-defined enum variants are Phase 3
            // follow-up work (S62+).
        }
    }
    entries
}

/// Walks a struct's StructLayout.fields, emitting a LayoutEntry per heap-
/// owning field at its byte offset in the parent. Offsets are computed using
/// each field's LLVM type size/alignment (matching compute_struct_size in
/// codegen_size.blood so that layout entries align with codegen's field GEPs).
fn walk_struct_fields_into(
    ctx: &mut codegen_ctx.CodegenCtx,
    def_id: u32,
    out_entries: &mut Vec<codegen_ctx.LayoutEntry>,
    base_offset: u32,
) {
    // Snapshot field metadata into parallel Vecs so the immutable borrow of
    // the StructLayout is released before we call &mut methods on ctx below.
    let mut llvm_types: Vec<String> = Vec.new();
    let mut hir_idxs: Vec<u32> = Vec.new();
    let mut has_hirs: Vec<bool> = Vec.new();
    match ctx.lookup_struct(def_id) {
        Option.Some(layout) => {
            for f in 0usize..layout.fields.len() {
                let field = &layout.fields[f];
                let has_hir = match &field.hir_type {
                    &Option.Some(_) => true,
                    &Option.None => false,
                };
                let hir_idx = match &field.hir_type {
                    &Option.Some(ref fid) => fid.index,
                    &Option.None => 0u32,
                };
                llvm_types.push(field.llvm_type.clone());
                hir_idxs.push(hir_idx);
                has_hirs.push(has_hir);
            }
        }
        Option.None => { return; }
    }
    let mut offset: u64 = base_offset as u64;
    for i in 0usize..llvm_types.len() {
        let field_size = codegen_size.llvm_type_size(llvm_types[i].as_str());
        let field_align = codegen_size.llvm_type_alignment(llvm_types[i].as_str());
        let padding = (field_align - (offset % field_align)) % field_align;
        offset = offset + padding;
        if has_hirs[i] {
            match classify_field_to_entry(ctx, hir_idxs[i], offset as u32) {
                Option.Some(entry) => { out_entries.push(entry); }
                Option.None => {}
            }
        }
        offset = offset + field_size;
    }
}

/// Classifies a single field's HIR type into an optional LayoutEntry at the
/// given offset. Returns Option.None when the field has no heap-owning parts
/// (primitives, references, function pointers, etc.).
fn classify_field_to_entry(
    ctx: &mut codegen_ctx.CodegenCtx,
    field_ty_id_idx: u32,
    offset: u32,
) -> Option<codegen_ctx.LayoutEntry> {
    let ty_id = type_intern.TyId.new(field_ty_id_idx);
    let kind = type_intern.type_interner().get(ty_id);
    match kind {
        &type_intern.InternedTypeKind.Adt { def_id, args } => {
            if ctx.string_def_id != 0 && def_id.index == ctx.string_def_id {
                return Option.Some(codegen_ctx.LayoutEntry {
                    offset: offset,
                    kind: 1,
                    inner_label: String.new(),
                    element_size: 0,
                });
            }
            if ctx.vec_def_id != 0 && def_id.index == ctx.vec_def_id {
                let interner = type_intern.type_interner();
                let arg_len = interner.ty_list_len(args);
                let (elem_label, elem_size) = if arg_len > 0 {
                    let elem_id = interner.get_ty_list_element(args, 0);
                    let elem_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, elem_id);
                    let sz = codegen_size.llvm_type_size(elem_llvm.as_str());
                    let lbl = maybe_layout_label_for_heap_owning(ctx, elem_id.index);
                    (lbl, sz)
                } else {
                    (String.new(), 0u64)
                };
                return Option.Some(codegen_ctx.LayoutEntry {
                    offset: offset,
                    kind: 2,
                    inner_label: elem_label,
                    element_size: elem_size,
                });
            }
            if ctx.box_def_id != 0 && def_id.index == ctx.box_def_id {
                let interner = type_intern.type_interner();
                let arg_len = interner.ty_list_len(args);
                let inner_label = if arg_len > 0 {
                    let inner_id = interner.get_ty_list_element(args, 0);
                    maybe_layout_label_for_heap_owning(ctx, inner_id.index)
                } else {
                    String.new()
                };
                return Option.Some(codegen_ctx.LayoutEntry {
                    offset: offset,
                    kind: 3,
                    inner_label: inner_label,
                    element_size: 0,
                });
            }
            // Builtin Option<T> / Result<T, E> field (A1 Phase 3b, GAP-2):
            // emit kind=5 at `offset` pointing to the enum's variant table
            // when any variant carries heap-owning payload.
            if (ctx.option_def_id != 0 && def_id.index == ctx.option_def_id)
                || (ctx.result_def_id != 0 && def_id.index == ctx.result_def_id) {
                let vt_label = build_builtin_enum_variant_table(ctx, field_ty_id_idx, def_id.index, args);
                if vt_label.len() > 0 {
                    return Option.Some(codegen_ctx.LayoutEntry {
                        offset: offset,
                        kind: 5,
                        inner_label: vt_label,
                        element_size: 0,
                    });
                }
                return Option.None;
            }
            // User-defined struct: emit kind=4 only if it has heap-owning subparts;
            // otherwise skip so the descriptor stays zero-entry for primitive ADTs.
            match ctx.lookup_struct(def_id.index) {
                Option.Some(_) => {
                    if ty_has_heap_owning_parts(ctx, field_ty_id_idx) {
                        let inner_label = ctx.add_layout_descriptor(field_ty_id_idx);
                        populate_layout_entries(ctx, field_ty_id_idx);
                        return Option.Some(codegen_ctx.LayoutEntry {
                            offset: offset,
                            kind: 4,
                            inner_label: inner_label,
                            element_size: 0,
                        });
                    }
                }
                Option.None => {}
            }
        }
        _ => {}
    }
    Option.None
}

/// Builds (or reuses a deduped) variant table for builtin Option<T> or
/// Result<T, E> (A1 Phase 3b, GAP-2). Returns the global label of the variant
/// table descriptor, or "" if no variant has heap-owning payload (caller
/// skips emitting a kind=5 entry in that case — freeze_fields has nothing
/// to dispatch to).
///
/// `enum_ty_id_idx` is the monomorphized enum TyId (e.g., Option<String>'s
/// TyId). `enum_def_id_idx` is the enum's DefId (Option or Result). `args` is
/// the TyList carrying the concrete type arguments.
///
/// Variant entries use the LayoutEntry shape with `offset` repurposed as the
/// variant discriminant tag; `kind` is set to 0 (the runtime walker ignores
/// it under kind=5 dispatch); `inner_label` is the sublayout label for the
/// variant's heap-owning payload (or "" emitted as NULL for unit / non-heap
/// variants).
///
/// Payload offset is hardcoded to 8 (i32 disc + 4 bytes pad) because any
/// heap-owning payload carries ≥ 8-byte alignment via its pointer(s),
/// forcing the enum's `[N x i64]` payload slot to 8-aligned, which in turn
/// forces payload_offset to 8.
fn build_builtin_enum_variant_table(
    ctx: &mut codegen_ctx.CodegenCtx,
    enum_ty_id_idx: u32,
    enum_def_id_idx: u32,
    args: type_intern.TyListId,
) -> String {
    let mut variant_entries: Vec<codegen_ctx.LayoutEntry> = Vec.new();
    let mut any_heap: bool = false;
    let payload_offset: u32 = 8;

    if ctx.option_def_id != 0 && enum_def_id_idx == ctx.option_def_id {
        // Variant 0: None (unit) — always NULL sublayout.
        variant_entries.push(codegen_ctx.LayoutEntry {
            offset: 0,
            kind: 0,
            inner_label: String.new(),
            element_size: 0,
        });
        // Variant 1: Some(T) — classify payload.
        let interner = type_intern.type_interner();
        let arg_len = interner.ty_list_len(args);
        let sub_label = if arg_len >= 1 {
            let t_id = interner.get_ty_list_element(args, 0);
            build_variant_payload_sublayout(ctx, t_id.index, payload_offset)
        } else {
            String.new()
        };
        if sub_label.len() > 0 { any_heap = true; }
        variant_entries.push(codegen_ctx.LayoutEntry {
            offset: 1,
            kind: 0,
            inner_label: sub_label,
            element_size: 0,
        });
    } else if ctx.result_def_id != 0 && enum_def_id_idx == ctx.result_def_id {
        // Variant 0: Ok(T) — classify T payload.
        let interner = type_intern.type_interner();
        let arg_len = interner.ty_list_len(args);
        let t_label = if arg_len >= 1 {
            let t_id = interner.get_ty_list_element(args, 0);
            build_variant_payload_sublayout(ctx, t_id.index, payload_offset)
        } else {
            String.new()
        };
        if t_label.len() > 0 { any_heap = true; }
        variant_entries.push(codegen_ctx.LayoutEntry {
            offset: 0,
            kind: 0,
            inner_label: t_label,
            element_size: 0,
        });
        // Variant 1: Err(E) — classify E payload.
        let e_label = if arg_len >= 2 {
            let e_id = interner.get_ty_list_element(args, 1);
            build_variant_payload_sublayout(ctx, e_id.index, payload_offset)
        } else {
            String.new()
        };
        if e_label.len() > 0 { any_heap = true; }
        variant_entries.push(codegen_ctx.LayoutEntry {
            offset: 1,
            kind: 0,
            inner_label: e_label,
            element_size: 0,
        });
    }

    if !any_heap {
        return String.new();
    }
    ctx.add_variant_table(enum_ty_id_idx, variant_entries)
}

/// Builds a sublayout for a single enum variant's payload (A1 Phase 3b).
/// Returns the sublayout label, or "" if the payload has no heap-owning
/// subparts. Reuses classify_field_to_entry to handle String / Vec / Box /
/// inline struct / nested Option / nested Result uniformly at the given
/// `payload_offset` within the enum.
fn build_variant_payload_sublayout(
    ctx: &mut codegen_ctx.CodegenCtx,
    payload_ty_id_idx: u32,
    payload_offset: u32,
) -> String {
    let mut entries: Vec<codegen_ctx.LayoutEntry> = Vec.new();
    match classify_field_to_entry(ctx, payload_ty_id_idx, payload_offset) {
        Option.Some(e) => { entries.push(e); }
        Option.None => {}
    }
    if entries.len() == 0 {
        return String.new();
    }
    ctx.add_anonymous_sublayout(entries)
}

/// Returns the layout descriptor label for `ty_id_idx` if that type has any
/// heap-owning subparts; returns an empty string otherwise. This avoids
/// emitting needless zero-entry descriptors for primitive element types
/// (e.g., Vec<i32>'s inner_layout).
fn maybe_layout_label_for_heap_owning(
    ctx: &mut codegen_ctx.CodegenCtx,
    ty_id_idx: u32,
) -> String {
    if !ty_has_heap_owning_parts(ctx, ty_id_idx) {
        return String.new();
    }
    let lbl = ctx.add_layout_descriptor(ty_id_idx);
    populate_layout_entries(ctx, ty_id_idx);
    lbl
}

/// Conservative test: does this type's memory representation contain any
/// heap-owning pointer (String data buffer, Vec data buffer, Box pointee,
/// or a nested aggregate that transitively owns heap)? Used to decide
/// whether to emit a layout descriptor for an inner type. Skips inference
/// variables / type parameters / references / raw pointers (no owned heap).
///
/// Recursion is bounded by type-tree depth under `MAX_DEPTH`; cyclic ADTs
/// go through Box / Ref which this function treats as non-heap for the
/// purpose of the recursive has-heap check (the Box path below returns true
/// immediately without descending), so there is no infinite-recursion risk.
fn ty_has_heap_owning_parts(ctx: &codegen_ctx.CodegenCtx, ty_id_idx: u32) -> bool {
    ty_has_heap_owning_parts_depth(ctx, ty_id_idx, 0u32)
}

fn ty_has_heap_owning_parts_depth(
    ctx: &codegen_ctx.CodegenCtx,
    ty_id_idx: u32,
    depth: u32,
) -> bool {
    if depth > 8 {
        // Arbitrary bound. Phase 3 may lift via explicit in-progress set.
        return true;
    }
    let ty_id = type_intern.TyId.new(ty_id_idx);
    let kind = type_intern.type_interner().get(ty_id);
    match kind {
        &type_intern.InternedTypeKind.Adt { def_id, args } => {
            if ctx.string_def_id != 0 && def_id.index == ctx.string_def_id { return true; }
            if ctx.vec_def_id != 0 && def_id.index == ctx.vec_def_id { return true; }
            if ctx.box_def_id != 0 && def_id.index == ctx.box_def_id { return true; }
            // Builtin Option<T> / Result<T, E> (A1 Phase 3b): heap-owning iff
            // any type arg transitively has heap-owning parts.
            if ctx.option_def_id != 0 && def_id.index == ctx.option_def_id {
                let interner = type_intern.type_interner();
                let arg_len = interner.ty_list_len(args);
                if arg_len >= 1 {
                    let t_id = interner.get_ty_list_element(args, 0);
                    if ty_has_heap_owning_parts_depth(ctx, t_id.index, depth + 1) {
                        return true;
                    }
                }
                return false;
            }
            if ctx.result_def_id != 0 && def_id.index == ctx.result_def_id {
                let interner = type_intern.type_interner();
                let arg_len = interner.ty_list_len(args);
                if arg_len >= 1 {
                    let t_id = interner.get_ty_list_element(args, 0);
                    if ty_has_heap_owning_parts_depth(ctx, t_id.index, depth + 1) {
                        return true;
                    }
                }
                if arg_len >= 2 {
                    let e_id = interner.get_ty_list_element(args, 1);
                    if ty_has_heap_owning_parts_depth(ctx, e_id.index, depth + 1) {
                        return true;
                    }
                }
                return false;
            }
            let _ = args;
            match ctx.lookup_struct(def_id.index) {
                Option.Some(layout) => {
                    for f in 0usize..layout.fields.len() {
                        match &layout.fields[f].hir_type {
                            &Option.Some(ref fid) => {
                                if ty_has_heap_owning_parts_depth(ctx, fid.index, depth + 1) {
                                    return true;
                                }
                            }
                            &Option.None => {}
                        }
                    }
                    false
                }
                Option.None => false,
            }
        }
        _ => false,
    }
}

/// Populates every layout descriptor currently in `ctx.layout_table`. Safe to
/// call multiple times — idempotent via each descriptor's `populated` flag.
/// Must be called before `ctx.emit_layout_descriptors()` so that the serialized
/// globals carry real field entries. The loop re-reads the table length each
/// iteration so newly-added inner-type descriptors (discovered while walking
/// user structs) are picked up in the same pass.
///
/// PERF-S78-PARALLEL: parallel codegen workers add per-worker layout
/// descriptors with offset labels (e.g., @blood_layout.200000) but the merge
/// pushes them to ctx.layout_table without updating ctx.layout_by_ty_id. A
/// ty_id_idx lookup-based populate would skip those entries (they aren't
/// reachable via the hashmap on main ctx). Iterating by INDEX populates each
/// descriptor in place; recursive populate_layout_entries calls during field
/// traversal still use layout_by_ty_id — those map to the FIRST-registered
/// descriptor for cycle protection, which is sufficient.
pub fn populate_all_layouts(ctx: &mut codegen_ctx.CodegenCtx) {
    let mut cursor: usize = 0;
    loop {
        let len = ctx.layout_table.len();
        if cursor >= len { break; }
        if !ctx.layout_table[cursor].populated {
            let ty_id_idx = ctx.layout_table[cursor].ty_id_idx;
            ctx.layout_table[cursor].populated = true;
            let entries = compute_layout_entries(ctx, ty_id_idx);
            ctx.layout_table[cursor].num_entries = entries.len() as u32;
            ctx.layout_table[cursor].entries = entries;
        }
        cursor = cursor + 1;
    }
}

/// Rebuilds ADT layouts using context-aware type resolution.
/// Call this after registering builtin ADTs and before code generation
/// to ensure all struct fields containing Vec/String/HashMap resolve to correct sizes.
pub fn rebuild_adt_layouts(
    ctx: &mut codegen_ctx.CodegenCtx,
    items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    for pass in 0u32..4 {
        for j in 0usize..items.len() {
            let entry = &items[j];
            match &entry.item.kind {
                &hir_item.ItemKind.Struct(ref struct_def) => {
                    let layout = build_struct_layout_with_ctx(ctx, entry.def_id.index, struct_def);
                    ctx.register_struct(layout);
                }
                &hir_item.ItemKind.Enum(ref enum_def) => {
                    let layout = build_enum_layout_with_ctx(ctx, entry.def_id.index, enum_def);
                    ctx.register_enum(layout);
                }
                _ => {}
            }
        }
    }
}

// ============================================================
// Vtable Generation
// ============================================================

/// Generates vtable layouts and vtable globals for dyn Trait dispatch.
///
/// This iterates over HIR items to:
/// 1. Build vtable layouts for all traits (method name → slot index)
/// 2. Record abstract trait method DefIds in trait_method_entries
/// 3. Generate vtable global constants for each trait impl
///
/// Must be called after populate_adt_registry and after function names are registered.
pub fn generate_vtables(
    ctx: &mut codegen_ctx.CodegenCtx,
    intern: &interner.StringInterner,
    items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    // Pass 1: Build vtable layouts for all traits
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Trait(ref trait_def) => {
                let trait_def_id = entry.def_id.index;
                let mut method_names: Vec<String> = Vec.new();
                let mut slot_idx: u32 = 0;
                // First, include supertrait methods (recursively)
                slot_idx = collect_supertrait_vtable_methods(ctx, intern, &trait_def.supertraits, items, trait_def_id, &mut method_names, slot_idx);
                // Then, own methods
                for ti in 0usize..trait_def.items.len() {
                    match &trait_def.items[ti] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            let method_name = match intern.resolve(assoc_fn.name.symbol) {
                                Option.Some(s) => s.clone(),
                                Option.None => {
                                    let mut fallback = common.make_string("method_");
                                    fallback.push_str(codegen_types.format_u64(assoc_fn.def_id.index as u64).as_str());
                                    fallback
                                }
                            };
                            // Record abstract trait method DefId
                            ctx.trait_method_entries.push(codegen_ctx.TraitMethodEntry {
                                method_def_id: assoc_fn.def_id.index,
                                trait_def_id: trait_def_id,
                                method_name: method_name.clone(),
                                slot_index: slot_idx,
                            });
                            method_names.push(method_name);
                            slot_idx += 1;
                        }
                        _ => {}
                    }
                }
                let method_count = slot_idx;
                ctx.vtable_layout_hash.insert(trait_def_id as u64, ctx.vtable_layouts.len() as u32);
                ctx.vtable_layouts.push(codegen_ctx.VtableLayout {
                    trait_def_id: trait_def_id,
                    method_count: method_count,
                    method_names: method_names,
                });
            }
            _ => {}
        }
    }

    // Pass 2: Generate vtable globals for each trait impl
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Impl(ref impl_def) => {
                match &impl_def.trait_ref {
                    &Option.Some(ref trait_ref) => {
                        generate_vtable_for_impl(ctx, intern, trait_ref.def_id.index, &impl_def.self_ty, &impl_def.items, items);
                    }
                    &Option.None => {}
                }
            }
            _ => {}
        }
    }
}

/// Recursively collects supertrait methods for vtable layout building.
/// Returns the number of methods added.
fn collect_supertrait_vtable_methods(
    ctx: &mut codegen_ctx.CodegenCtx,
    intern: &interner.StringInterner,
    supertraits: &Vec<hir_ty.TraitRef>,
    all_items: &Vec<hir_lower_ctx.ItemEntry>,
    child_trait_def_id: u32,
    method_names: &mut Vec<String>,
    base_slot: u32,
) -> u32 {
    let mut slot_idx: u32 = base_slot;
    for si in 0usize..supertraits.len() {
        let super_def_id = supertraits[si].def_id.index;
        // Find the supertrait definition in all_items
        for ai in 0usize..all_items.len() {
            if all_items[ai].def_id.index == super_def_id {
                match &all_items[ai].item.kind {
                    &hir_item.ItemKind.Trait(ref super_trait_def) => {
                        // Recurse into super-supertraits first
                        slot_idx = collect_supertrait_vtable_methods(ctx, intern, &super_trait_def.supertraits, all_items, child_trait_def_id, method_names, slot_idx);
                        // Add this supertrait's methods
                        for ti in 0usize..super_trait_def.items.len() {
                            match &super_trait_def.items[ti] {
                                &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                    let method_name = match intern.resolve(assoc_fn.name.symbol) {
                                        Option.Some(s) => s.clone(),
                                        Option.None => {
                                            let mut fallback = common.make_string("method_");
                                            fallback.push_str(codegen_types.format_u64(assoc_fn.def_id.index as u64).as_str());
                                            fallback
                                        }
                                    };
                                    ctx.trait_method_entries.push(codegen_ctx.TraitMethodEntry {
                                        method_def_id: assoc_fn.def_id.index,
                                        trait_def_id: child_trait_def_id,
                                        method_name: method_name.clone(),
                                        slot_index: slot_idx,
                                    });
                                    method_names.push(method_name);
                                    slot_idx += 1;
                                }
                                _ => {}
                            }
                        }
                    }
                    _ => {}
                }
                break;
            }
        }
    }
    slot_idx
}

/// Generate a vtable global constant for a single trait impl.
fn generate_vtable_for_impl(
    ctx: &mut codegen_ctx.CodegenCtx,
    intern: &interner.StringInterner,
    trait_def_id: u32,
    self_ty: &type_intern.TyId,
    impl_items: &Vec<hir_item.AssocItem>,
    all_items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    // Look up the vtable layout for this trait
    let layout_idx: u32 = match ctx.vtable_layout_hash.get(trait_def_id as u64) {
        Option.Some(idx) => idx,
        Option.None => { return; }
    };
    let layout = &ctx.vtable_layouts[layout_idx as usize];
    if layout.method_count == 0 {
        return;
    }

    // Determine the type DefId for the vtable key
    let type_def_id: u32 = match type_intern.resolve_adt_def_id_id(*self_ty) {
        Option.Some(did) => did,
        Option.None => { return; }
    };

    // Build vtable name: __vtable_{TraitName}_{TypeName}_{index}
    let mut vtable_name = common.make_string("__vtable_");
    // Use trait item name if available
    for ti in 0usize..all_items.len() {
        if all_items[ti].def_id.index == trait_def_id {
            match intern.resolve(all_items[ti].item.name.symbol) {
                Option.Some(s) => { vtable_name.push_str(s.as_str()); }
                Option.None => { vtable_name.push_str("trait"); }
            }
            break;
        }
    }
    vtable_name.push('_');
    vtable_name.push_str(codegen_types.format_u64(type_def_id as u64).as_str());
    vtable_name.push('_');
    vtable_name.push_str(codegen_types.format_u64(ctx.vtable_name_entries.len() as u64).as_str());

    // Build the vtable LLVM IR: @name = linkonce_odr constant [N x ptr] [ptr null, ptr null, ptr @m1, ...]
    let slot_count: u32 = 2u32 + layout.method_count;
    let mut ir = common.make_string("@");
    ir.push_str(vtable_name.as_str());
    ir.push_str(" = linkonce_odr constant [");
    ir.push_str(codegen_types.format_u64(slot_count as u64).as_str());
    ir.push_str(" x ptr] [ptr null, ptr null");

    // For each method slot, find the impl method function name
    for mi in 0usize..layout.method_names.len() {
        let method_name = &layout.method_names[mi];
        ir.push_str(", ptr ");
        // Find the impl method matching this name
        let mut found = false;
        for ii in 0usize..impl_items.len() {
            match &impl_items[ii] {
                &hir_item.AssocItem.Fn(ref assoc_fn) => {
                    let impl_method_name = match intern.resolve(assoc_fn.name.symbol) {
                        Option.Some(s) => s.clone(),
                        Option.None => common.make_string(""),
                    };
                    if string_eq_str(impl_method_name.as_str(), method_name.as_str()) {
                        // Look up the compiled function name for this DefId
                        match ctx.lookup_def_name(assoc_fn.def_id.index) {
                            Option.Some(fn_name) => {
                                ir.push('@');
                                ir.push_str(fn_name.as_str());
                                found = true;
                            }
                            Option.None => {}
                        }
                    }
                }
                _ => {}
            }
            if found { break; }
        }
        if !found {
            // Method not in impl — look for default method in the trait definition
            for ai in 0usize..all_items.len() {
                if all_items[ai].def_id.index == trait_def_id {
                    match &all_items[ai].item.kind {
                        &hir_item.ItemKind.Trait(ref tdef) => {
                            for tmi in 0usize..tdef.items.len() {
                                match &tdef.items[tmi] {
                                    &hir_item.AssocItem.Fn(ref trait_fn) => {
                                        let trait_method_name = match intern.resolve(trait_fn.name.symbol) {
                                            Option.Some(s) => s.clone(),
                                            Option.None => common.make_string(""),
                                        };
                                        if string_eq_str(trait_method_name.as_str(), method_name.as_str()) {
                                            match ctx.lookup_def_name(trait_fn.def_id.index) {
                                                Option.Some(fn_name) => {
                                                    ir.push('@');
                                                    ir.push_str(fn_name.as_str());
                                                    found = true;
                                                }
                                                Option.None => {}
                                            }
                                        }
                                    }
                                    _ => {}
                                }
                                if found { break; }
                            }
                        }
                        _ => {}
                    }
                    break;
                }
            }
            if !found {
                // Method not in this trait's defaults — search other impl blocks
                // for the same concrete type (handles supertrait methods)
                for oi in 0usize..all_items.len() {
                    match &all_items[oi].item.kind {
                        &hir_item.ItemKind.Impl(ref other_impl) => {
                            // Check if this impl is for the same concrete type
                            let other_type_id = match type_intern.resolve_adt_def_id_id(other_impl.self_ty) {
                                Option.Some(did) => did,
                                Option.None => { continue; }
                            };
                            if other_type_id != type_def_id { continue; }
                            // Search this impl's methods
                            for oii in 0usize..other_impl.items.len() {
                                match &other_impl.items[oii] {
                                    &hir_item.AssocItem.Fn(ref other_fn) => {
                                        let other_name = match intern.resolve(other_fn.name.symbol) {
                                            Option.Some(s) => s.clone(),
                                            Option.None => common.make_string(""),
                                        };
                                        if string_eq_str(other_name.as_str(), method_name.as_str()) {
                                            match ctx.lookup_def_name(other_fn.def_id.index) {
                                                Option.Some(fn_name) => {
                                                    ir.push('@');
                                                    ir.push_str(fn_name.as_str());
                                                    found = true;
                                                }
                                                Option.None => {}
                                            }
                                        }
                                    }
                                    _ => {}
                                }
                                if found { break; }
                            }
                        }
                        _ => {}
                    }
                    if found { break; }
                }
                if !found {
                    // Search ALL trait definitions for default method with this name
                    for di in 0usize..all_items.len() {
                        match &all_items[di].item.kind {
                            &hir_item.ItemKind.Trait(ref any_tdef) => {
                                for dti in 0usize..any_tdef.items.len() {
                                    match &any_tdef.items[dti] {
                                        &hir_item.AssocItem.Fn(ref dfn) => {
                                            let dname = match intern.resolve(dfn.name.symbol) {
                                                Option.Some(s) => s.clone(),
                                                Option.None => common.make_string(""),
                                            };
                                            if string_eq_str(dname.as_str(), method_name.as_str()) {
                                                match ctx.lookup_def_name(dfn.def_id.index) {
                                                    Option.Some(fn_name) => {
                                                        ir.push('@');
                                                        ir.push_str(fn_name.as_str());
                                                        found = true;
                                                    }
                                                    Option.None => {}
                                                }
                                            }
                                        }
                                        _ => {}
                                    }
                                    if found { break; }
                                }
                            }
                            _ => {}
                        }
                        if found { break; }
                    }
                    if !found {
                        ir.push_str("null");
                    }
                }
            }
        }
    }

    ir.push_str("]\n");

    // Store vtable name and IR
    ctx.vtable_name_entries.push(codegen_ctx.VtableNameEntry {
        trait_def_id: trait_def_id,
        type_def_id: type_def_id,
        vtable_name: vtable_name.clone(),
    });
    ctx.vtable_defs.push(ir);
}

/// Builds a StructLayout using basic type resolution (no ADT registry lookups).
/// Used in pass 1 to get all ADTs registered before resolving nested types.
fn build_struct_layout_basic(def_id: u32, struct_def: &hir_item.StructDef) -> codegen_ctx.StructLayout {
    let mut fields: Vec<codegen_ctx.AdtFieldInfo> = Vec.new();
    let mut llvm_type = common.make_string("{ ");

    match &struct_def.body {
        &hir_item.StructBody.Record(ref struct_fields) => {
            for fi in 0usize..struct_fields.len() {
                if fi > 0 {
                    llvm_type.push_str(", ");
                }
                let field_ty_hir = type_intern.ty_id_to_type(struct_fields[fi].ty);
                let field_ty = codegen_types.type_to_llvm(&field_ty_hir);
                llvm_type.push_str(field_ty.as_str());
                // Store HIR type for indexing element size calculation
                fields.push(codegen_ctx.AdtFieldInfo {
                    llvm_type: field_ty,
                    hir_type: Option.Some(struct_fields[fi].ty),
                });
            }
        }
        &hir_item.StructBody.Tuple(ref tuple_fields) => {
            for fi in 0usize..tuple_fields.len() {
                if fi > 0 {
                    llvm_type.push_str(", ");
                }
                let tuple_field_hir = type_intern.ty_id_to_type(type_intern.TyId.new(tuple_fields[fi].index));
                let field_ty = codegen_types.type_to_llvm(&tuple_field_hir);
                llvm_type.push_str(field_ty.as_str());
                // Store HIR type for indexing element size calculation
                fields.push(codegen_ctx.AdtFieldInfo {
                    llvm_type: field_ty,
                    hir_type: Option.Some(type_intern.TyId.new(tuple_fields[fi].index)),
                });
            }
        }
        &hir_item.StructBody.Unit => {
            // Unit struct: empty
        }
    }

    llvm_type.push_str(" }");

    // Handle edge case: empty struct
    if fields.len() == 0 {
        llvm_type = common.make_string("{}");
    }

    // Union layout: LLVM type = { largest_field_type } (all fields at offset 0)
    if struct_def.is_union && fields.len() > 0 {
        let mut max_size: u64 = 0;
        let mut max_idx: usize = 0;
        for fi in 0usize..fields.len() {
            let sz = codegen_size.llvm_type_size(fields[fi].llvm_type.as_str());
            if sz > max_size {
                max_size = sz;
                max_idx = fi;
            }
        }
        llvm_type = common.make_string("{ ");
        llvm_type.push_str(fields[max_idx].llvm_type.as_str());
        llvm_type.push_str(" }");
    }

    codegen_ctx.StructLayout {
        def_id: def_id,
        fields: fields,
        llvm_type: llvm_type,
        is_packed: struct_def.is_packed,
        align: struct_def.align,
        is_union: struct_def.is_union,
    }
}

/// Builds an EnumLayout for an effect handler definition.
/// Handler structs are laid out like enums: { i32_discriminant, [N x i64]_payload }
/// where N is computed from the actual byte sizes of state fields (ceil(total_bytes / 8)),
/// not simply the number of fields. This ensures aggregate types like String (24 bytes)
/// get enough payload slots.
fn build_handler_enum_layout(ctx: &mut codegen_ctx.CodegenCtx, def_id: u32, handler_def: &hir_item.HandlerDef) -> codegen_ctx.EnumLayout {
    let state_count = handler_def.state.len();

    // Build variant payload fields.
    // Each field gets an i64 slot in the payload for 8-byte alignment.
    // This ensures the shadow, return wrapper, and op body all use the same
    // byte offsets (field N at offset N*8 within the payload).
    let mut fields: Vec<codegen_ctx.AdtFieldInfo> = Vec.new();
    let mut payload_type = common.make_string("{ ");
    let mut total_state_bytes: u64 = 0;
    for si in 0usize..state_count {
        let field_ty_id = handler_def.state[si].ty;
        let field_llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, field_ty_id);
        let field_size = codegen_size.llvm_type_size(field_llvm_ty.as_str());
        total_state_bytes += ((field_size + 7) / 8) * 8;
        if si > 0 {
            payload_type.push_str(", ");
        }
        // Use i64 as payload slot type for uniform 8-byte alignment.
        // Init stores native-typed values; loads read back at native type.
        payload_type.push_str("i64");
        fields.push(codegen_ctx.AdtFieldInfo {
            llvm_type: field_llvm_ty,
            hir_type: Option.Some(field_ty_id),
        });
    }
    payload_type.push_str(" }");

    // Single variant (variant_idx = 0) holding all state fields
    let mut variants: Vec<codegen_ctx.VariantLayout> = Vec.new();
    variants.push(codegen_ctx.VariantLayout {
        variant_idx: 0,
        fields: fields,
        payload_llvm_type: if state_count > 0 { payload_type } else { common.make_string("{}") },
    });

    // Build LLVM type: { i32, [N x i64] } for stateful, { i32 } for stateless
    // N = one i64 slot per state field for uniform 8-byte alignment
    let mut llvm_type = common.make_string("{ i32");
    let max_payload_size: u64 = if state_count > 0 {
        let num_i64_slots = (total_state_bytes + 7) / 8;
        llvm_type.push_str(", [");
        llvm_type.push_str(codegen_types.format_u64(num_i64_slots).as_str());
        llvm_type.push_str(" x i64]");
        num_i64_slots * 8
    } else {
        0
    };
    llvm_type.push_str(" }");

    // Register total state byte size for PushHandler shadow alloca sizing
    ctx.register_handler_state_byte_size(def_id, total_state_bytes as u32);

    codegen_ctx.EnumLayout {
        def_id: def_id,
        discriminant_type: common.make_string("i32"),
        variants: variants,
        llvm_type: llvm_type,
        max_payload_size: max_payload_size,
    }
}

/// Builds a StructLayout using context-aware type resolution.
/// ADT fields resolve to their actual struct/enum types from the registry.
fn build_struct_layout_with_ctx(
    ctx: &mut codegen_ctx.CodegenCtx,
    def_id: u32,
    struct_def: &hir_item.StructDef,
) -> codegen_ctx.StructLayout {
    let mut fields: Vec<codegen_ctx.AdtFieldInfo> = Vec.new();
    let mut llvm_type = common.make_string("{ ");

    match &struct_def.body {
        &hir_item.StructBody.Record(ref struct_fields) => {
            for fi in 0usize..struct_fields.len() {
                if fi > 0 {
                    llvm_type.push_str(", ");
                }
                let field_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, struct_fields[fi].ty);
                llvm_type.push_str(field_ty.as_str());
                // Store HIR type for indexing element size calculation
                fields.push(codegen_ctx.AdtFieldInfo {
                    llvm_type: field_ty,
                    hir_type: Option.Some(struct_fields[fi].ty),
                });
            }
        }
        &hir_item.StructBody.Tuple(ref tuple_fields) => {
            for fi in 0usize..tuple_fields.len() {
                if fi > 0 {
                    llvm_type.push_str(", ");
                }
                let field_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, type_intern.TyId.new(tuple_fields[fi].index));
                llvm_type.push_str(field_ty.as_str());
                // Store HIR type for indexing element size calculation
                fields.push(codegen_ctx.AdtFieldInfo {
                    llvm_type: field_ty,
                    hir_type: Option.Some(type_intern.TyId.new(tuple_fields[fi].index)),
                });
            }
        }
        &hir_item.StructBody.Unit => {
            // Unit struct: empty
        }
    }

    llvm_type.push_str(" }");

    if fields.len() == 0 {
        llvm_type = common.make_string("{}");
    }

    // Union layout: LLVM type = { largest_field_type } (all fields at offset 0)
    if struct_def.is_union && fields.len() > 0 {
        let mut max_size: u64 = 0;
        let mut max_idx: usize = 0;
        for fi in 0usize..fields.len() {
            let sz = codegen_size.llvm_type_size(fields[fi].llvm_type.as_str());
            if sz > max_size {
                max_size = sz;
                max_idx = fi;
            }
        }
        llvm_type = common.make_string("{ ");
        llvm_type.push_str(fields[max_idx].llvm_type.as_str());
        llvm_type.push_str(" }");
    }

    codegen_ctx.StructLayout {
        def_id: def_id,
        fields: fields,
        llvm_type: llvm_type,
        is_packed: struct_def.is_packed,
        align: struct_def.align,
        is_union: struct_def.is_union,
    }
}

/// Builds an EnumLayout using context-aware type resolution.
/// ADT fields in enum payloads resolve to their actual struct/enum types from the registry.
fn build_enum_layout_with_ctx(
    ctx: &mut codegen_ctx.CodegenCtx,
    def_id: u32,
    enum_def: &hir_item.EnumDef,
) -> codegen_ctx.EnumLayout {
    let mut variants: Vec<codegen_ctx.VariantLayout> = Vec.new();
    let mut max_payload_size: u64 = 0;
    let mut max_alignment: u64 = 1;
    let mut has_payload: bool = false;

    for vi in 0usize..enum_def.variants.len() {
        let variant = &enum_def.variants[vi];
        let mut fields: Vec<codegen_ctx.AdtFieldInfo> = Vec.new();
        let mut payload_type = common.make_string("{}");

        match &variant.kind {
            &hir_item.VariantKind.Unit => {
                // No payload
            }
            &hir_item.VariantKind.Tuple(ref tuple_fields) => {
                let mut pt = common.make_string("{ ");
                for fi in 0usize..tuple_fields.len() {
                    if fi > 0 {
                        pt.push_str(", ");
                    }
                    let tuple_ty_id = type_intern.TyId.new(tuple_fields[fi].index);
                    let field_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, tuple_ty_id);
                    pt.push_str(field_ty.as_str());
                    fields.push(codegen_ctx.AdtFieldInfo {
                        llvm_type: field_ty,
                        hir_type: Option.Some(type_intern.TyId.new(tuple_fields[fi].index)),
                    });
                }
                pt.push_str(" }");
                if tuple_fields.len() > 0 {
                    has_payload = true;
                    payload_type = pt;
                }
            }
            &hir_item.VariantKind.Record(ref record_fields) => {
                let mut pt = common.make_string("{ ");
                for fi in 0usize..record_fields.len() {
                    if fi > 0 {
                        pt.push_str(", ");
                    }
                    let field_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, record_fields[fi].ty);
                    pt.push_str(field_ty.as_str());
                    fields.push(codegen_ctx.AdtFieldInfo {
                        llvm_type: field_ty,
                        hir_type: Option.Some(record_fields[fi].ty),
                    });
                }
                pt.push_str(" }");
                if record_fields.len() > 0 {
                    has_payload = true;
                    payload_type = pt;
                }
            }
        }

        // Use proper struct size with padding (not naive sum of field sizes)
        let variant_size = codegen_size.llvm_type_size(payload_type.as_str());
        let variant_align = codegen_size.llvm_type_alignment(payload_type.as_str());
        if variant_size > max_payload_size {
            max_payload_size = variant_size;
        }
        if variant_align > max_alignment {
            max_alignment = variant_align;
        }

        variants.push(codegen_ctx.VariantLayout {
            variant_idx: variant.discriminant,
            fields: fields,
            payload_llvm_type: payload_type,
        });

    }

    // Always use i32 for discriminant (matching reference compiler)
    let discriminant_type = common.make_string("i32");

    // Build enum LLVM type with alignment-aware payload array.
    // The payload array element type is chosen to satisfy the maximum alignment
    // requirement across all variant payloads (matching reference compiler behavior).
    let mut llvm_type = common.make_string("{ i32");
    if has_payload && max_payload_size > 0 {
        if max_alignment >= 8 {
            let num_elements = (max_payload_size + 7) / 8;
            llvm_type.push_str(", [");
            let count_str = codegen_types.format_u64(num_elements);
            llvm_type.push_str(count_str.as_str());
            llvm_type.push_str(" x i64]");
            max_payload_size = num_elements * 8;
        } else if max_alignment >= 4 {
            let num_elements = (max_payload_size + 3) / 4;
            llvm_type.push_str(", [");
            let count_str = codegen_types.format_u64(num_elements);
            llvm_type.push_str(count_str.as_str());
            llvm_type.push_str(" x i32]");
            max_payload_size = num_elements * 4;
        } else if max_alignment >= 2 {
            let num_elements = (max_payload_size + 1) / 2;
            llvm_type.push_str(", [");
            let count_str = codegen_types.format_u64(num_elements);
            llvm_type.push_str(count_str.as_str());
            llvm_type.push_str(" x i16]");
            max_payload_size = num_elements * 2;
        } else {
            llvm_type.push_str(", [");
            let size_str = codegen_types.format_u64(max_payload_size);
            llvm_type.push_str(size_str.as_str());
            llvm_type.push_str(" x i8]");
        }
    }
    llvm_type.push_str(" }");

    codegen_ctx.EnumLayout {
        def_id: def_id,
        discriminant_type: discriminant_type,
        variants: variants,
        llvm_type: llvm_type,
        max_payload_size: max_payload_size,
    }
}

// ============================================================
// Simple Function Generator
// ============================================================

/// Generates a simple function that returns a constant.
pub fn generate_constant_function(name: &str, value: i64) -> String {
    let mut output = String.new();
    output.push_str("define i64 @");
    output.push_str(name);
    output.push_str("() {\n");
    output.push_str("entry:\n");
    output.push_str("    ret i64 ");
    let val_str = codegen_types.format_i64(value);
    output.push_str(val_str.as_str());
    output.push_str("\n}\n");
    output
}

// ============================================================
// Module Preamble
// ============================================================

/// Generates the standard module preamble.
pub fn module_preamble(module_name: &str) -> String {
    let mut output = String.new();
    output.push_str("; ModuleID = '");
    output.push_str(module_name);
    output.push_str("'\n");
    output.push_str("source_filename = \"");
    output.push_str(module_name);
    output.push_str(".blood\"\n");
    output.push_str("target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128\"\n");
    output.push_str("target triple = \"x86_64-unknown-linux-gnu\"\n\n");
    output
}

/// Returns true if the user's `fn main` in `items` has a unit return type
/// (`fn main()` with no `-> T`). False if `main` returns `i32`, or if no
/// `main` item is present (legacy `generate_module` path with empty items).
///
/// Used by `intrinsic_declarations` to emit the correct C-level `@main`
/// trampoline: `call void @blood_main(); ret i32 0` for unit-return,
/// `%ret = call i32 @blood_main(); ret i32 %ret` for i32-return.
pub fn main_returns_unit(items: &Vec<hir_lower_ctx.ItemEntry>) -> bool {
    let main_sym_index = interner.SpecialIdents.main_sym().index;
    let unit_ty_index = type_intern.CommonTypes.unit().index;
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                if entry.item.name.symbol.index == main_sym_index {
                    return fn_def.sig.return_ty.index == unit_ty_index;
                }
            }
            _ => {}
        }
    }
    false
}

/// Generates standard intrinsic declarations.
///
/// `main_returns_unit` controls how the C-level `@main` trampoline calls
/// `@blood_main`: a unit-return `fn main()` is emitted as `define void
/// @blood_main()`, so calling it as i32 reads whatever the ABI leaves in
/// RAX (E3-BUG-1). Pass true for unit-return to emit `call void` + `ret i32 0`.
pub fn intrinsic_declarations(main_returns_unit: bool) -> String {
    let mut output = String.new();
    output.push_str("\n; Intrinsic declarations\n");
    output.push_str("declare void @llvm.memcpy.p0.p0.i64(ptr, ptr, i64, i1)\n");
    output.push_str("declare void @llvm.memset.p0.i64(ptr, i8, i64, i1)\n");
    output.push_str("declare void @llvm.trap()\n");
    output.push_str("declare void @llvm.dbg.declare(metadata, metadata, metadata)\n");
    output.push_str("declare void @llvm.debugtrap()\n");
    output.push_str("declare ptr @llvm.stacksave()\n");
    output.push_str("declare void @llvm.stackrestore(ptr)\n");

    // C library declarations
    output.push_str("\n; C library declarations\n");
    output.push_str("declare i32 @puts(ptr)\n");

    // Box runtime declarations
    output.push_str("\n; Box runtime declarations\n");
    output.push_str("declare ptr @box_new(ptr, i64)\n");
    output.push_str("declare ptr @box_as_ref(ptr)\n");

    // Effect handler evidence API declarations (from libblood_runtime.a)
    output.push_str("\n; Effect handler evidence API declarations\n");
    output.push_str("declare ptr @blood_evidence_create()\n");
    output.push_str("declare ptr @blood_evidence_current()\n");
    output.push_str("declare void @blood_evidence_set_current(ptr)\n");
    output.push_str("declare void @blood_evidence_push_with_state(ptr, i64, ptr, i64)\n");
    output.push_str("declare void @blood_evidence_push_by_index(ptr, i64, ptr, i64)\n");
    output.push_str("declare void @blood_evidence_set_inline(i64)\n");
    output.push_str("declare void @blood_evidence_clear_inline()\n");
    output.push_str("declare i64 @blood_evidence_pop(ptr)\n");
    output.push_str("declare void @blood_evidence_destroy(ptr)\n");
    output.push_str("declare i64 @blood_evidence_register(ptr, i64, ptr, i64, i64)\n");
    output.push_str("declare i64 @blood_perform(i64, i32, ptr, i64, i64)\n");
    output.push_str("declare i64 @blood_continuation_create_multishot(ptr, ptr)\n");
    output.push_str("declare i64 @blood_continuation_resume_with_regions(i64, i64)\n");
    output.push_str("declare void @blood_continuation_add_suspended_region(i64, i64)\n");
    output.push_str("\n; libmprompt-based NTR handler dispatch (sub-tasks 4-6 vertical slice + 3d)\n");
    output.push_str("declare ptr @blood_prompt_create()\n");
    output.push_str("declare ptr @blood_prompt_enter(ptr, ptr, ptr)\n");
    output.push_str("declare i64 @blood_perform_ntr(i64, i32, ptr, i64, i32)\n");
    output.push_str("declare ptr @blood_resume(ptr, ptr)\n");
    output.push_str("declare void @blood_panic_div_zero()\n");
    output.push_str("declare void @blood_panic_index_out_of_bounds(i64, i64)\n");
    output.push_str("declare void @blood_panic_index_out_of_bounds_loc(i64, i64, ptr)\n");
    output.push_str("\n; Identity continuation for tail-resumptive performs\n");
    output.push_str("define internal i64 @__blood_identity_continuation(i64 %0, ptr %1) {\n");
    output.push_str("entry:\n");
    output.push_str("  ret i64 %0\n");
    output.push_str("}\n");

    // Builtin constructor stubs (used as function pointers for match dispatch, not called directly)
    output.push_str("\n; Builtin constructor stubs\n");
    output.push_str("define internal void @option_none_ctor() { ret void }\n");
    output.push_str("define internal void @option_some_ctor(ptr %0) { ret void }\n");
    output.push_str("declare void @string_new(ptr)\n");
    output.push_str("declare void @string_from(ptr, ptr)\n");
    output.push_str("declare void @string_with_capacity(ptr, i64)\n");
    output.push_str("declare void @vec_new(i64, ptr)\n");

    // Format string conversion runtime declarations
    // These return { ptr, i64 } fat pointers (&str).
    output.push_str("\n; Format string conversion runtime declarations\n");
    output.push_str("declare { ptr, i64 } @int_to_string(i32)\n");
    output.push_str("declare { ptr, i64 } @bool_to_string(i1)\n");
    output.push_str("declare { ptr, i64 } @float_to_string(double)\n");
    output.push_str("declare { ptr, i64 } @char_to_string(i32)\n");

    // Builtin method runtime declarations
    // These are runtime functions called by builtin method resolution.
    // Signatures match blood-rust's codegen/context/mod.rs.
    output.push_str("\n; String method runtime declarations\n");
    output.push_str("declare i64 @string_len(ptr)\n");
    output.push_str("declare void @string_push(ptr, i32)\n");
    output.push_str("declare void @string_push_str(ptr, ptr)\n");
    output.push_str("declare { ptr, i64 } @string_as_str(ptr)\n");
    output.push_str("declare { ptr, i64 } @string_as_bytes(ptr)\n");
    output.push_str("declare i32 @string_is_empty(ptr)\n");
    output.push_str("declare i32 @string_contains(ptr, ptr)\n");
    output.push_str("declare i32 @string_starts_with(ptr, ptr)\n");
    output.push_str("declare i32 @string_ends_with(ptr, ptr)\n");

    output.push_str("\n; str method runtime declarations\n");
    output.push_str("declare { ptr, i64 } @str_as_bytes(ptr)\n");

    output.push_str("\n; Vec method runtime declarations\n");
    output.push_str("declare i64 @vec_len(ptr)\n");
    output.push_str("declare void @vec_push(ptr, ptr, i64)\n");
    output.push_str("declare i32 @vec_pop(ptr, i64, ptr)\n");
    output.push_str("declare void @vec_clear(ptr)\n");
    output.push_str("declare void @vec_with_capacity(i64, i64, ptr)\n");
    output.push_str("declare i32 @vec_is_empty(ptr)\n");
    output.push_str("declare i64 @vec_capacity(ptr)\n");
    output.push_str("declare i32 @vec_get(ptr, i64, i64, ptr)\n");
    output.push_str("declare ptr @vec_get_ptr(ptr, i64, i64)\n");
    output.push_str("declare i32 @vec_contains(ptr, ptr, i64)\n");
    output.push_str("declare void @vec_remove(ptr, i64, i64, ptr)\n");
    output.push_str("declare void @vec_insert(ptr, i64, ptr, i64)\n");
    output.push_str("declare void @vec_reverse(ptr, i64)\n");
    output.push_str("declare void @vec_first(ptr, i64, ptr)\n");
    output.push_str("declare void @vec_last(ptr, i64, ptr)\n");
    output.push_str("declare void @vec_free(ptr, i64)\n");

    output.push_str("\n; HashMap method runtime declarations\n");
    output.push_str("declare void @hashmap_new(i64, i64, i32, ptr)\n");
    output.push_str("declare i32 @hashmap_insert(ptr, ptr, ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare i32 @hashmap_get(ptr, ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare i32 @hashmap_contains_key(ptr, ptr, i64, i64, i32)\n");
    output.push_str("declare i64 @hashmap_len(ptr)\n");
    output.push_str("declare i32 @hashmap_is_empty(ptr)\n");
    output.push_str("declare i32 @hashmap_remove(ptr, ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare void @hashmap_clone(ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare void @hashmap_keys_new(ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare i32 @hashmap_keys_next(ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare void @hashmap_values_new(ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare i32 @hashmap_values_next(ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare void @hashmap_iter_new(ptr, i64, i64, i32, ptr)\n");
    output.push_str("declare i32 @hashmap_iter_next(ptr, i64, i64, i32, ptr, ptr)\n");
    // C3 Phase C Step 2: _fn variants accept per-K hash/eq fn-pointers in
    // place of kk, enabling user-defined ADT HashMap keys. Runtime signatures
    // in runtime/blood-runtime/rt_hashmap.blood (S64 commit aa9f594).
    // Blood's `fn(...)` type lowers to `{ ptr fn_addr, ptr env }` (closure
    // shape), so the runtime sees `{ ptr, ptr }` for each fn-pointer arg.
    output.push_str("declare i32 @hashmap_insert_fn(ptr, ptr, ptr, i64, i64, { ptr, ptr }, { ptr, ptr }, ptr)\n");
    output.push_str("declare i32 @hashmap_get_fn(ptr, ptr, i64, i64, { ptr, ptr }, { ptr, ptr }, ptr)\n");
    output.push_str("declare i32 @hashmap_contains_key_fn(ptr, ptr, i64, i64, { ptr, ptr }, { ptr, ptr })\n");
    output.push_str("declare i32 @hashmap_remove_fn(ptr, ptr, i64, i64, { ptr, ptr }, { ptr, ptr }, ptr)\n");

    output.push_str("\n; Option method runtime declarations\n");
    output.push_str("declare i32 @option_is_some(ptr)\n");
    output.push_str("declare i32 @option_is_none(ptr)\n");
    output.push_str("declare void @option_unwrap_or(ptr, i64, ptr, ptr)\n");
    output.push_str("declare void @option_expect(ptr, i64, ptr, ptr)\n");
    output.push_str("declare void @option_unwrap(ptr, i64, ptr)\n");
    output.push_str("declare void @option_as_ref(ptr, i64, ptr)\n");

    output.push_str("\n; Slice method runtime declarations\n");
    output.push_str("declare i64 @slice_len(ptr)\n");

    // Region memory management runtime wrappers
    // The runtime uses blood_region_* prefix; we provide region_* wrappers for codegen
    output.push_str("\n; Region memory management\n");
    output.push_str("declare i64 @blood_region_create(i64, i64)\n");
    output.push_str("declare void @blood_region_destroy(i64)\n");
    output.push_str("declare void @blood_region_reset(i64)\n");
    output.push_str("declare void @blood_region_protect(i64, i32)\n");
    output.push_str("declare void @blood_region_activate(i64)\n");
    output.push_str("declare void @blood_region_deactivate()\n");
    output.push_str("declare i64 @blood_region_deactivate_get()\n");
    output.push_str("declare i64 @blood_region_alloc(i64, i64, i64)\n");
    output.push_str("declare i32 @blood_region_exit_scope(i64)\n");
    output.push_str("declare i64 @blood_region_used(i64)\n");
    output.push_str("declare void @blood_region_trim(i64)\n");
    output.push_str("declare i64 @blood_region_committed(i64)\n");
    output.push_str("declare i64 @blood_region_alloc_count(i64)\n");
    output.push_str("declare i64 @blood_region_active_id()\n");
    output.push_str("declare i64 @blood_system_alloc_live_bytes()\n");
    output.push_str("define internal i64 @region_create(i64 %0, i64 %1) { %r = call i64 @blood_region_create(i64 %0, i64 %1) ret i64 %r }\n");
    output.push_str("define internal void @region_destroy(i64 %0) { call void @blood_region_destroy(i64 %0) ret void }\n");
    output.push_str("define internal void @region_reset(i64 %0) { call void @blood_region_reset(i64 %0) ret void }\n");
    output.push_str("define internal void @region_protect(i64 %0, i32 %1) { call void @blood_region_protect(i64 %0, i32 %1) ret void }\n");
    output.push_str("define internal void @region_activate(i64 %0) { call void @blood_region_activate(i64 %0) ret void }\n");
    output.push_str("define internal void @region_deactivate() { call void @blood_region_deactivate() ret void }\n");
    output.push_str("define internal i64 @region_deactivate_get() { %r = call i64 @blood_region_deactivate_get() ret i64 %r }\n");
    output.push_str("define internal i64 @region_alloc(i64 %0, i64 %1, i64 %2) { %r = call i64 @blood_region_alloc(i64 %0, i64 %1, i64 %2) ret i64 %r }\n");
    output.push_str("define internal i32 @region_exit_scope(i64 %0) { %r = call i32 @blood_region_exit_scope(i64 %0) ret i32 %r }\n");
    output.push_str("define internal i64 @region_used(i64 %0) { %r = call i64 @blood_region_used(i64 %0) ret i64 %r }\n");
    output.push_str("define internal void @region_trim(i64 %0) { call void @blood_region_trim(i64 %0) ret void }\n");
    output.push_str("define internal i64 @region_committed(i64 %0) { %r = call i64 @blood_region_committed(i64 %0) ret i64 %r }\n");
    output.push_str("define internal i64 @region_alloc_count(i64 %0) { %r = call i64 @blood_region_alloc_count(i64 %0) ret i64 %r }\n");
    output.push_str("define internal i64 @region_active_id() { %r = call i64 @blood_region_active_id() ret i64 %r }\n");
    output.push_str("define internal i64 @system_alloc_live_bytes() { %r = call i64 @blood_system_alloc_live_bytes() ret i64 %r }\n");
    output.push_str("declare i64 @blood_realloc_diag_count()\n");
    output.push_str("declare i64 @blood_realloc_diag_wasted()\n");
    output.push_str("declare i64 @blood_realloc_diag_inplace()\n");
    output.push_str("declare i64 @blood_realloc_diag_inplace_bytes()\n");
    output.push_str("declare i64 @blood_realloc_diag_offset_delta()\n");
    output.push_str("declare void @blood_realloc_stats_reset()\n");
    output.push_str("declare void @blood_print_alloc_hist()\n");
    output.push_str("declare void @blood_alloc_hist_reset()\n");
    output.push_str("define internal i64 @realloc_diag_count() { %r = call i64 @blood_realloc_diag_count() ret i64 %r }\n");
    output.push_str("define internal i64 @realloc_diag_wasted() { %r = call i64 @blood_realloc_diag_wasted() ret i64 %r }\n");
    output.push_str("define internal i64 @realloc_diag_inplace() { %r = call i64 @blood_realloc_diag_inplace() ret i64 %r }\n");
    output.push_str("define internal i64 @realloc_diag_inplace_bytes() { %r = call i64 @blood_realloc_diag_inplace_bytes() ret i64 %r }\n");
    output.push_str("define internal i64 @realloc_diag_offset_delta() { %r = call i64 @blood_realloc_diag_offset_delta() ret i64 %r }\n");
    output.push_str("define internal void @realloc_stats_reset() { call void @blood_realloc_stats_reset() ret void }\n");
    output.push_str("define internal void @print_alloc_hist() { call void @blood_print_alloc_hist() ret void }\n");
    output.push_str("define internal void @alloc_hist_reset() { call void @blood_alloc_hist_reset() ret void }\n");

    // Allocation tagging
    output.push_str("declare void @blood_alloc_tag_set(i64)\n");
    output.push_str("declare i64 @blood_alloc_tag_get()\n");
    output.push_str("declare void @blood_alloc_tag_reset()\n");
    output.push_str("declare void @blood_alloc_tag_report()\n");
    output.push_str("declare i64 @blood_alloc_tag_count(i64)\n");
    output.push_str("declare i64 @blood_alloc_tag_bytes(i64)\n");
    output.push_str("define internal void @alloc_tag_set(i64 %0) { call void @blood_alloc_tag_set(i64 %0) ret void }\n");
    output.push_str("define internal i64 @alloc_tag_get() { %r = call i64 @blood_alloc_tag_get() ret i64 %r }\n");
    output.push_str("define internal void @alloc_tag_reset() { call void @blood_alloc_tag_reset() ret void }\n");
    output.push_str("define internal void @alloc_tag_report() { call void @blood_alloc_tag_report() ret void }\n");
    output.push_str("define internal i64 @alloc_tag_count(i64 %0) { %r = call i64 @blood_alloc_tag_count(i64 %0) ret i64 %r }\n");
    output.push_str("define internal i64 @alloc_tag_bytes(i64 %0) { %r = call i64 @blood_alloc_tag_bytes(i64 %0) ret i64 %r }\n");

    // Memory management - generational references
    output.push_str("\n; Memory management - generational references\n");
    output.push_str("declare i64 @blood_alloc_or_abort(i64, ptr)\n");
    output.push_str("declare void @blood_free(i64, i64)\n");
    output.push_str("declare i32 @blood_register_allocation(i64, i64)\n");
    output.push_str("declare void @blood_unregister_allocation(i64)\n");
    output.push_str("declare i32 @blood_validate_generation(i64, i32)\n");
    output.push_str("declare i32 @blood_get_generation(i64)\n");
    output.push_str("declare i32 @blood_lazy_register_gen(i64)\n");
    output.push_str("declare void @blood_increment_generation(ptr)\n");
    output.push_str("declare void @blood_stale_reference_panic(i32, i32)\n");

    // Snapshot validation for effect handlers
    output.push_str("\n; Snapshot validation\n");
    output.push_str("declare ptr @blood_snapshot_create()\n");
    output.push_str("declare void @blood_snapshot_add_entry(ptr, i64, i32)\n");
    output.push_str("declare i64 @blood_snapshot_validate(ptr)\n");
    output.push_str("declare void @blood_snapshot_destroy(ptr)\n");
    output.push_str("declare void @blood_snapshot_stale_panic(ptr, i64)\n");
    output.push_str("declare ptr @blood_effect_context_get_snapshot()\n");
    output.push_str("declare void @blood_effect_context_set_snapshot(ptr)\n");
    output.push_str("declare ptr @blood_effect_context_take_snapshot()\n");

    // Persistent allocation (reference counting)
    output.push_str("\n; Persistent allocation (reference counting)\n");
    output.push_str("declare ptr @blood_persistent_alloc(i64, i64, i32, ptr)\n");
    output.push_str("declare void @blood_persistent_decrement(i64)\n");

    // Frozen<T> support (persist + freeze)
    output.push_str("declare ptr @blood_persist(ptr, i64)\n");
    output.push_str("declare i1 @blood_freeze(ptr)\n");
    output.push_str("declare i1 @blood_freeze_fields(ptr, ptr)\n");

    // Blood-name → runtime-name wrappers
    // Blood registers builtins with user-friendly names (e.g., "print"),
    // but the runtime exports them under different names (e.g., "print_str").
    // These wrappers bridge the gap. Uses named temps to avoid SSA numbering issues.
    output.push_str("\n; Blood builtin name wrappers\n");

    // print/println/eprint/eprintln → *_str runtime variants (for &str args)
    output.push_str("declare void @print_str({ ptr, i64 })\n");
    output.push_str("declare void @println_str({ ptr, i64 })\n");
    output.push_str("declare void @eprint_str({ ptr, i64 })\n");
    output.push_str("declare void @eprintln_str({ ptr, i64 })\n");
    output.push_str("define internal void @print({ ptr, i64 } %s) {\n  call void @print_str({ ptr, i64 } %s)\n  ret void\n}\n");
    output.push_str("define internal void @println({ ptr, i64 } %s) {\n  call void @println_str({ ptr, i64 } %s)\n  ret void\n}\n");
    output.push_str("define internal void @eprint({ ptr, i64 } %s) {\n  call void @eprint_str({ ptr, i64 } %s)\n  ret void\n}\n");
    output.push_str("define internal void @eprintln({ ptr, i64 } %s) {\n  call void @eprintln_str({ ptr, i64 } %s)\n  ret void\n}\n");

    // assert → blood_assert (Blood bool/i1 → runtime i32 conversion)
    output.push_str("declare void @blood_assert(i32)\n");
    output.push_str("declare void @blood_assert_eq_int(i32, i32)\n");
    output.push_str("declare void @blood_assert_eq_bool(i1, i1)\n");
    output.push_str("declare void @blood_assert_eq_i64(i64, i64)\n");
    output.push_str("declare void @blood_assert_eq_u32(i32, i32)\n");
    output.push_str("declare void @blood_assert_eq_u64(i64, i64)\n");
    output.push_str("declare void @blood_assert_eq_usize(i64, i64)\n");
    output.push_str("declare void @blood_assert_eq_str({ ptr, i64 }, { ptr, i64 })\n");
    output.push_str("declare void @blood_assert_ne_int(i32, i32)\n");
    output.push_str("define internal void @assert(i1 %cond) {\n  %ext = zext i1 %cond to i32\n  call void @blood_assert(i32 %ext)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_int(i32 %a, i32 %b) {\n  call void @blood_assert_eq_int(i32 %a, i32 %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_bool(i1 %a, i1 %b) {\n  call void @blood_assert_eq_bool(i1 %a, i1 %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_i64(i64 %a, i64 %b) {\n  call void @blood_assert_eq_i64(i64 %a, i64 %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_u32(i32 %a, i32 %b) {\n  call void @blood_assert_eq_u32(i32 %a, i32 %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_u64(i64 %a, i64 %b) {\n  call void @blood_assert_eq_u64(i64 %a, i64 %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_usize(i64 %a, i64 %b) {\n  call void @blood_assert_eq_usize(i64 %a, i64 %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_eq_str({ ptr, i64 } %a, { ptr, i64 } %b) {\n  call void @blood_assert_eq_str({ ptr, i64 } %a, { ptr, i64 } %b)\n  ret void\n}\n");
    output.push_str("define internal void @assert_ne_int(i32 %a, i32 %b) {\n  call void @blood_assert_ne_int(i32 %a, i32 %b)\n  ret void\n}\n");

    // unreachable/todo → panic with message string constants
    // Note: @panic is declared by the runtime function codegen path, not here.
    output.push_str("@.str.unreachable = private unnamed_addr constant [26 x i8] c\"unreachable code reached!\\00\"\n");
    output.push_str("@.str.todo = private unnamed_addr constant [21 x i8] c\"not yet implemented!\\00\"\n");
    output.push_str("define internal void @unreachable() noreturn {\n  call void @panic({ ptr, i64 } { ptr @.str.unreachable, i64 25 })\n  unreachable\n}\n");
    output.push_str("define internal void @todo() noreturn {\n  call void @panic({ ptr, i64 } { ptr @.str.todo, i64 20 })\n  unreachable\n}\n");

    // process_exit → libc exit
    output.push_str("declare void @exit(i32) noreturn\n");
    output.push_str("define internal void @process_exit(i32 %code) noreturn {\n  call void @exit(i32 %code)\n  unreachable\n}\n");

    // Low-level memory builtins → blood runtime (all i64 addresses)
    // Wrapper names prefixed with __blood_ to avoid collisions with bridge-declared
    // C functions (malloc, free, realloc, memcpy).
    output.push_str("declare i64 @blood_alloc_simple(i64)\n");
    output.push_str("declare i64 @blood_realloc(i64, i64)\n");
    output.push_str("declare void @blood_free_simple(i64)\n");
    output.push_str("declare i64 @blood_memcpy(i64, i64, i64)\n");
    output.push_str("define internal i64 @__blood_alloc(i64 %sz) {\n  %r = call i64 @blood_alloc_simple(i64 %sz)\n  ret i64 %r\n}\n");
    output.push_str("define internal i64 @__blood_realloc(i64 %p, i64 %sz) {\n  %r = call i64 @blood_realloc(i64 %p, i64 %sz)\n  ret i64 %r\n}\n");
    output.push_str("define internal void @__blood_free(i64 %p) {\n  call void @blood_free_simple(i64 %p)\n  ret void\n}\n");
    output.push_str("define internal i64 @__blood_memcpy(i64 %d, i64 %s, i64 %n) {\n  %r = call i64 @blood_memcpy(i64 %d, i64 %s, i64 %n)\n  ret i64 %r\n}\n");

    // str_concat → blood_str_concat
    output.push_str("declare { ptr, i64 } @blood_str_concat({ ptr, i64 }, { ptr, i64 })\n");
    output.push_str("define internal { ptr, i64 } @str_concat({ ptr, i64 } %a, { ptr, i64 } %b) {\n  %r = call { ptr, i64 } @blood_str_concat({ ptr, i64 } %a, { ptr, i64 } %b)\n  ret { ptr, i64 } %r\n}\n");

    // Builtins whose Blood types (Option<T>, String) don't match runtime ABI.
    // The runtime uses concrete types, not opaque ptrs.
    output.push_str("\n; Parsing / conversion / IO runtime declarations\n");
    output.push_str("declare double @parse_f64({ ptr, i64 })\n");
    output.push_str("declare i64 @parse_i64_radix({ ptr, i64 }, i32)\n");
    output.push_str("declare i32 @char_from_u32(i32)\n");
    output.push_str("declare { ptr, i64 } @read_line()\n");

    // Math library wrappers (Blood name → libm name where they differ)
    output.push_str("\n; Math library wrappers\n");
    output.push_str("declare double @fabs(double)\n");
    output.push_str("declare float @fabsf(float)\n");
    output.push_str("declare float @sqrtf(float)\n");
    output.push_str("define internal double @abs_f64(double %x) {\n  %r = call double @fabs(double %x)\n  ret double %r\n}\n");
    output.push_str("define internal float @abs_f32(float %x) {\n  %r = call float @fabsf(float %x)\n  ret float %r\n}\n");
    output.push_str("define internal float @sqrt_f32(float %x) {\n  %r = call float @sqrtf(float %x)\n  ret float %r\n}\n");

    // Thread builtins → blood_thread_spawn / blood_thread_join runtime wrappers
    output.push_str("\n; Thread runtime declarations\n");
    output.push_str("declare i64 @blood_thread_spawn(i64, i64)\n");
    output.push_str("declare i64 @blood_thread_join(i64)\n");
    output.push_str("define internal i64 @thread_spawn(i64 %f, i64 %a) {\n  %r = call i64 @blood_thread_spawn(i64 %f, i64 %a)\n  ret i64 %r\n}\n");
    output.push_str("define internal i64 @thread_join(i64 %h) {\n  %r = call i64 @blood_thread_join(i64 %h)\n  ret i64 %r\n}\n");

    // Allocation bypass for parallel codegen
    output.push_str("\n; Allocation bypass\n");
    output.push_str("declare void @blood_set_alloc_bypass_tracking(i32)\n");
    output.push_str("define internal void @set_alloc_bypass_tracking(i32 %v) {\n  call void @blood_set_alloc_bypass_tracking(i32 %v)\n  ret void\n}\n");

    // Default StaleReference handler op: aborts with diagnostic.
    // Signature: (state: ptr, args: ptr, arg_count: i64, continuation: i64) -> i64
    output.push_str("\n; Default StaleReference handler (aborts on stale reference)\n");
    output.push_str("define internal i64 @__blood_stale_ref_default_handler(ptr %state, ptr %args, i64 %arg_count, i64 %cont) {\n");
    output.push_str("  %expected_ptr = getelementptr i64, ptr %args, i64 0\n");
    output.push_str("  %expected_i64 = load i64, ptr %expected_ptr\n");
    output.push_str("  %expected = trunc i64 %expected_i64 to i32\n");
    output.push_str("  %actual_ptr = getelementptr i64, ptr %args, i64 1\n");
    output.push_str("  %actual_i64 = load i64, ptr %actual_ptr\n");
    output.push_str("  %actual = trunc i64 %actual_i64 to i32\n");
    output.push_str("  call void @blood_stale_reference_panic(i32 %expected, i32 %actual)\n");
    output.push_str("  unreachable\n");
    output.push_str("}\n");

    // StaleReference perform wrapper: packs i32 args into [2 x i64] and performs
    output.push_str("define internal void @blood_perform_stale_ref(i32 %expected, i32 %actual) {\n");
    output.push_str("  %args = alloca [2 x i64]\n");
    output.push_str("  %e = zext i32 %expected to i64\n");
    output.push_str("  store i64 %e, ptr %args\n");
    output.push_str("  %p1 = getelementptr i64, ptr %args, i64 1\n");
    output.push_str("  %a = zext i32 %actual to i64\n");
    output.push_str("  store i64 %a, ptr %p1\n");
    output.push_str("  call i64 @blood_perform_ntr(i64 4100, i32 0, ptr %args, i64 2, i32 1)\n");
    output.push_str("  unreachable\n");
    output.push_str("}\n");

    // Entry point: main() trampoline that replaces runtime.c
    output.push_str("\n; Entry point (replaces runtime.c)\n");
    output.push_str("declare void @blood_set_stack_size()\n");
    output.push_str("declare void @blood_init_args(i32, ptr)\n");
    output.push_str("define i32 @main(i32 %argc, ptr %argv) {\n");
    output.push_str("  call void @blood_set_stack_size()\n");
    output.push_str("  call void @blood_init_args(i32 %argc, ptr %argv)\n");

    // Install default StaleReference handler (effect ID 4100 = 0x1004)
    output.push_str("  %__sr_ev = call ptr @blood_evidence_create()\n");
    output.push_str("  call void @blood_evidence_set_current(ptr %__sr_ev)\n");
    output.push_str("  %__sr_ops = alloca [1 x ptr]\n");
    output.push_str("  store ptr @__blood_stale_ref_default_handler, ptr %__sr_ops\n");
    output.push_str("  %__sr_reg = call i64 @blood_evidence_register(ptr %__sr_ev, i64 4100, ptr %__sr_ops, i64 1, i64 1)\n");
    output.push_str("  call void @blood_evidence_push_by_index(ptr %__sr_ev, i64 %__sr_reg, ptr null, i64 0)\n");

    // Call blood_main. The C ABI requires @main to return i32, but the
    // user's `fn main()` without `-> i32` lowers to `define void @blood_main()`.
    // Calling a void function as i32 reads whatever the ABI left in RAX, which
    // leaks the last-computed value as the process exit code (E3-BUG-1). So we
    // emit the matching call shape and explicitly `ret i32 0` for unit-return.
    if main_returns_unit {
        output.push_str("  call void @blood_main()\n");
        output.push_str("  ret i32 0\n");
    } else {
        output.push_str("  %ret = call i32 @blood_main()\n");
        output.push_str("  ret i32 %ret\n");
    }
    output.push_str("}\n");

    output
}

// ============================================================
// External Function Declarations
// ============================================================

/// Generates an external function declaration.
pub fn extern_function(name: &str, params: &Vec<String>, ret_ty: &str) -> String {
    let mut output = String.new();
    output.push_str("declare ");
    output.push_str(ret_ty);
    output.push_str(" @");
    output.push_str(name);
    output.push_str("(");
    for i in 0usize..params.len() {
        if i > 0 {
            output.push_str(", ");
        }
        output.push_str(params[i].as_str());
    }
    output.push_str(")\n");
    output
}

// ============================================================
// String Helpers
// ============================================================

/// Checks if an LLVM type string is "{}" (empty struct / unit type).
fn is_empty_struct_type(ty: &str) -> bool {
    let bytes = ty.as_bytes();
    if bytes.len() == 2 {
        bytes[0] == 123 && bytes[1] == 125
    } else {
        false
    }
}


/// Compares two &str for equality.
fn string_eq_str(a: &str, b: &str) -> bool {
    let a_bytes = a.as_bytes();
    let b_bytes = b.as_bytes();
    if a_bytes.len() != b_bytes.len() {
        return false;
    }
    for i in 0usize..a_bytes.len() {
        if a_bytes[i] != b_bytes[i] {
            return false;
        }
    }
    true
}

// ============================================================
// Integration Tests (compile-time verification)
// ============================================================

/// Generates a minimal test module to verify codegen works.
pub fn generate_test_module() -> String {
    let mut output = String.new();

    // Module header
    output.push_str("; Test module for Blood codegen\n");
    output.push_str("source_filename = \"test.blood\"\n\n");

    // Simple function that returns 42
    output.push_str("define i64 @test_return() {\n");
    output.push_str("entry:\n");
    output.push_str("    ret i64 42\n");
    output.push_str("}\n\n");

    // Function with parameters
    output.push_str("define i64 @test_add(i64 %a, i64 %b) {\n");
    output.push_str("entry:\n");
    output.push_str("    %result = add i64 %a, %b\n");
    output.push_str("    ret i64 %result\n");
    output.push_str("}\n\n");

    // Function with control flow
    output.push_str("define i64 @test_if(i64 %cond) {\n");
    output.push_str("entry:\n");
    output.push_str("    %cmp = icmp ne i64 %cond, 0\n");
    output.push_str("    br i1 %cmp, label %then, label %else\n");
    output.push_str("then:\n");
    output.push_str("    br label %merge\n");
    output.push_str("else:\n");
    output.push_str("    br label %merge\n");
    output.push_str("merge:\n");
    output.push_str("    %result = phi i64 [ 1, %then ], [ 0, %else ]\n");
    output.push_str("    ret i64 %result\n");
    output.push_str("}\n");

    output
}
