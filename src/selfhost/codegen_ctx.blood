module blood.codegen_ctx;

// Blood Self-Hosted Compiler - Codegen Context
//
// This module defines the context used during MIR to LLVM IR codegen.
// It manages register allocation, local variable tracking, and IR emission.

mod ast;
mod common;
mod hir_def;
mod hir_ty;
mod mir_def;
mod mir_types;
mod mir_stmt;
mod mir_term;
mod mir_body;
mod mir_ntr_scope;
mod codegen_types;
mod hashmap;
mod type_intern;

// ============================================================
// Codegen Error Types
// ============================================================

/// Categories of errors that can occur during code generation.
pub enum CodegenErrorKind {
    /// ADT (struct/enum) not found in registry.
    AdtLookupFailed,
    /// Function DefId not found in def_names table.
    FnLookupFailed,
    /// Static variable DefId not found or missing def_id.
    StaticLookupFailed,
    /// Type parameter substitution failed (index out of bounds).
    TypeSubstitutionFailed,
    /// Enum variant not found in layout registry.
    VariantLookupFailed,
    /// Effect operation index lookup failed.
    EffectOpLookupFailed,
    /// Unsupported operation (e.g., bitwise on float).
    UnsupportedOperation,
    /// LLVM type string could not be parsed.
    TypeParseFailed,
    /// Internal codegen error (unexpected state).
    InternalError,
}

/// A note attached to a codegen error providing additional context.
pub struct CodegenNote {
    /// The note message.
    pub message: String,
    /// Optional source span for the note.
    pub span: Option<common.Span>,
}

impl CodegenNote {
    /// Creates a note without a span.
    pub fn new(message: String) -> CodegenNote {
        CodegenNote {
            message: message,
            span: Option.None,
        }
    }

    /// Creates a note with a source span.
    pub fn with_span(message: String, span: common.Span) -> CodegenNote {
        CodegenNote {
            message: message,
            span: Option.Some(span),
        }
    }
}

/// An error produced during code generation.
pub struct CodegenError {
    /// The kind of error.
    pub kind: CodegenErrorKind,
    /// Human-readable description of the error.
    pub message: String,
    /// The function being generated when the error occurred (if known).
    pub fn_name: Option<String>,
    /// Source span where the error occurred (if known).
    pub span: Option<common.Span>,
    /// Additional contextual notes.
    pub notes: Vec<CodegenNote>,
}

impl CodegenError {
    /// Creates a new codegen error.
    pub fn new(kind: CodegenErrorKind, message: String) -> CodegenError {
        CodegenError {
            kind: kind,
            message: message,
            fn_name: Option.None,
            span: Option.None,
            notes: Vec.new(),
        }
    }

    /// Creates a new codegen error with function context.
    pub fn with_fn(kind: CodegenErrorKind, message: String, fn_name: String) -> CodegenError {
        CodegenError {
            kind: kind,
            message: message,
            fn_name: Option.Some(fn_name),
            span: Option.None,
            notes: Vec.new(),
        }
    }
}

// ============================================================
// Codegen Name (CgName) — Zero-Allocation Value Names
// ============================================================

/// A codegen value name that can be written to the output without heap allocation.
/// Instead of creating String objects for "%tmp42" or "label7", we store the
/// prefix type and integer, writing directly to the output buffer on demand.
pub enum CgName {
    /// %tmpN — SSA temporary value
    Temp(u32),
    /// %_N — local alloca name
    Local(u32),
    /// labelN — branch label
    Label(u32),
    /// bbN — MIR basic block label
    Block(u32),
    /// Arbitrary string value (pass-through SSA names, constants, etc.)
    Str(String),
}

// ============================================================
// ADT Layout Types
// ============================================================

/// Information about a single field's type (LLVM and optionally HIR).
pub struct AdtFieldInfo {
    /// The LLVM type string for this field (e.g., "i32", "ptr", "{ i32, i64 }").
    pub llvm_type: String,
    /// The HIR type for this field, if known (interned). Used for computing element sizes during indexing.
    pub hir_type: Option<type_intern.TyId>,
}

/// Layout of a struct type.
pub struct StructLayout {
    /// The DefId of the struct.
    pub def_id: u32,
    /// The fields in declaration order.
    pub fields: Vec<AdtFieldInfo>,
    /// The complete LLVM type string (e.g., "{ i32, i64, ptr }").
    pub llvm_type: String,
    /// Whether this struct is packed (no padding between fields).
    pub is_packed: bool,
    /// Explicit minimum alignment (from #[repr(align(N))]), 0 = none.
    pub align: u32,
    /// Whether this is a C union (all fields overlap at offset 0).
    pub is_union: bool,
}

/// Layout of a single enum variant.
pub struct VariantLayout {
    /// The variant's discriminant index.
    pub variant_idx: u32,
    /// The fields/payload types for this variant.
    pub fields: Vec<AdtFieldInfo>,
    /// The LLVM type for this variant's payload (e.g., "{ i32, ptr }"), or "{}" for unit.
    pub payload_llvm_type: String,
}

/// Layout of an enum type.
pub struct EnumLayout {
    /// The DefId of the enum.
    pub def_id: u32,
    /// The LLVM type of the discriminant tag (e.g., "i8", "i32", "i64").
    pub discriminant_type: String,
    /// Layouts for each variant.
    pub variants: Vec<VariantLayout>,
    /// The complete LLVM type string (e.g., "{ i64, [16 x i8] }").
    pub llvm_type: String,
    /// The maximum payload size in bytes across all variants.
    pub max_payload_size: u64,
}

/// An ADT registry entry: either a struct or an enum.
pub enum AdtEntry {
    Struct(StructLayout),
    Enum(EnumLayout),
}

// ============================================================
// Codegen Context
// ============================================================

/// Context for generating LLVM IR from MIR.
pub struct CodegenCtx {
    /// The output buffer for LLVM IR.
    pub output: String,
    /// Current indentation level.
    indent_level: u32,
    /// Counter for generating unique SSA value names.
    value_counter: u32,
    /// Counter for generating unique labels.
    label_counter: u32,
    /// Mapping from MIR locals to LLVM value names.
    local_names: Vec<LocalName>,
    /// Mapping from MIR locals to their LLVM type strings.
    local_types: Vec<LocalType>,
    /// Mapping from MIR locals to their signedness (true = signed).
    local_signedness: Vec<LocalSignedness>,
    /// Mapping from MIR locals to their HIR types (for ADT lookups during projection).
    local_hir_types: Vec<LocalHirType>,
    /// Locals allocated via region allocator (freed on StorageDead).
    region_locals: Vec<RegionLocalEntry>,
    /// Locals allocated via persistent (ref-counted) allocator (decremented on StorageDead).
    persistent_locals: Vec<PersistentLocalEntry>,
    /// Region-tier locals whose blood_alloc_or_abort is deferred to RegionEnter.
    /// Entries: (region_local_idx, local_idx, ty_id).
    pub deferred_region_allocs: Vec<(u32, u32, type_intern.TyId)>,
    /// The current function being generated.
    current_fn: Option<String>,
    /// String constants table for global string literals.
    string_table: Vec<StringConstant>,
    /// Counter for generating unique string constant names.
    string_counter: u32,
    /// Mapping from DefIds to their global names (functions, consts, statics).
    def_names: Vec<DefNameEntry>,
    /// ADT type registry: maps DefIds to their layout information.
    pub adt_registry: Vec<AdtEntry>,
    /// Hash index for struct lookups: def_id -> index in adt_registry
    adt_struct_hash: hashmap.HashMapU64U32,
    /// Hash index for enum lookups: def_id -> index in adt_registry
    adt_enum_hash: hashmap.HashMapU64U32,
    /// Cache for type_to_llvm results: TyId.index → index in type_llvm_cache
    pub type_llvm_hash: hashmap.HashMapU64U32,
    /// Cached LLVM type strings for resolved TyIds.
    pub type_llvm_cache: Vec<String>,
    // Hash indexes for O(1) lookups
    /// Hash index for def_names: def_id -> index in def_names vec
    def_names_hash: hashmap.HashMapU64U32,
    /// Hash index for local_names: local_id -> index in local_names vec
    local_names_hash: hashmap.HashMapU64U32,
    /// Hash index for local_types: local_id -> index in local_types vec
    local_types_hash: hashmap.HashMapU64U32,
    /// Hash index for local_signedness: local_id -> index in local_signedness vec
    local_signedness_hash: hashmap.HashMapU64U32,
    /// Hash index for local_hir_types: local_id -> index in local_hir_types vec
    local_hir_types_hash: hashmap.HashMapU64U32,
    /// Hash set for region_locals: local_id -> 1 if present
    region_locals_hash: hashmap.HashMapU64U32,
    /// Hash set for persistent_locals: local_id -> 1 if present
    persistent_locals_hash: hashmap.HashMapU64U32,
    /// Hash index for string_table: string content hash -> index in string_table vec
    string_table_hash: hashmap.HashMapU64U32,
    /// Layout descriptor table for Frozen<T> deep-freeze traversal (GAP-2, A1 Phase 1).
    /// One entry per distinct inner type T encountered at a Frozen<T> aggregate site.
    /// Phase 1 emits zero-entry placeholders so `blood_freeze_fields` has a real
    /// descriptor pointer to inspect; Phase 2+ populates real field offsets.
    pub layout_table: Vec<LayoutDescriptor>,
    /// Counter for generating unique layout descriptor labels.
    pub layout_counter: u32,
    /// Hash index for layout_table: inner TyId.index -> index in layout_table vec.
    /// Within a single context, ensures each distinct inner type gets exactly one
    /// descriptor global. Across workers, duplicate descriptors are permitted
    /// (labels are disambiguated by the 100000 offset pattern used for strings).
    layout_by_ty_id: hashmap.HashMapU64U32,
    /// Hash set for static def_ids: def_id -> 1 if static
    static_defs_hash: hashmap.HashMapU64U32,
    /// LLVM types for static variables: def_id -> index in static_types vec
    static_types_hash: hashmap.HashMapU64U32,
    /// LLVM type strings for static variables.
    static_types: Vec<String>,
    /// HIR types for static variables: def_id -> TyId
    static_hir_types_hash: hashmap.HashMapU64U32,
    /// Hash set for const def_ids: def_id -> 1 if const
    const_defs_hash: hashmap.HashMapU64U32,
    /// Bridge const values: def_id -> i64 value (for inline emission)
    bridge_const_values: hashmap.HashMapU64U64,
    /// Hash set for foreign/bridge def_ids: def_id -> 1 if foreign
    foreign_defs_hash: hashmap.HashMapU64U32,
    /// Function signatures for generic call fixup: def_id -> index in fn_signatures vec
    fn_signatures: Vec<FnSigEntry>,
    fn_sigs_hash: hashmap.HashMapU64U32,
    /// Per-function temporary region ID. When non-zero, add_string_constant
    /// deactivates this region before allocating so string_table entries
    /// persist in the parent codegen_region rather than the resettable temp region.
    pub fn_temp_region: u64,
    /// Write buffer for batching file I/O during streaming codegen.
    write_buffer: String,
    /// Output file path for streaming codegen.
    output_path: String,
    /// Whether to emit MIR annotations as comments in LLVM IR.
    pub trace_codegen: bool,
    /// Whether to route dyn Trait dispatch through VFT content-hash lookup.
    pub vft_dispatch: bool,
    /// Per-function call remapping for trait default methods.
    /// When generating a default method body, calls to trait abstract method
    /// DefIds are redirected to concrete impl method DefIds.
    pub call_remaps: Vec<common.CallRemapEntry>,
    /// Mapping from handler DefId to effect DefId for evidence API calls.
    /// Vec entries allow iteration for cloning; hash for O(1) lookup.
    pub handler_effect_entries: Vec<HandlerEffectEntry>,
    handler_effect_hash: hashmap.HashMapU64U32,
    /// Mapping from handler DefId to handler kind (0=Deep, 1=Shallow).
    handler_kind_hash: hashmap.HashMapU64U32,
    /// Mapping from handler DefId to state field count.
    /// Used during PushHandler codegen to determine if handler is truly stateless.
    handler_state_count_hash: hashmap.HashMapU64U32,
    /// Mapping from handler DefId to total state byte size.
    /// Used during PushHandler codegen to allocate correctly-sized state shadow allocas.
    /// Accounts for aggregate types like String (24 bytes) that need more than 8 bytes.
    handler_state_byte_size_hash: hashmap.HashMapU64U32,
    /// Whether the current function being generated is a handler op body.
    /// When true, Resume terminators emit `ret i64` instead of blood_resume calls.
    pub is_handler_op: bool,
    /// Capture store-back info for inline handler op bodies.
    /// When is_handler_op and captures exist, Resume must store local values
    /// back through parent pointers before returning.
    pub handler_capture_locals: Vec<u32>,
    pub handler_capture_tys: Vec<type_intern.TyId>,
    /// Deferred inline handler stub function definitions.
    /// Collected during PushInlineHandler codegen, emitted after all bodies.
    pub inline_stubs: Vec<String>,
    /// Counter for generating unique inline handler stub names.
    pub inline_stub_count: u32,
    /// Current handler nesting depth for inline evidence optimization (EFF-OPT-003/004).
    /// Only call blood_evidence_set_inline when depth reaches 1 (single handler scope).
    pub handler_depth: u32,
    /// MIR local index of the handler op state field (passed by pointer).
    /// Set to 1 when compiling handler op bodies, -1 otherwise.
    /// When >= 0, the local's alloca is `ptr` and accesses go through the pointer.
    pub handler_op_state_local: i32,
    /// Number of state fields in the current handler op body (0 if not a handler op).
    /// When > 1, locals 2..1+count are state fields accessed via GEP into the state pointer.
    pub handler_op_state_field_count: u32,
    /// True while emitting a handler op body whose effect is mprompt-eligible.
    /// When set, Resume terminators compile to `blood_resume(%__cont, value)`
    /// (the libmprompt mp_resume path); otherwise Resume compiles to a simple
    /// state-writeback + ret i64 sequence (the fallthrough path used by TR
    /// handler ops and inline handler op closures). Set by
    /// codegen.generate_function_with_ctx at function entry based on
    /// handler_op_body_effect_hash + is_mprompt_eligible_effect; reset
    /// to false at function exit. Always false for non-handler-op
    /// functions and for inline handler op bodies (which don't have
    /// a registered effect mapping).
    pub current_handler_op_uses_mprompt_resume: bool,
    /// Hash set of handler op body DefIds.  Value 1 = is a handler op body.
    handler_op_body_hash: hashmap.HashMapU64U32,
    /// Vec of handler op body DefIds (for cloning to worker contexts).
    pub handler_op_body_ids: Vec<u32>,
    /// Maps handler op body DefId → handled effect DefId.
    /// Populated alongside register_handler_op_body. Consumed by
    /// generate_function_with_ctx to decide whether Resume terminators
    /// in this body should call blood_resume (mp_resume) or compile as a
    /// simple state-writeback + ret i64. Inline handler op bodies (closures
    /// with is_handler_op=true) do NOT get an entry here and always take
    /// the ret-i64 fallthrough path — this is *only observationally correct*
    /// for effect ops with unit () return type (B1 audit, S44). Inline
    /// handlers for non-unit-return ops are rejected at typeck
    /// (typeck_expr.blood InlineHandle branch) to avoid silent
    /// miscompilation. Extending this mapping to inline bodies (so they can
    /// route through libmprompt as named handlers do) is tracked as B1a.
    handler_op_body_effect_hash: hashmap.HashMapU64U32,
    /// Vec of (body_def_id, effect_def_id) pairs for cloning to workers.
    pub handler_op_body_effect_entries: Vec<HandlerOpBodyEffectEntry>,
    /// Mapping from op DefId → positional op_index within its effect.
    /// MIR stores op_def.index as op_index; codegen resolves via this table.
    op_def_index_hash: hashmap.HashMapU64U32,
    /// Vec of (op_def_id, positional_index) for cloning to worker contexts.
    pub op_def_index_entries: Vec<OpDefIndexEntry>,
    /// Per-handler state shadow alloca names.
    /// Set during PushHandler codegen, read during CallReturnClause codegen.
    /// Keyed by handler_def_id to support nested handlers.
    pub handler_state_shadows: Vec<HandlerStateShadow>,
    /// Errors accumulated during code generation.
    pub codegen_errors: Vec<CodegenError>,
    /// Warnings accumulated during code generation.
    pub codegen_warnings: Vec<String>,
    /// The span of the MIR statement/terminator currently being compiled.
    /// Set before each statement/terminator codegen, used by codegen_error().
    pub current_span: Option<common.Span>,
    /// Cache of fn pointer wrapper: def_id → index into fn_ptr_wrapper_names/defs.
    fn_ptr_wrapper_hash: hashmap.HashMapU64U32,
    /// Wrapper function names (e.g., "fn_name$fnptr"), indexed by wrapper hash value.
    fn_ptr_wrapper_names: Vec<String>,
    /// Deferred fn pointer wrapper function LLVM IR definitions.
    /// Collected when FnDef values are used, emitted after all function bodies.
    pub fn_ptr_wrapper_defs: Vec<String>,
    /// Vtable global constant definitions (LLVM IR text).
    /// Collected during vtable generation, emitted after string constants.
    pub vtable_defs: Vec<String>,
    /// Vtable lookup: hash(trait_def_id, impl_type_def_id) → index in vtable_defs.
    vtable_hash: hashmap.HashMapU64U32,
    /// Vtable layout: hash(trait_def_id) → index in vtable_layouts.
    vtable_layout_hash: hashmap.HashMapU64U32,
    /// Vtable layouts: stores (trait_def_id, method_count, method_names).
    vtable_layouts: Vec<VtableLayout>,
    /// Trait method info: abstract trait method DefId → (trait_def_id, method_name, slot_index).
    /// Used to identify vtable dispatch calls.
    pub trait_method_entries: Vec<TraitMethodEntry>,
    /// Vtable name entries: (trait_def_id, type_def_id) → vtable global name.
    pub vtable_name_entries: Vec<VtableNameEntry>,
    /// Effect-captured local indices for the current function.
    /// Set from escape analysis; used during Perform codegen for snapshot creation.
    pub effect_captured_locals: Vec<u32>,
    /// Non-tail-resumptive handler scopes in the current function.
    /// Populated at function codegen start by running mir_ntr_scope.analyze_ntr_scopes
    /// and filtering to handlers with handler_needs_abort = true. TR scopes stay
    /// on the direct-call fast path and do not appear here.
    ///
    /// Consumers (sub-tasks 4–6): body function emission, PushHandler (mp_prompt_enter),
    /// and Perform (blood_perform_ntr inside body functions). Empty for functions
    /// with no NTR handlers — those functions emit no body_fn / prompt plumbing.
    pub ntr_scopes: Vec<mir_ntr_scope.NtrScope>,
    /// Index into `ntr_scopes` identifying the scope currently being emitted
    /// as a body function, or -1 when emitting the outer function. We key on
    /// scope INDEX rather than handler_def_id because a single function can
    /// contain multiple `with H handle { ... }` blocks with the same handler
    /// but different captures and body blocks — those are distinct scopes
    /// with distinct body functions, and the intercepts in local_cg and
    /// block_label_cg need the exact scope to answer correctly.
    ///
    /// Threaded through statement and terminator emission so capture-aware
    /// reads/writes and body_fn_return redirection trigger at the right
    /// sites. Initialized to -1, set by codegen_body_fn.emit_body_fn before
    /// emitting body blocks, reset to -1 immediately after.
    pub in_ntr_body_fn_scope_idx: i32,
    /// The basic block currently being emitted. Set at the top of
    /// codegen_term.emit_basic_block, read by statement emitters that need
    /// to locate their place in the CFG (PushHandler uses this to pair its
    /// occurrence with the matching entry in `ntr_scopes` when a single
    /// function contains multiple `with H handle { ... }` blocks that share
    /// a handler_id but have distinct captures/body blocks).
    pub current_bb: mir_def.BasicBlockId,
    /// DefId of the function currently being emitted. Stored on ctx so
    /// statement emitters that need to reference function-scoped LLVM
    /// symbols (PushHandler's mprompt path references `@body_fn_<fn_id>_<pb>`
    /// and `%env_ty_<fn_id>_<pb>`) can reconstruct those names without
    /// threading `body: &MirBody` through every emission path. Set by
    /// generate_function_with_ctx before block emission starts.
    pub current_fn_def_id: u32,
    /// Signals that a statement inside the current block already emitted an
    /// unconditional terminator (typically PushHandler's mprompt branch to
    /// the pop block). When true, codegen_term.emit_basic_block skips the
    /// MIR terminator's emission — otherwise two branches would leave the
    /// block and LLVM would reject the IR. Cleared after each block.
    pub block_terminated_by_stmt: bool,
    /// Backward liveness at basic block entries. Flat grid:
    /// live_at_entry[bb_idx * perform_liveness_locals + local_idx].
    /// Empty if the function has no Perform terminators.
    pub perform_liveness: Vec<bool>,
    /// Number of locals (stride) for the perform_liveness grid.
    pub perform_liveness_locals: u32,
    /// Stack of active region LLVM register names.
    /// Pushed when blood_region_activate is called, popped when blood_region_deactivate is called.
    /// Used during Perform codegen to emit blood_continuation_add_suspended_region calls.
    pub active_regions: Vec<String>,
    /// Non-tail-resumptive effect set + abort state (Cancel/Error support).
    /// Packed into a single Vec<u64> to minimize struct layout impact.
    /// [0..N): effect DefIds, [N]: abort label string index, etc.
    non_tail_resumptive_effects: hashmap.HashMapU64U32,
    /// Per-effect flag: 1 if any handler op for this effect contains a
    /// `resume(...)` expression. Populated during handler info collection
    /// (main_handler.collect_handler_info) via a HIR walk. Used by
    /// is_mprompt_eligible_effect to avoid routing resumable handlers
    /// through the libmprompt abort trampoline.
    effect_has_resume_hash: hashmap.HashMapU64U32,
    pub frozen_def_id: u32,
    /// DefId of builtin String (0 if unknown). Used by the Frozen<T> layout
    /// walker to classify fields as kind=1 (String data-buffer freeze).
    pub string_def_id: u32,
    /// DefId of builtin Vec (0 if unknown). Used by the Frozen<T> layout
    /// walker to classify fields as kind=2 (Vec data-buffer + per-element walk).
    pub vec_def_id: u32,
    /// DefId of builtin Box (0 if unknown). Used by the Frozen<T> layout
    /// walker to classify fields as kind=3 (Box pointee freeze + recurse).
    pub box_def_id: u32,
    /// Per-op tail-resumptive classification.
    /// Key: (effect_def_id << 32) | op_sym_index. Value: 1 = TR, absent = NTR.
    pub tail_resumptive_ops: hashmap.HashMapU64U32,
    /// Abort label strings for non-tail-resumptive handler codegen, keyed by handler DefId.
    /// Each entry is 3 consecutive strings: [abort_store_label, merge_label, result_alloca].
    /// Index via handler_abort_hash: handler_def_id → base index in this Vec.
    abort_label_stack: Vec<String>,
    /// Maps handler DefId → base index in abort_label_stack (each entry is 3 strings).
    handler_abort_hash: hashmap.HashMapU64U32,
    /// Deferred alloca instructions that must appear in the entry block.
    /// Collected during basic block codegen (e.g., PushHandler shadow allocas),
    /// emitted at the end of the entry block before the branch to BB0.
    pub deferred_entry_allocas: Vec<String>,
    /// Active unchecked checks. Indexed by UncheckedCheck ordinal:
    /// 0=Bounds, 1=Overflow, 2=Generation, 3=Null, 4=Alignment.
    /// True means the check is currently suppressed.
    pub unchecked_active: Vec<bool>,
    /// Current function's DISubprogram metadata ID (0 = none).
    pub debug_subprogram_id: u32,
    /// Current function's DILocation metadata ID for instructions (0 = none).
    pub debug_location_id: u32,
    /// Last emitted source line (to avoid duplicate DILocation allocation).
    pub debug_last_line: u32,
    /// Counter for assigning unique metadata node IDs (!0, !1, ...).
    pub debug_metadata_counter: u32,
    /// Accumulated debug metadata nodes to emit at end of module.
    pub debug_metadata: Vec<String>,
    /// Source filename for debug info.
    pub debug_source_file: String,
}

/// Entry mapping a handler DefId to its effect DefId.
pub struct HandlerEffectEntry {
    pub handler_def_id: u32,
    pub effect_def_id: u32,
}

/// Entry mapping an op DefId to its positional index within the effect.
pub struct OpDefIndexEntry {
    pub effect_def_id: u32,
    pub op_name_sym: u32,
    pub positional_index: u32,
}

/// Entry mapping a handler op body DefId to its handled effect DefId.
/// Used to decide whether Resume terminators in that body should compile
/// to the mprompt blood_resume path (sub-task 3d).
pub struct HandlerOpBodyEffectEntry {
    pub body_def_id: u32,
    pub effect_def_id: u32,
}

/// Vtable layout for a trait: maps method indices to slot positions.
pub struct VtableLayout {
    pub trait_def_id: u32,
    pub method_count: u32,
    /// Method names in slot order.
    pub method_names: Vec<String>,
}

/// Mapping from an abstract trait method DefId to its trait and slot.
pub struct TraitMethodEntry {
    pub method_def_id: u32,
    pub trait_def_id: u32,
    pub method_name: String,
    pub slot_index: u32,
}

/// Vtable name entry: maps (trait_def_id, type_def_id) to vtable global name.
pub struct VtableNameEntry {
    pub trait_def_id: u32,
    pub type_def_id: u32,
    pub vtable_name: String,
}

/// Mapping from a handler DefId to its state shadow alloca name.
pub struct HandlerStateShadow {
    pub handler_def_id: u32,
    pub shadow_name: String,
}

/// Mapping from a MIR local to its LLVM type.
struct LocalType {
    local_id: u32,
    llvm_type: String,
}

/// Mapping from a MIR local to its HIR type (for ADT layout lookups).
struct LocalHirType {
    local_id: u32,
    hir_type: type_intern.TyId,
}

/// Mapping from a MIR local to its signedness.
struct LocalSignedness {
    local_id: u32,
    is_signed: bool,
}

/// Entry in the string constant table.
pub struct StringConstant {
    /// The global label for this string constant.
    label: String,
    /// The string content.
    content: String,
    /// The length of the string (including null terminator).
    length: usize,
}

/// A single field entry in a Frozen<T> layout descriptor (GAP-2 Phase 2).
/// Describes one heap-owning field of an aggregate: its offset in the parent
/// struct, the kind of heap owner (String/Vec/Box/inline-struct), an optional
/// label for the inner type's descriptor, and the element stride for Vec walks.
pub struct LayoutEntry {
    /// Byte offset within the parent aggregate.
    pub offset: u32,
    /// Kind discriminant: 1=String, 2=Vec, 3=Box, 4=inline struct.
    pub kind: u32,
    /// Layout descriptor label for the inner type (Vec element / Box pointee /
    /// inline struct). Empty string if no inner descriptor (leaf or primitive).
    pub inner_label: String,
    /// Element stride in bytes for Vec walks (sizeof(T) for Vec<T>). 0 for others.
    pub element_size: u64,
}

/// Entry in the Frozen<T> layout descriptor table (GAP-2 deep-freeze traversal).
/// One entry per distinct inner type T encountered at a Frozen<T> aggregate site.
/// Phase 1 emitted zero-entry placeholders; Phase 2 populates real field entries
/// for String / Vec / Box / inline nested struct fields of the inner type.
pub struct LayoutDescriptor {
    /// The global label for this descriptor (e.g., `@blood_layout.0`).
    pub label: String,
    /// The inner TyId.index this descriptor describes (for dedup).
    pub ty_id_idx: u32,
    /// Number of field entries (== entries.len(), kept for emit convenience).
    pub num_entries: u32,
    /// The concrete field entries describing heap-owning fields.
    pub entries: Vec<LayoutEntry>,
    /// True once populate_layout_entries has walked this type's fields.
    /// Guards against infinite recursion through cyclic ADTs (e.g., Box<Self>).
    pub populated: bool,
}

/// Mapping from a MIR local to its LLVM name.
struct LocalName {
    local_id: u32,
    name: String,
}

/// Tracks a local that was allocated via a region allocator.
/// The gen_name is the LLVM alloca holding the i32 generation returned by
/// blood_alloc_or_abort's out-parameter. Used at `&x` sites to capture the
/// generation into the fat reference's field 1.
struct RegionLocalEntry {
    local_id: u32,
    gen_name: String,
}

/// Tracks a local that was allocated via persistent (ref-counted) allocation.
/// The slot_id_name is the LLVM alloca holding the i64 slot ID returned by
/// blood_persistent_alloc. StorageDead must load from this alloca (not the
/// pointer alloca) to call blood_persistent_decrement with the correct ID.
struct PersistentLocalEntry {
    local_id: u32,
    slot_id_name: String,
    gen_name: String,
}

/// Mapping from a DefId to its global name (for functions, consts, statics).
pub struct DefNameEntry {
    pub def_id: u32,
    pub name: String,
}

impl DefNameEntry {
    /// Creates a new DefNameEntry.
    pub fn new(def_id: u32, name: String) -> DefNameEntry {
        DefNameEntry { def_id, name }
    }
}

/// Stored LLVM function signature for generic call fixup.
pub struct FnSigEntry {
    pub def_id: u32,
    pub param_types: Vec<String>,
    pub return_type: String,
}

impl CodegenCtx {
    /// Creates a new codegen context.
    pub fn new() -> CodegenCtx {
        CodegenCtx {
            // Pre-allocate output buffer (1 MB) and write buffer (64 KB)
            // to reduce realloc frequency during codegen
            output: String.new(),
            indent_level: 0,
            value_counter: 0,
            label_counter: 0,
            // Per-function Vecs: pre-allocate for typical function size (~64 locals)
            local_names: Vec.with_capacity(64),
            local_types: Vec.with_capacity(64),
            local_signedness: Vec.with_capacity(64),
            local_hir_types: Vec.with_capacity(64),
            region_locals: Vec.with_capacity(16),
            persistent_locals: Vec.with_capacity(16),
            deferred_region_allocs: Vec.new(),
            current_fn: Option.None,
            // Persistent cross-function Vecs: pre-allocate for typical compiler size
            string_table: Vec.with_capacity(512),
            string_counter: 0,
            def_names: Vec.with_capacity(2048),
            adt_registry: Vec.with_capacity(256),
            adt_struct_hash: hashmap.HashMapU64U32.with_capacity(256),
            adt_enum_hash: hashmap.HashMapU64U32.with_capacity(256),
            type_llvm_hash: hashmap.HashMapU64U32.with_capacity(512),
            type_llvm_cache: Vec.with_capacity(512),
            def_names_hash: hashmap.HashMapU64U32.with_capacity(2048),
            local_names_hash: hashmap.HashMapU64U32.with_capacity(64),
            local_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            local_signedness_hash: hashmap.HashMapU64U32.with_capacity(64),
            local_hir_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            region_locals_hash: hashmap.HashMapU64U32.with_capacity(16),
            persistent_locals_hash: hashmap.HashMapU64U32.with_capacity(16),


            string_table_hash: hashmap.HashMapU64U32.with_capacity(512),
            layout_table: Vec.with_capacity(16),
            layout_counter: 0,
            layout_by_ty_id: hashmap.HashMapU64U32.with_capacity(16),
            static_defs_hash: hashmap.HashMapU64U32.with_capacity(64),
            static_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            static_hir_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            static_types: Vec.with_capacity(64),
            const_defs_hash: hashmap.HashMapU64U32.with_capacity(64),
