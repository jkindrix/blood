            vft_dispatch: false,
            call_remaps: Vec.new(),
            handler_effect_entries: Vec.with_capacity(32),
            handler_effect_hash: hashmap.HashMapU64U32.with_capacity(32),
            handler_kind_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_state_count_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_state_byte_size_hash: hashmap.HashMapU64U32.with_capacity(16),
            is_handler_op: false,
            handler_capture_locals: Vec.new(),
            handler_capture_tys: Vec.new(),
            inline_stubs: Vec.with_capacity(128),
            inline_stub_count: 0,
            handler_depth: 0,
            handler_op_state_local: -1,
            handler_op_state_field_count: 0,
            current_handler_op_uses_mprompt_resume: false,
            handler_op_body_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_op_body_ids: Vec.with_capacity(16),
            handler_op_body_effect_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_op_body_effect_entries: Vec.with_capacity(16),
            op_def_index_hash: hashmap.HashMapU64U32.with_capacity(16),
            op_def_index_entries: Vec.with_capacity(16),
            handler_state_shadows: Vec.with_capacity(8),
            codegen_errors: Vec.new(),
            codegen_warnings: Vec.new(),
            current_span: Option.None,
            fn_ptr_wrapper_hash: hashmap.HashMapU64U32.with_capacity(32),
            fn_ptr_wrapper_names: Vec.with_capacity(32),
            fn_ptr_wrapper_defs: Vec.with_capacity(32),
            vtable_defs: Vec.with_capacity(32),
            vtable_hash: hashmap.HashMapU64U32.with_capacity(32),
            vtable_layout_hash: hashmap.HashMapU64U32.with_capacity(16),
            vtable_layouts: Vec.with_capacity(16),
            trait_method_entries: Vec.with_capacity(32),
            vtable_name_entries: Vec.with_capacity(32),
            effect_captured_locals: Vec.new(),
            ntr_scopes: Vec.new(),
            in_ntr_body_fn_scope_idx: -1i32,
            current_bb: mir_def.BasicBlockId.dummy(),
            block_terminated_by_stmt: false,
            current_fn_def_id: 0,
            perform_liveness: Vec.new(),
            perform_liveness_locals: 0,
            active_regions: Vec.with_capacity(4),
            non_tail_resumptive_effects: hashmap.HashMapU64U32.with_capacity(8),
            effect_has_resume_hash: hashmap.HashMapU64U32.with_capacity(8),
            frozen_def_id: 0,
            string_def_id: 0,
            vec_def_id: 0,
            box_def_id: 0,
            tail_resumptive_ops: hashmap.HashMapU64U32.with_capacity(16),
            abort_label_stack: Vec.new(),
            handler_abort_hash: hashmap.HashMapU64U32.new(),
            deferred_entry_allocas: Vec.new(),
            unchecked_active: vec_bool_5_false(),
            debug_subprogram_id: 0,
            debug_location_id: 0,
            debug_last_line: 0,
            debug_metadata_counter: 0,
            debug_metadata: Vec.new(),
            debug_source_file: String.new(),
        }
    }

    /// Creates a new codegen context with pre-populated def names.
    pub fn with_def_names(def_names: Vec<DefNameEntry>) -> CodegenCtx {
        // Build hash index for def_names
        let mut def_names_hash = hashmap.HashMapU64U32.with_capacity(def_names.len());
        for i in 0usize..def_names.len() {
            def_names_hash.insert(def_names[i].def_id as u64, i as u32);
        }

        CodegenCtx {
            output: String.new(),
            indent_level: 0,
            value_counter: 0,
            label_counter: 0,
            local_names: Vec.with_capacity(64),
            local_types: Vec.with_capacity(64),
            local_signedness: Vec.with_capacity(64),
            local_hir_types: Vec.with_capacity(64),
            region_locals: Vec.with_capacity(16),
            persistent_locals: Vec.with_capacity(16),
            deferred_region_allocs: Vec.new(),
            current_fn: Option.None,
            string_table: Vec.with_capacity(512),
            string_counter: 0,
            def_names: def_names,
            adt_registry: Vec.with_capacity(256),
            adt_struct_hash: hashmap.HashMapU64U32.with_capacity(256),
            adt_enum_hash: hashmap.HashMapU64U32.with_capacity(256),
            type_llvm_hash: hashmap.HashMapU64U32.with_capacity(512),
            type_llvm_cache: Vec.with_capacity(512),
            def_names_hash: def_names_hash,
            local_names_hash: hashmap.HashMapU64U32.with_capacity(64),
            local_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            local_signedness_hash: hashmap.HashMapU64U32.with_capacity(64),
            local_hir_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            region_locals_hash: hashmap.HashMapU64U32.with_capacity(16),
            persistent_locals_hash: hashmap.HashMapU64U32.with_capacity(16),


            string_table_hash: hashmap.HashMapU64U32.with_capacity(512),
            layout_table: Vec.with_capacity(16),
            layout_counter: 0,
            layout_by_ty_id: hashmap.HashMapU64U32.with_capacity(16),
            static_defs_hash: hashmap.HashMapU64U32.with_capacity(64),
            static_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            static_hir_types_hash: hashmap.HashMapU64U32.with_capacity(64),
            static_types: Vec.with_capacity(64),
            const_defs_hash: hashmap.HashMapU64U32.with_capacity(64),
            bridge_const_values: hashmap.HashMapU64U64.new(),
            foreign_defs_hash: hashmap.HashMapU64U32.with_capacity(64),
            fn_signatures: Vec.with_capacity(512),
            fn_sigs_hash: hashmap.HashMapU64U32.with_capacity(512),
            fn_temp_region: 0 as u64,
            write_buffer: String.new(),
            output_path: String.new(),
            trace_codegen: false,
            vft_dispatch: false,
            call_remaps: Vec.new(),
            handler_effect_entries: Vec.with_capacity(32),
            handler_effect_hash: hashmap.HashMapU64U32.with_capacity(32),
            handler_kind_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_state_count_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_state_byte_size_hash: hashmap.HashMapU64U32.with_capacity(16),
            is_handler_op: false,
            handler_capture_locals: Vec.new(),
            handler_capture_tys: Vec.new(),
            inline_stubs: Vec.with_capacity(128),
            inline_stub_count: 0,
            handler_depth: 0,
            handler_op_state_local: -1,
            handler_op_state_field_count: 0,
            current_handler_op_uses_mprompt_resume: false,
            handler_op_body_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_op_body_ids: Vec.with_capacity(16),
            handler_op_body_effect_hash: hashmap.HashMapU64U32.with_capacity(16),
            handler_op_body_effect_entries: Vec.with_capacity(16),
            op_def_index_hash: hashmap.HashMapU64U32.with_capacity(16),
            op_def_index_entries: Vec.with_capacity(16),
            handler_state_shadows: Vec.with_capacity(8),
            codegen_errors: Vec.new(),
            codegen_warnings: Vec.new(),
            current_span: Option.None,
            fn_ptr_wrapper_hash: hashmap.HashMapU64U32.with_capacity(32),
            fn_ptr_wrapper_names: Vec.with_capacity(32),
            fn_ptr_wrapper_defs: Vec.with_capacity(32),
            vtable_defs: Vec.with_capacity(32),
            vtable_hash: hashmap.HashMapU64U32.with_capacity(32),
            vtable_layout_hash: hashmap.HashMapU64U32.with_capacity(16),
            vtable_layouts: Vec.with_capacity(16),
            trait_method_entries: Vec.with_capacity(32),
            vtable_name_entries: Vec.with_capacity(32),
            effect_captured_locals: Vec.new(),
