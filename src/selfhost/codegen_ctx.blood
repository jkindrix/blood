            current_bb: mir_def.BasicBlockId.dummy(),
            block_terminated_by_stmt: false,
            current_fn_def_id: 0,
            perform_liveness: Vec.new(),
            perform_liveness_locals: 0,
            active_regions: Vec.with_capacity(4),
            non_tail_resumptive_effects: hashmap.HashMapU64U32.with_capacity(8),
            effect_has_resume_hash: hashmap.HashMapU64U32.with_capacity(8),
            frozen_def_id: 0,
            string_def_id: 0,
            vec_def_id: 0,
            box_def_id: 0,
            tail_resumptive_ops: hashmap.HashMapU64U32.with_capacity(16),
            abort_label_stack: Vec.new(),
            handler_abort_hash: hashmap.HashMapU64U32.new(),
            deferred_entry_allocas: Vec.new(),
            unchecked_active: vec_bool_5_false(),
            debug_subprogram_id: 0,
            debug_location_id: 0,
            debug_last_line: 0,
            debug_metadata_counter: 0,
            debug_metadata: Vec.new(),
            debug_source_file: String.new(),
        }
    }

    /// Registers a DefId with its global name.
    /// Deactivates temp region so the name string persists across function resets.
    pub fn register_def_name(self: &mut CodegenCtx, def_id: u32, name: String) {
        let had_temp = self.fn_temp_region != 0;
        if had_temp { region_deactivate(); }
        let cloned = name.clone();
        let idx = self.def_names.len() as u32;
        self.def_names.push(DefNameEntry { def_id, name: cloned });
        self.def_names_hash.insert(def_id as u64, idx);
        if had_temp { region_activate(self.fn_temp_region); }
    }

    /// Looks up the global name for a DefId.
    /// def_names_hash is authoritative: register_def_name updates it on every
    /// push. Duplicate registrations overwrite the hash to the LATEST index,
    /// which is acceptable — the latest registration is the one that should win.
    pub fn lookup_def_name(self: &CodegenCtx, def_id: u32) -> Option<String> {
        match self.def_names_hash.get(def_id as u64) {
            Option.Some(idx) => Option.Some(self.def_names[idx as usize].name.clone()),
            Option.None => Option.None,
        }
    }

    /// Gets a reference to a def name. Zero allocation.
    /// Returns None if not found. Same authoritative-hash contract as lookup_def_name.
    pub fn lookup_def_name_ref(self: &CodegenCtx, def_id: u32) -> Option<&String> {
        match self.def_names_hash.get(def_id as u64) {
            Option.Some(idx) => Option.Some(&self.def_names[idx as usize].name),
            Option.None => Option.None,
        }
    }

    /// Registers LLVM function signature for a compiled function (keyed by def_id).
    pub fn register_fn_signature(self: &mut CodegenCtx, def_id: u32, param_types: Vec<String>, return_type: String) {
        // Deactivate temp region so signature data persists across function resets.
        // Must deep-clone param_types and return_type since they may point into the temp region.
        let had_temp_sig = self.fn_temp_region != 0;
        if had_temp_sig { region_deactivate(); }
        let mut cloned_params: Vec<String> = Vec.with_capacity(param_types.len());
        for pi in 0usize..param_types.len() {
            cloned_params.push(param_types[pi].clone());
        }
        let cloned_ret = return_type.clone();
        let idx = self.fn_signatures.len() as u32;
        self.fn_signatures.push(FnSigEntry { def_id, param_types: cloned_params, return_type: cloned_ret });
        self.fn_sigs_hash.insert(def_id as u64, idx);
        if had_temp_sig { region_activate(self.fn_temp_region); }
    }

    /// Looks up the LLVM function signature for a given def_id.
    /// Returns the parameter types and return type if found.
    pub fn lookup_fn_param_type(self: &CodegenCtx, def_id: u32, param_idx: usize) -> Option<String> {
        match self.fn_sigs_hash.get(def_id as u64) {
            Option.Some(idx) => {
                let entry = &self.fn_signatures[idx as usize];
                if param_idx < entry.param_types.len() {
                    return Option.Some(entry.param_types[param_idx].clone());
                }
                Option.None
            }
            Option.None => Option.None,
        }
    }

    /// Looks up the LLVM return type for a given def_id.
    pub fn lookup_fn_ret_type(self: &CodegenCtx, def_id: u32) -> Option<String> {
        match self.fn_sigs_hash.get(def_id as u64) {
            Option.Some(idx) => {
                let entry = &self.fn_signatures[idx as usize];
                Option.Some(entry.return_type.clone())
            }
            Option.None => Option.None,
        }
    }

    /// Returns the number of registered def_names.
    pub fn def_names_count(self: &CodegenCtx) -> usize {
        self.def_names.len()
    }

    /// Returns the def_id and name for a def_name entry at the given index.
    pub fn def_name_at(self: &CodegenCtx, index: usize) -> (u32, String) {
        let entry = &self.def_names[index];
        (entry.def_id, entry.name.clone())
    }

    /// Gets or creates a fn pointer wrapper for the given def_id.
    /// Returns the wrapper function name (e.g., "fn_name$fnptr").
    /// The wrapper has signature (ptr %env, params...) -> ret and
    /// forwards to the original function ignoring the env parameter.
    pub fn get_or_create_fn_wrapper(self: &mut CodegenCtx, def_id: u32) -> Option<String> {
        // Check cache first
        match self.fn_ptr_wrapper_hash.get(def_id as u64) {
            Option.Some(idx) => {
                return Option.Some(self.fn_ptr_wrapper_names[idx as usize].clone());
            }
            Option.None => {}
        }

        // Deactivate temp region so wrapper strings persist across function resets.
        let had_temp_wrap = self.fn_temp_region != 0;
        if had_temp_wrap { region_deactivate(); }

        // Get the original function name
        let fn_name = match self.lookup_def_name(def_id) {
            Option.Some(name) => name,
            Option.None => {
                if had_temp_wrap { region_activate(self.fn_temp_region); }
                return Option.None;
            }
        };

        // Build wrapper name
        let mut wrapper_name = fn_name.clone();
        wrapper_name.push_str("$fnptr");

        // Get parameter types and return type from fn_signatures
        let has_sig = match self.fn_sigs_hash.get(def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        };

        // Build wrapper function definition
        let mut def = String.new();
        def.push_str("define linkonce_odr ");

        if has_sig {
            let sig_idx = match self.fn_sigs_hash.get(def_id as u64) {
                Option.Some(idx) => idx as usize,
                Option.None => 0,
            };
            let ret_ty_str = self.fn_signatures[sig_idx].return_type.clone();
            let param_count = self.fn_signatures[sig_idx].param_types.len();

            // Return type
            def.push_str(ret_ty_str.as_str());
            def.push_str(" @\"");
            def.push_str(wrapper_name.as_str());
            def.push_str("\"(ptr %env");

            // Add original parameters
            for pi in 0usize..param_count {
                def.push_str(", ");
                let pty = self.fn_signatures[sig_idx].param_types[pi].clone();
                def.push_str(pty.as_str());
                def.push_str(" %p");
                def.push_str(codegen_types.format_u64(pi as u64).as_str());
            }
            def.push_str(") {\nentry:\n");

            // Build the forwarding call
            let ret_bytes = ret_ty_str.as_bytes();
            let is_void = (ret_bytes.len() == 4 && ret_bytes[0] == 118 && ret_bytes[1] == 111 && ret_bytes[2] == 105 && ret_bytes[3] == 100) || (ret_bytes.len() == 2 && ret_bytes[0] == 123 && ret_bytes[1] == 125);
            if is_void {
                def.push_str("  call void @");
            } else {
                def.push_str("  %result = call ");
                def.push_str(ret_ty_str.as_str());
                def.push_str(" @");
            }
            def.push_str(fn_name.as_str());
            def.push_str("(");
            for ai in 0usize..param_count {
                if ai > 0 {
                    def.push_str(", ");
                }
                let pty = self.fn_signatures[sig_idx].param_types[ai].clone();
                def.push_str(pty.as_str());
                def.push_str(" %p");
                def.push_str(codegen_types.format_u64(ai as u64).as_str());
            }
            def.push_str(")\n");

            // Return
            if is_void {
                def.push_str("  ret void\n");
            } else {
                def.push_str("  ret ");
                def.push_str(ret_ty_str.as_str());
                def.push_str(" %result\n");
            }
            def.push_str("}\n");
        } else {
            // No signature info — generate a generic ptr-returning wrapper
            def.push_str("i64 @\"");
            def.push_str(wrapper_name.as_str());
            def.push_str("\"(ptr %env) {\nentry:\n");
            def.push_str("  %result = call i64 @");
            def.push_str(fn_name.as_str());
            def.push_str("()\n");
            def.push_str("  ret i64 %result\n");
            def.push_str("}\n");
        }

        // Cache the wrapper name and store the definition for later emission
        let idx = self.fn_ptr_wrapper_names.len() as u32;
        self.fn_ptr_wrapper_names.push(wrapper_name.clone());
        self.fn_ptr_wrapper_defs.push(def);
        self.fn_ptr_wrapper_hash.insert(def_id as u64, idx);

        if had_temp_wrap { region_activate(self.fn_temp_region); }
        Option.Some(wrapper_name)
    }

    /// Registers a DefId as a static variable.
    pub fn register_static(self: &mut CodegenCtx, def_id: u32) {
        self.static_defs_hash.insert(def_id as u64, 1);
    }

    /// Registers the LLVM type for a static variable.
    pub fn register_static_type(self: &mut CodegenCtx, def_id: u32, llvm_type: String) {
        let idx = self.static_types.len() as u32;
        self.static_types.push(llvm_type);
        self.static_types_hash.insert(def_id as u64, idx);
    }

    /// Returns the LLVM type for a static variable, if registered.
    pub fn get_static_type(self: &CodegenCtx, def_id: u32) -> Option<String> {
        match self.static_types_hash.get(def_id as u64) {
            Option.Some(idx) => {
                Option.Some(self.static_types[idx as usize].clone())
            }
            Option.None => Option.None,
        }
    }

    /// Registers the HIR type for a static variable (for array element size resolution).
    pub fn register_static_hir_type(self: &mut CodegenCtx, def_id: u32, ty_id: type_intern.TyId) {
        self.static_hir_types_hash.insert(def_id as u64, ty_id.index);
    }

    /// Returns the HIR type for a static variable, if registered.
    pub fn lookup_static_hir_type(self: &CodegenCtx, def_id: u32) -> Option<type_intern.TyId> {
        match self.static_hir_types_hash.get(def_id as u64) {
            Option.Some(idx) => Option.Some(type_intern.TyId.new(idx)),
            Option.None => Option.None,
        }
    }

    /// Returns true if the given DefId is a static variable.
    pub fn is_static(self: &CodegenCtx, def_id: u32) -> bool {
        match self.static_defs_hash.get(def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// Registers a DefId as a const item.
    pub fn register_const(self: &mut CodegenCtx, def_id: u32) {
        self.const_defs_hash.insert(def_id as u64, 1);
    }

    /// Returns true if the given DefId is a const item.
    pub fn is_const(self: &CodegenCtx, def_id: u32) -> bool {
        match self.const_defs_hash.get(def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// Registers a bridge constant with its inline value.
    pub fn register_bridge_const(self: &mut CodegenCtx, def_id: u32, value: i64) {
        self.const_defs_hash.insert(def_id as u64, 1);
        self.bridge_const_values.insert(def_id as u64, value as u64);
    }

    /// Returns the inline value for a bridge constant, or None if not a bridge const.
    pub fn get_bridge_const_value(self: &CodegenCtx, def_id: u32) -> Option<i64> {
        match self.bridge_const_values.get(def_id as u64) {
            Option.Some(v) => Option.Some(v as i64),
            Option.None => Option.None,
        }
    }

    /// Registers a DefId as a foreign/bridge function.
    pub fn register_foreign_def(self: &mut CodegenCtx, def_id: u32) {
        self.foreign_defs_hash.insert(def_id as u64, 1);
    }

    /// Returns true if the given DefId is a foreign/bridge function.
    pub fn is_foreign_def(self: &CodegenCtx, def_id: u32) -> bool {
        match self.foreign_defs_hash.get(def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// Remaps a DefId through the call_remaps table.
    /// If the DefId matches a from_def_id in call_remaps, returns the to_def_id.
    /// Otherwise returns the original def_id unchanged.
    pub fn remap_def_id(self: &CodegenCtx, def_id: u32) -> u32 {
        for i in 0usize..self.call_remaps.len() {
            if self.call_remaps[i].from_def_id == def_id {
                return self.call_remaps[i].to_def_id;
            }
        }
        def_id
    }

    /// Look up trait method info for a given abstract trait method DefId.
    /// Returns the TraitMethodEntry if this DefId is a trait method, None otherwise.
    pub fn lookup_trait_method(self: &CodegenCtx, method_def_id: u32) -> Option<&TraitMethodEntry> {
        for i in 0usize..self.trait_method_entries.len() {
            if self.trait_method_entries[i].method_def_id == method_def_id {
                return Option.Some(&self.trait_method_entries[i]);
            }
        }
        Option.None
    }

    /// Look up vtable global name for a (trait_def_id, type_def_id) pair.
    pub fn lookup_vtable_name(self: &CodegenCtx, trait_def_id: u32, type_def_id: u32) -> Option<&String> {
        for i in 0usize..self.vtable_name_entries.len() {
            if self.vtable_name_entries[i].trait_def_id == trait_def_id &&
               self.vtable_name_entries[i].type_def_id == type_def_id {
                return Option.Some(&self.vtable_name_entries[i].vtable_name);
            }
        }
        Option.None
    }

    /// Registers a handler DefId → effect DefId mapping.
    pub fn register_handler_effect(self: &mut CodegenCtx, handler_def_id: u32, effect_def_id: u32) {
        self.handler_effect_entries.push(HandlerEffectEntry { handler_def_id, effect_def_id });
        self.handler_effect_hash.insert(handler_def_id as u64, effect_def_id);
    }

    /// Registers a handler DefId → kind mapping (0=Deep, 1=Shallow).
    pub fn register_handler_kind(self: &mut CodegenCtx, handler_def_id: u32, kind: u32) {
        self.handler_kind_hash.insert(handler_def_id as u64, kind);
    }

    /// Returns whether a handler is deep (true) or shallow (false).
    pub fn handler_is_deep(self: &CodegenCtx, handler_def_id: u32) -> bool {
        match self.handler_kind_hash.get(handler_def_id as u64) {
            Option.Some(v) => v == 0,
            Option.None => true,
        }
    }

    /// Looks up the effect DefId for a handler DefId.
    pub fn lookup_handler_effect(self: &CodegenCtx, handler_def_id: u32) -> Option<u32> {
        match self.handler_effect_hash.get(handler_def_id as u64) {
            Option.Some(v) => Option.Some(v),
            Option.None => Option.None,
        }
    }

    /// Registers an effect DefId as non-tail-resumptive (handler may not call resume).
    pub fn register_non_tail_resumptive_effect(self: &mut CodegenCtx, effect_def_id: u32) {
        self.non_tail_resumptive_effects.insert(effect_def_id as u64, 1);
    }

    /// Checks if an effect DefId is non-tail-resumptive.
    pub fn is_non_tail_resumptive_effect(self: &CodegenCtx, effect_def_id: u32) -> bool {
        match self.non_tail_resumptive_effects.get(effect_def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// Registers a specific effect op as tail-resumptive (value=1).
    /// Only registers if no prior classification exists (NTR overrides TR).
    pub fn register_tail_resumptive_op(self: &mut CodegenCtx, effect_def_id: u32, op_sym_index: u32) {
        let key: u64 = ((effect_def_id as u64) << 32) | (op_sym_index as u64);
        match self.tail_resumptive_ops.get(key) {
            Option.Some(_) => {} // already classified — don't override
            Option.None => { self.tail_resumptive_ops.insert(key, 1); }
        }
    }

    /// Marks a specific effect op as non-tail-resumptive (value=0).
    /// Overrides any previous TR classification (NTR always wins).
    pub fn register_non_tail_resumptive_op(self: &mut CodegenCtx, effect_def_id: u32, op_sym_index: u32) {
        let key: u64 = ((effect_def_id as u64) << 32) | (op_sym_index as u64);
        self.tail_resumptive_ops.insert(key, 0);
    }

    /// Checks if a specific effect op is tail-resumptive.
    pub fn is_tail_resumptive_op(self: &CodegenCtx, effect_def_id: u32, op_sym_index: u32) -> bool {
        let key: u64 = ((effect_def_id as u64) << 32) | (op_sym_index as u64);
        match self.tail_resumptive_ops.get(key) {
            Option.Some(v) => v == 1,
            Option.None => false,
        }
    }

    /// Checks if a handler needs an abort target (its effect is non-tail-resumptive).
    pub fn handler_needs_abort(self: &CodegenCtx, handler_def_id: u32) -> bool {
        match self.lookup_handler_effect(handler_def_id) {
            Option.Some(effect_id) => self.is_non_tail_resumptive_effect(effect_id),
            Option.None => false,
        }
    }

    /// Records that at least one handler op for this effect contains a
    /// `resume(...)` expression. Sets the bit unconditionally on each call
    /// (idempotent). Consumed by is_mprompt_eligible_effect.
    pub fn register_effect_has_resume(self: &mut CodegenCtx, effect_def_id: u32) {
        self.effect_has_resume_hash.insert(effect_def_id as u64, 1u32);
    }

    /// Returns true if any handler op for this effect contains `resume(...)`.
    pub fn effect_has_resume(self: &CodegenCtx, effect_def_id: u32) -> bool {
        match self.effect_has_resume_hash.get(effect_def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// True if the effect's handlers route through the libmprompt
    /// body-fn extraction path. Every non-tail-resumptive effect
    /// (abort-only and resumable alike) is eligible after sub-tasks
    /// 3d, 3f, 3f-body and 3g closed the resumable-NTR gaps:
    ///
    ///   - 3d wired blood_resume into the Resume codegen so body's
    ///     final value propagates back through the mp_resume chain.
    ///   - 3f threaded the `_N_gen` alloca pointer through the env
    ///     so Rvalue.Ref inside body_fn resolves companion generation
    ///     storage to `%cap_N_gen_ptr`.
    ///   - 3f-body moved pop_block's pre-PopHandler statements into
    ///     body_fn so bodies with non-Copy tail expressions compute
    ///     their body_result on the gstack before body_fn_return
    ///     propagates it.
    ///   - 3g added an active-dispatch skip to blood_perform_ntr so a
    ///     handler re-performing its own effect yields past itself to
    ///     the next-outer handler instead of tripping mp_yield's
    ///     ancestor assertion.
    ///
    /// Sub-task 3e then deleted the setjmp/longjmp abort stack wholesale:
    /// every NTR handler now funnels through libmprompt; returning `true`
    /// is the only way an effect reaches codegen's PushHandler rewrite.
    pub fn is_mprompt_eligible_effect(self: &CodegenCtx, effect_def_id: u32) -> bool {
        self.is_non_tail_resumptive_effect(effect_def_id)
    }

    /// Returns true if the current function has a recorded NTR scope for this
    /// handler DefId. Driven by mir_ntr_scope pre-scan results filtered through
    /// handler_needs_abort. Used by PushHandler emission to gate the mp_prompt
    /// setup (env pack + blood_prompt_enter) that distinguishes NTR from TR
    /// handlers; TR-only handlers skip the prompt and the body-fn extraction.
    pub fn has_ntr_scope_for_handler(self: &CodegenCtx, handler_def_id: u32) -> bool {
        for i in 0usize..self.ntr_scopes.len() {
            if self.ntr_scopes[i].handler_id.index == handler_def_id {
                return true;
            }
        }
        false
    }

    /// Returns the NTR scope for a given handler DefId, or None if no such
    /// scope exists in the current function. Consumed by body fn emission
    /// (sub-task 4) to walk the scope's body_blocks and captures.
    pub fn ntr_scope_for_handler(self: &CodegenCtx, handler_def_id: u32) -> Option<&mir_ntr_scope.NtrScope> {
        for i in 0usize..self.ntr_scopes.len() {
            if self.ntr_scopes[i].handler_id.index == handler_def_id {
                return Option.Some(&self.ntr_scopes[i]);
            }
        }
        Option.None
    }

    /// Returns true if the given basic block is part of any recorded NTR
    /// scope's body. Used by the main function's emission loop to SKIP body
    /// blocks (they're redirected into the extracted body function).
    pub fn is_ntr_body_block(self: &CodegenCtx, bb: mir_def.BasicBlockId) -> bool {
        for i in 0usize..self.ntr_scopes.len() {
            if self.ntr_scopes[i].contains_block(bb) {
                return true;
            }
        }
        false
    }

    /// Number of NTR scopes in the current function's pre-scan.
    pub fn ntr_scope_count(self: &CodegenCtx) -> usize {
        self.ntr_scopes.len()
    }

    /// Returns the index into `ntr_scopes` of the scope whose push_block
    /// matches the given block ID, or -1 if no such scope exists. Keyed on
    /// push_block (not handler_id) because a single function may use the
    /// same handler across multiple `with H handle { ... }` sites, producing
    /// distinct scopes with distinct captures.
    ///
    /// Consumed by PushHandler emission (sub-task 5) to locate the exact
    /// scope whose env struct type and body function it must emit.
    pub fn ntr_scope_idx_for_push_block(self: &CodegenCtx, bb: mir_def.BasicBlockId) -> i32 {
        for i in 0usize..self.ntr_scopes.len() {
            if self.ntr_scopes[i].push_block.index == bb.index {
                return i as i32;
            }
        }
        -1i32
    }

    /// Returns true if the given basic block is the push_block or pop_block
    /// of any NTR scope in the current function. Used by the outer
    /// function's block-emission loop: body-interior blocks are emitted in
    /// the body function and must be skipped in the outer, but push_block
    /// (for pre-PushHandler statements + PushHandler's mprompt emission) and
    /// pop_block (for PopHandler + CallReturnClause + CallFinallyClause)
    /// remain in the outer function.
    pub fn is_ntr_push_or_pop_block(self: &CodegenCtx, bb: mir_def.BasicBlockId) -> bool {
        for i in 0usize..self.ntr_scopes.len() {
            let scope = &self.ntr_scopes[i];
            if scope.push_block.index == bb.index || scope.pop_block.index == bb.index {
                return true;
            }
        }
        false
    }

    /// True when some NTR scope strictly contains the block — i.e. `bb` is
    /// in some scope S's body_blocks AND `bb` is neither S.push_block nor
    /// S.pop_block. Such blocks belong inside an extracted body function
    /// (possibly the body_fn of an enclosing scope, if `bb` itself is a
    /// nested scope's push/pop) and must be skipped in the outer function's
    /// block emission.
    ///
    /// This replaces the earlier "is_body AND NOT push_or_pop" heuristic,
    /// which incorrectly kept nested scopes' push/pop blocks in the outer
    /// function — the innermost enclosing body_fn owns them instead.
    pub fn ntr_block_is_strictly_contained(self: &CodegenCtx, bb: mir_def.BasicBlockId) -> bool {
        for i in 0usize..self.ntr_scopes.len() {
            let scope = &self.ntr_scopes[i];
            if scope.push_block.index == bb.index {
                continue;
            }
            if scope.pop_block.index == bb.index {
                continue;
            }
            if scope.contains_block(bb) {
                return true;
            }
        }
        false
    }

    /// Returns the number of statements that must be skipped at the start
    /// of `bb` when the outer function or an enclosing body_fn emits it.
    /// Nonzero when `bb` is the pop_block of an mprompt scope registered
    /// in `ntr_scopes`: those leading statements compute the handle-block's
    /// body_result on the gstack and are emitted as the `pop_pre` trailer
    /// in body_fn. Zero for every other block, including when body_fn
    /// itself is emitting the pop_block's pre-statements (body_fn does
    /// not route through emit_basic_block for that emission).
    pub fn mprompt_pop_pre_stmt_skip(self: &CodegenCtx, bb: mir_def.BasicBlockId) -> usize {
        for i in 0usize..self.ntr_scopes.len() {
            let scope = &self.ntr_scopes[i];
            if scope.pop_block.index == bb.index {
                return scope.pop_pre_stmt_count as usize;
            }
        }
        0
    }

    /// Returns the index of the INNERMOST NTR scope that strictly contains
    /// `bb` (i.e. `bb` is in body_blocks but not the scope's push/pop), or
    /// -1 when no scope strictly contains it. "Innermost" is approximated
    /// by smallest `body_blocks.len()` among candidates — safe because
    /// scopes are either properly nested or disjoint (no overlaps) in
    /// well-formed MIR.
    ///
    /// Consumed by body_fn emission (and block_label_cg): a scope S's
    /// body_fn emits `bb` iff S is `bb`'s innermost owning scope. This
    /// prevents duplicate emission of nested scopes' inner bodies in
    /// enclosing body_fns.
    pub fn ntr_innermost_owning_scope_idx(self: &CodegenCtx, bb: mir_def.BasicBlockId) -> i32 {
        let mut best: i32 = -1i32;
        let mut best_size: usize = 0;
        for i in 0usize..self.ntr_scopes.len() {
            let scope = &self.ntr_scopes[i];
            if scope.push_block.index == bb.index {
                continue;
            }
            if scope.pop_block.index == bb.index {
                continue;
            }
            if !scope.contains_block(bb) {
                continue;
            }
            let size = scope.body_blocks.len();
            if best < 0 || size < best_size {
                best = i as i32;
                best_size = size;
            }
        }
        best
    }

    /// Marks that statement/terminator emission is happening inside the
    /// extracted body function for the scope at `scope_idx` in `ntr_scopes`.
    /// Sub-task 4's body_fn emitter sets this immediately before re-emitting
    /// body blocks and clears it when body_fn emission completes.
    pub fn enter_body_fn(self: &mut CodegenCtx, scope_idx: u32) {
        self.in_ntr_body_fn_scope_idx = scope_idx as i32;
    }

    /// Clears the body_fn-emission flag. Must be called before returning to
    /// outer-function emission so capture substitution and body_fn_return
    /// redirection do not leak into outer code.
    pub fn exit_body_fn(self: &mut CodegenCtx) {
        self.in_ntr_body_fn_scope_idx = -1i32;
    }

    /// True if the codegen is currently emitting inside an NTR body function.
    pub fn is_in_ntr_body_fn(self: &CodegenCtx) -> bool {
        self.in_ntr_body_fn_scope_idx >= 0i32
    }

    /// Returns the active body_fn scope if the codegen is inside one, None
    /// otherwise. Used by emit_place / local_alloca_name (sub-task 4) to
    /// substitute env-pointer reads/writes for captured locals.
    pub fn current_body_fn_scope(self: &CodegenCtx) -> Option<&mir_ntr_scope.NtrScope> {
        if self.in_ntr_body_fn_scope_idx < 0i32 {
            return Option.None;
        }
        let idx = self.in_ntr_body_fn_scope_idx as usize;
        if idx >= self.ntr_scopes.len() {
            return Option.None;
        }
        Option.Some(&self.ntr_scopes[idx])
    }

    /// Stores abort label state for a handler (3 strings: abort_store, merge, result_alloca).
    pub fn push_abort_labels(self: &mut CodegenCtx, handler_def_id: u32, abort_store: String, merge: String, result_alloca: String) {
        let base = self.abort_label_stack.len() as u32;
        self.handler_abort_hash.insert(handler_def_id as u64, base);
        self.abort_label_stack.push(abort_store);
        self.abort_label_stack.push(merge);
        self.abort_label_stack.push(result_alloca);
    }

    /// Returns true if a specific handler has pending abort label state.
    pub fn has_abort_labels_for(self: &CodegenCtx, handler_def_id: u32) -> bool {
        match self.handler_abort_hash.get(handler_def_id as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// Gets the abort store label for a handler.
    pub fn get_abort_store_label(self: &CodegenCtx, handler_def_id: u32) -> &String {
        let base = match self.handler_abort_hash.get(handler_def_id as u64) {
            Option.Some(b) => b as usize,
            Option.None => 0,
        };
        &self.abort_label_stack[base]
    }

    /// Gets the abort merge label for a handler.
    pub fn get_abort_merge_label(self: &CodegenCtx, handler_def_id: u32) -> &String {
        let base = match self.handler_abort_hash.get(handler_def_id as u64) {
            Option.Some(b) => b as usize,
            Option.None => 0,
        };
        &self.abort_label_stack[base + 1]
    }

    /// Gets the abort result alloca name for a handler.
    pub fn get_abort_result_alloca(self: &CodegenCtx, handler_def_id: u32) -> &String {
        let base = match self.handler_abort_hash.get(handler_def_id as u64) {
            Option.Some(b) => b as usize,
            Option.None => 0,
        };
        &self.abort_label_stack[base + 2]
    }

    /// Removes a handler's abort label state.
    pub fn pop_abort_labels(self: &mut CodegenCtx, handler_def_id: u32) {
        self.handler_abort_hash.remove(handler_def_id as u64);
    }

    /// Set up debug info for a function. Call before emit_fn_header.
    /// Records the DISubprogram and sets debug_subprogram_id so emit_fn_header
    /// attaches !dbg to the define line.
    pub fn setup_debug_function(self: &mut CodegenCtx, fn_name: &str, source_line: u32, module_index: u32, module_count: u32) {
        if self.debug_source_file.len() == 0 {
            self.debug_subprogram_id = 0;
            self.debug_location_id = 0;
            self.debug_last_line = 0;
            return;
        }
        let id = self.debug_metadata_counter;
        self.debug_metadata_counter = id + 1;
        self.debug_subprogram_id = id;
        self.debug_last_line = 0;
        // Compute IDs: file_id = module_index + 1, subroutine = N+1, empty = N+2
        let n: u32 = if module_count > 0 { module_count } else { 1 };
        let file_id: u32 = if module_index < n { module_index + 1 } else { 1 };
        let subroutine_id: u32 = n + 1;
        let empty_id: u32 = n + 2;
        let had_temp = self.fn_temp_region != 0;
        if had_temp { region_deactivate(); }
        let mut md = common.make_string("!");
        md.push_str(codegen_types.format_u64(id as u64).as_str());
        md.push_str(" = distinct !DISubprogram(name: \"");
        md.push_str(fn_name);
        md.push_str("\", scope: !");
        md.push_str(codegen_types.format_u64(file_id as u64).as_str());
        md.push_str(", file: !");
        md.push_str(codegen_types.format_u64(file_id as u64).as_str());
        md.push_str(", line: ");
        md.push_str(codegen_types.format_u64(source_line as u64).as_str());
        md.push_str(", type: !");
        md.push_str(codegen_types.format_u64(subroutine_id as u64).as_str());
        md.push_str(", scopeLine: ");
        md.push_str(codegen_types.format_u64(source_line as u64).as_str());
        md.push_str(", spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !");
        md.push_str(codegen_types.format_u64(empty_id as u64).as_str());
        md.push_str(")\n");
        self.debug_metadata.push(md);
        // Emit a DILocation for this function's instructions
        let loc_id = self.debug_metadata_counter;
        self.debug_metadata_counter = loc_id + 1;
        self.debug_location_id = loc_id;
        let mut loc = common.make_string("!");
        loc.push_str(codegen_types.format_u64(loc_id as u64).as_str());
        loc.push_str(" = !DILocation(line: ");
        loc.push_str(codegen_types.format_u64(source_line as u64).as_str());
        loc.push_str(", column: 1, scope: !");
        loc.push_str(codegen_types.format_u64(id as u64).as_str());
        loc.push_str(")\n");
        self.debug_metadata.push(loc);
        if had_temp { region_activate(self.fn_temp_region); }
    }

    /// Initialize debug info for the module. Must be called once before any
    /// setup_debug_function calls. Reserves metadata IDs 0-3 for the fixed
    /// compile unit, file, subroutine type, and empty tuple.
    pub fn init_debug_info(self: &mut CodegenCtx, source_file: &str, module_count: u32) {
        self.debug_source_file = common.make_string(source_file);
        // Reserve IDs: !0=CompileUnit, !1..!N=DIFile per module,
        // !(N+1)=SubroutineType, !(N+2)=empty, !(N+3-4)=flags, !(N+5)=BasicType
        let n: u32 = if module_count > 0 { module_count } else { 1 };
        self.debug_metadata_counter = n + 6;
    }

    /// Emit all accumulated debug metadata as a string (for appending to module IR).
    pub fn emit_debug_metadata(self: &CodegenCtx, module_names: &Vec<String>) -> String {
        if self.debug_source_file.len() == 0 {
            return String.new();
        }
        let n: u32 = if module_names.len() > 0 { module_names.len() as u32 } else { 1 };
        let sub_id: u32 = n + 1;
        let empty_id: u32 = n + 2;
        let flag1_id: u32 = n + 3;
        let flag2_id: u32 = n + 4;
        let basic_id: u32 = n + 5;
        let mut out = String.new();
        out.push_str("\n; Debug metadata\n");
        out.push_str("!llvm.dbg.cu = !{!0}\n");
        out.push_str("!llvm.module.flags = !{!");
        out.push_str(codegen_types.format_u64(flag1_id as u64).as_str());
        out.push_str(", !");
        out.push_str(codegen_types.format_u64(flag2_id as u64).as_str());
        out.push_str("}\n\n");
        out.push_str("!0 = distinct !DICompileUnit(language: DW_LANG_C99, file: !1, producer: \"bloodc\", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug, enums: !");
        out.push_str(codegen_types.format_u64(empty_id as u64).as_str());
        out.push_str(")\n");
        // Emit DIFile nodes: !1..!N
        for mi in 0u32..n {
            let mi_plus_1: u64 = (mi + 1) as u64;
            out.push_str("!");
            out.push_str(codegen_types.format_u64(mi_plus_1).as_str());
            out.push_str(" = !DIFile(filename: \"");
            let mi_idx: usize = mi as usize;
            if mi == 0 {
                out.push_str(self.debug_source_file.as_str());
            } else if mi_idx < module_names.len() {
                let path = module_names[mi_idx].as_str();
                let basename = extract_filename_string(path);
                out.push_str(basename.as_str());
            } else {
                out.push_str("unknown.blood");
            }
            out.push_str("\", directory: \".\")\n");
        }
        out.push_str("!");
        out.push_str(codegen_types.format_u64(sub_id as u64).as_str());
        out.push_str(" = !DISubroutineType(types: !");
        out.push_str(codegen_types.format_u64(empty_id as u64).as_str());
        out.push_str(")\n!");
        out.push_str(codegen_types.format_u64(empty_id as u64).as_str());
        out.push_str(" = !{}\n!");
        out.push_str(codegen_types.format_u64(flag1_id as u64).as_str());
        out.push_str(" = !{i32 7, !\"Dwarf Version\", i32 4}\n!");
        out.push_str(codegen_types.format_u64(flag2_id as u64).as_str());
        out.push_str(" = !{i32 2, !\"Debug Info Version\", i32 3}\n!");
        out.push_str(codegen_types.format_u64(basic_id as u64).as_str());
        out.push_str(" = !DIBasicType(name: \"i64\", size: 64, encoding: DW_ATE_signed)\n\n");
        for md in &self.debug_metadata {
            out.push_str(md.as_str());
        }
        out
    }

    /// Emit the debug location suffix for the current instruction.
    /// Uses the current statement's span line if available, otherwise
    /// falls back to the function-level location.
    pub fn emit_dbg(self: &mut CodegenCtx) {
        if self.debug_subprogram_id == 0 {
            return;
        }
        // Get the current line from the span if available
        let current_line = match &self.current_span {
            &Option.Some(ref span) => {
                if span.line > 0 { span.line } else { 0 }
            }
            &Option.None => 0,
        };
        if current_line > 0 && current_line != self.debug_last_line {
            // Line changed — allocate a new DILocation
            let had_temp = self.fn_temp_region != 0;
            if had_temp { region_deactivate(); }
            let loc_id = self.debug_metadata_counter;
            self.debug_metadata_counter = loc_id + 1;
            self.debug_location_id = loc_id;
            self.debug_last_line = current_line;
            let mut loc = common.make_string("!");
            loc.push_str(codegen_types.format_u64(loc_id as u64).as_str());
            loc.push_str(" = !DILocation(line: ");
            loc.push_str(codegen_types.format_u64(current_line as u64).as_str());
            loc.push_str(", column: 1, scope: !");
            loc.push_str(codegen_types.format_u64(self.debug_subprogram_id as u64).as_str());
            loc.push_str(")\n");
            self.debug_metadata.push(loc);
            if had_temp { region_activate(self.fn_temp_region); }
        }
        if self.debug_location_id > 0 {
            self.write(", !dbg !");
            self.write(codegen_types.format_u64(self.debug_location_id as u64).as_str());
        }
    }

    /// Write a newline terminating an LLVM instruction, with optional !dbg suffix.
    pub fn end_insn(self: &mut CodegenCtx) {
        self.emit_dbg();
        self.write("\n");
    }

    /// Emit a debug variable declaration for a local alloca.
    /// Call after emit_alloca_cg for named user variables (not temporaries).
    pub fn emit_debug_variable(self: &mut CodegenCtx, alloca_name: &CgName, var_name: &str, line: u32) {
        if self.debug_subprogram_id == 0 || var_name.len() == 0 {
            return;
        }
        let had_temp = self.fn_temp_region != 0;
        if had_temp { region_deactivate(); }
        // Allocate DILocalVariable metadata
        let var_id = self.debug_metadata_counter;
        self.debug_metadata_counter = var_id + 1;
        let mut md = common.make_string("!");
        md.push_str(codegen_types.format_u64(var_id as u64).as_str());
        md.push_str(" = !DILocalVariable(name: \"");
        md.push_str(var_name);
        md.push_str("\", scope: !");
        md.push_str(codegen_types.format_u64(self.debug_subprogram_id as u64).as_str());
        md.push_str(", file: !1, line: ");
        md.push_str(codegen_types.format_u64(line as u64).as_str());
        md.push_str(", type: !6)\n");
        self.debug_metadata.push(md);
        if had_temp { region_activate(self.fn_temp_region); }
        // Emit llvm.dbg.declare intrinsic call
        self.write("  call void @llvm.dbg.declare(metadata ptr ");
        self.write_cgname(alloca_name);
        self.write(", metadata !");
        self.write(codegen_types.format_u64(var_id as u64).as_str());
        self.write(", metadata !DIExpression())");
        self.end_insn();
    }

    /// Enter an unchecked block — suppress the specified checks.
    pub fn enter_unchecked(self: &mut CodegenCtx, checks: &Vec<ast.UncheckedCheck>) {
        for i in 0usize..checks.len() {
            let idx = unchecked_check_index(&checks[i]);
            self.unchecked_active[idx] = true;
        }
    }

    /// Exit an unchecked block — re-enable the specified checks.
    pub fn exit_unchecked(self: &mut CodegenCtx, checks: &Vec<ast.UncheckedCheck>) {
        for i in 0usize..checks.len() {
            let idx = unchecked_check_index(&checks[i]);
            self.unchecked_active[idx] = false;
        }
    }

    /// Returns true if the specified check is currently suppressed.
    pub fn is_check_suppressed(self: &CodegenCtx, check: &ast.UncheckedCheck) -> bool {
        let idx = unchecked_check_index(check);
        self.unchecked_active[idx]
    }

    /// Registers handler DefId → state field count mapping.
    pub fn register_handler_state_count(self: &mut CodegenCtx, handler_def_id: u32, state_count: u32) {
        self.handler_state_count_hash.insert(handler_def_id as u64, state_count);
    }

    /// Looks up the state field count for a handler DefId.
    /// Returns 0 if not registered.
    pub fn lookup_handler_state_count(self: &CodegenCtx, handler_def_id: u32) -> u32 {
        match self.handler_state_count_hash.get(handler_def_id as u64) {
            Option.Some(v) => v,
            Option.None => 0,
        }
    }

    /// Registers handler DefId → total state byte size mapping.
    pub fn register_handler_state_byte_size(self: &mut CodegenCtx, handler_def_id: u32, byte_size: u32) {
        self.handler_state_byte_size_hash.insert(handler_def_id as u64, byte_size);
    }

    /// Looks up the total state byte size for a handler DefId.
    /// Returns 0 if not registered.
    pub fn lookup_handler_state_byte_size(self: &CodegenCtx, handler_def_id: u32) -> u32 {
        match self.handler_state_byte_size_hash.get(handler_def_id as u64) {
            Option.Some(v) => v,
            Option.None => 0,
        }
    }

    /// Registers a state shadow alloca name for a handler.
    pub fn set_handler_state_shadow(self: &mut CodegenCtx, handler_def_id: u32, shadow_name: String) {
        self.handler_state_shadows.push(HandlerStateShadow {
            handler_def_id,
            shadow_name,
        });
    }

    /// Looks up the state shadow alloca name for a handler.
    /// Returns the most recent (last pushed) shadow for the handler_def_id.
    /// Sequential same-type handler instances push new shadows; the most
    /// recent one corresponds to the currently active instance.
    pub fn get_handler_state_shadow(self: &CodegenCtx, handler_def_id: u32) -> Option<&String> {
        let mut result: Option<&String> = Option.None;
        for i in 0usize..self.handler_state_shadows.len() {
            if self.handler_state_shadows[i].handler_def_id == handler_def_id {
                result = Option.Some(&self.handler_state_shadows[i].shadow_name);
            }
        }
        result
    }

    /// Resets per-function state while keeping global state (def_names).
    pub fn reset_function_state(self: &mut CodegenCtx) {
        self.output = String.new();
        self.indent_level = 0;
        self.value_counter = 0;
        self.label_counter = 0;
        self.local_names = Vec.new();
        self.local_types = Vec.new();
        self.local_signedness = Vec.new();
        self.current_fn = Option.None;
        self.current_span = Option.None;
        // Note: string_table and def_names are preserved
    }

    // ======== Output Management ========

    /// Writes a string to the output.
    pub fn write(self: &mut CodegenCtx, s: &str) {
        self.output.push_str(s);
    }

    /// Writes a String to the output.
    pub fn write_string(self: &mut CodegenCtx, s: &String) {
        self.output.push_str(s.as_str());
    }

    /// Writes a newline with current indentation.
    pub fn writeln(self: &mut CodegenCtx, s: &str) {
        self.write_indent();
        self.write(s);
        self.write("\n");
    }

    /// Writes a newline.
    pub fn newline(self: &mut CodegenCtx) {
        self.write("\n");
    }

    /// Writes current indentation.
    pub fn write_indent(self: &mut CodegenCtx) {
        for i in 0u32..self.indent_level {
            self.write("    ");
        }
    }

    /// Increases indentation level.
    pub fn indent(self: &mut CodegenCtx) {
        self.indent_level = self.indent_level + 1;
    }

    /// Decreases indentation level.
    pub fn dedent(self: &mut CodegenCtx) {
        if self.indent_level > 0 {
            self.indent_level = self.indent_level - 1;
        }
    }

    /// Writes a u64 as decimal digits directly to the output. No String allocation.
    pub fn write_u64(self: &mut CodegenCtx, n: u64) {
        if n == 0 {
            self.output.push('0');
            return;
        }
        // Find the highest power of 10 <= n
        let mut divisor: u64 = 1;
        let mut temp: u64 = n;
        while temp >= 10 {
            divisor *= 10;
            temp /= 10;
        }
        // Write digits from most significant to least
        let mut d: u64 = divisor;
        while d > 0 {
            let digit: u64 = (n / d) % 10;
            let d32: u32 = digit as u32;
            let ch: char = (48u32 + d32) as char;
            self.output.push(ch);
            d /= 10;
        }
    }

    /// Writes a CgName to the output without allocating any String.
    pub fn write_cgname(self: &mut CodegenCtx, name: &CgName) {
        match name {
            &CgName.Temp(n) => {
                self.write("%tmp");
                self.write_u64(n as u64);
            }
            &CgName.Local(n) => {
                self.write("%_");
                self.write_u64(n as u64);
            }
            &CgName.Label(n) => {
                self.write("label");
                self.write_u64(n as u64);
            }
            &CgName.Block(n) => {
                self.write("bb");
                self.write_u64(n as u64);
            }
            &CgName.Str(ref s) => {
                self.write(s.as_str());
            }
        }
    }

    /// Converts a CgName to a String representation for use at boundaries
    /// where String is required (e.g., llvm_args vectors).
    pub fn cgname_to_string(name: &CgName) -> String {
        match name {
            &CgName.Temp(n) => {
                let mut s = common.make_string("%tmp");
                let ns = codegen_types.format_u64(n as u64);
                s.push_str(ns.as_str());
                s
            }
            &CgName.Local(n) => {
                let mut s = common.make_string("%_");
                let ns = codegen_types.format_u64(n as u64);
                s.push_str(ns.as_str());
                s
            }
            &CgName.Label(n) => {
                let mut s = common.make_string("label");
                let ns = codegen_types.format_u64(n as u64);
                s.push_str(ns.as_str());
                s
            }
            &CgName.Block(n) => {
                let mut s = common.make_string("bb");
                let ns = codegen_types.format_u64(n as u64);
                s.push_str(ns.as_str());
                s
            }
            &CgName.Str(ref s) => {
                s.clone()
            }
        }
    }

    // ======== Buffered File I/O ========

    /// Sets the output file path for buffered streaming writes.
    pub fn set_output_path(self: &mut CodegenCtx, path: &str) {
        self.output_path = String.new();
        self.output_path.push_str(path);
    }

    /// Appends text to the write buffer. Flushes to disk when buffer exceeds 65536 bytes.
    pub fn buffer_write(self: &mut CodegenCtx, s: &str) {
        self.write_buffer.push_str(s);
        if self.write_buffer.len() > 65536 {
            self.flush_write_buffer();
        }
    }

    /// Flushes the write buffer to the output file.
    pub fn flush_write_buffer(self: &mut CodegenCtx) {
        if self.write_buffer.len() > 0 {
            file_append_string(self.output_path.as_str(), self.write_buffer.as_str());
            self.write_buffer = String.new();
        }
    }

    /// Writes an HIR type as LLVM IR directly to the output buffer.
    /// Uses the fast path (no String allocation) for common types,
    /// falls back to type_to_llvm for compound types.
    pub fn write_type(self: &mut CodegenCtx, ty: &hir_ty.Type) {
        match codegen_types.type_to_llvm_fast(ty) {
            Option.Some(s) => self.write(s),
            Option.None => {
                let s = codegen_types.type_to_llvm(ty);
                self.write(s.as_str());
            }
        }
    }

    /// Writes an HIR type as LLVM IR directly to the output buffer,
    /// using ADT registry lookups. No String allocation for common types.
    pub fn write_type_with_ctx(self: &mut CodegenCtx, ty: &hir_ty.Type) {
        match &ty.kind {
            &hir_ty.TypeKind.Adt { def_id, args: _ } => {
                let s = self.adt_llvm_type(def_id.index);
                self.write(s.as_str());
            }
            _ => self.write_type(ty),
        }
    }

    // ======== Value Names ========

    /// Generates a new unique temporary CgName. Zero allocation.
    pub fn fresh_temp_cg(self: &mut CodegenCtx) -> CgName {
        let n = self.value_counter;
        self.value_counter = self.value_counter + 1;
        CgName.Temp(n)
    }

    /// Generates a new unique label CgName. Zero allocation.
    pub fn fresh_label_cg(self: &mut CodegenCtx) -> CgName {
        let n = self.label_counter;
        self.label_counter = self.label_counter + 1;
        CgName.Label(n)
    }

    /// Returns a CgName for a basic block label. Zero allocation.
    pub fn block_label_cg(self: &CodegenCtx, block: mir_def.BasicBlockId) -> CgName {
        // When emitting an NTR body function (sub-task 4), any branch whose
        // target is OUTSIDE the body function's block set (e.g. pop_block or
        // post-scope code) is redirected. Two redirection targets:
        //
        //   - `body_fn_prepop` — for branches targeting THIS scope's
        //     pop_block when it has pre-PopHandler statements (sub-task
        //     3f-body). body_fn emits those statements under that label
        //     before falling through to body_fn_return.
        //   - `body_fn_return` — for every other out-of-body branch.
        //     body_fn's return trailer sets the normal-return flag and
        //     returns body's final value to mp_prompt_enter.
        //
        // This lets terminator emission stay unchanged while body_fn
        // terminates cleanly at every exit edge.
        if self.in_ntr_body_fn_scope_idx >= 0i32 {
            let idx = self.in_ntr_body_fn_scope_idx as usize;
            if idx < self.ntr_scopes.len() {
                let scope = &self.ntr_scopes[idx];
                if !scope.body_fn_contains_block(block) {
                    if block.index == scope.pop_block.index && scope.pop_pre_stmt_count > 0 {
                        return CgName.Str(common.make_string("body_fn_prepop"));
                    }
                    return CgName.Str(common.make_string("body_fn_return"));
                }
            }
        }
        CgName.Block(block.index)
    }

    /// Returns a CgName for a MIR local alloca.
    ///
    /// In body_fn mode (sub-task 4), a captured local is NOT a local alloca
    /// inside body_fn — its storage lives on the outer function's stack, and
    /// body_fn accesses it via a pointer loaded from the env struct at entry.
    /// For those, this returns the env-loaded pointer name (`%cap_<N>_ptr`).
    /// Non-capture locals emit the normal `%_<N>` — body_fn allocates those
    /// on its own gstack in its entry block.
    pub fn local_cg(self: &CodegenCtx, local: mir_def.MirLocalId) -> CgName {
        if self.in_ntr_body_fn_scope_idx >= 0i32 {
            let idx = self.in_ntr_body_fn_scope_idx as usize;
            if idx < self.ntr_scopes.len() {
                if self.ntr_scopes[idx].captures_local(local) {
                    let mut s = common.make_string("%cap_");
                    s.push_str(codegen_types.format_u64(local.index as u64).as_str());
                    s.push_str("_ptr");
                    return CgName.Str(s);
                }
            }
        }
        CgName.Local(local.index)
    }

    /// Gets the LLVM name for a MIR local.
    /// Gets a reference to the local's LLVM name. Zero allocation.
    /// Returns None if the local has no registered name (use local_cg() for %_N fallback).
    pub fn local_name_ref(self: &CodegenCtx, local: mir_def.MirLocalId) -> Option<&String> {
        match self.local_names_hash.get(local.index as u64) {
            Option.Some(idx) => {
                return Option.Some(&self.local_names[idx as usize].name);
            }
            Option.None => {}
        }
        Option.None
    }

    /// Registers a local with its LLVM name.
    pub fn register_local(self: &mut CodegenCtx, local: mir_def.MirLocalId, name: String) {
        let idx = self.local_names.len() as u32;
        self.local_names.push(LocalName {
            local_id: local.index,
            name: name,
        });
        self.local_names_hash.insert(local.index as u64, idx);
    }

    /// Registers a local with its LLVM type.
    pub fn register_local_type(self: &mut CodegenCtx, local: mir_def.MirLocalId, llvm_type: String) {
        let idx = self.local_types.len() as u32;
        self.local_types.push(LocalType {
            local_id: local.index,
            llvm_type: llvm_type,
        });
        self.local_types_hash.insert(local.index as u64, idx);
    }

    /// Gets the LLVM type for a MIR local.
    pub fn get_local_type(self: &CodegenCtx, local: mir_def.MirLocalId) -> String {
        // Fast path: hash lookup
        match self.local_types_hash.get(local.index as u64) {
            Option.Some(idx) => {
                return self.local_types[idx as usize].llvm_type.clone();
            }
            Option.None => {}
        }
        // Fallback: return i64 if type not found
        common.make_string("i64")
    }

    /// Gets the LLVM type for a MIR local as &str. Zero allocation.
    /// Returns "i64" if type not found.
    pub fn get_local_type_str(self: &CodegenCtx, local: mir_def.MirLocalId) -> &str {
        match self.local_types_hash.get(local.index as u64) {
            Option.Some(idx) => {
                self.local_types[idx as usize].llvm_type.as_str()
            }
            Option.None => "i64",
        }
    }

    /// Gets a reference to the local's LLVM type string. Zero allocation.
    /// Returns None if the local has no registered type.
    pub fn get_local_type_ref(self: &CodegenCtx, local: mir_def.MirLocalId) -> Option<&String> {
        match self.local_types_hash.get(local.index as u64) {
            Option.Some(idx) => {
                return Option.Some(&self.local_types[idx as usize].llvm_type);
            }
            Option.None => {}
        }
        Option.None
    }

    /// Registers a local with its signedness (true = signed, false = unsigned).
    pub fn register_local_signedness(self: &mut CodegenCtx, local: mir_def.MirLocalId, is_signed: bool) {
        let idx = self.local_signedness.len() as u32;
        self.local_signedness.push(LocalSignedness {
            local_id: local.index,
            is_signed: is_signed,
        });
        self.local_signedness_hash.insert(local.index as u64, idx);
    }

    /// Returns whether a local is signed. Defaults to true if not found.
    pub fn is_local_signed(self: &CodegenCtx, local: mir_def.MirLocalId) -> bool {
        // Fast path: hash lookup
        match self.local_signedness_hash.get(local.index as u64) {
            Option.Some(idx) => {
                return self.local_signedness[idx as usize].is_signed;
            }
            Option.None => {}
        }
        // Default to signed if not found
        true
    }

    /// Registers a local with its HIR type.
    pub fn register_local_hir_type(self: &mut CodegenCtx, local: mir_def.MirLocalId, hir_type: type_intern.TyId) {
        let idx = self.local_hir_types.len() as u32;
        self.local_hir_types.push(LocalHirType {
            local_id: local.index,
            hir_type: hir_type,
        });
        self.local_hir_types_hash.insert(local.index as u64, idx);
    }

    /// Gets the HIR type for a MIR local.
    pub fn get_local_hir_type(self: &CodegenCtx, local: mir_def.MirLocalId) -> Option<type_intern.TyId> {
        // Fast path: hash lookup
        match self.local_hir_types_hash.get(local.index as u64) {
            Option.Some(idx) => {
                return Option.Some(self.local_hir_types[idx as usize].hir_type);
            }
            Option.None => {}
        }
        Option.None
    }

    /// Marks a local as region-allocated (will be unregistered on StorageDead).
    /// gen_name is the LLVM alloca holding the i32 generation from blood_alloc_or_abort.
    pub fn mark_region_allocated(self: &mut CodegenCtx, local: mir_def.MirLocalId, gen_name: String) {
        let idx = self.region_locals.len() as u32;
        self.region_locals.push(RegionLocalEntry { local_id: local.index, gen_name: gen_name });
        self.region_locals_hash.insert(local.index as u64, idx);
    }

    /// Marks a local as persistent-allocated (will be decremented on StorageDead).
    pub fn mark_persistent_allocated(self: &mut CodegenCtx, local: mir_def.MirLocalId, slot_id_name: String, gen_name: String) {
        let idx = self.persistent_locals.len() as u32;
        self.persistent_locals.push(PersistentLocalEntry { local_id: local.index, slot_id_name: slot_id_name, gen_name: gen_name });
        self.persistent_locals_hash.insert(local.index as u64, idx);
    }

    /// Returns true if a local is region-allocated.
    pub fn is_region_allocated(self: &CodegenCtx, local: mir_def.MirLocalId) -> bool {
        self.region_locals_hash.contains_key(local.index as u64)
    }

    /// Returns true if the current function has ANY region/persistent/handler-state
    /// locals. Lets hot-path callers skip the three-hash-lookup escape check when
    /// the function has no escaped locals at all — the common case in selfhost.
    pub fn has_any_escaped_locals(self: &CodegenCtx) -> bool {
        self.region_locals.len() > 0
            || self.persistent_locals.len() > 0
            || self.handler_op_state_local >= 0
    }

    /// Returns the gen alloca name for a heap-allocated local (region or persistent),
    /// or None if the local is stack-allocated.
    pub fn get_heap_gen_name(self: &CodegenCtx, local: mir_def.MirLocalId) -> Option<&String> {
        match self.region_locals_hash.get(local.index as u64) {
            Option.Some(idx) => {
                return Option.Some(&self.region_locals[idx as usize].gen_name);
            }
            Option.None => {}
        }
        match self.persistent_locals_hash.get(local.index as u64) {
            Option.Some(idx) => {
                Option.Some(&self.persistent_locals[idx as usize].gen_name)
            }
            Option.None => Option.None,
        }
    }

    /// Returns true if a local is persistent-allocated.
    pub fn is_persistent_allocated(self: &CodegenCtx, local: mir_def.MirLocalId) -> bool {
        self.persistent_locals_hash.contains_key(local.index as u64)
    }

    /// Returns the slot_id alloca name for a persistent-allocated local.
    pub fn get_persistent_slot_id_name(self: &CodegenCtx, local: mir_def.MirLocalId) -> Option<&String> {
        match self.persistent_locals_hash.get(local.index as u64) {
            Option.Some(idx) => {
                let i: usize = (idx - 1) as usize;
                Option.Some(&self.persistent_locals[i].slot_id_name)
            }
            Option.None => Option.None,
        }
    }

    /// Returns true if a local is the handler op state pointer.
    /// When true, the local's alloca holds a `ptr` (not the value directly),
    /// and all loads/stores must go through the pointer indirection.
    pub fn is_handler_state_ptr(self: &CodegenCtx, local: mir_def.MirLocalId) -> bool {
        self.handler_op_state_local >= 0 && local.index == (self.handler_op_state_local as u32)
    }

    /// Returns true if a local is a handler state field (not the state pointer itself,
    /// but a secondary field accessed via GEP into the state struct).
    /// For state_field_count=2, local 2 is a state field (maps to field 1).
    /// Field 0 is accessed via *_1 (state pointer dereference).
    pub fn is_handler_state_field(self: &CodegenCtx, local: mir_def.MirLocalId) -> bool {
        if self.handler_op_state_field_count <= 1 {
            return false;
        }
        // State field locals: 2 through state_field_count (inclusive)
        // MIR _2 = field 1, MIR _3 = field 2, etc.
        local.index >= 2 && local.index <= self.handler_op_state_field_count
    }

    /// Returns the GEP field index for a handler state field local.
    /// Local 2 = field index 1, local 3 = field index 2, etc.
    pub fn handler_state_field_gep_index(self: &CodegenCtx, local: mir_def.MirLocalId) -> u32 {
        local.index - 1
    }

    /// Registers a DefId as a handler op body function.
    /// state_count is the number of state fields in the enclosing handler.
    pub fn register_handler_op_body(self: &mut CodegenCtx, def_id: u32, state_count: u32) {
        self.handler_op_body_hash.insert(def_id as u64, state_count);
        self.handler_op_body_ids.push(def_id);
    }

    /// Returns true if the given DefId is a handler op body function.
    pub fn is_handler_op_body(self: &CodegenCtx, def_id: u32) -> bool {
        self.handler_op_body_hash.contains_key(def_id as u64)
    }

    /// Records a handler op body's handled effect. Allows Resume codegen
    /// inside that body to ask is_mprompt_eligible_effect and branch
    /// between the ret-i64 fallthrough and the mprompt blood_resume path.
    pub fn register_handler_op_body_effect(self: &mut CodegenCtx, body_def_id: u32, effect_def_id: u32) {
        self.handler_op_body_effect_hash.insert(body_def_id as u64, effect_def_id);
        self.handler_op_body_effect_entries.push(HandlerOpBodyEffectEntry {
            body_def_id,
            effect_def_id,
        });
    }

    /// Returns the handled effect DefId for a handler op body, if one was
    /// registered. Returns None for functions that are not handler op bodies
    /// and for inline handler op bodies (which are not currently registered
    /// with an effect mapping — they fall through to the ret-i64 Resume path).
    pub fn handler_op_body_effect(self: &CodegenCtx, body_def_id: u32) -> Option<u32> {
        match self.handler_op_body_effect_hash.get(body_def_id as u64) {
            Option.Some(eid) => Option.Some(eid),
            Option.None => Option.None,
        }
    }

    /// Returns the number of state fields for a handler op body.
    /// Returns 0 if the handler has no state or the DefId is not a handler op.
    pub fn handler_op_state_count(self: &CodegenCtx, def_id: u32) -> u32 {
        match self.handler_op_body_hash.get(def_id as u64) {
            Option.Some(v) => v,
            Option.None => 0,
        }
    }

    /// Registers an (effect_def_id, op_name_symbol) → positional index mapping.
    pub fn register_op_def_index(self: &mut CodegenCtx, effect_def_id: u32, op_name_sym: u32, positional_index: u32) {
        self.op_def_index_entries.push(OpDefIndexEntry { effect_def_id, op_name_sym, positional_index });
        let key = ((effect_def_id as u64) << 32) | (op_name_sym as u64);
        self.op_def_index_hash.insert(key, positional_index);
    }

    /// Looks up the positional op_index for an (effect_def_id, op_name_symbol) pair.
    /// Returns 0 as fallback if not found.
    pub fn resolve_op_index(self: &CodegenCtx, effect_def_id: u32, op_name_sym: u32) -> u32 {
        let key = ((effect_def_id as u64) << 32) | (op_name_sym as u64);
        match self.op_def_index_hash.get(key) {
            Option.Some(idx) => idx,
            Option.None => 0,
        }
    }

    /// Clears all local names, types, and signedness (for reuse between functions).
    /// Uses Vec.new() / HashMap.new() instead of .clear() so allocations go to
    /// whichever region is currently active (enabling per-function temp region reset).
    pub fn clear_locals(self: &mut CodegenCtx) {
        self.local_names = Vec.new();
        self.local_types = Vec.new();
        self.local_signedness = Vec.new();
        self.local_hir_types = Vec.new();
        self.region_locals = Vec.new();
        self.persistent_locals = Vec.new();
        self.deferred_region_allocs = Vec.new();
        self.local_names_hash = hashmap.HashMapU64U32.new();
        self.local_types_hash = hashmap.HashMapU64U32.new();
        self.local_signedness_hash = hashmap.HashMapU64U32.new();
        self.local_hir_types_hash = hashmap.HashMapU64U32.new();
        self.region_locals_hash = hashmap.HashMapU64U32.new();
        self.persistent_locals_hash = hashmap.HashMapU64U32.new();
        self.effect_captured_locals = Vec.new();
        self.deferred_entry_allocas = Vec.new();
        self.handler_state_shadows = Vec.new();
        self.in_ntr_body_fn_scope_idx = -1i32;
        self.current_bb = mir_def.BasicBlockId.dummy();
        self.block_terminated_by_stmt = false;
        self.current_fn_def_id = 0;
    }

    // ======== Error Reporting ========

    /// Records a codegen error with the current function and span context.
    /// Deactivates temp region so error data persists across function resets.
    pub fn codegen_error(self: &mut CodegenCtx, kind: CodegenErrorKind, message: String) {
        let had_temp_err = self.fn_temp_region != 0;
        if had_temp_err { region_deactivate(); }
        let fn_name = match &self.current_fn {
            &Option.Some(ref name) => Option.Some(name.clone()),
            &Option.None => Option.None,
        };
        let span = match &self.current_span {
            &Option.Some(ref s) => Option.Some(*s),
            &Option.None => Option.None,
        };
        self.codegen_errors.push(CodegenError {
            kind: kind,
            message: message,
            fn_name: fn_name,
            span: span,
            notes: Vec.new(),
        });
        if had_temp_err { region_activate(self.fn_temp_region); }
    }

    /// Records a codegen error with the current context and an attached note.
    /// Deactivates temp region so error data persists across function resets.
    pub fn codegen_error_with_note(self: &mut CodegenCtx, kind: CodegenErrorKind, message: String, note: String) {
        let had_temp_err2 = self.fn_temp_region != 0;
        if had_temp_err2 { region_deactivate(); }
        let fn_name = match &self.current_fn {
            &Option.Some(ref name) => Option.Some(name.clone()),
            &Option.None => Option.None,
        };
        let span = match &self.current_span {
            &Option.Some(ref s) => Option.Some(*s),
            &Option.None => Option.None,
        };
        let mut notes = Vec.new();
        notes.push(CodegenNote.new(note));
        self.codegen_errors.push(CodegenError {
            kind: kind,
            message: message,
            fn_name: fn_name,
            span: span,
            notes: notes,
        });
        if had_temp_err2 { region_activate(self.fn_temp_region); }
    }

    /// Returns true if any codegen errors have been recorded.
    pub fn has_codegen_errors(self: &CodegenCtx) -> bool {
        self.codegen_errors.len() > 0
    }

    /// Takes ownership of accumulated errors, leaving the error list empty.
    pub fn take_errors(self: &mut CodegenCtx) -> Vec<CodegenError> {
        let mut errors: Vec<CodegenError> = Vec.new();
        for err in &self.codegen_errors {
            let fn_name = match &err.fn_name {
                &Option.Some(ref name) => Option.Some(name.clone()),
                &Option.None => Option.None,
            };
            let span = match &err.span {
                &Option.Some(ref s) => Option.Some(*s),
                &Option.None => Option.None,
            };
            let mut notes = Vec.new();
            for note in &err.notes {
                let note_span = match &note.span {
                    &Option.Some(ref s) => Option.Some(*s),
                    &Option.None => Option.None,
                };
                notes.push(CodegenNote {
                    message: note.message.clone(),
                    span: note_span,
                });
            }
            errors.push(CodegenError {
                kind: clone_error_kind(&err.kind),
                message: err.message.clone(),
                fn_name: fn_name,
                span: span,
                notes: notes,
            });
        }
        self.codegen_errors.clear();
        errors
    }

    /// Takes ownership of accumulated warnings, leaving the warning list empty.
    pub fn take_warnings(self: &mut CodegenCtx) -> Vec<String> {
        let mut warnings: Vec<String> = Vec.new();
        for i in 0usize..self.codegen_warnings.len() {
            warnings.push(self.codegen_warnings[i].clone());
        }
        self.codegen_warnings.clear();
        warnings
    }

    // ======== ADT Registry ========

    /// Registers a struct layout in the ADT registry.
    pub fn register_struct(self: &mut CodegenCtx, layout: StructLayout) {
        let idx = self.adt_registry.len() as u32;
        let did = layout.def_id;
        self.adt_registry.push(AdtEntry.Struct(layout));
        self.adt_struct_hash.insert(did as u64, idx);
    }

    /// Registers an enum layout in the ADT registry.
    pub fn register_enum(self: &mut CodegenCtx, layout: EnumLayout) {
        let idx = self.adt_registry.len() as u32;
        let did = layout.def_id;
        self.adt_registry.push(AdtEntry.Enum(layout));
        self.adt_enum_hash.insert(did as u64, idx);
    }

    /// Looks up a struct layout by DefId.
    /// Scans from the end so that later registrations (e.g., pass 2 with resolved
    /// nested ADT types) take precedence over earlier ones.
    pub fn lookup_struct(self: &CodegenCtx, def_id: u32) -> Option<&StructLayout> {
        match self.adt_struct_hash.get(def_id as u64) {
            Option.Some(idx) => {
                match &self.adt_registry[idx as usize] {
                    &AdtEntry.Struct(ref layout) => Option.Some(layout),
                    &AdtEntry.Enum(_) => Option.None,
                }
            }
            Option.None => Option.None,
        }
    }

    /// Looks up an enum layout by DefId.
    pub fn lookup_enum(self: &CodegenCtx, def_id: u32) -> Option<&EnumLayout> {
        match self.adt_enum_hash.get(def_id as u64) {
            Option.Some(idx) => {
                match &self.adt_registry[idx as usize] {
                    &AdtEntry.Enum(ref layout) => Option.Some(layout),
                    &AdtEntry.Struct(_) => Option.None,
                }
            }
            Option.None => Option.None,
        }
    }

    /// Looks up a struct field's HIR type by struct DefId and field index.
    pub fn lookup_field_hir_type(self: &CodegenCtx, def_id: u32, field_idx: u32) -> Option<type_intern.TyId> {
        match self.lookup_struct(def_id) {
            Option.Some(layout) => {
                if (field_idx as usize) < layout.fields.len() {
                    match &layout.fields[field_idx as usize].hir_type {
                        &Option.Some(ty_id) => Option.Some(ty_id),
                        &Option.None => Option.None,
                    }
                } else {
                    Option.None
                }
            }
            Option.None => Option.None,
        }
    }

    /// Gets the LLVM type for an ADT (struct or enum) by DefId.
    /// Returns "ptr" as fallback if not found in the registry.
    /// Scans from the end so that pass 2 entries (with resolved nested types)
    /// take precedence over pass 1 entries.
    pub fn adt_llvm_type(self: &CodegenCtx, def_id: u32) -> String {
        match self.adt_struct_hash.get(def_id as u64) {
            Option.Some(idx) => {
                match &self.adt_registry[idx as usize] {
                    &AdtEntry.Struct(ref layout) => { return layout.llvm_type.clone(); }
                    _ => {}
                }
            }
            Option.None => {}
        }
        match self.adt_enum_hash.get(def_id as u64) {
            Option.Some(idx) => {
                match &self.adt_registry[idx as usize] {
                    &AdtEntry.Enum(ref layout) => { return layout.llvm_type.clone(); }
                    _ => {}
                }
            }
            Option.None => {}
        }
        // Fallback: check if this is a known builtin ADT
        match self.lookup_def_name(def_id) {
            Option.Some(name) => {
                let name_bytes = name.as_bytes();
                // Vec -> { ptr, i64, i64 }
                if name_bytes.len() == 3 && name_bytes[0] == 86 && name_bytes[1] == 101 && name_bytes[2] == 99 {
                    return common.make_string("{ ptr, i64, i64 }");
                }
                // String -> { ptr, i64, i64 }
                if name_bytes.len() == 6 && name_bytes[0] == 83 && name_bytes[1] == 116 && name_bytes[2] == 114 {
                    return common.make_string("{ ptr, i64, i64 }");
                }
                // HashMap -> { ptr, i64, i64 }
                if name_bytes.len() == 7 && name_bytes[0] == 72 && name_bytes[1] == 97 && name_bytes[2] == 115 && name_bytes[3] == 104 {
                    return common.make_string("{ ptr, i64, i64 }");
                }
                // HashMapKeys -> { ptr, i64 }
                if name_bytes.len() == 11 && name_bytes[0] == 72 && name_bytes[7] == 75 && name_bytes[8] == 101 {
                    return common.make_string("{ ptr, i64 }");
                }
                // HashMapValues -> { ptr, i64 }
                if name_bytes.len() == 13 && name_bytes[0] == 72 && name_bytes[7] == 86 && name_bytes[8] == 97 {
                    return common.make_string("{ ptr, i64 }");
                }
                // Box -> ptr
                if name_bytes.len() == 3 && name_bytes[0] == 66 && name_bytes[1] == 111 && name_bytes[2] == 120 {
                    return common.make_string("ptr");
                }
                common.make_string("ptr")
            }
            Option.None => common.make_string("ptr"),
        }
    }

    /// Converts a type to LLVM IR, using the ADT registry for struct/enum types.
    /// This is the context-aware version that properly resolves ADT types.
    /// Falls back to `codegen_types.type_to_llvm` for non-ADT types.
    pub fn type_to_llvm_with_ctx(self: &CodegenCtx, ty: &hir_ty.Type) -> String {
        match &ty.kind {
            &hir_ty.TypeKind.Adt { def_id, args: _ } => {
                self.adt_llvm_type(def_id.index)
            }
            &hir_ty.TypeKind.Tuple(ref elems) => {
                if elems.len() == 0 {
                    common.make_string("{}")
                } else {
                    let mut result = common.make_string("{ ");
                    for i in 0usize..elems.len() {
                        if i > 0 {
                            result.push_str(", ");
                        }
                        let elem_str = self.type_to_llvm_with_ctx(&elems[i]);
                        result.push_str(elem_str.as_str());
                    }
                    result.push_str(" }");
                    result
                }
            }
            _ => codegen_types.type_to_llvm(ty),
        }
    }

    /// Generates the name for a MIR local alloca. In body_fn mode returns
    /// the env-loaded capture pointer name for captured locals; see
    /// `local_cg` for the rationale.
    pub fn local_alloca_name(self: &mut CodegenCtx, local: mir_def.MirLocalId) -> String {
        if self.in_ntr_body_fn_scope_idx >= 0i32 {
            let idx = self.in_ntr_body_fn_scope_idx as usize;
            if idx < self.ntr_scopes.len() {
                if self.ntr_scopes[idx].captures_local(local) {
                    let mut s = common.make_string("%cap_");
                    s.push_str(codegen_types.format_u64(local.index as u64).as_str());
                    s.push_str("_ptr");
                    return s;
                }
            }
        }
        let mut name = common.make_string("%_");
        let num_str = codegen_types.format_u64(local.index as u64);
        name.push_str(num_str.as_str());
        name
    }

    // ======== Block Labels ========

    // ======== Function Management ========

    /// Begins generating a new function.
    pub fn begin_function(self: &mut CodegenCtx, name: String) {
        self.current_fn = Option.Some(name.clone());
        self.current_span = Option.None;
        self.value_counter = 0;
        self.local_names.clear();
    }

    /// Ends the current function.
    pub fn end_function(self: &mut CodegenCtx) {
        self.current_fn = Option.None;
        self.current_span = Option.None;
    }

    /// Returns the current function name, or empty string if none.
    pub fn current_function(self: &CodegenCtx) -> String {
        match &self.current_fn {
            &Option.Some(ref name) => name.clone(),
            &Option.None => common.make_string(""),
        }
    }

    // ======== String Constants ========

    /// Adds a string constant to the table and returns its global label.
    /// When fn_temp_region is active, deactivates it so allocations go to
    /// the parent region (string_table must outlive per-function temp regions).
    pub fn add_string_constant(self: &mut CodegenCtx, content: &String) -> String {
        // Deactivate temp region so string_table allocations persist
        let had_temp = self.fn_temp_region != 0;
        if had_temp {
            region_deactivate();
        }

        // Fast path: check hash index
        let hash = hashmap.hash_string(content);
        match self.string_table_hash.get(hash) {
            Option.Some(idx) => {
                // Verify it's the same string (handle hash collisions)
                if string_equal(&self.string_table[idx as usize].content, content) {
                    let result = self.string_table[idx as usize].label.clone();
                    if had_temp { region_activate(self.fn_temp_region); }
                    return result;
                }
                // Hash collision - fall through to linear scan
            }
            Option.None => {
                // Definitely new, add it
                let n = self.string_counter;
                self.string_counter = self.string_counter + 1;
                let mut label = common.make_string("@.str.");
                let num_str = codegen_types.format_u64(n as u64);
                label.push_str(num_str.as_str());

                let length = content.len() + 1; // +1 for null terminator
                let idx = self.string_table.len() as u32;

                self.string_table.push(StringConstant {
                    label: label.clone(),
                    content: content.clone(),
                    length: length,
                });
                self.string_table_hash.insert(hash, idx);

                if had_temp { region_activate(self.fn_temp_region); }
                return label;
            }
        }

        // Hash collision case: linear scan
        for i in 0usize..self.string_table.len() {
            if string_equal(&self.string_table[i].content, content) {
                let result = self.string_table[i].label.clone();
                if had_temp { region_activate(self.fn_temp_region); }
                return result;
            }
        }

        // Not found, add new (collision case)
        let n = self.string_counter;
        self.string_counter = self.string_counter + 1;
        let mut label = common.make_string("@.str.");
        let num_str = codegen_types.format_u64(n as u64);
        label.push_str(num_str.as_str());

        let length = content.len() + 1;

        self.string_table.push(StringConstant {
            label: label.clone(),
            content: content.clone(),
            length: length,
        });

        if had_temp { region_activate(self.fn_temp_region); }
        label
    }

    /// Emits all string constants as global declarations.
    /// Should be called at the beginning of the module.
    pub fn emit_string_constants(self: &mut CodegenCtx) {
        for i in 0usize..self.string_table.len() {
            let entry = &self.string_table[i];
            // Emit: @.str.N = private unnamed_addr constant [M x i8] c"...\00"
            self.write_string(&entry.label);
            self.write(" = private unnamed_addr constant [");
            let len_str = codegen_types.format_u64(entry.length as u64);
            self.write_string(&len_str);
            self.write(" x i8] c\"");
            self.emit_string_literal_bytes(&entry.content);
            self.write("\\00\"\n");
        }
        if self.string_table.len() > 0 {
            self.newline();
        }
    }

    /// Returns the global label for a Frozen<T> layout descriptor describing the
    /// inner type at `ty_id_idx`. If no descriptor exists yet, creates a zero-entry
    /// placeholder (Phase 1 infrastructure; Phase 2 populates real field offsets).
    /// Deduplicated within a single CodegenCtx via `layout_by_ty_id`.
    pub fn add_layout_descriptor(self: &mut CodegenCtx, ty_id_idx: u32) -> String {
        // Deactivate per-function temp region so layout_table entries persist
        // in the codegen_region (same pattern as add_string_constant).
        let had_temp = self.fn_temp_region != 0;
        if had_temp {
            region_deactivate();
        }

        match self.layout_by_ty_id.get(ty_id_idx as u64) {
            Option.Some(idx) => {
                let result = self.layout_table[idx as usize].label.clone();
                if had_temp { region_activate(self.fn_temp_region); }
                return result;
            }
            Option.None => {
                let n = self.layout_counter;
                self.layout_counter = self.layout_counter + 1;
                let mut label = common.make_string("@blood_layout.");
                let num_str = codegen_types.format_u64(n as u64);
                label.push_str(num_str.as_str());

                let new_idx = self.layout_table.len() as u32;
                self.layout_table.push(LayoutDescriptor {
                    label: label.clone(),
                    ty_id_idx: ty_id_idx,
                    num_entries: 0,
                    entries: Vec.new(),
                    populated: false,
                });
                self.layout_by_ty_id.insert(ty_id_idx as u64, new_idx);

                if had_temp { region_activate(self.fn_temp_region); }
                return label;
            }
        }
    }

    /// Returns the label for an "indirect wrapper" layout descriptor: a
    /// descriptor with exactly one kind=3 entry at offset 0 pointing to the
    /// inner type's own layout. Used for Frozen<T> aggregates where T is
    /// stored by pointer (heap types / anything the compiler didn't inline).
    /// The walker reads the pointer at offset 0, freezes the pointee, and
    /// recurses with the inner layout.
    /// Dedup key is (t_ty_id_idx | 0x80000000) so wrappers don't collide
    /// with direct T descriptors. Caller is responsible for ensuring the
    /// inner T's descriptor exists and will be populated — pass its label
    /// via `inner_label`.
    pub fn add_indirect_layout_wrapper(
        self: &mut CodegenCtx,
        t_ty_id_idx: u32,
        inner_label: String,
    ) -> String {
        // Set the high bit of the u64 key so indirect wrappers dedup in their
        // own namespace, never colliding with direct T descriptors (whose
        // keys are 32-bit ty_id_idx values zero-extended into u64).
        let wrap_key: u64 = (t_ty_id_idx as u64) | 0x8000000000000000u64;
        match self.layout_by_ty_id.get(wrap_key) {
            Option.Some(idx) => {
                return self.layout_table[idx as usize].label.clone();
            }
            Option.None => {}
        }
        let had_temp = self.fn_temp_region != 0;
        if had_temp { region_deactivate(); }
        let n = self.layout_counter;
        self.layout_counter = self.layout_counter + 1;
        let mut label = common.make_string("@blood_layout.");
        let num_str = codegen_types.format_u64(n as u64);
        label.push_str(num_str.as_str());
        let new_idx = self.layout_table.len() as u32;
        let mut wrap_entries: Vec<LayoutEntry> = Vec.new();
        wrap_entries.push(LayoutEntry {
            offset: 0,
            kind: 3,
            inner_label: inner_label,
            element_size: 0,
        });
        self.layout_table.push(LayoutDescriptor {
            label: label.clone(),
            ty_id_idx: t_ty_id_idx,
            num_entries: 1,
            entries: wrap_entries,
            populated: true,
        });
        self.layout_by_ty_id.insert(wrap_key, new_idx);
        if had_temp { region_activate(self.fn_temp_region); }
        label
    }

    /// Emits all layout descriptors as module-level globals. Called once per
    /// module after per-function codegen finishes (batch and streaming paths).
    /// Each descriptor serializes as
    ///   { i32 num_entries, [N x { i32 offset, i32 kind, ptr inner_layout, i64 elem_size }] }
    /// with a zero-length array when num_entries==0 (A1 Phase 1 placeholder
    /// shape, still valid when A1 Phase 2 populates entries for types with
    /// no heap-owning fields). LLVM reserves 4 bytes of tail-padding after
    /// the i32 count so the 8-byte-aligned entry array starts at offset 8.
    pub fn emit_layout_descriptors(self: &mut CodegenCtx) {
        for i in 0usize..self.layout_table.len() {
            // Snapshot the count; we re-index fields below via self.layout_table[i].
            let n = self.layout_table[i].num_entries;
            let n_str = codegen_types.format_u64(n as u64);
            let label_clone = self.layout_table[i].label.clone();
            self.write_string(&label_clone);
            self.write(" = private unnamed_addr constant { i32, [");
            self.write_string(&n_str);
            self.write(" x { i32, i32, ptr, i64 }] } { i32 ");
            self.write_string(&n_str);
            self.write(", [");
            self.write_string(&n_str);
            self.write(" x { i32, i32, ptr, i64 }] ");
            if n == 0 {
                self.write("zeroinitializer }\n");
            } else {
                self.write("[");
                for e in 0u32..n {
                    if e > 0 { self.write(", "); }
                    let off = self.layout_table[i].entries[e as usize].offset;
                    let kind = self.layout_table[i].entries[e as usize].kind;
                    let esz = self.layout_table[i].entries[e as usize].element_size;
                    let inner_label = self.layout_table[i].entries[e as usize].inner_label.clone();
                    let off_str = codegen_types.format_u64(off as u64);
                    let kind_str = codegen_types.format_u64(kind as u64);
                    let esz_str = codegen_types.format_u64(esz);
                    self.write("{ i32, i32, ptr, i64 } { i32 ");
                    self.write_string(&off_str);
                    self.write(", i32 ");
                    self.write_string(&kind_str);
                    self.write(", ptr ");
                    if inner_label.len() == 0 {
                        self.write("null");
                    } else {
                        self.write_string(&inner_label);
                    }
                    self.write(", i64 ");
                    self.write_string(&esz_str);
                    self.write(" }");
                }
                self.write("] }\n");
            }
        }
        if self.layout_table.len() > 0 {
            self.newline();
        }
    }

    /// Emits a string literal as LLVM string bytes (escaping special chars).
    fn emit_string_literal_bytes(self: &mut CodegenCtx, s: &String) {
        let bytes = s.as_bytes();
        for i in 0usize..bytes.len() {
            let b = bytes[i];
            if b == 34 {
                // Quote "
                self.write("\\22");
            } else if b == 92 {
                // Backslash
                self.write("\\5C");
            } else if b == 10 {
                // Newline
                self.write("\\0A");
            } else if b == 13 {
                // Carriage return
                self.write("\\0D");
            } else if b == 9 {
                // Tab
                self.write("\\09");
            } else if b < 32 || b > 126 {
                // Non-printable - emit as hex
                self.write("\\");
                let hex = byte_to_hex(b);
                self.write_string(&hex);
            } else {
                // Printable character
                self.output.push(b as char);
            }
        }
    }


    // ======== Worker Context for Parallel Codegen ========

    /// Generates LLVM declare statements for all registered function signatures.
    /// Returns a Vec of (def_id, declare_string) pairs.
    /// Used by per-module split to emit cross-module forward declarations.
    pub fn generate_all_declares(self: &CodegenCtx) -> Vec<(u32, String)> {
        let mut result: Vec<(u32, String)> = Vec.with_capacity(self.fn_signatures.len());
        // Deduplicate: when cached + fresh sigs both exist for the same def_id,
        // fn_sigs_hash points to the latest entry. Only emit that one.
        let mut seen = hashmap.HashMapU64U32.with_capacity(self.fn_signatures.len());
        for i in 0usize..self.fn_signatures.len() {
            let sig = &self.fn_signatures[i];
            // Skip if we've already emitted a declare for this def_id
            match seen.get(sig.def_id as u64) {
                Option.Some(_) => { continue; }
                Option.None => {}
            }
            seen.insert(sig.def_id as u64, 1);
            let name_opt = self.lookup_def_name(sig.def_id);
            let name = match &name_opt {
                &Option.Some(ref n) => n,
                &Option.None => { continue; }
            };
            let mut decl = String.new();
            decl.push_str("declare ");
            decl.push_str(sig.return_type.as_str());
            decl.push_str(" @");
            decl.push_str(name.as_str());
            decl.push('(');
            for pi in 0usize..sig.param_types.len() {
                if pi > 0 {
                    decl.push_str(", ");
                }
                decl.push_str(sig.param_types[pi].as_str());
            }
            decl.push_str(")\n");
            result.push((sig.def_id, decl));
        }
        result
    }

    /// Serializes all function signatures to a tab-separated text format.
    /// Format: one line per function: def_id\tname\tret_type\tparam1\tparam2\t...
    pub fn serialize_fn_signatures(self: &CodegenCtx) -> String {
        let mut out = String.new();
        for i in 0usize..self.fn_signatures.len() {
            let sig = &self.fn_signatures[i];
            let name_opt = self.lookup_def_name(sig.def_id);
            let name = match &name_opt {
                &Option.Some(ref n) => n,
                &Option.None => { continue; }
            };
            out.push_str(codegen_types.format_u64(sig.def_id as u64).as_str());
            out.push('\t');
            out.push_str(name.as_str());
            out.push('\t');
            out.push_str(sig.return_type.as_str());
            for pi in 0usize..sig.param_types.len() {
                out.push('\t');
                out.push_str(sig.param_types[pi].as_str());
            }
            out.push('\n');
        }
        out
    }

    /// Loads function signatures from tab-separated text and registers them on this context.
    /// Used to restore cached signatures for unchanged modules during incremental builds.
    pub fn load_fn_signatures(self: &mut CodegenCtx, data: &str) {
        let bytes = data.as_bytes();
        let len = bytes.len();
        let mut pos: usize = 0;
        while pos < len {
            // Find end of line
            let line_start = pos;
            let mut line_end = pos;
            while line_end < len && bytes[line_end] != 10 { line_end += 1; }
            if line_end == line_start { pos = line_end + 1; continue; }

            // Parse tab-separated fields: def_id, name, ret_type, params...
            let mut fields: Vec<(usize, usize)> = Vec.new(); // (start, end) pairs
            let mut field_start = line_start;
            let mut fi = line_start;
            while fi <= line_end {
                if fi == line_end || bytes[fi] == 9 { // '\t' or end
                    fields.push((field_start, fi));
                    field_start = fi + 1;
                }
                fi += 1;
            }
            if fields.len() < 3 { pos = line_end + 1; continue; }

            // Field 0: def_id
            let mut def_id: u32 = 0;
            let mut di = fields[0].0;
            while di < fields[0].1 {
                if bytes[di] >= 48 && bytes[di] <= 57 {
                    def_id = def_id * 10 + ((bytes[di] - 48) as u32);
                }
                di += 1;
            }

            // Field 1: name
            let mut name = String.new();
            let mut ni = fields[1].0;
            while ni < fields[1].1 { name.push(bytes[ni] as char); ni += 1; }

            // Field 2: return type
            let mut ret_ty = String.new();
            let mut ri = fields[2].0;
            while ri < fields[2].1 { ret_ty.push(bytes[ri] as char); ri += 1; }

            // Fields 3+: param types
            let mut param_types: Vec<String> = Vec.new();
            for pi in 3usize..fields.len() {
                let mut pt = String.new();
                let mut pti = fields[pi].0;
                while pti < fields[pi].1 { pt.push(bytes[pti] as char); pti += 1; }
                if pt.len() > 0 {
                    param_types.push(pt);
                }
            }

            // Register name and signature
            self.register_def_name(def_id, name);
            self.register_fn_signature(def_id, param_types, ret_ty);

            pos = line_end + 1;
        }
    }

    /// Creates an isolated worker context that clones read-only state from the parent.
    /// Worker contexts have their own string table, counters, and per-function state.
    /// Used for parallel codegen: each thread gets a worker ctx, produces IR independently,
    /// then string tables are merged back into the parent.
    pub fn create_worker_ctx(self: &CodegenCtx) -> CodegenCtx {
        // Clone def_names (read-only during codegen)
        let mut worker_def_names: Vec<DefNameEntry> = Vec.new();
        let mut worker_def_hash = hashmap.HashMapU64U32.with_capacity(self.def_names.len());
        for i in 0usize..self.def_names.len() {
            let entry = &self.def_names[i];
            worker_def_names.push(DefNameEntry.new(entry.def_id, entry.name.clone()));
            worker_def_hash.insert(entry.def_id as u64, i as u32);
        }

        // Deep-clone adt_registry (read-only during codegen, but each thread needs its own copy)
        let mut worker_adt_registry: Vec<AdtEntry> = Vec.new();
        for ai in 0usize..self.adt_registry.len() {
            match &self.adt_registry[ai] {
                &AdtEntry.Struct(ref sl) => {
                    let mut cloned_fields: Vec<AdtFieldInfo> = Vec.new();
                    for fi in 0usize..sl.fields.len() {
                        let field = &sl.fields[fi];
                        cloned_fields.push(AdtFieldInfo {
                            llvm_type: field.llvm_type.clone(),
                            hir_type: field.hir_type,
                        });
                    }
                    worker_adt_registry.push(AdtEntry.Struct(StructLayout {
                        def_id: sl.def_id,
                        fields: cloned_fields,
                        llvm_type: sl.llvm_type.clone(),
                        is_packed: sl.is_packed,
                        align: sl.align,
                        is_union: sl.is_union,
                    }));
                }
                &AdtEntry.Enum(ref el) => {
                    let mut cloned_variants: Vec<VariantLayout> = Vec.new();
                    for vi in 0usize..el.variants.len() {
                        let variant = &el.variants[vi];
                        let mut cloned_vfields: Vec<AdtFieldInfo> = Vec.new();
                        for vfi in 0usize..variant.fields.len() {
                            let vf = &variant.fields[vfi];
                            cloned_vfields.push(AdtFieldInfo {
                                llvm_type: vf.llvm_type.clone(),
                                hir_type: vf.hir_type,
                            });
                        }
                        cloned_variants.push(VariantLayout {
                            variant_idx: variant.variant_idx,
                            fields: cloned_vfields,
                            payload_llvm_type: variant.payload_llvm_type.clone(),
                        });
                    }
                    worker_adt_registry.push(AdtEntry.Enum(EnumLayout {
                        def_id: el.def_id,
                        discriminant_type: el.discriminant_type.clone(),
                        variants: cloned_variants,
                        llvm_type: el.llvm_type.clone(),
                        max_payload_size: el.max_payload_size,
                    }));
                }
            }
        }

        // Populate ADT hash maps from the cloned registry.
        let mut worker_adt_struct_hash = hashmap.HashMapU64U32.with_capacity(worker_adt_registry.len());
        let mut worker_adt_enum_hash = hashmap.HashMapU64U32.with_capacity(worker_adt_registry.len());
        for ari in 0usize..worker_adt_registry.len() {
            match &worker_adt_registry[ari] {
                &AdtEntry.Struct(ref sl) => {
                    worker_adt_struct_hash.insert(sl.def_id as u64, ari as u32);
                }
                &AdtEntry.Enum(ref el) => {
                    worker_adt_enum_hash.insert(el.def_id as u64, ari as u32);
                }
            }
        }

        let mut worker = CodegenCtx {
            output: String.new(),
            indent_level: 0,
            value_counter: 0,
            label_counter: 0,
            local_names: Vec.new(),
            local_types: Vec.new(),
            local_signedness: Vec.new(),
            local_hir_types: Vec.new(),
            region_locals: Vec.new(),
            persistent_locals: Vec.new(),
            deferred_region_allocs: Vec.new(),
            current_fn: Option.None,
            string_table: Vec.new(),
            string_counter: 0,
            def_names: worker_def_names,
            adt_registry: worker_adt_registry,
            adt_struct_hash: worker_adt_struct_hash,
            adt_enum_hash: worker_adt_enum_hash,
            type_llvm_hash: hashmap.HashMapU64U32.new(),
            type_llvm_cache: Vec.new(),
            def_names_hash: worker_def_hash,
            local_names_hash: hashmap.HashMapU64U32.new(),
            local_types_hash: hashmap.HashMapU64U32.new(),
            local_signedness_hash: hashmap.HashMapU64U32.new(),
            local_hir_types_hash: hashmap.HashMapU64U32.new(),
            region_locals_hash: hashmap.HashMapU64U32.new(),
            persistent_locals_hash: hashmap.HashMapU64U32.new(),
            string_table_hash: hashmap.HashMapU64U32.new(),
            layout_table: Vec.new(),
            layout_counter: 0,
            layout_by_ty_id: hashmap.HashMapU64U32.new(),
            static_defs_hash: hashmap.HashMapU64U32.new(),
            static_types_hash: hashmap.HashMapU64U32.new(),
            static_hir_types_hash: hashmap.HashMapU64U32.new(),
            static_types: Vec.new(),
            const_defs_hash: hashmap.HashMapU64U32.new(),
            bridge_const_values: hashmap.HashMapU64U64.new(),
            foreign_defs_hash: hashmap.HashMapU64U32.new(),
            fn_signatures: Vec.new(),
            fn_sigs_hash: hashmap.HashMapU64U32.new(),
            fn_temp_region: 0 as u64,
            write_buffer: String.new(),
            output_path: String.new(),
            trace_codegen: self.trace_codegen,
            vft_dispatch: self.vft_dispatch,
            call_remaps: Vec.new(),
            handler_effect_entries: Vec.new(),
            handler_effect_hash: hashmap.HashMapU64U32.new(),
            handler_kind_hash: hashmap.HashMapU64U32.new(),
            handler_state_count_hash: hashmap.HashMapU64U32.new(),
            handler_state_byte_size_hash: hashmap.HashMapU64U32.new(),
            is_handler_op: false,
            handler_capture_locals: Vec.new(),
            handler_capture_tys: Vec.new(),
            inline_stubs: Vec.new(),
            inline_stub_count: 0,
            handler_depth: 0,
            handler_op_state_local: -1,
            handler_op_state_field_count: 0,
            current_handler_op_uses_mprompt_resume: false,
            handler_op_body_hash: hashmap.HashMapU64U32.new(),
            handler_op_body_ids: Vec.new(),
            handler_op_body_effect_hash: hashmap.HashMapU64U32.new(),
            handler_op_body_effect_entries: Vec.new(),
            op_def_index_hash: hashmap.HashMapU64U32.new(),
            op_def_index_entries: Vec.new(),
            handler_state_shadows: Vec.new(),
            codegen_errors: Vec.new(),
            codegen_warnings: Vec.new(),
            current_span: Option.None,
            fn_ptr_wrapper_hash: hashmap.HashMapU64U32.with_capacity(32),
            fn_ptr_wrapper_names: Vec.with_capacity(32),
            fn_ptr_wrapper_defs: Vec.with_capacity(32),
            vtable_defs: Vec.new(),
            vtable_hash: hashmap.HashMapU64U32.new(),
            vtable_layout_hash: hashmap.HashMapU64U32.new(),
            vtable_layouts: Vec.new(),
            trait_method_entries: Vec.new(),
            vtable_name_entries: Vec.new(),
            effect_captured_locals: Vec.new(),
            ntr_scopes: Vec.new(),
            in_ntr_body_fn_scope_idx: -1i32,
            current_bb: mir_def.BasicBlockId.dummy(),
            block_terminated_by_stmt: false,
            current_fn_def_id: 0,
            perform_liveness: Vec.new(),
            perform_liveness_locals: 0,
            active_regions: Vec.with_capacity(4),
            non_tail_resumptive_effects: hashmap.HashMapU64U32.new(),
            effect_has_resume_hash: hashmap.HashMapU64U32.new(),
            frozen_def_id: 0,
            string_def_id: 0,
            vec_def_id: 0,
            box_def_id: 0,
            tail_resumptive_ops: hashmap.HashMapU64U32.new(),
            abort_label_stack: Vec.new(),
            handler_abort_hash: hashmap.HashMapU64U32.new(),
            deferred_entry_allocas: Vec.new(),
            unchecked_active: vec_bool_5_false(),
            debug_subprogram_id: 0,
            debug_location_id: 0,
            debug_last_line: 0,
            debug_metadata_counter: 0,
            debug_metadata: Vec.new(),
            debug_source_file: String.new(),
        };

        // Copy handler_op_body_ids with state counts (read-only, needed to flag handler op bodies)
        for hbi in 0usize..self.handler_op_body_ids.len() {
            let hbi_def_id = self.handler_op_body_ids[hbi];
            let hbi_state_count = self.handler_op_state_count(hbi_def_id);
            worker.register_handler_op_body(hbi_def_id, hbi_state_count);
        }

        // Copy handler_op_body_effect entries so worker contexts can
        // resolve a handler op body's effect during Resume codegen.
        for hebi in 0usize..self.handler_op_body_effect_entries.len() {
            let hebe = &self.handler_op_body_effect_entries[hebi];
            worker.register_handler_op_body_effect(hebe.body_def_id, hebe.effect_def_id);
        }

        // Copy handler_effect_entries (read-only, needed during codegen)
        for hei in 0usize..self.handler_effect_entries.len() {
            let he = &self.handler_effect_entries[hei];
            worker.register_handler_effect(he.handler_def_id, he.effect_def_id);
            worker.register_handler_state_count(he.handler_def_id, self.lookup_handler_state_count(he.handler_def_id));
            worker.register_handler_state_byte_size(he.handler_def_id, self.lookup_handler_state_byte_size(he.handler_def_id));
            let kind_val = if self.handler_is_deep(he.handler_def_id) { 0u32 } else { 1u32 };
            worker.register_handler_kind(he.handler_def_id, kind_val);
        }

        // Copy non-tail-resumptive effect set (read-only, needed for PushHandler abort targets)
        for ntri in 0usize..self.handler_effect_entries.len() {
            let ntr_eid = self.handler_effect_entries[ntri].effect_def_id;
            if self.is_non_tail_resumptive_effect(ntr_eid) {
                worker.register_non_tail_resumptive_effect(ntr_eid);
            }
            // Copy effect-has-resume flag so workers agree with the main
            // context on mprompt eligibility (gates PushHandler's mprompt
            // path and emit_perform_ntr).
            if self.effect_has_resume(ntr_eid) {
                worker.register_effect_has_resume(ntr_eid);
            }
        }

        worker.frozen_def_id = self.frozen_def_id;
        worker.string_def_id = self.string_def_id;
        worker.vec_def_id = self.vec_def_id;
        worker.box_def_id = self.box_def_id;
        // Copy per-op tail-resumptive map (read-only, needed for Perform codegen)
        for odi2 in 0usize..self.op_def_index_entries.len() {
            let ode2 = &self.op_def_index_entries[odi2];
            if self.is_tail_resumptive_op(ode2.effect_def_id, ode2.op_name_sym) {
                worker.register_tail_resumptive_op(ode2.effect_def_id, ode2.op_name_sym);
            }
        }

        // Copy op_def_index_entries (read-only, needed for Perform op_index resolution)
        for odi in 0usize..self.op_def_index_entries.len() {
            let ode = &self.op_def_index_entries[odi];
            worker.register_op_def_index(ode.effect_def_id, ode.op_name_sym, ode.positional_index);
        }

        // Copy function signatures (read-only, needed at call sites)
        for fi in 0usize..self.fn_signatures.len() {
            let sig = &self.fn_signatures[fi];
            let mut cloned_params: Vec<String> = Vec.new();
            for pi in 0usize..sig.param_types.len() {
                let mut p = String.new();
                p.push_str(sig.param_types[pi].as_str());
                cloned_params.push(p);
            }
            let mut cloned_ret = String.new();
            cloned_ret.push_str(sig.return_type.as_str());
            worker.register_fn_signature(sig.def_id, cloned_params, cloned_ret);
        }

        // Copy static and const defs hashes (read-only)
        for si in 0usize..self.def_names.len() {
            let entry = &self.def_names[si];
            if self.is_static(entry.def_id) {
                worker.register_static(entry.def_id);
                match self.get_static_type(entry.def_id) {
                    Option.Some(ty) => {
                        worker.register_static_type(entry.def_id, ty);
                    }
                    Option.None => {}
                }
            }
            if self.is_const(entry.def_id) {
                worker.register_const(entry.def_id);
            }
            if self.is_foreign_def(entry.def_id) {
                worker.register_foreign_def(entry.def_id);
            }
        }

        worker
    }

    /// Returns the number of string constants in the string table.
    pub fn string_table_len(self: &CodegenCtx) -> usize {
        self.string_table.len()
    }

    /// Returns the content of the string constant at the given index.
    pub fn string_content_at(self: &CodegenCtx, index: usize) -> &String {
        &self.string_table[index].content
    }

    /// Returns the label of the string constant at the given index.
    pub fn string_label_at(self: &CodegenCtx, index: usize) -> &String {
        &self.string_table[index].label
    }
}

/// A string label remapping entry (from worker-local to final label).
pub struct StringRemap {
    /// The worker-local label (e.g., "@.str.0").
    pub from: String,
    /// The final label in the merged table (e.g., "@.str.42").
    pub to: String,
}

/// Merges a worker's string table into the main context's string table.
/// Returns a list of remappings (worker label -> final label) for any labels that changed.
/// String constants that already exist in the main table are deduplicated.
pub fn merge_string_tables(
    main_ctx: &mut CodegenCtx,
    worker_ctx: &CodegenCtx,
) -> Vec<StringRemap> {
    let mut remaps: Vec<StringRemap> = Vec.new();

    for i in 0usize..worker_ctx.string_table_len() {
        let content = worker_ctx.string_content_at(i);
        let worker_label = worker_ctx.string_label_at(i);

        // Add to main (deduplicates internally)
        let final_label = main_ctx.add_string_constant(content);

        // If the label changed, record the remapping
        if !string_equal(worker_label, &final_label) {
            remaps.push(StringRemap {
                from: worker_label.clone(),
                to: final_label,
            });
        }

    }

    remaps
}

/// Applies string label remappings to an IR string.
/// Replaces each occurrence of remap.from with remap.to.
/// Only needed when parallel codegen produces worker-local string labels.
pub fn remap_string_labels(ir: &String, remaps: &Vec<StringRemap>) -> String {
    if remaps.len() == 0 {
        return ir.clone();
    }

    let mut result = ir.clone();

    // Apply remappings. Since labels are unique (@.str.N), simple replacement is safe.
    // Process in reverse order of label number to avoid @.str.1 replacing part of @.str.10.
    let mut i: usize = remaps.len();
    while i > 0 {
        i -= 1;
        let remap = &remaps[i];
        result = string_replace(&result, &remap.from, &remap.to);
    }

    result
}

/// Extract the filename portion from a path (after last '/') into a String.
fn extract_filename_string(path: &str) -> String {
    let pb = path.as_bytes();
    let mut last_slash: i64 = -1;
    for i in 0usize..pb.len() {
        if pb[i] == 47 {
            last_slash = i as i64;
        }
    }
    let mut result = String.new();
    let start: usize = if last_slash >= 0 { (last_slash + 1) as usize } else { 0 };
    for i in start..pb.len() {
        let ch: char = pb[i] as char;
        result.push(ch);
    }
    result
}

/// Replaces all occurrences of `from` with `to` in `s`.
fn string_replace(s: &String, from: &String, to: &String) -> String {
    let s_bytes = s.as_bytes();
    let from_bytes = from.as_bytes();
    let to_bytes = to.as_bytes();
    let s_len = s_bytes.len();
    let from_len = from_bytes.len();

    if from_len == 0 || from_len > s_len {
        return s.clone();
    }

    let mut result = String.new();
    let mut i: usize = 0;

    while i < s_len {
        // Check if `from` starts at position i
        if i + from_len <= s_len {
            let mut matches = true;
            let mut j: usize = 0;
            while j < from_len {
                if s_bytes[i + j] != from_bytes[j] {
                    matches = false;
                    j = from_len; // break
                }
                j += 1;
            }
            if matches {
                // Append replacement
                for k in 0usize..to_bytes.len() {
                    result.push(to_bytes[k] as char);
                }
                i += from_len;
                continue;
            }
        }
        result.push(s_bytes[i] as char);
        i += 1;
    }

    result
}

// ============================================================
// String Helpers
// ============================================================

/// Clones a CodegenErrorKind.
pub fn clone_error_kind(kind: &CodegenErrorKind) -> CodegenErrorKind {
    match kind {
        &CodegenErrorKind.AdtLookupFailed => CodegenErrorKind.AdtLookupFailed,
        &CodegenErrorKind.FnLookupFailed => CodegenErrorKind.FnLookupFailed,
        &CodegenErrorKind.StaticLookupFailed => CodegenErrorKind.StaticLookupFailed,
        &CodegenErrorKind.TypeSubstitutionFailed => CodegenErrorKind.TypeSubstitutionFailed,
        &CodegenErrorKind.VariantLookupFailed => CodegenErrorKind.VariantLookupFailed,
        &CodegenErrorKind.EffectOpLookupFailed => CodegenErrorKind.EffectOpLookupFailed,
        &CodegenErrorKind.UnsupportedOperation => CodegenErrorKind.UnsupportedOperation,
        &CodegenErrorKind.TypeParseFailed => CodegenErrorKind.TypeParseFailed,
        &CodegenErrorKind.InternalError => CodegenErrorKind.InternalError,
    }
}

/// Converts a CodegenErrorKind to a human-readable category string.
pub fn error_kind_label(kind: &CodegenErrorKind) -> &str {
    match kind {
        &CodegenErrorKind.AdtLookupFailed => "ADT lookup failed",
        &CodegenErrorKind.FnLookupFailed => "function lookup failed",
        &CodegenErrorKind.StaticLookupFailed => "static lookup failed",
        &CodegenErrorKind.TypeSubstitutionFailed => "type substitution failed",
        &CodegenErrorKind.VariantLookupFailed => "variant lookup failed",
        &CodegenErrorKind.EffectOpLookupFailed => "effect operation lookup failed",
        &CodegenErrorKind.UnsupportedOperation => "unsupported operation",
        &CodegenErrorKind.TypeParseFailed => "type parse failed",
        &CodegenErrorKind.InternalError => "internal codegen error",
    }
}

/// Returns the error code string for a CodegenErrorKind.
pub fn error_kind_code(kind: &CodegenErrorKind) -> &str {
    match kind {
        &CodegenErrorKind.AdtLookupFailed => "E0800",
        &CodegenErrorKind.FnLookupFailed => "E0801",
        &CodegenErrorKind.StaticLookupFailed => "E0802",
        &CodegenErrorKind.TypeSubstitutionFailed => "E0803",
        &CodegenErrorKind.VariantLookupFailed => "E0804",
        &CodegenErrorKind.EffectOpLookupFailed => "E0805",
        &CodegenErrorKind.UnsupportedOperation => "E0806",
        &CodegenErrorKind.TypeParseFailed => "E0807",
        &CodegenErrorKind.InternalError => "E0808",
    }
}

/// Clones a String.
fn vec_bool_5_false() -> Vec<bool> {
    let mut v: Vec<bool> = Vec.with_capacity(5);
    v.push(false);
    v.push(false);
    v.push(false);
    v.push(false);
    v.push(false);
    v
}

fn unchecked_check_index(check: &ast.UncheckedCheck) -> usize {
    match check {
        &ast.UncheckedCheck.Bounds => 0,
        &ast.UncheckedCheck.Overflow => 1,
        &ast.UncheckedCheck.Generation => 2,
        &ast.UncheckedCheck.Null => 3,
        &ast.UncheckedCheck.Alignment => 4,
    }
}


/// Compares two strings for equality.
fn string_equal(a: &String, b: &String) -> bool {
    let a_bytes = a.as_bytes();
    let b_bytes = b.as_bytes();
    if a_bytes.len() != b_bytes.len() {
        return false;
    }
    for i in 0usize..a_bytes.len() {
        if a_bytes[i] != b_bytes[i] {
            return false;
        }
    }
    true
}

/// Converts a byte to a two-character hex string.
fn byte_to_hex(b: u8) -> String {
    let mut result = String.new();
    let high = (b >> 4) & 0xF;
    let low = b & 0xF;
    result.push(nibble_to_hex(high));
    result.push(nibble_to_hex(low));
    result
}

/// Converts a nibble (0-15) to a hex character.
fn nibble_to_hex(n: u8) -> char {
    if n < 10 {
        (48u8 + n) as char
    } else {
        (55u8 + n) as char
    }
}
