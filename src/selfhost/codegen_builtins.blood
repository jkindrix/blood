module blood.codegen_builtins;

// Blood Self-Hosted Compiler - Builtin Type Method Codegen
//
// Codegen for builtin type methods: Vec, String, str, Option, Box.
// These functions emit LLVM IR for runtime calls with special calling
// conventions that differ from the generic function call path.

mod codegen_ctx;
mod codegen_emit;
mod codegen_expr;
mod codegen_place;
mod codegen_types;
mod codegen_size;
mod common;
mod mir_types;
mod mir_def;
mod mir_body;
mod type_intern;

// ============================================================
// Utility Helpers (local copies — standard per-file pattern)
// ============================================================


pub fn cgname_to_string(name: &codegen_ctx.CgName) -> String {
    match name {
        &codegen_ctx.CgName.Temp(n) => {
            let mut s = common.make_string("%tmp");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Local(n) => {
            let mut s = common.make_string("%_");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Label(n) => {
            let mut s = common.make_string("label");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Block(n) => {
            let mut s = common.make_string("bb");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Str(ref s) => {
            s.clone()
        }
    }
}

pub fn string_eq_str(a: &str, b: &str) -> bool {
    let a_bytes = a.as_bytes();
    let b_bytes = b.as_bytes();
    if a_bytes.len() != b_bytes.len() {
        return false;
    }
    for i in 0usize..a_bytes.len() {
        if a_bytes[i] != b_bytes[i] {
            return false;
        }
    }
    true
}

/// Emits an operand as a bare pointer. If the operand is a gen ref { ptr, i32 },
/// extracts field 0 (the data pointer). Otherwise returns the value unchanged.
fn emit_operand_as_ptr(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
) -> String {
    let (val, ty) = codegen_expr.emit_operand_typed(ctx, operand);
    if string_eq_str(ty.as_str(), "{ ptr, i32 }") {
        let stripped = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&stripped);
        ctx.write(" = extractvalue { ptr, i32 } ");
        ctx.write_string(&val);
        ctx.write(", 0\n");
        return cgname_to_string(&stripped);
    }
    val
}

// ============================================================
// Builtin Type Method Codegen
// ============================================================

pub fn is_vec_new(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_new")
}

/// Checks if the function name is @vec_push.
pub fn is_vec_push(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_push")
}

/// Checks if the function name is @vec_len.
pub fn is_vec_len(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_len")
}

/// Checks if the function name is @vec_pop.
pub fn is_vec_pop(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_pop")
}

/// Checks if the function name is @vec_clear.
pub fn is_vec_clear(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_clear")
}

/// Checks if the function name is @vec_get.
pub fn is_vec_get(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_get")
}

/// Checks if the function name is @vec_with_capacity.
pub fn is_vec_with_capacity(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_with_capacity")
}

/// Emits a vec_with_capacity call with correct calling convention.
/// Runtime signature: void @vec_with_capacity(i64 elem_size, i64 capacity, ptr out_ptr)
///
/// Uses emit_place_data_ptr to handle region/persistent indirection.
pub fn emit_vec_with_capacity_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // Get data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get element size from the destination's HIR type (Vec<T>)
    // Must resolve through Place projections: if destination is _0.Field(5),
    // the local's type is the struct, not Vec<T>. We need the field's type.
    let elem_size: u64 = match resolve_place_hir_type(ctx, destination) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Get capacity from first argument
    let cap_val = codegen_expr.emit_operand(ctx, &args[0]);

    // Emit: call void @vec_with_capacity(i64 elem_size, i64 capacity, ptr out_ptr)
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.begin_call(Option.None, "void", "@vec_with_capacity");
    ctx.call_arg_str(true, "i64", elem_size_str.as_str());
    ctx.call_arg_str(false, "i64", cap_val.as_str());
    ctx.call_arg_str(false, "ptr", out_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Extracts element size from a Vec<T> / &Vec<T> / &&Vec<T> TyId (via interner,
/// no Type tree). Peels all `&` layers so receiver types from wrapper functions
/// — where MIR auto-refs an already-ref parameter into `&&Vec<T>` — resolve to
/// the correct element size. Symmetric to S90's `extract_hashmap_sizes` fix.
pub fn extract_vec_element_size_id(ctx: &mut codegen_ctx.CodegenCtx, ty_id: type_intern.TyId) -> u64 {
    let unwrapped = type_intern.unwrap_all_refs_id(ty_id);
    match type_intern.get_adt_args(unwrapped) {
        Option.Some(args) => {
            let interner = type_intern.type_interner();
            if interner.ty_list_len(args) > 0 {
                let elem_id = interner.get_ty_list_element(args, 0);
                codegen_size.type_size_with_ctx_id(ctx, elem_id)
            } else {
                8
            }
        }
        Option.None => 8,
    }
}

/// Resolves a Place's final HIR type by walking through projections.
/// For `_local.Field(5)`, returns the type of field 5 of the local's struct.
/// Falls back to the local's direct type if no projections or resolution fails.
pub fn resolve_place_hir_type(
    ctx: &mut codegen_ctx.CodegenCtx,
    place: &mir_types.Place,
) -> Option<type_intern.TyId> {
    let mut current_ty = match ctx.get_local_hir_type(place.local) {
        Option.Some(ty_id) => ty_id,
        Option.None => { return Option.None; }
    };
    for i in 0usize..place.projection.len() {
        match &place.projection[i] {
            &mir_types.PlaceElem.Field(idx) => {
                let unwrapped = type_intern.unwrap_ref_id(current_ty);
                match type_intern.get_adt_def_id(unwrapped) {
                    Option.Some(def_id) => {
                        match ctx.lookup_field_hir_type(def_id.index, idx) {
                            Option.Some(field_ty) => {
                                current_ty = field_ty;
                            }
                            Option.None => { return Option.Some(current_ty); }
                        }
                    }
                    Option.None => { return Option.Some(current_ty); }
                }
            }
            &mir_types.PlaceElem.Deref => {
                current_ty = type_intern.unwrap_ref_id(current_ty);
            }
            _ => {}
        }
    }
    Option.Some(current_ty)
}

/// Emits a vec_new call with correct calling convention.
/// Runtime signature: void @vec_new(i64 elem_size, ptr out_ptr)
///
/// Uses emit_place_data_ptr to handle region/persistent indirection.
pub fn emit_vec_new_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // Get data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get element size from the destination's HIR type (Vec<T>)
    // Must resolve through Place projections: if destination is _0.Field(5),
    // the local's type is the struct, not Vec<T>. We need the field's type.
    let elem_size: u64 = match resolve_place_hir_type(ctx, destination) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Emit: call void @vec_new(i64 elem_size, ptr out_ptr)
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.begin_call(Option.None, "void", "@vec_new");
    ctx.call_arg_str(true, "i64", elem_size_str.as_str());
    ctx.call_arg_str(false, "ptr", out_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_push call with correct calling convention.
/// Runtime signature: void @vec_push(ptr vec, ptr elem_ptr, i64 elem_size)
pub fn emit_vec_push_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&mut Vec<T>)
    // args[1] is the element (T)
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get element value and type
    let (elem_val, elem_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);

    // Save stack pointer before alloca so we can restore after vec_push.
    // Without this, allocas inside loops cause unbounded stack growth.
    let stack_save = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&stack_save);
    ctx.write(" = call ptr @llvm.stacksave()\n");

    // Allocate temporary storage for the element
    let elem_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&elem_alloca);
    ctx.write(" = alloca ");
    ctx.write_string(&elem_ty);
    ctx.write(", align 8\n");

    // Store element value to alloca
    ctx.emit_store_str_cg(elem_ty.as_str(), elem_val.as_str(), &elem_alloca);

    // Get element size from the element's HIR type
    let elem_size: u64 = match &args[1] {
        &mir_types.Operand.Copy(ref place) => {
            match ctx.get_local_hir_type(place.local) {
                Option.Some(ty_id) => {
                    codegen_size.type_size_with_ctx_id(ctx, ty_id)
                }
                Option.None => 8,
            }
        }
        &mir_types.Operand.Move(ref place) => {
            match ctx.get_local_hir_type(place.local) {
                Option.Some(ty_id) => {
                    codegen_size.type_size_with_ctx_id(ctx, ty_id)
                }
                Option.None => 8,
            }
        }
        &mir_types.Operand.Constant(ref c) => {
            codegen_size.type_size_with_ctx_id(ctx, c.ty)
        }
    };

    // Emit: call void @vec_push(ptr vec, ptr elem_ptr, i64 elem_size)
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.begin_call(Option.None, "void", "@vec_push");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.call_arg_cg(false, "ptr", &elem_alloca);
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.end_call();

    // Restore stack pointer to reclaim the alloca.
    // This prevents unbounded stack growth when vec_push is called in a loop.
    ctx.write_indent();
    ctx.write("call void @llvm.stackrestore(ptr ");
    ctx.write_cgname(&stack_save);
    ctx.write(")\n");

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_len call with correct calling convention.
/// Runtime signature: i64 @vec_len(ptr vec)
pub fn emit_vec_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&Vec<T>)
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call i64 @vec_len(ptr vec)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@vec_len");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_pop call with correct calling convention.
/// Runtime signature: i32 @vec_pop(ptr vec, i64 elem_size, ptr out_ptr)
/// Returns 1 on success (element popped), 0 if vec was empty.
pub fn emit_vec_pop_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&mut Vec<T>)
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get element size from destination's HIR type (Option<T>)
    // pop returns Option<T>, so we need to extract T's size
    let elem_size: u64 = match ctx.get_local_hir_type(destination.local) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Allocate output pointer for the popped element
    let out_alloca = ctx.fresh_temp_cg();
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.write_indent();
    ctx.write_cgname(&out_alloca);
    ctx.write(" = alloca [");
    ctx.write_string(&elem_size_str);
    ctx.write(" x i8], align 8\n");

    // Emit: %result = call i32 @vec_pop(ptr vec, i64 elem_size, ptr out_ptr)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i32", "@vec_pop");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.call_arg_cg(false, "ptr", &out_alloca);
    ctx.end_call();

    // Build Option<T> in destination
    // Option layout is { i32 tag, [N x i64] value } — tag is i32, NOT i8.
    // tag = 0 for None, tag = 1 for Some
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Store the tag as i32 (vec_pop returns i32: 0=empty/None, 1=success/Some)
    ctx.emit_store_cg("i32", &result, dest_ptr.as_str());

    // If result was 1 (Some), copy the element data
    // Calculate offset for the value field (after tag, with alignment)
    let value_offset = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&value_offset);
    ctx.write(" = getelementptr i8, ptr ");
    ctx.write_string(&dest_ptr);
    ctx.write(", i64 8\n"); // Assuming 8-byte alignment for Option payload

    // Copy element data from out_alloca to Option's value field
    ctx.write_indent();
    ctx.write("call void @llvm.memcpy.p0.p0.i64(ptr ");
    ctx.write_cgname(&value_offset);
    ctx.write(", ptr ");
    ctx.write_cgname(&out_alloca);
    ctx.write(", i64 ");
    ctx.write_string(&elem_size_str);
    ctx.write(", i1 false)\n");

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_clear call with correct calling convention.
/// Runtime signature: void @vec_clear(ptr vec)
pub fn emit_vec_clear_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&mut Vec<T>)
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: call void @vec_clear(ptr vec)
    ctx.begin_call(Option.None, "void", "@vec_clear");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_get call with correct calling convention. The Blood method
/// `Vec.get(&self, index: usize) -> Option<&T>` is dispatched via the runtime
/// `vec_get_ptr(ptr vec, i64 index, i64 elem_size) -> ptr` which returns a
/// pointer to the in-place element (or null on OOB). The result is wrapped in
/// `Option<&T>` with a generationally-tracked fat ref `{ ptr, i32 }` whose gen
/// comes from `blood_lazy_register_gen` on the buffer base — matching the
/// pattern used by `emit_string_as_str_call` (S51, A3 Step 4b) so that freeing
/// the buffer (e.g. via vec_ensure_cap's realloc) bumps the gen and stale `&T`
/// refs trip on deref.
///
/// Without this dedicated emitter, Vec.get falls through the generic dispatch
/// path and emits a call site that doesn't match the runtime ABI (S91).
pub fn emit_vec_get_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] = &Vec<T> (or &&Vec<T> in wrappers, due to MIR auto-ref of an
    // already-ref param); args[1] = usize index.
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Element size from the receiver type. extract_vec_element_size_id peels
    // all ref layers, so wrapper-call shapes (&&Vec<T>) resolve correctly.
    let elem_size: u64 = match get_arg_type(ctx, &args[0]) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };
    let elem_size_str = codegen_types.format_u64(elem_size);

    // Index value (usize -> i64 in Blood lowering).
    let idx_val = codegen_expr.emit_operand(ctx, &args[1]);

    // Call: %elem_ptr = call ptr @vec_get_ptr(ptr vec, i64 idx, i64 elem_size)
    let elem_ptr = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&elem_ptr), "ptr", "@vec_get_ptr");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.call_arg_str(false, "i64", idx_val.as_str());
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.end_call();

    // Read data buffer base address (Vec layout: { data: i64, len, cap } at
    // offset 0). Used for lazy gen registration so the returned &T's gen is
    // tied to the buffer's lifetime.
    let data_addr = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&data_addr);
    ctx.write(" = load i64, ptr ");
    ctx.write_string(&vec_ptr);
    ctx.write(", align 8\n");

    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Branch on null elem_ptr: null -> Option.None, non-null -> Option.Some.
    let is_null = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&is_null);
    ctx.write(" = icmp eq ptr ");
    ctx.write_cgname(&elem_ptr);
    ctx.write(", null\n");

    let some_label = ctx.fresh_label_cg();
    let none_label = ctx.fresh_label_cg();
    let end_label = ctx.fresh_label_cg();

    ctx.emit_cond_br_cg(&is_null, &none_label, &some_label);

    // Some path: register gen on buffer, build { ptr, i32 } fat ref, store
    // discriminant=1 + payload at dest+8.
    ctx.emit_label_cg(&some_label);
    let gen_val = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&gen_val), "i32", "@blood_lazy_register_gen");
    ctx.call_arg_cg(true, "i64", &data_addr);
    ctx.end_call();

    let ref0 = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&ref0);
    ctx.write(" = insertvalue { ptr, i32 } zeroinitializer, ptr ");
    ctx.write_cgname(&elem_ptr);
    ctx.write(", 0\n");
    let fat_ref = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&fat_ref);
    ctx.write(" = insertvalue { ptr, i32 } ");
    ctx.write_cgname(&ref0);
    ctx.write(", i32 ");
    ctx.write_cgname(&gen_val);
    ctx.write(", 1\n");

    ctx.write_indent();
    ctx.write("store i32 1, ptr ");
    ctx.write_string(&dest_ptr);
    ctx.write(", align 8\n");
    let payload_off = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&payload_off);
    ctx.write(" = getelementptr i8, ptr ");
    ctx.write_string(&dest_ptr);
    ctx.write(", i64 8\n");
    ctx.write_indent();
    ctx.write("store { ptr, i32 } ");
    ctx.write_cgname(&fat_ref);
    ctx.write(", ptr ");
    ctx.write_cgname(&payload_off);
    ctx.write(", align 8\n");
    ctx.emit_br_cg(&end_label);

    // None path: just write discriminant=0; payload bits irrelevant.
    ctx.emit_label_cg(&none_label);
    ctx.write_indent();
    ctx.write("store i32 0, ptr ");
    ctx.write_string(&dest_ptr);
    ctx.write(", align 8\n");
    ctx.emit_br_cg(&end_label);

    ctx.emit_label_cg(&end_label);

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Returns the HIR type of an Operand. Used by builtin emitters that need to
/// inspect the receiver/arg type for size or generic parameter extraction.
fn get_arg_type(
    ctx: &mut codegen_ctx.CodegenCtx,
    arg: &mir_types.Operand,
) -> Option<type_intern.TyId> {
    match arg {
        &mir_types.Operand.Copy(ref place) => ctx.get_local_hir_type(place.local),
        &mir_types.Operand.Move(ref place) => ctx.get_local_hir_type(place.local),
        &mir_types.Operand.Constant(ref c) => Option.Some(c.ty),
    }
}

// ============================================================
// String Builtin Handling
// ============================================================
// String runtime functions have special calling conventions:
//   string_new(ptr out_ptr) -> void
//   string_len(ptr self) -> i64
//   string_push(ptr self, i32 char) -> void
//   string_push_str(ptr self, ptr str_ref) -> void     (str_ref = ptr to {ptr, i64})
//   string_as_str(ptr self) -> {ptr, i64}
//   string_as_bytes(ptr self) -> {ptr, i64}

/// Checks if the function name is @string_new.
pub fn is_string_new(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_new")
}

/// Checks if the function name is @string_from.
pub fn is_string_from(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_from")
}

/// Checks if the function name is @string_with_capacity.
pub fn is_string_with_capacity(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_with_capacity")
}

/// Checks if the function name is @string_push_str.
pub fn is_string_push_str(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_push_str")
}

/// Checks if the function name is @string_len.
pub fn is_string_len(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_len")
}

/// Checks if the function name is @string_push.
pub fn is_string_push(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_push")
}

/// Checks if the function name is @string_as_str.
pub fn is_string_as_str(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_as_str")
}

/// Checks if the function name is @string_as_bytes.
pub fn is_string_as_bytes(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_as_bytes")
}

/// Emits a string_new call with correct calling convention.
/// Runtime signature: void @string_new(ptr out_ptr)
///
/// Emits a string_new call. Uses emit_place_data_ptr for region/persistent indirection.
pub fn emit_string_new_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // Get data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Emit: call void @string_new(ptr out_ptr)
    ctx.begin_call(Option.None, "void", "@string_new");
    ctx.call_arg_str(true, "ptr", out_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_from call with correct calling convention.
/// Runtime signature: void @string_from(ptr out_ptr, ptr str_ref)
pub fn emit_string_from_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get output data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get the &str argument (fat pointer) and stage into a stack temp,
    // because the runtime expects a pointer to BloodStr.
    let (arg_val, arg_ty) = codegen_expr.emit_operand_typed(ctx, &args[0]);
    let str_tmp = ctx.fresh_temp_cg();
    ctx.emit_alloca_cg(&str_tmp, "{ ptr, i64 }");
    ctx.emit_store_str_cg("{ ptr, i64 }", arg_val.as_str(), &str_tmp);

    // Emit: call void @string_from(ptr out_ptr, ptr str_tmp)
    ctx.begin_call(Option.None, "void", "@string_from");
    ctx.call_arg_str(true, "ptr", out_ptr.as_str());
    ctx.call_arg_cg(false, "ptr", &str_tmp);
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_with_capacity call with correct calling convention.
/// Runtime signature: void @string_with_capacity(ptr out_ptr, i64 cap)
pub fn emit_string_with_capacity_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get output data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get the usize arg (i64 at LLVM layer on x86_64).
    let (cap_val, cap_ty) = codegen_expr.emit_operand_typed(ctx, &args[0]);

    // Emit: call void @string_with_capacity(ptr out_ptr, i64 cap_val)
    ctx.begin_call(Option.None, "void", "@string_with_capacity");
    ctx.call_arg_str(true, "ptr", out_ptr.as_str());
    ctx.call_arg_str(false, "i64", cap_val.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_push_str call with correct calling convention.
/// Runtime signature: void @string_push_str(ptr self, ptr str_ref)
pub fn emit_string_push_str_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get the &str argument (fat pointer)
    let (arg_val, arg_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);

    // Alloca temp for the &str fat pointer (runtime expects ptr to BloodStr)
    let str_tmp = ctx.fresh_temp_cg();
    ctx.emit_alloca_cg(&str_tmp, "{ ptr, i64 }");

    // Store the &str value into the temp
    ctx.emit_store_str_cg("{ ptr, i64 }", arg_val.as_str(), &str_tmp);

    // Emit: call void @string_push_str(ptr self, ptr str_ptr)
    ctx.begin_call(Option.None, "void", "@string_push_str");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.call_arg_cg(false, "ptr", &str_tmp);
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_len call with correct calling convention.
/// Runtime signature: i64 @string_len(ptr self)
pub fn emit_string_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call i64 @string_len(ptr self)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@string_len");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_push call with correct calling convention.
/// Runtime signature: void @string_push(ptr self, i32 char)
pub fn emit_string_push_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get char argument - it may be { i32 } struct, need to extract i32
    let (char_val, char_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);

    // If char type is a struct { i32 }, extract the i32
    let char_i32 = if string_eq_str(char_ty.as_str(), "{ i32 }") {
        let extracted = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&extracted);
        ctx.write(" = extractvalue { i32 } ");
        ctx.write_string(&char_val);
        ctx.write(", 0\n");
        cgname_to_string(&extracted)
    } else {
        char_val
    };

    // Emit: call void @string_push(ptr self, i32 char)
    ctx.begin_call(Option.None, "void", "@string_push");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.call_arg_str(false, "i32", char_i32.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Extracts the generation value for a MIR operand's allocation.
/// Returns Some(gen_cgname) if the operand is a direct local with a gen alloca
/// (region or persistent tier), None otherwise (stack, constant, or deref'd).
fn extract_operand_gen(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> Option<codegen_ctx.CgName> {
    let place = match operand {
        &mir_types.Operand.Copy(ref p) => p,
        &mir_types.Operand.Move(ref p) => p,
        &mir_types.Operand.Constant(_) => { return Option.None; }
    };
    // Only direct locals (no projections) have trackable gen
    if place.projection.len() > 0 {
        return Option.None;
    }
    match ctx.get_heap_gen_name(place.local) {
        Option.Some(gen_name) => {
            let gen_tmp = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&gen_tmp);
            ctx.write(" = load i32, ptr ");
            ctx.write(gen_name.as_str());
            ctx.write("\n");
            Option.Some(gen_tmp)
        }
        Option.None => Option.None,
    }
}

/// Packs a generation value into the upper 32 bits of a { ptr, i64 } &str value.
/// Returns a new { ptr, i64 } with i64 = (gen << 32) | original_len.
/// If gen is None (stack/unknown), returns the original value unchanged.
fn pack_gen_into_str_result(
    ctx: &mut codegen_ctx.CodegenCtx,
    str_val: &codegen_ctx.CgName,
    generation: &Option<codegen_ctx.CgName>,
) -> codegen_ctx.CgName {
    match generation {
        &Option.None => {
            // No gen to pack — return as-is (gen bits are already 0)
            return codegen_ctx.CgName.Str(codegen_ctx.CodegenCtx.cgname_to_string(str_val));
        }
        &Option.Some(ref gen_val) => {
            // Extract ptr (field 0) and len (field 1) from original
            let orig_ptr = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&orig_ptr);
            ctx.write(" = extractvalue { ptr, i64 } ");
            ctx.write_cgname(str_val);
            ctx.write(", 0\n");
            let orig_len = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&orig_len);
            ctx.write(" = extractvalue { ptr, i64 } ");
            ctx.write_cgname(str_val);
            ctx.write(", 1\n");
            // Pack: (zext gen to i64) << 32 | len
            let gen_ext = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&gen_ext);
            ctx.write(" = zext i32 ");
            ctx.write_cgname(gen_val);
            ctx.write(" to i64\n");
            let gen_shifted = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&gen_shifted);
            ctx.write(" = shl i64 ");
            ctx.write_cgname(&gen_ext);
            ctx.write(", 32\n");
            let packed = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&packed);
            ctx.write(" = or i64 ");
            ctx.write_cgname(&gen_shifted);
            ctx.write(", ");
            ctx.write_cgname(&orig_len);
            ctx.write("\n");
            // Rebuild { ptr, i64 } with packed value
            let tmp1 = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&tmp1);
            ctx.write(" = insertvalue { ptr, i64 } zeroinitializer, ptr ");
            ctx.write_cgname(&orig_ptr);
            ctx.write(", 0\n");
            let tmp2 = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&tmp2);
            ctx.write(" = insertvalue { ptr, i64 } ");
            ctx.write_cgname(&tmp1);
            ctx.write(", i64 ");
            ctx.write_cgname(&packed);
            ctx.write(", 1\n");
            tmp2
        }
    }
}

/// Emits a string_as_str call with correct calling convention.
/// Runtime signature: { ptr, i64 } @string_as_str(ptr self)
pub fn emit_string_as_str_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call { ptr, i64 } @string_as_str(ptr self)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "{ ptr, i64 }", "@string_as_str");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.end_call();

    // Lazily register the data buffer in the gen hash table; free of the
    // underlying buffer (via blood_free_simple → unregister_allocation) bumps
    // the gen, so old &str references see a mismatch on deref.
    let data_ptr = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write_cgname(&result);
    ctx.write(", 0\n");
    let data_addr = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&data_addr);
    ctx.write(" = ptrtoint ptr ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" to i64\n");
    let data_gen = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&data_gen), "i32", "@blood_lazy_register_gen");
    ctx.call_arg_cg(true, "i64", &data_addr);
    ctx.end_call();
    let data_gen_opt = Option.Some(data_gen);

    let packed_result = pack_gen_into_str_result(ctx, &result, &data_gen_opt);

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("{ ptr, i64 }", &packed_result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_as_bytes call with correct calling convention.
/// Runtime signature: { ptr, i64 } @string_as_bytes(ptr self)
pub fn emit_string_as_bytes_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call { ptr, i64 } @string_as_bytes(ptr self)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "{ ptr, i64 }", "@string_as_bytes");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.end_call();

    // Lazily register the data buffer in the gen hash table; free of the
    // underlying buffer (via blood_free_simple → unregister_allocation) bumps
    // the gen, so old &[u8] references see a mismatch on deref. Mirrors
    // emit_string_as_str_call (S51, A3 Step 4b).
    let data_ptr = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write_cgname(&result);
    ctx.write(", 0\n");
    let data_addr = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&data_addr);
    ctx.write(" = ptrtoint ptr ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" to i64\n");
    let data_gen = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&data_gen), "i32", "@blood_lazy_register_gen");
    ctx.call_arg_cg(true, "i64", &data_addr);
    ctx.end_call();
    let data_gen_opt = Option.Some(data_gen);

    // Pack data buffer gen into the returned &[u8] (upper 32 bits of i64)
    let packed_result = pack_gen_into_str_result(ctx, &result, &data_gen_opt);

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("{ ptr, i64 }", &packed_result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

// ============================================================
// Option Builtin Handling
// ============================================================
// Option runtime functions have special calling conventions:
//   option_is_some(ptr self) -> i32
//   option_is_none(ptr self) -> i32
//   option_unwrap(ptr self, i64 elem_size, ptr out_ptr) -> void
//   option_as_ref(ptr self, i64 elem_size, ptr out_ptr) -> void

// ============================================================
// &str runtime functions have special calling conventions:
//   str_len({ ptr, i64 }) -> i64
//   str_eq({ ptr, i64 }, { ptr, i64 }) -> i1
//   str_concat({ ptr, i64 }, { ptr, i64 }) -> { ptr, i64 }
//
// The generic call path passes &str by pointer (creating &&str),
// but the runtime expects { ptr, i64 } by value. These handlers
// load the fat pointer from the pointer before calling.

pub fn is_str_len(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@str_len")
}

pub fn is_str_eq(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@str_eq")
}

pub fn is_str_concat(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@str_concat")
}

/// Helper: load a { ptr, i64 } fat pointer from a pointer operand.
/// The generic call path for &str methods produces a pointer to the
/// fat pointer alloca. This loads the actual { ptr, i64 } value.
pub fn load_str_fat_ptr(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> codegen_ctx.CgName {
    let (arg_val, arg_ty) = codegen_expr.emit_operand_typed(ctx, operand);
    // If it's already a { ptr, i64 }, return as-is
    if string_eq_str(arg_ty.as_str(), "{ ptr, i64 }") {
        return codegen_ctx.CgName.Str(arg_val);
    }
    // Gen ref { ptr, i32 } to &str: extract data ptr, then load { ptr, i64 }
    if string_eq_str(arg_ty.as_str(), "{ ptr, i32 }") {
        let data_ptr = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&data_ptr);
        ctx.write(" = extractvalue { ptr, i32 } ");
        ctx.write_string(&arg_val);
        ctx.write(", 0\n");
        let loaded = ctx.fresh_temp_cg();
        ctx.emit_load_cg2(&loaded, "{ ptr, i64 }", &data_ptr);
        return loaded;
    }
    // Otherwise it's a ptr — load the { ptr, i64 } from it
    let loaded = ctx.fresh_temp_cg();
    ctx.emit_load_cg(&loaded, "{ ptr, i64 }", arg_val.as_str());
    loaded
}

/// Emits gen validation for a { ptr, i64 } &str value.
/// Gen is packed in the upper 32 bits of field 1: i64 = (gen << 32) | len.
/// If gen != 0, validates against the gen registry. On failure, triggers
/// StaleReference effect. gen == 0 means static/stack ref — skip validation.
pub fn emit_str_gen_validation(ctx: &mut codegen_ctx.CodegenCtx, str_val: &codegen_ctx.CgName) {
    // Extract packed i64 from field 1
    let packed = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&packed);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write_cgname(str_val);
    ctx.write(", 1\n");
    // Extract gen from upper 32 bits: lshr 32, trunc to i32
    let gen_shifted = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&gen_shifted);
    ctx.write(" = lshr i64 ");
    ctx.write_cgname(&packed);
    ctx.write(", 32\n");
    let gen_val = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&gen_val);
    ctx.write(" = trunc i64 ");
    ctx.write_cgname(&gen_shifted);
    ctx.write(" to i32\n");
    // gen == 0 → skip validation (static/stack ref)
    let is_zero = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg2(&is_zero, "eq", "i32", &gen_val, "0");
    let skip_lbl = ctx.fresh_label_cg();
    let check_lbl = ctx.fresh_label_cg();
    ctx.emit_cond_br_cg(&is_zero, &skip_lbl, &check_lbl);
    // check: validate generation via registry
    ctx.emit_label_cg(&check_lbl);
    let data_ptr = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write_cgname(str_val);
    ctx.write(", 0\n");
    let addr_i64 = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&addr_i64);
    ctx.write(" = ptrtoint ptr ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" to i64\n");
    let valid = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&valid), "i32", "@blood_validate_generation");
    ctx.call_arg_cg(true, "i64", &addr_i64);
    ctx.call_arg_cg(false, "i32", &gen_val);
    ctx.end_call();
    let is_valid = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg2(&is_valid, "ne", "i32", &valid, "0");
    let ok_lbl = ctx.fresh_label_cg();
    let stale_lbl = ctx.fresh_label_cg();
    ctx.emit_cond_br_cg(&is_valid, &ok_lbl, &stale_lbl);
    // stale: trigger StaleReference effect
    ctx.emit_label_cg(&stale_lbl);
    let actual_gen = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&actual_gen), "i32", "@blood_get_generation");
    ctx.call_arg_cg(true, "i64", &addr_i64);
    ctx.end_call();
    ctx.begin_call(Option.None, "void", "@blood_perform_stale_ref");
    ctx.call_arg_cg(true, "i32", &gen_val);
    ctx.call_arg_cg(false, "i32", &actual_gen);
    ctx.end_call();
    ctx.write("  unreachable\n");
    // ok → skip: merge and continue
    ctx.emit_label_cg(&ok_lbl);
    ctx.emit_br_cg(&skip_lbl);
    ctx.emit_label_cg(&skip_lbl);
}

/// Emits a str_len call with correct calling convention.
/// Runtime signature: i64 @str_len({ ptr, i64 })
pub fn emit_str_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Load the &str fat pointer from the operand
    let str_val = load_str_fat_ptr(ctx, &args[0]);

    // Validate gen (packed in upper 32 bits of i64 field)
    emit_str_gen_validation(ctx, &str_val);

    // Emit: %result = call i64 @str_len({ ptr, i64 } %str_val)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@str_len");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &str_val);
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a str_eq call with correct calling convention.
/// Runtime signature: i1 @str_eq({ ptr, i64 }, { ptr, i64 })
pub fn emit_str_eq_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Load both &str fat pointers
    let str_a = load_str_fat_ptr(ctx, &args[0]);
    let str_b = load_str_fat_ptr(ctx, &args[1]);

    // Validate gen on both args (packed in upper 32 bits of i64 field)
    emit_str_gen_validation(ctx, &str_a);
    emit_str_gen_validation(ctx, &str_b);

    // Emit: %result = call i1 @str_eq({ ptr, i64 } %a, { ptr, i64 } %b)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &str_a);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &str_b);
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i1", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

