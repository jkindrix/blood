// Blood Self-Hosted Compiler - Builtin Type Method Codegen
//
// Codegen for builtin type methods: Vec, String, str, Option, Box.
// These functions emit LLVM IR for runtime calls with special calling
// conventions that differ from the generic function call path.

mod codegen_ctx;
mod codegen_emit;
mod codegen_expr;
mod codegen_place;
mod codegen_types;
mod codegen_size;
mod common;
mod mir_types;
mod mir_def;
mod mir_body;
mod type_intern;

// ============================================================
// Utility Helpers (local copies — standard per-file pattern)
// ============================================================

pub fn clone_string(s: &String) -> String {
    let mut result = String.new();
    result.push_str(s.as_str());
    result
}

pub fn cgname_to_string(name: &codegen_ctx.CgName) -> String {
    match name {
        &codegen_ctx.CgName.Temp(n) => {
            let mut s = common.make_string("%tmp");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Local(n) => {
            let mut s = common.make_string("%_");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Label(n) => {
            let mut s = common.make_string("label");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Block(n) => {
            let mut s = common.make_string("bb");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Str(ref s) => {
            clone_string(s)
        }
    }
}

pub fn string_eq_str(a: &str, b: &str) -> bool {
    let a_bytes = a.as_bytes();
    let b_bytes = b.as_bytes();
    if a_bytes.len() != b_bytes.len() {
        return false;
    }
    for i in 0usize..a_bytes.len() {
        if a_bytes[i] != b_bytes[i] {
            return false;
        }
    }
    true
}

/// Emits an operand as a bare pointer. If the operand is a gen ref { ptr, i32 },
/// extracts field 0 (the data pointer). Otherwise returns the value unchanged.
fn emit_operand_as_ptr(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
) -> String {
    let (val, ty) = codegen_expr.emit_operand_typed(ctx, operand);
    if string_eq_str(ty.as_str(), "{ ptr, i32 }") {
        let stripped = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&stripped);
        ctx.write(" = extractvalue { ptr, i32 } ");
        ctx.write_string(&val);
        ctx.write(", 0\n");
        return cgname_to_string(&stripped);
    }
    val
}

// ============================================================
// Builtin Type Method Codegen
// ============================================================

pub fn is_vec_new(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_new")
}

/// Checks if the function name is @vec_push.
pub fn is_vec_push(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_push")
}

/// Checks if the function name is @vec_len.
pub fn is_vec_len(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_len")
}

/// Checks if the function name is @vec_pop.
pub fn is_vec_pop(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_pop")
}

/// Checks if the function name is @vec_clear.
pub fn is_vec_clear(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_clear")
}

/// Checks if the function name is @vec_with_capacity.
pub fn is_vec_with_capacity(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@vec_with_capacity")
}

/// Emits a vec_with_capacity call with correct calling convention.
/// Runtime signature: void @vec_with_capacity(i64 elem_size, i64 capacity, ptr out_ptr)
///
/// Uses emit_place_data_ptr to handle region/persistent indirection.
pub fn emit_vec_with_capacity_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // Get data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get element size from the destination's HIR type (Vec<T>)
    // Must resolve through Place projections: if destination is _0.Field(5),
    // the local's type is the struct, not Vec<T>. We need the field's type.
    let elem_size: u64 = match resolve_place_hir_type(ctx, destination) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Get capacity from first argument
    let cap_val = codegen_expr.emit_operand(ctx, &args[0]);

    // Emit: call void @vec_with_capacity(i64 elem_size, i64 capacity, ptr out_ptr)
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.begin_call(Option.None, "void", "@vec_with_capacity");
    ctx.call_arg_str(true, "i64", elem_size_str.as_str());
    ctx.call_arg_str(false, "i64", cap_val.as_str());
    ctx.call_arg_str(false, "ptr", out_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Extracts element size from a Vec<T> or &Vec<T> TyId (via interner, no Type tree).
pub fn extract_vec_element_size_id(ctx: &mut codegen_ctx.CodegenCtx, ty_id: type_intern.TyId) -> u64 {
    let unwrapped = type_intern.unwrap_ref_id(ty_id);
    match type_intern.get_adt_args(unwrapped) {
        Option.Some(args) => {
            let interner = type_intern.type_interner();
            if interner.ty_list_len(args) > 0 {
                let elem_id = interner.get_ty_list_element(args, 0);
                codegen_size.type_size_with_ctx_id(ctx, elem_id)
            } else {
                8
            }
        }
        Option.None => 8,
    }
}

/// Resolves a Place's final HIR type by walking through projections.
/// For `_local.Field(5)`, returns the type of field 5 of the local's struct.
/// Falls back to the local's direct type if no projections or resolution fails.
pub fn resolve_place_hir_type(
    ctx: &mut codegen_ctx.CodegenCtx,
    place: &mir_types.Place,
) -> Option<type_intern.TyId> {
    let mut current_ty = match ctx.get_local_hir_type(place.local) {
        Option.Some(ty_id) => ty_id,
        Option.None => { return Option.None; }
    };
    for i in 0usize..place.projection.len() {
        match &place.projection[i] {
            &mir_types.PlaceElem.Field(idx) => {
                let unwrapped = type_intern.unwrap_ref_id(current_ty);
                match type_intern.get_adt_def_id(unwrapped) {
                    Option.Some(def_id) => {
                        match ctx.lookup_field_hir_type(def_id.index, idx) {
                            Option.Some(field_ty) => {
                                current_ty = field_ty;
                            }
                            Option.None => { return Option.Some(current_ty); }
                        }
                    }
                    Option.None => { return Option.Some(current_ty); }
                }
            }
            &mir_types.PlaceElem.Deref => {
                current_ty = type_intern.unwrap_ref_id(current_ty);
            }
            _ => {}
        }
    }
    Option.Some(current_ty)
}

/// Emits a vec_new call with correct calling convention.
/// Runtime signature: void @vec_new(i64 elem_size, ptr out_ptr)
///
/// Uses emit_place_data_ptr to handle region/persistent indirection.
pub fn emit_vec_new_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // Get data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get element size from the destination's HIR type (Vec<T>)
    // Must resolve through Place projections: if destination is _0.Field(5),
    // the local's type is the struct, not Vec<T>. We need the field's type.
    let elem_size: u64 = match resolve_place_hir_type(ctx, destination) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Emit: call void @vec_new(i64 elem_size, ptr out_ptr)
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.begin_call(Option.None, "void", "@vec_new");
    ctx.call_arg_str(true, "i64", elem_size_str.as_str());
    ctx.call_arg_str(false, "ptr", out_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_push call with correct calling convention.
/// Runtime signature: void @vec_push(ptr vec, ptr elem_ptr, i64 elem_size)
pub fn emit_vec_push_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&mut Vec<T>)
    // args[1] is the element (T)
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get element value and type
    let (elem_val, elem_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);

    // Save stack pointer before alloca so we can restore after vec_push.
    // Without this, allocas inside loops cause unbounded stack growth.
    let stack_save = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&stack_save);
    ctx.write(" = call ptr @llvm.stacksave()\n");

    // Allocate temporary storage for the element
    let elem_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&elem_alloca);
    ctx.write(" = alloca ");
    ctx.write_string(&elem_ty);
    ctx.write(", align 8\n");

    // Store element value to alloca
    ctx.emit_store_str_cg(elem_ty.as_str(), elem_val.as_str(), &elem_alloca);

    // Get element size from the element's HIR type
    let elem_size: u64 = match &args[1] {
        &mir_types.Operand.Copy(ref place) => {
            match ctx.get_local_hir_type(place.local) {
                Option.Some(ty_id) => {
                    codegen_size.type_size_with_ctx_id(ctx, ty_id)
                }
                Option.None => 8,
            }
        }
        &mir_types.Operand.Move(ref place) => {
            match ctx.get_local_hir_type(place.local) {
                Option.Some(ty_id) => {
                    codegen_size.type_size_with_ctx_id(ctx, ty_id)
                }
                Option.None => 8,
            }
        }
        &mir_types.Operand.Constant(ref c) => {
            codegen_size.type_size_with_ctx_id(ctx, c.ty)
        }
    };

    // Emit: call void @vec_push(ptr vec, ptr elem_ptr, i64 elem_size)
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.begin_call(Option.None, "void", "@vec_push");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.call_arg_cg(false, "ptr", &elem_alloca);
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.end_call();

    // Restore stack pointer to reclaim the alloca.
    // This prevents unbounded stack growth when vec_push is called in a loop.
    ctx.write_indent();
    ctx.write("call void @llvm.stackrestore(ptr ");
    ctx.write_cgname(&stack_save);
    ctx.write(")\n");

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_len call with correct calling convention.
/// Runtime signature: i64 @vec_len(ptr vec)
pub fn emit_vec_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&Vec<T>)
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call i64 @vec_len(ptr vec)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@vec_len");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a vec_pop call with correct calling convention.
/// Runtime signature: i32 @vec_pop(ptr vec, i64 elem_size, ptr out_ptr)
/// Returns 1 on success (element popped), 0 if vec was empty.
pub fn emit_vec_pop_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the vec (&mut Vec<T>)
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get vec pointer - strip gen ref if present (FFI expects bare ptr).
    let vec_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get element size from destination's HIR type (Option<T>)
    // pop returns Option<T>, so we need to extract T's size
    let elem_size: u64 = match ctx.get_local_hir_type(destination.local) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Allocate output pointer for the popped element
    let out_alloca = ctx.fresh_temp_cg();
    let elem_size_str = codegen_types.format_u64(elem_size);
    ctx.write_indent();
    ctx.write_cgname(&out_alloca);
    ctx.write(" = alloca [");
    ctx.write_string(&elem_size_str);
    ctx.write(" x i8], align 8\n");

    // Emit: %result = call i32 @vec_pop(ptr vec, i64 elem_size, ptr out_ptr)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i32", "@vec_pop");
    ctx.call_arg_str(true, "ptr", vec_ptr.as_str());
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.call_arg_cg(false, "ptr", &out_alloca);
    ctx.end_call();

    // Build Option<T> in destination
    // Option is typically { i8 tag, T value }
    // tag = 0 for None, tag = 1 for Some
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Store the tag (result from vec_pop: 0=empty/None, 1=success/Some)
    let tag_i8 = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&tag_i8);
    ctx.write(" = trunc i32 ");
    ctx.write_cgname(&result);
    ctx.write(" to i8\n");
    ctx.emit_store_cg("i8", &tag_i8, dest_ptr.as_str());

    // If result was 1 (Some), copy the element data
    // Calculate offset for the value field (after tag, with alignment)
    let value_offset = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&value_offset);
    ctx.write(" = getelementptr i8, ptr ");
    ctx.write_string(&dest_ptr);
    ctx.write(", i64 8\n"); // Assuming 8-byte alignment for Option payload

    // Copy element data from out_alloca to Option's value field
    ctx.write_indent();
    ctx.write("call void @llvm.memcpy.p0.p0.i64(ptr ");
    ctx.write_cgname(&value_offset);
    ctx.write(", ptr ");
    ctx.write_cgname(&out_alloca);
    ctx.write(", i64 ");
    ctx.write_string(&elem_size_str);
    ctx.write(", i1 false)\n");

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

