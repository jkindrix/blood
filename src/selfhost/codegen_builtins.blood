// ============================================================
// String Builtin Handling
// ============================================================
// String runtime functions have special calling conventions:
//   string_new(ptr out_ptr) -> void
//   string_len(ptr self) -> i64
//   string_push(ptr self, i32 char) -> void
//   string_push_str(ptr self, ptr str_ref) -> void     (str_ref = ptr to {ptr, i64})
//   string_as_str(ptr self) -> {ptr, i64}
//   string_as_bytes(ptr self) -> {ptr, i64}

/// Checks if the function name is @string_new.
pub fn is_string_new(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_new")
}

/// Checks if the function name is @string_push_str.
pub fn is_string_push_str(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_push_str")
}

/// Checks if the function name is @string_len.
pub fn is_string_len(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_len")
}

/// Checks if the function name is @string_push.
pub fn is_string_push(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_push")
}

/// Checks if the function name is @string_as_str.
pub fn is_string_as_str(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_as_str")
}

/// Checks if the function name is @string_as_bytes.
pub fn is_string_as_bytes(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@string_as_bytes")
}

/// Emits a string_new call with correct calling convention.
/// Runtime signature: void @string_new(ptr out_ptr)
///
/// Emits a string_new call. Uses emit_place_data_ptr for region/persistent indirection.
pub fn emit_string_new_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // Get data pointer (handles region/persistent heap indirection)
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Emit: call void @string_new(ptr out_ptr)
    ctx.begin_call(Option.None, "void", "@string_new");
    ctx.call_arg_str(true, "ptr", out_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_push_str call with correct calling convention.
/// Runtime signature: void @string_push_str(ptr self, ptr str_ref)
pub fn emit_string_push_str_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get the &str argument (fat pointer)
    let (arg_val, arg_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);

    // Alloca temp for the &str fat pointer (runtime expects ptr to BloodStr)
    let str_tmp = ctx.fresh_temp_cg();
    ctx.emit_alloca_cg(&str_tmp, "{ ptr, i64 }");

    // Store the &str value into the temp
    ctx.emit_store_str_cg("{ ptr, i64 }", arg_val.as_str(), &str_tmp);

    // Emit: call void @string_push_str(ptr self, ptr str_ptr)
    ctx.begin_call(Option.None, "void", "@string_push_str");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.call_arg_cg(false, "ptr", &str_tmp);
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_len call with correct calling convention.
/// Runtime signature: i64 @string_len(ptr self)
pub fn emit_string_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call i64 @string_len(ptr self)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@string_len");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_push call with correct calling convention.
/// Runtime signature: void @string_push(ptr self, i32 char)
pub fn emit_string_push_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get char argument - it may be { i32 } struct, need to extract i32
    let (char_val, char_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);

    // If char type is a struct { i32 }, extract the i32
    let char_i32 = if string_eq_str(char_ty.as_str(), "{ i32 }") {
        let extracted = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&extracted);
        ctx.write(" = extractvalue { i32 } ");
        ctx.write_string(&char_val);
        ctx.write(", 0\n");
        cgname_to_string(&extracted)
    } else {
        char_val
    };

    // Emit: call void @string_push(ptr self, i32 char)
    ctx.begin_call(Option.None, "void", "@string_push");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.call_arg_str(false, "i32", char_i32.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Extracts the generation value for a MIR operand's allocation.
/// Returns Some(gen_cgname) if the operand is a direct local with a gen alloca
/// (region or persistent tier), None otherwise (stack, constant, or deref'd).
fn extract_operand_gen(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> Option<codegen_ctx.CgName> {
    let place = match operand {
        &mir_types.Operand.Copy(ref p) => p,
        &mir_types.Operand.Move(ref p) => p,
        &mir_types.Operand.Constant(_) => { return Option.None; }
    };
    // Only direct locals (no projections) have trackable gen
    if place.projection.len() > 0 {
        return Option.None;
    }
    match ctx.get_heap_gen_name(place.local) {
        Option.Some(gen_name) => {
            let gen_tmp = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&gen_tmp);
            ctx.write(" = load i32, ptr ");
            ctx.write(gen_name.as_str());
            ctx.write("\n");
            Option.Some(gen_tmp)
        }
        Option.None => Option.None,
    }
}

/// Packs a generation value into the upper 32 bits of a { ptr, i64 } &str value.
/// Returns a new { ptr, i64 } with i64 = (gen << 32) | original_len.
/// If gen is None (stack/unknown), returns the original value unchanged.
fn pack_gen_into_str_result(
    ctx: &mut codegen_ctx.CodegenCtx,
    str_val: &codegen_ctx.CgName,
    generation: &Option<codegen_ctx.CgName>,
) -> codegen_ctx.CgName {
    match generation {
        &Option.None => {
            // No gen to pack — return as-is (gen bits are already 0)
            return codegen_ctx.CgName.Str(codegen_ctx.CodegenCtx.cgname_to_string(str_val));
        }
        &Option.Some(ref gen_val) => {
            // Extract ptr (field 0) and len (field 1) from original
            let orig_ptr = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&orig_ptr);
            ctx.write(" = extractvalue { ptr, i64 } ");
            ctx.write_cgname(str_val);
            ctx.write(", 0\n");
            let orig_len = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&orig_len);
            ctx.write(" = extractvalue { ptr, i64 } ");
            ctx.write_cgname(str_val);
            ctx.write(", 1\n");
            // Pack: (zext gen to i64) << 32 | len
            let gen_ext = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&gen_ext);
            ctx.write(" = zext i32 ");
            ctx.write_cgname(gen_val);
            ctx.write(" to i64\n");
            let gen_shifted = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&gen_shifted);
            ctx.write(" = shl i64 ");
            ctx.write_cgname(&gen_ext);
            ctx.write(", 32\n");
            let packed = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&packed);
            ctx.write(" = or i64 ");
            ctx.write_cgname(&gen_shifted);
            ctx.write(", ");
            ctx.write_cgname(&orig_len);
            ctx.write("\n");
            // Rebuild { ptr, i64 } with packed value
            let tmp1 = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&tmp1);
            ctx.write(" = insertvalue { ptr, i64 } zeroinitializer, ptr ");
            ctx.write_cgname(&orig_ptr);
            ctx.write(", 0\n");
            let tmp2 = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&tmp2);
            ctx.write(" = insertvalue { ptr, i64 } ");
            ctx.write_cgname(&tmp1);
            ctx.write(", i64 ");
            ctx.write_cgname(&packed);
            ctx.write(", 1\n");
            tmp2
        }
    }
}

/// Emits a string_as_str call with correct calling convention.
/// Runtime signature: { ptr, i64 } @string_as_str(ptr self)
pub fn emit_string_as_str_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Extract gen from self operand's allocation (if region/persistent)
    let self_gen = extract_operand_gen(ctx, &args[0]);

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call { ptr, i64 } @string_as_str(ptr self)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "{ ptr, i64 }", "@string_as_str");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.end_call();

    // Pack gen into the returned &str (upper 32 bits of i64 field)
    let packed_result = pack_gen_into_str_result(ctx, &result, &self_gen);

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("{ ptr, i64 }", &packed_result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a string_as_bytes call with correct calling convention.
/// Runtime signature: { ptr, i64 } @string_as_bytes(ptr self)
pub fn emit_string_as_bytes_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Extract gen from self operand's allocation (if region/persistent)
    let self_gen = extract_operand_gen(ctx, &args[0]);

    // Get string pointer - strip gen ref if present (FFI expects bare ptr).
    let str_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Emit: %result = call { ptr, i64 } @string_as_bytes(ptr self)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "{ ptr, i64 }", "@string_as_bytes");
    ctx.call_arg_str(true, "ptr", str_ptr.as_str());
    ctx.end_call();

    // Pack gen into the returned &[u8] (upper 32 bits of i64 field)
    let packed_result = pack_gen_into_str_result(ctx, &result, &self_gen);

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("{ ptr, i64 }", &packed_result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

// ============================================================
// Option Builtin Handling
// ============================================================
// Option runtime functions have special calling conventions:
//   option_is_some(ptr self) -> i32
//   option_is_none(ptr self) -> i32
//   option_unwrap(ptr self, i64 elem_size, ptr out_ptr) -> void
//   option_as_ref(ptr self, i64 elem_size, ptr out_ptr) -> void

// ============================================================
// &str runtime functions have special calling conventions:
//   str_len({ ptr, i64 }) -> i64
//   str_eq({ ptr, i64 }, { ptr, i64 }) -> i1
//   str_concat({ ptr, i64 }, { ptr, i64 }) -> { ptr, i64 }
//
// The generic call path passes &str by pointer (creating &&str),
// but the runtime expects { ptr, i64 } by value. These handlers
// load the fat pointer from the pointer before calling.

pub fn is_str_len(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@str_len")
}

pub fn is_str_eq(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@str_eq")
}

pub fn is_str_concat(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@str_concat")
}

/// Helper: load a { ptr, i64 } fat pointer from a pointer operand.
/// The generic call path for &str methods produces a pointer to the
/// fat pointer alloca. This loads the actual { ptr, i64 } value.
pub fn load_str_fat_ptr(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> codegen_ctx.CgName {
    let (arg_val, arg_ty) = codegen_expr.emit_operand_typed(ctx, operand);
    // If it's already a { ptr, i64 }, return as-is
    if string_eq_str(arg_ty.as_str(), "{ ptr, i64 }") {
        return codegen_ctx.CgName.Str(arg_val);
    }
    // Gen ref { ptr, i32 } to &str: extract data ptr, then load { ptr, i64 }
    if string_eq_str(arg_ty.as_str(), "{ ptr, i32 }") {
        let data_ptr = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&data_ptr);
        ctx.write(" = extractvalue { ptr, i32 } ");
        ctx.write_string(&arg_val);
        ctx.write(", 0\n");
        let loaded = ctx.fresh_temp_cg();
        ctx.emit_load_cg2(&loaded, "{ ptr, i64 }", &data_ptr);
        return loaded;
    }
    // Otherwise it's a ptr — load the { ptr, i64 } from it
    let loaded = ctx.fresh_temp_cg();
    ctx.emit_load_cg(&loaded, "{ ptr, i64 }", arg_val.as_str());
    loaded
}

/// Emits gen validation for a { ptr, i64 } &str value.
/// Gen is packed in the upper 32 bits of field 1: i64 = (gen << 32) | len.
/// If gen != 0, validates against the gen registry. On failure, triggers
/// StaleReference effect. gen == 0 means static/stack ref — skip validation.
pub fn emit_str_gen_validation(ctx: &mut codegen_ctx.CodegenCtx, str_val: &codegen_ctx.CgName) {
    // Extract packed i64 from field 1
    let packed = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&packed);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write_cgname(str_val);
    ctx.write(", 1\n");
    // Extract gen from upper 32 bits: lshr 32, trunc to i32
    let gen_shifted = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&gen_shifted);
    ctx.write(" = lshr i64 ");
    ctx.write_cgname(&packed);
    ctx.write(", 32\n");
    let gen_val = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&gen_val);
    ctx.write(" = trunc i64 ");
    ctx.write_cgname(&gen_shifted);
    ctx.write(" to i32\n");
    // gen == 0 → skip validation (static/stack ref)
    let is_zero = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg2(&is_zero, "eq", "i32", &gen_val, "0");
    let skip_lbl = ctx.fresh_label_cg();
    let check_lbl = ctx.fresh_label_cg();
    ctx.emit_cond_br_cg(&is_zero, &skip_lbl, &check_lbl);
    // check: validate generation via registry
    ctx.emit_label_cg(&check_lbl);
    let data_ptr = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write_cgname(str_val);
    ctx.write(", 0\n");
    let addr_i64 = ctx.fresh_temp_cg();
    ctx.write("  ");
    ctx.write_cgname(&addr_i64);
    ctx.write(" = ptrtoint ptr ");
    ctx.write_cgname(&data_ptr);
    ctx.write(" to i64\n");
    let valid = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&valid), "i32", "@blood_validate_generation");
    ctx.call_arg_cg(true, "i64", &addr_i64);
    ctx.call_arg_cg(false, "i32", &gen_val);
    ctx.end_call();
    let is_valid = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg2(&is_valid, "ne", "i32", &valid, "0");
    let ok_lbl = ctx.fresh_label_cg();
    let stale_lbl = ctx.fresh_label_cg();
    ctx.emit_cond_br_cg(&is_valid, &ok_lbl, &stale_lbl);
    // stale: trigger StaleReference effect
    ctx.emit_label_cg(&stale_lbl);
    let actual_gen = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&actual_gen), "i32", "@blood_get_generation");
    ctx.call_arg_cg(true, "i64", &addr_i64);
    ctx.end_call();
    ctx.begin_call(Option.None, "void", "@blood_perform_stale_ref");
    ctx.call_arg_cg(true, "i32", &gen_val);
    ctx.call_arg_cg(false, "i32", &actual_gen);
    ctx.end_call();
    ctx.write("  unreachable\n");
    // ok → skip: merge and continue
    ctx.emit_label_cg(&ok_lbl);
    ctx.emit_br_cg(&skip_lbl);
    ctx.emit_label_cg(&skip_lbl);
}

/// Emits a str_len call with correct calling convention.
/// Runtime signature: i64 @str_len({ ptr, i64 })
pub fn emit_str_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Load the &str fat pointer from the operand
    let str_val = load_str_fat_ptr(ctx, &args[0]);

    // Validate gen (packed in upper 32 bits of i64 field)
    emit_str_gen_validation(ctx, &str_val);

    // Emit: %result = call i64 @str_len({ ptr, i64 } %str_val)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@str_len");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &str_val);
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a str_eq call with correct calling convention.
/// Runtime signature: i1 @str_eq({ ptr, i64 }, { ptr, i64 })
pub fn emit_str_eq_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Load both &str fat pointers
    let str_a = load_str_fat_ptr(ctx, &args[0]);
    let str_b = load_str_fat_ptr(ctx, &args[1]);

    // Validate gen on both args (packed in upper 32 bits of i64 field)
    emit_str_gen_validation(ctx, &str_a);
    emit_str_gen_validation(ctx, &str_b);

    // Emit: %result = call i1 @str_eq({ ptr, i64 } %a, { ptr, i64 } %b)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &str_a);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &str_b);
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i1", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits a str_concat call with correct calling convention.
/// Runtime signature: { ptr, i64 } @str_concat({ ptr, i64 }, { ptr, i64 })
pub fn emit_str_concat_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 {
        ctx.emit_unreachable();
        return;
    }

    // Load both &str fat pointers
    let str_a = load_str_fat_ptr(ctx, &args[0]);
    let str_b = load_str_fat_ptr(ctx, &args[1]);

    // Validate gen on both args (packed in upper 32 bits of i64 field)
    emit_str_gen_validation(ctx, &str_a);
    emit_str_gen_validation(ctx, &str_b);

    // Emit: %result = call { ptr, i64 } @str_concat({ ptr, i64 } %a, { ptr, i64 } %b)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "{ ptr, i64 }", "@str_concat");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &str_a);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &str_b);
    ctx.end_call();

    // Store result to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("{ ptr, i64 }", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Checks if the function name is @option_is_some.
pub fn is_option_is_some(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@option_is_some")
}

/// Checks if the function name is @option_is_none.
pub fn is_option_is_none(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@option_is_none")
}

/// Checks if the function name is @option_unwrap.
pub fn is_option_unwrap(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@option_unwrap")
}

/// Checks if the function name is @option_as_ref.
pub fn is_option_as_ref(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@option_as_ref")
}

// ============================================================
// Box runtime functions have special calling conventions:
//   box_new(ptr value_ptr, i64 value_size) -> ptr

/// Checks if the function name is @box_new.
pub fn is_box_new(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@box_new")
}

/// Emits a box_new call with correct calling convention.
/// Runtime signature: ptr @box_new(ptr value_ptr, i64 value_size)
///
/// The generic call path passes the value by-value (as an LLVM aggregate),
/// which LLVM decomposes into register-sized chunks per ABI. box_new expects
/// a pointer to the value and its size. This handler stores the value to a
/// temp alloca and passes (ptr, i64) correctly.
pub fn emit_box_new_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is the value to box (type T)
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get value and its LLVM type
    let (val, val_ty) = codegen_expr.emit_operand_typed(ctx, &args[0]);

    // Allocate temporary storage for the value
    let val_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&val_alloca);
    ctx.write(" = alloca ");
    ctx.write_string(&val_ty);
    ctx.write(", align 8\n");

    // Store value to alloca
    ctx.emit_store_str_cg(val_ty.as_str(), val.as_str(), &val_alloca);

    // Get value size from HIR type
    let val_size: u64 = match &args[0] {
        &mir_types.Operand.Copy(ref place) => {
            match ctx.get_local_hir_type(place.local) {
                Option.Some(ty_id) => {
                    codegen_size.type_size_with_ctx_id(ctx, ty_id)
                }
                Option.None => 8,
            }
        }
        &mir_types.Operand.Move(ref place) => {
            match ctx.get_local_hir_type(place.local) {
                Option.Some(ty_id) => {
                    codegen_size.type_size_with_ctx_id(ctx, ty_id)
                }
                Option.None => 8,
            }
        }
        &mir_types.Operand.Constant(ref c) => {
            codegen_size.type_size_with_ctx_id(ctx, c.ty)
        }
    };

    // Emit: %result = call ptr @box_new(ptr val_alloca, i64 val_size)
    let result = ctx.fresh_temp_cg();
    let val_size_str = codegen_types.format_u64(val_size);
    ctx.begin_call(Option.Some(&result), "ptr", "@box_new");
    ctx.call_arg_cg(true, "ptr", &val_alloca);
    ctx.call_arg_str(false, "i64", val_size_str.as_str());
    ctx.end_call();

    // Store result pointer to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("ptr", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Checks if the function name is @box_as_ref.
pub fn is_box_as_ref(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@box_as_ref")
}

/// Emits a box_as_ref call with correct calling convention.
/// Runtime signature: ptr @box_as_ref(ptr boxed) -> ptr
///
/// MIR method calls auto-borrow the receiver, so args[0] is &Box<T> (a pointer
/// to the variable holding the Box pointer). We must load through it once to get
/// the actual Box value (the data pointer) before passing to box_as_ref.
pub fn emit_box_as_ref_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    // args[0] is &Box<T> — a reference to the Box variable
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Emit the operand as bare pointer (strip gen ref if present)
    let ref_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Load through the reference to get the Box value (the data pointer)
    let box_val = ctx.fresh_temp_cg();
    ctx.emit_load_cg2(&box_val, "ptr", &codegen_ctx.CgName.Str(ref_ptr));

    // Emit: %result = call ptr @box_as_ref(ptr box_val)
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "ptr", "@box_as_ref");
    ctx.call_arg_cg(true, "ptr", &box_val);
    ctx.end_call();

    // Store result pointer to destination
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("ptr", &result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

pub fn is_persist(func_val: &String) -> bool {
    string_eq_str(func_val.as_str(), "@persist")
}

/// Emits a persist() call — copies the argument value into the destination.
/// The destination local was already allocated as persistent (ptr to heap buffer)
/// by emit_allocas_with_escapes, so this is just a value copy through the heap pointer.
pub fn emit_persist_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Evaluate the argument
    let (arg_val, arg_ty) = codegen_expr.emit_operand_typed(ctx, &args[0]);

    // Get the destination data pointer (for persistent locals, this loads the heap ptr)
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Store the value through the persistent buffer pointer
    if !string_eq_str(arg_ty.as_str(), "{}") {
        ctx.emit_store(arg_ty.as_str(), arg_val.as_str(), dest_ptr.as_str());
    }

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits an inline is_some check using i32 discriminant.
/// Standard enum convention: None = discriminant 0, Some = discriminant 1.
/// Discriminant type is i32, matching the enum layout (codegen.blood:662).
pub fn emit_option_is_some_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get option pointer - strip gen ref if present (FFI expects bare ptr).
    let opt_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Load i32 discriminant (enum discriminant type is always i32)
    let disc = ctx.fresh_temp_cg();
    ctx.emit_load_cg(&disc, "i32", opt_ptr.as_str());

    // is_some = (discriminant == 1), since Some is variant index 1
    let cmp_result = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg2(&cmp_result, "eq", "i32", &disc, "1");

    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i1", &cmp_result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits an inline is_none check using i32 discriminant.
/// Standard enum convention: None = discriminant 0, Some = discriminant 1.
/// Discriminant type is i32, matching the enum layout (codegen.blood:662).
pub fn emit_option_is_none_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get option pointer - strip gen ref if present (FFI expects bare ptr).
    let opt_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Load i32 discriminant (enum discriminant type is always i32)
    let disc = ctx.fresh_temp_cg();
    ctx.emit_load_cg(&disc, "i32", opt_ptr.as_str());

    // is_none = (discriminant == 0), since None is variant index 0
    let cmp_result = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg2(&cmp_result, "eq", "i32", &disc, "0");

    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i1", &cmp_result, dest_ptr.as_str());

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits an option_unwrap call with correct calling convention.
/// Runtime signature: void @option_unwrap(ptr self, i64 elem_size, ptr out_ptr)
pub fn emit_option_unwrap_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get option pointer - strip gen ref if present (FFI expects bare ptr).
    let opt_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get destination pointer and its size
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    let dest_ty = ctx.get_local_type(destination.local);

    // Get element size from destination type
    let elem_size: u64 = match ctx.get_local_hir_type(destination.local) {
        Option.Some(ty_id) => {
            codegen_size.type_size_with_ctx_id(ctx, ty_id)
        }
        Option.None => 8,
    };

    // Encode payload alignment in upper 32 bits.
    // Option enum layout is { i32, [N x i64] } — payload at offset 8 (i64-aligned).
    // The runtime's decode_size_and_offset uses: offset = max(4, align).
    let payload_align: u64 = 8;
    let packed_size = (payload_align << 32) | elem_size;

    // Emit: call void @option_unwrap(ptr self, i64 packed_size, ptr out_ptr)
    let elem_size_str = codegen_types.format_u64(packed_size);
    ctx.begin_call(Option.None, "void", "@option_unwrap");
    ctx.call_arg_str(true, "ptr", opt_ptr.as_str());
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.call_arg_str(false, "ptr", dest_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

/// Emits an option_as_ref call with correct calling convention.
/// Runtime signature: void @option_as_ref(ptr self, i64 elem_size, ptr out_ptr)
pub fn emit_option_as_ref_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 {
        ctx.emit_unreachable();
        return;
    }

    // Get option pointer - strip gen ref if present (FFI expects bare ptr).
    let opt_ptr = emit_operand_as_ptr(ctx, &args[0]);

    // Get destination pointer
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    // Get element size from destination type (Option<&T>)
    let elem_size: u64 = match ctx.get_local_hir_type(destination.local) {
        Option.Some(ty_id) => extract_vec_element_size_id(ctx, ty_id),
        Option.None => 8,
    };

    // Encode payload alignment in upper 32 bits.
    // Option enum layout is { i32, [N x i64] } — payload at offset 8 (i64-aligned).
    // The runtime's decode_size_and_offset uses: offset = max(4, align).
    let payload_align: u64 = 8;
    let packed_size = (payload_align << 32) | elem_size;

    // Emit: call void @option_as_ref(ptr self, i64 packed_size, ptr out_ptr)
    let elem_size_str = codegen_types.format_u64(packed_size);
    ctx.begin_call(Option.None, "void", "@option_as_ref");
    ctx.call_arg_str(true, "ptr", opt_ptr.as_str());
    ctx.call_arg_str(false, "i64", elem_size_str.as_str());
    ctx.call_arg_str(false, "ptr", dest_ptr.as_str());
    ctx.end_call();

    // Jump to continuation
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}
