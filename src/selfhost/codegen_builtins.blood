/// Dispatch descriptor for a HashMap<K, V> call site.
///
/// kk classification:
///   0 — primitive key (u32/u64/i32/...). Runtime uses generic memcmp hashing.
///   1 — builtin String key. Runtime uses the hash_string_key fast path.
///   2 — user-defined ADT key. Codegen emits per-K hash/eq wrapper fns and
///       routes through @hashmap_*_fn variants with fn-pointer args.
///
/// key_ty_id is the resolved TyId of K (after ref unwrapping). It is meaningful
/// only when kk == 2 — used to look up and emit wrapper functions.
pub struct HashMapDispatch {
    pub ks: u64,
    pub vs: u64,
    pub kk: u64,
    pub key_ty_id: type_intern.TyId,
}

fn extract_hashmap_sizes(
    ctx: &mut codegen_ctx.CodegenCtx,
    ty_id: type_intern.TyId,
) -> HashMapDispatch {
    // Deep-unwrap to handle wrapper functions where MIR produces &&HashMap<K, V>
    // (auto-ref of an already-`&HashMap<K, V>` parameter under a `&self` method).
    // Single-level unwrap leaves `&HashMap<K, V>`, which is not an Adt, so
    // get_adt_args returns None and the builtin falls back to default sizes
    // (ks=8, vs=8) — silently miscompiling primitive-keyed HashMaps.
    let unwrapped = type_intern.unwrap_all_refs_id(ty_id);
    match type_intern.get_adt_args(unwrapped) {
        Option.Some(args) => {
            let interner = type_intern.type_interner();
            if interner.ty_list_len(args) >= 2 {
                let key_id = interner.get_ty_list_element(args, 0);
                let val_id = interner.get_ty_list_element(args, 1);
                let ks = codegen_size.type_size_with_ctx_id(ctx, key_id);
                let vs = codegen_size.type_size_with_ctx_id(ctx, val_id);
                let key_base = type_intern.unwrap_ref_id(key_id);
                let (kk, kty) = classify_hashmap_key(ctx, key_base);
                HashMapDispatch { ks: ks, vs: vs, kk: kk, key_ty_id: kty }
            } else {
                hashmap_default_sizes()
            }
        }
        Option.None => hashmap_default_sizes(),
    }
}

/// Classifies a HashMap key TyId into (kk, key_ty_id).
/// key_ty_id is only meaningful for kk == 2 (user ADT).
fn classify_hashmap_key(
    ctx: &mut codegen_ctx.CodegenCtx,
    key_base: type_intern.TyId,
) -> (u64, type_intern.TyId) {
    match type_intern.get_adt_def_id(key_base) {
        Option.Some(def_id) => {
            if ctx.string_def_id != 0 && def_id.index == ctx.string_def_id {
                (1u64, type_intern.TyId.new(0))
            } else {
                (2u64, key_base)
            }
        }
        Option.None => (0u64, type_intern.TyId.new(0)),
    }
}

fn get_hashmap_type_from_arg(
    ctx: &mut codegen_ctx.CodegenCtx,
    arg: &mir_types.Operand,
) -> Option<type_intern.TyId> {
    match arg {
        &mir_types.Operand.Copy(ref place) => ctx.get_local_hir_type(place.local),
        &mir_types.Operand.Move(ref place) => ctx.get_local_hir_type(place.local),
        &mir_types.Operand.Constant(ref c) => Option.Some(c.ty),
    }
}

fn hashmap_emit_cont(
    ctx: &mut codegen_ctx.CodegenCtx,
    target: &Option<mir_def.BasicBlockId>,
) {
    match target {
        &Option.Some(t) => {
            let label = ctx.block_label_cg(t);
            ctx.emit_br_cg(&label);
        }
        &Option.None => {
            ctx.emit_unreachable();
        }
    }
}

fn hashmap_build_option(
    ctx: &mut codegen_ctx.CodegenCtx,
    destination: &mir_types.Place,
    result: &codegen_ctx.CgName,
    val_alloca: &codegen_ctx.CgName,
    val_size: u64,
) {
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i32", result, dest_ptr.as_str());
    let val_off = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&val_off);
    ctx.write(" = getelementptr i8, ptr ");
    ctx.write_string(&dest_ptr);
    ctx.write(", i64 8\n");
    let vs_str = codegen_types.format_u64(val_size);
    ctx.write_indent();
    ctx.write("call void @llvm.memcpy.p0.p0.i64(ptr ");
    ctx.write_cgname(&val_off);
    ctx.write(", ptr ");
    ctx.write_cgname(val_alloca);
    ctx.write(", i64 ");
    ctx.write_string(&vs_str);
    ctx.write(", i1 false)\n");
}

fn hashmap_default_sizes() -> HashMapDispatch {
    HashMapDispatch { ks: 8, vs: 8, kk: 0, key_ty_id: type_intern.TyId.new(0) }
}

/// Constructs the LLVM constant struct literal for passing a wrapper fn
/// through Blood's `fn(...)` closure ABI. Blood lowers `fn(A, B) -> R` to
/// `{ ptr fn_addr, ptr env }`; for pure wrappers we pass `env = null`.
///
/// Returns a string like `{ ptr @__blood_hashmap_hash_ty42, ptr null }` that
/// can be embedded directly as a call-site argument value.
fn hashmap_fnptr_closure_literal(wrapper_name: &str) -> String {
    let mut s = common.make_string("{ ptr @");
    s.push_str(wrapper_name);
    s.push_str(", ptr null }");
    s
}

/// Returns the LLVM symbol name for the per-K hash wrapper fn at this TyId.
/// Shape: `__blood_hashmap_hash_ty<N>` where N = key_ty_id.index. Uses the
/// interned type id (not ADT DefId) so the same wrapper is reused across
/// any generic instantiations that canonicalize to the same TyId.
fn hashmap_hash_wrapper_name(ty_id_index: u32) -> String {
    let mut s = common.make_string("__blood_hashmap_hash_ty");
    s.push_str(codegen_types.format_u64(ty_id_index as u64).as_str());
    s
}

/// Returns the LLVM symbol name for the per-K eq wrapper fn. Shape:
/// `__blood_hashmap_eq_ty<N>` — same conventions as hashmap_hash_wrapper_name.
fn hashmap_eq_wrapper_name(ty_id_index: u32) -> String {
    let mut s = common.make_string("__blood_hashmap_eq_ty");
    s.push_str(codegen_types.format_u64(ty_id_index as u64).as_str());
    s
}

/// Result of attempting to emit per-K hash/eq wrappers for a user ADT key.
/// Ok variants hold the (hash_wrapper_name, eq_wrapper_name) pair; MissingHash/Eq
/// indicates the user forgot an impl (typeck enforcement is Phase C Step 3).
pub enum HashMapWrapperResult {
    Ok(String, String),
    MissingHash,
    MissingEq,
}

/// Ensures the per-K hash/eq wrapper pair is present in `ctx.hashmap_wrapper_defs`
/// (emitted exactly once per unique K in this codegen context). Returns the
/// LLVM symbol names on success; returns MissingHash/Eq if the user did not
/// declare an `impl Hash for K` (resp. `impl PartialEq for K`) — in that case
/// the call site emits an unreachable as a best-effort runtime trap until
/// Phase C Step 3 turns this into a typeck error.
pub fn get_or_emit_hashmap_wrappers(
    ctx: &mut codegen_ctx.CodegenCtx,
    key_ty_id: type_intern.TyId,
) -> HashMapWrapperResult {
    let ty_idx = key_ty_id.index;
    let hash_name = hashmap_hash_wrapper_name(ty_idx);
    let eq_name = hashmap_eq_wrapper_name(ty_idx);

    if ctx.hashmap_wrapper_emitted(ty_idx) {
        return HashMapWrapperResult.Ok(hash_name, eq_name);
    }

    // Resolve the user's Hash.hash and PartialEq.eq methods.
    let hash_def_id = match ctx.lookup_hash_method(ty_idx) {
        Option.Some(d) => d,
        Option.None => { return HashMapWrapperResult.MissingHash; }
    };
    let eq_def_id = match ctx.lookup_eq_method(ty_idx) {
        Option.Some(d) => d,
        Option.None => { return HashMapWrapperResult.MissingEq; }
    };

    // Map DefIds to their emitted LLVM symbols via the def_name table.
    // If either symbol is unknown, fall through to the same error path —
    // this typically means the impl method wasn't registered at Pass 1b
    // (a compiler bug rather than a user error, but we handle it gracefully).
    let hash_target = match ctx.lookup_def_name(hash_def_id) {
        Option.Some(n) => n,
        Option.None => { return HashMapWrapperResult.MissingHash; }
    };
    let eq_target = match ctx.lookup_def_name(eq_def_id) {
        Option.Some(n) => n,
        Option.None => { return HashMapWrapperResult.MissingEq; }
    };

    // Hash wrapper — adapts the runtime's closure-shaped fn-pointer ABI to
    // the user's Blood method signature.
    //
    // Runtime call (rt_hashmap's hash_key_fn):
    //   call void %fn_ptr(ptr %env, ptr %key_ptr, { ptr, i32 } %state_ref)
    //
    // User's method (`impl Hash for T { fn hash(&self, state: &mut u64) }`):
    //   void @defN_hash({ ptr, i32 } %self_ref, { ptr, i32 } %state_ref)
    //
    // The wrapper discards %env (it never captures), lifts the raw %key_ptr
    // into a Blood generational reference by calling @blood_get_generation
    // to obtain the current gen for the bucket address, and forwards
    // %state_ref unchanged.
    let mut hash_def = String.new();
    hash_def.push_str("define linkonce_odr void @\"");
    hash_def.push_str(hash_name.as_str());
    hash_def.push_str("\"(ptr %env, ptr %key_ptr, { ptr, i32 } %state_ref) {\nentry:\n");
    hash_def.push_str("  %key_addr = ptrtoint ptr %key_ptr to i64\n");
    hash_def.push_str("  %key_gen = call i32 @blood_get_generation(i64 %key_addr)\n");
    hash_def.push_str("  %self_ref_0 = insertvalue { ptr, i32 } zeroinitializer, ptr %key_ptr, 0\n");
    hash_def.push_str("  %self_ref = insertvalue { ptr, i32 } %self_ref_0, i32 %key_gen, 1\n");
    hash_def.push_str("  call void @");
    hash_def.push_str(hash_target.as_str());
    hash_def.push_str("({ ptr, i32 } %self_ref, { ptr, i32 } %state_ref)\n");
    hash_def.push_str("  ret void\n");
    hash_def.push_str("}\n");
    ctx.hashmap_wrapper_defs.push(hash_def);

    // Eq wrapper — same shape as hash, except both key slots are raw `*mut u8`
    // at the runtime ABI boundary (rt_hashmap's keys_eq_fn).
    //
    // Runtime call:
    //   call i1 %fn_ptr(ptr %env, ptr %a_ptr, ptr %b_ptr)
    //
    // User's method (`impl PartialEq for T { fn eq(&self, other: &Self) -> bool }`):
    //   i1 @defN_eq({ ptr, i32 } %self_ref, { ptr, i32 } %other_ref)
    //
    // Blood's bool lowers to i1 (codegen_size:166) so the return type lines
    // up with the runtime's declared `-> bool`.
    let mut eq_def = String.new();
    eq_def.push_str("define linkonce_odr i1 @\"");
    eq_def.push_str(eq_name.as_str());
    eq_def.push_str("\"(ptr %env, ptr %a_ptr, ptr %b_ptr) {\nentry:\n");
    eq_def.push_str("  %a_addr = ptrtoint ptr %a_ptr to i64\n");
    eq_def.push_str("  %a_gen = call i32 @blood_get_generation(i64 %a_addr)\n");
    eq_def.push_str("  %a_ref_0 = insertvalue { ptr, i32 } zeroinitializer, ptr %a_ptr, 0\n");
    eq_def.push_str("  %a_ref = insertvalue { ptr, i32 } %a_ref_0, i32 %a_gen, 1\n");
    eq_def.push_str("  %b_addr = ptrtoint ptr %b_ptr to i64\n");
    eq_def.push_str("  %b_gen = call i32 @blood_get_generation(i64 %b_addr)\n");
    eq_def.push_str("  %b_ref_0 = insertvalue { ptr, i32 } zeroinitializer, ptr %b_ptr, 0\n");
    eq_def.push_str("  %b_ref = insertvalue { ptr, i32 } %b_ref_0, i32 %b_gen, 1\n");
    eq_def.push_str("  %r = call i1 @");
    eq_def.push_str(eq_target.as_str());
    eq_def.push_str("({ ptr, i32 } %a_ref, { ptr, i32 } %b_ref)\n");
    eq_def.push_str("  ret i1 %r\n");
    eq_def.push_str("}\n");
    ctx.hashmap_wrapper_defs.push(eq_def);

    ctx.mark_hashmap_wrapper_emitted(ty_idx);
    HashMapWrapperResult.Ok(hash_name, eq_name)
}

/// Emits a compile-time diagnostic and an unreachable trap when a user ADT
/// HashMap key is missing a Hash or PartialEq impl. Kept bounded to the
/// call-site so each diagnostic mentions the specific missing trait.
fn emit_missing_trait_error(
    ctx: &mut codegen_ctx.CodegenCtx,
    trait_name: &str,
) {
    ctx.write("  ; C3 Phase C Step 2: HashMap key missing impl ");
    ctx.write(trait_name);
    ctx.write(" — typeck enforcement pending (Phase C Step 3)\n");
    ctx.emit_unreachable();
}

pub fn emit_hashmap_new_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    let sizes = match resolve_place_hir_type(ctx, destination) {
        Option.Some(ty_id) => extract_hashmap_sizes(ctx, ty_id),
        Option.None => hashmap_default_sizes(),
    };
    let ks_str = codegen_types.format_u64(sizes.ks);
    let vs_str = codegen_types.format_u64(sizes.vs);
    let kk_str = codegen_types.format_u64(sizes.kk);
    ctx.begin_call(Option.None, "void", "@hashmap_new");
    ctx.call_arg_str(true, "i64", ks_str.as_str());
    ctx.call_arg_str(false, "i64", vs_str.as_str());
    ctx.call_arg_str(false, "i32", kk_str.as_str());
    ctx.call_arg_str(false, "ptr", out_ptr.as_str());
    ctx.end_call();
    hashmap_emit_cont(ctx, target);
}

pub fn emit_hashmap_insert_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 3 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let sizes = match get_hashmap_type_from_arg(ctx, &args[0]) {
        Option.Some(ty_id) => extract_hashmap_sizes(ctx, ty_id),
        Option.None => hashmap_default_sizes(),
    };
    let ks = sizes.ks;
    let vs = sizes.vs;
    let ks_str = codegen_types.format_u64(ks);
    let vs_str = codegen_types.format_u64(vs);
    let kk_str = codegen_types.format_u64(sizes.kk);
    let (key_val, key_ty) = codegen_expr.emit_operand_typed(ctx, &args[1]);
    let (val_val, val_ty) = codegen_expr.emit_operand_typed(ctx, &args[2]);

    let stack_save = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&stack_save);
    ctx.write(" = call ptr @llvm.stacksave()\n");

    let key_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&key_alloca);
    ctx.write(" = alloca ");
    ctx.write_string(&key_ty);
    ctx.write(", align 8\n");
    ctx.emit_store_str_cg(key_ty.as_str(), key_val.as_str(), &key_alloca);

    let val_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&val_alloca);
    ctx.write(" = alloca ");
    ctx.write_string(&val_ty);
    ctx.write(", align 8\n");
    ctx.emit_store_str_cg(val_ty.as_str(), val_val.as_str(), &val_alloca);

    let old_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&old_alloca);
    ctx.write(" = alloca [");
    ctx.write_string(&vs_str);
    ctx.write(" x i8], align 8\n");

    let result = ctx.fresh_temp_cg();
    if sizes.kk == 2 {
        // User ADT key path — route through the fn-pointer variant with
        // per-K hash/eq wrappers so the runtime can invoke the user-defined
        // Hash and PartialEq impls without knowing the concrete type.
        let wrappers = get_or_emit_hashmap_wrappers(ctx, sizes.key_ty_id);
        match wrappers {
            HashMapWrapperResult.Ok(hash_name, eq_name) => {
                let hash_closure = hashmap_fnptr_closure_literal(hash_name.as_str());
                let eq_closure = hashmap_fnptr_closure_literal(eq_name.as_str());
                ctx.begin_call(Option.Some(&result), "i32", "@hashmap_insert_fn");
                ctx.call_arg_str(true, "ptr", map_ptr.as_str());
                ctx.call_arg_cg(false, "ptr", &key_alloca);
                ctx.call_arg_cg(false, "ptr", &val_alloca);
                ctx.call_arg_str(false, "i64", ks_str.as_str());
                ctx.call_arg_str(false, "i64", vs_str.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", hash_closure.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", eq_closure.as_str());
                ctx.call_arg_cg(false, "ptr", &old_alloca);
                ctx.end_call();
            }
            HashMapWrapperResult.MissingHash => { emit_missing_trait_error(ctx, "Hash"); return; }
            HashMapWrapperResult.MissingEq => { emit_missing_trait_error(ctx, "PartialEq"); return; }
        }
    } else {
        // Primitive (kk=0) or builtin String (kk=1) — existing fast path.
        ctx.begin_call(Option.Some(&result), "i32", "@hashmap_insert");
        ctx.call_arg_str(true, "ptr", map_ptr.as_str());
        ctx.call_arg_cg(false, "ptr", &key_alloca);
        ctx.call_arg_cg(false, "ptr", &val_alloca);
        ctx.call_arg_str(false, "i64", ks_str.as_str());
        ctx.call_arg_str(false, "i64", vs_str.as_str());
        ctx.call_arg_str(false, "i32", kk_str.as_str());
        ctx.call_arg_cg(false, "ptr", &old_alloca);
        ctx.end_call();
    }

    hashmap_build_option(ctx, destination, &result, &old_alloca, vs);

    ctx.write_indent();
    ctx.write("call void @llvm.stackrestore(ptr ");
    ctx.write_cgname(&stack_save);
    ctx.write(")\n");
    hashmap_emit_cont(ctx, target);
}

pub fn emit_hashmap_get_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let sizes = match get_hashmap_type_from_arg(ctx, &args[0]) {
        Option.Some(ty_id) => extract_hashmap_sizes(ctx, ty_id),
        Option.None => hashmap_default_sizes(),
    };
    let vs = sizes.vs;
    let ks_str = codegen_types.format_u64(sizes.ks);
    let vs_str = codegen_types.format_u64(vs);
    let kk_str = codegen_types.format_u64(sizes.kk);
    let key_ptr = emit_operand_as_ptr(ctx, &args[1]);

    let val_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&val_alloca);
    ctx.write(" = alloca [");
    ctx.write_string(&vs_str);
    ctx.write(" x i8], align 8\n");

    let result = ctx.fresh_temp_cg();
    if sizes.kk == 2 {
        let wrappers = get_or_emit_hashmap_wrappers(ctx, sizes.key_ty_id);
        match wrappers {
            HashMapWrapperResult.Ok(hash_name, eq_name) => {
                let hash_closure = hashmap_fnptr_closure_literal(hash_name.as_str());
                let eq_closure = hashmap_fnptr_closure_literal(eq_name.as_str());
                ctx.begin_call(Option.Some(&result), "i32", "@hashmap_get_fn");
                ctx.call_arg_str(true, "ptr", map_ptr.as_str());
                ctx.call_arg_str(false, "ptr", key_ptr.as_str());
                ctx.call_arg_str(false, "i64", ks_str.as_str());
                ctx.call_arg_str(false, "i64", vs_str.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", hash_closure.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", eq_closure.as_str());
                ctx.call_arg_cg(false, "ptr", &val_alloca);
                ctx.end_call();
            }
            HashMapWrapperResult.MissingHash => { emit_missing_trait_error(ctx, "Hash"); return; }
            HashMapWrapperResult.MissingEq => { emit_missing_trait_error(ctx, "PartialEq"); return; }
        }
    } else {
        ctx.begin_call(Option.Some(&result), "i32", "@hashmap_get");
        ctx.call_arg_str(true, "ptr", map_ptr.as_str());
        ctx.call_arg_str(false, "ptr", key_ptr.as_str());
        ctx.call_arg_str(false, "i64", ks_str.as_str());
        ctx.call_arg_str(false, "i64", vs_str.as_str());
        ctx.call_arg_str(false, "i32", kk_str.as_str());
        ctx.call_arg_cg(false, "ptr", &val_alloca);
        ctx.end_call();
    }

    hashmap_build_option(ctx, destination, &result, &val_alloca, vs);
    hashmap_emit_cont(ctx, target);
}

pub fn emit_hashmap_contains_key_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let sizes = match get_hashmap_type_from_arg(ctx, &args[0]) {
        Option.Some(ty_id) => extract_hashmap_sizes(ctx, ty_id),
        Option.None => hashmap_default_sizes(),
    };
    let ks_str = codegen_types.format_u64(sizes.ks);
    let vs_str = codegen_types.format_u64(sizes.vs);
    let kk_str = codegen_types.format_u64(sizes.kk);
    let key_ptr = emit_operand_as_ptr(ctx, &args[1]);

    let result = ctx.fresh_temp_cg();
    if sizes.kk == 2 {
        let wrappers = get_or_emit_hashmap_wrappers(ctx, sizes.key_ty_id);
        match wrappers {
            HashMapWrapperResult.Ok(hash_name, eq_name) => {
                let hash_closure = hashmap_fnptr_closure_literal(hash_name.as_str());
                let eq_closure = hashmap_fnptr_closure_literal(eq_name.as_str());
                ctx.begin_call(Option.Some(&result), "i32", "@hashmap_contains_key_fn");
                ctx.call_arg_str(true, "ptr", map_ptr.as_str());
                ctx.call_arg_str(false, "ptr", key_ptr.as_str());
                ctx.call_arg_str(false, "i64", ks_str.as_str());
                ctx.call_arg_str(false, "i64", vs_str.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", hash_closure.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", eq_closure.as_str());
                ctx.end_call();
            }
            HashMapWrapperResult.MissingHash => { emit_missing_trait_error(ctx, "Hash"); return; }
            HashMapWrapperResult.MissingEq => { emit_missing_trait_error(ctx, "PartialEq"); return; }
        }
    } else {
        ctx.begin_call(Option.Some(&result), "i32", "@hashmap_contains_key");
        ctx.call_arg_str(true, "ptr", map_ptr.as_str());
        ctx.call_arg_str(false, "ptr", key_ptr.as_str());
        ctx.call_arg_str(false, "i64", ks_str.as_str());
        ctx.call_arg_str(false, "i64", vs_str.as_str());
        ctx.call_arg_str(false, "i32", kk_str.as_str());
        ctx.end_call();
    }

    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    let bool_val = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&bool_val);
    ctx.write(" = trunc i32 ");
    ctx.write_cgname(&result);
    ctx.write(" to i1\n");
    ctx.emit_store_cg("i1", &bool_val, dest_ptr.as_str());
    hashmap_emit_cont(ctx, target);
}

pub fn emit_hashmap_len_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i64", "@hashmap_len");
    ctx.call_arg_str(true, "ptr", map_ptr.as_str());
    ctx.end_call();
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    ctx.emit_store_cg("i64", &result, dest_ptr.as_str());
    hashmap_emit_cont(ctx, target);
}

pub fn emit_hashmap_is_empty_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i32", "@hashmap_is_empty");
    ctx.call_arg_str(true, "ptr", map_ptr.as_str());
    ctx.end_call();
    let dest_ptr = codegen_place.emit_place_data_ptr(ctx, destination);
    let bool_val = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&bool_val);
    ctx.write(" = trunc i32 ");
    ctx.write_cgname(&result);
    ctx.write(" to i1\n");
    ctx.emit_store_cg("i1", &bool_val, dest_ptr.as_str());
    hashmap_emit_cont(ctx, target);
}

pub fn emit_hashmap_remove_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 2 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let sizes = match get_hashmap_type_from_arg(ctx, &args[0]) {
        Option.Some(ty_id) => extract_hashmap_sizes(ctx, ty_id),
        Option.None => hashmap_default_sizes(),
    };
    let vs = sizes.vs;
    let ks_str = codegen_types.format_u64(sizes.ks);
    let vs_str = codegen_types.format_u64(vs);
    let kk_str = codegen_types.format_u64(sizes.kk);
    let key_ptr = emit_operand_as_ptr(ctx, &args[1]);

    let val_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&val_alloca);
    ctx.write(" = alloca [");
    ctx.write_string(&vs_str);
    ctx.write(" x i8], align 8\n");

    let result = ctx.fresh_temp_cg();
    if sizes.kk == 2 {
        let wrappers = get_or_emit_hashmap_wrappers(ctx, sizes.key_ty_id);
        match wrappers {
            HashMapWrapperResult.Ok(hash_name, eq_name) => {
                let hash_closure = hashmap_fnptr_closure_literal(hash_name.as_str());
                let eq_closure = hashmap_fnptr_closure_literal(eq_name.as_str());
                ctx.begin_call(Option.Some(&result), "i32", "@hashmap_remove_fn");
                ctx.call_arg_str(true, "ptr", map_ptr.as_str());
                ctx.call_arg_str(false, "ptr", key_ptr.as_str());
                ctx.call_arg_str(false, "i64", ks_str.as_str());
                ctx.call_arg_str(false, "i64", vs_str.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", hash_closure.as_str());
                ctx.call_arg_str(false, "{ ptr, ptr }", eq_closure.as_str());
                ctx.call_arg_cg(false, "ptr", &val_alloca);
                ctx.end_call();
            }
            HashMapWrapperResult.MissingHash => { emit_missing_trait_error(ctx, "Hash"); return; }
            HashMapWrapperResult.MissingEq => { emit_missing_trait_error(ctx, "PartialEq"); return; }
        }
    } else {
        ctx.begin_call(Option.Some(&result), "i32", "@hashmap_remove");
        ctx.call_arg_str(true, "ptr", map_ptr.as_str());
        ctx.call_arg_str(false, "ptr", key_ptr.as_str());
        ctx.call_arg_str(false, "i64", ks_str.as_str());
        ctx.call_arg_str(false, "i64", vs_str.as_str());
        ctx.call_arg_str(false, "i32", kk_str.as_str());
        ctx.call_arg_cg(false, "ptr", &val_alloca);
        ctx.end_call();
    }

    hashmap_build_option(ctx, destination, &result, &val_alloca, vs);
    hashmap_emit_cont(ctx, target);
}

/// Emits a call to hashmap_clone(src, key_size, val_size, key_kind, out).
/// Copies the hash table structure and data array from src to destination.
pub fn emit_hashmap_clone_call(
    ctx: &mut codegen_ctx.CodegenCtx,
    args: &Vec<mir_types.Operand>,
    destination: &mir_types.Place,
    target: &Option<mir_def.BasicBlockId>,
) {
    if args.len() < 1 { ctx.emit_unreachable(); return; }
    let map_ptr = emit_operand_as_ptr(ctx, &args[0]);
    let sizes = match get_hashmap_type_from_arg(ctx, &args[0]) {
        Option.Some(ty_id) => extract_hashmap_sizes(ctx, ty_id),
        Option.None => hashmap_default_sizes(),
    };
    let ks_str = codegen_types.format_u64(sizes.ks);
    let vs_str = codegen_types.format_u64(sizes.vs);
    let kk_str = codegen_types.format_u64(sizes.kk);
    let out_ptr = codegen_place.emit_place_data_ptr(ctx, destination);

    ctx.begin_call(Option.None, "void", "@hashmap_clone");
    ctx.call_arg_str(true, "ptr", map_ptr.as_str());
    ctx.call_arg_str(false, "i64", ks_str.as_str());
    ctx.call_arg_str(false, "i64", vs_str.as_str());
    ctx.call_arg_str(false, "i32", kk_str.as_str());
    ctx.call_arg_str(false, "ptr", out_ptr.as_str());
    ctx.end_call();
    hashmap_emit_cont(ctx, target);
}

