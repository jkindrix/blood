    let key_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&key_alloca);
    ctx.write(" = alloca [");
    ctx.write_string(&ks_str);
    ctx.write(" x i8], align 8\n");

    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i32", "@hashmap_keys_next");
    ctx.call_arg_str(true, "ptr", iter_ptr.as_str());
