module blood.codegen_streaming;

// Blood Self-Hosted Compiler - Streaming Code Generator
//
// This module provides streaming codegen functions that write LLVM IR
// to disk one function at a time, avoiding OOM on large programs.
// Blood has no destructors, so without streaming the memory grows unbounded.

mod common;
mod hir_def;
mod hir_ty;
mod hir_item;
mod hir_lower_ctx;
mod mir_def;
mod mir_types;
mod mir_stmt;
mod mir_term;
mod mir_body;
mod codegen_types;
mod codegen_ctx;
mod codegen_expr;
mod codegen_stmt;
mod codegen_term;
mod codegen;
mod interner;
mod type_intern;
mod hir_expr;

// ============================================================
// Streaming Code Generation
// ============================================================

/// Begins streaming module generation by writing the module header to a file.
/// Returns a CodegenCtx that the caller uses for per-function generation.
/// The caller must register def_names and call generate_function_to_file for each body,
/// then call finish_streaming_module to write trailing declarations.
pub fn begin_streaming_module(
    module_name: &str,
    output_path: &str,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    module_count: u32,
    main_returns_unit: bool,
) -> codegen_ctx.CodegenCtx {
    let mut ctx = codegen_ctx.CodegenCtx.new();

    // Initialize DWARF debug info with per-module file tracking.
    ctx.init_debug_info(module_name, module_count);

    // NOTE: ADT registry population is done by the caller after registering
    // builtin ADTs (Vec, String, HashMap, Box). This ensures builtins are
    // available during populate_adt_registry so Box<T> resolves to "ptr"
    // instead of being expanded as { i8, [sizeof(T) x i8] }.

    // Build module header
    let mut header = String.new();
    header.push_str("; ModuleID = '");
    header.push_str(module_name);
    header.push_str("'\n");
    header.push_str("source_filename = \"");
    header.push_str(module_name);
    header.push_str(".blood\"\n");
    header.push_str("target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128\"\n");
    header.push_str("target triple = \"x86_64-unknown-linux-gnu\"\n");
    header.push_str("\n");

    // Intrinsic and runtime declarations — must come BEFORE function definitions
    // so that `declare @foo` followed by `define @foo` is valid LLVM IR
    // (the reverse order — define then declare — is a redefinition error).
    let decls = codegen.intrinsic_declarations(main_returns_unit);
    header.push_str(decls.as_str());

    // Write header + declarations to file (overwrite/create) and store path for buffered writes
    file_write_string(output_path, header.as_str());
    ctx.set_output_path(output_path);

    ctx
}

/// Generates LLVM IR for a single function and buffers it for batched file I/O.
/// Returns true on success.
pub fn generate_function_to_file(
    ctx: &mut codegen_ctx.CodegenCtx,
    body: &mir_body.MirBody,
    fn_name: &str,
    module_index: u32,
    module_count: u32,
) -> bool {
    let fn_ir = codegen.generate_function_with_ctx(ctx, body, fn_name, module_index, module_count);

    // Buffer the function IR (auto-flushes at 64KB)
    ctx.buffer_write(fn_ir.as_str());

    true
}

/// Finishes streaming module generation by buffering string constants and declarations,
/// then flushing the write buffer to disk.
/// Returns true on success.
pub fn finish_streaming_module(
    ctx: &mut codegen_ctx.CodegenCtx,
) -> bool {
    // Emit string constants into ctx.output, then copy to avoid aliased borrow
    ctx.output = String.new();
    ctx.emit_string_constants();
    let constants_ir = ctx.output.clone();
    ctx.buffer_write(constants_ir.as_str());

    // Intrinsic declarations already emitted in begin_streaming_module header

    true
}

/// Evaluates a static item's initializer body to produce an LLVM constant string.
/// Handles literal expressions (int, float, bool, char) and negated literals.
/// Falls back to zeroinitializer for complex expressions.
fn evaluate_static_initializer(
    static_def: &hir_item.StaticDef,
    bodies: &Vec<hir_lower_ctx.BodyEntry>,
    llvm_type: &str,
) -> String {
    let target_id = static_def.body_id.index;
    for bi in 0usize..bodies.len() {
        if bodies[bi].body_id.index == target_id {
            return evaluate_const_expr(&bodies[bi].body.expr, llvm_type);
        }
    }
    common.make_string("zeroinitializer")
}

/// Evaluates a HIR expression to an LLVM constant string.
/// Returns zeroinitializer for unsupported expressions.
fn evaluate_const_expr(expr: &hir_expr.Expr, llvm_type: &str) -> String {
    match &expr.kind {
        &hir_expr.ExprKind.Literal(ref lit) => {
            evaluate_literal(lit, llvm_type)
        }
        &hir_expr.ExprKind.Unary { operator: ref unary_op, operand: ref inner } => {
            match unary_op {
                &common.UnaryOp.Neg => {
                    match &inner.as_ref().kind {
                        &hir_expr.ExprKind.Literal(ref lit) => {
                            evaluate_negated_literal(lit, llvm_type)
                        }
                        _ => common.make_string("zeroinitializer"),
                    }
                }
                _ => common.make_string("zeroinitializer"),
            }
        }
        _ => common.make_string("zeroinitializer"),
    }
}

/// Converts a literal to an LLVM constant string.
fn evaluate_literal(lit: &hir_expr.Literal, llvm_type: &str) -> String {
    match &lit.kind {
        &hir_expr.LiteralKind.Int { val: ref v, ty: ref _t } => {
            codegen_types.format_u128(*v)
        }
        &hir_expr.LiteralKind.Float { bits: ref b, ty: ref _t } => {
            codegen_types.f64_bits_to_llvm_hex(*b)
        }
        &hir_expr.LiteralKind.Bool(b) => {
            if b { common.make_string("1") } else { common.make_string("0") }
        }
        &hir_expr.LiteralKind.Char(c) => {
            codegen_types.format_u128(c as u128)
        }
        _ => common.make_string("zeroinitializer"),
    }
}

/// Converts a negated literal to an LLVM constant string.
fn evaluate_negated_literal(lit: &hir_expr.Literal, llvm_type: &str) -> String {
    match &lit.kind {
        &hir_expr.LiteralKind.Int { val: ref v, ty: ref _t } => {
            let neg_val = 0i128 - (*v as i128);
            codegen_types.format_i128(neg_val)
        }
        &hir_expr.LiteralKind.Float { bits: ref b, ty: ref _t } => {
            // Flip the sign bit (bit 63)
            let neg_bits = *b ^ 0x8000000000000000;
            codegen_types.f64_bits_to_llvm_hex(neg_bits)
        }
        _ => common.make_string("zeroinitializer"),
    }
}

/// Emits LLVM global variable declarations for static items with proper names.
/// Should be called after begin_streaming_module but before generating functions.
/// Uses the interner to get the actual static variable names.
pub fn emit_static_globals_with_names(
    ctx: &mut codegen_ctx.CodegenCtx,
    interner: &interner.StringInterner,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    bodies: &Vec<hir_lower_ctx.BodyEntry>,
    thread_local_def_ids: &Vec<u32>,
) {
    let mut output = String.new();
    output.push_str("\n; Static global variables\n");

    for i in 0usize..items.len() {
        let item = &items[i].item;
        match &item.kind {
            &hir_item.ItemKind.Static(ref static_def) => {
                // Get mangled name for the static using the actual symbol name
                // Convention: names are stored WITHOUT @ prefix, @ is added when emitting
                let mut name = String.new();
                name.push_str("def");
                push_u32(&mut name, item.def_id.index);
                name.push('_');
                // Get the actual name from the interner
                match interner.resolve(item.name.symbol) {
                    Option.Some(symbol_name) => {
                        name.push_str(symbol_name.as_str());
                    }
                    Option.None => {
                        name.push_str("STATIC");
                    }
                }

                // Get LLVM type for the static's type (use codegen_stmt for generic arg handling)
                let static_hir_ty = type_intern.ty_id_to_type(static_def.ty);
                let llvm_type = codegen_stmt.type_to_llvm_with_ctx(ctx, &static_hir_ty);

                // Evaluate the static's initializer expression
                let init_str = evaluate_static_initializer(static_def, bodies, llvm_type.as_str());

                // Emit global variable declaration
                // Format: @name = [thread_local] global <type> <initializer>
                output.push('@');
                output.push_str(name.as_str());
                // Check if this static is marked #[thread_local]
                let mut is_tl: bool = false;
                for tli in 0usize..thread_local_def_ids.len() {
                    if thread_local_def_ids[tli] == item.def_id.index {
                        is_tl = true;
                    }
                }
                if is_tl {
                    output.push_str(" = thread_local global ");
                } else {
                    output.push_str(" = global ");
                }
                output.push_str(llvm_type.as_str());
                output.push(' ');
                output.push_str(init_str.as_str());
                output.push('\n');

                // Register the static's name (without @), mark it as static, and store its LLVM type
                ctx.register_def_name(item.def_id.index, name);
                ctx.register_static(item.def_id.index);
                ctx.register_static_type(item.def_id.index, llvm_type);
                ctx.register_static_hir_type(item.def_id.index, static_def.ty);
            }
            &hir_item.ItemKind.Const(ref _const_def) => {
                // Mark this DefId as a const item so codegen can call its body function
                // (instead of treating it as a function pointer reference)
                ctx.register_const(item.def_id.index);
            }
            _ => {}
        }
    }

    output.push('\n');
    ctx.buffer_write(output.as_str());
}

/// Helper to push u32 as decimal string.
fn push_u32(s: &mut String, val: u32) {
    if val == 0 {
        s.push('0');
        return;
    }
    let mut digits: Vec<u8> = Vec.new();
    let mut n = val;
    while n > 0 {
        digits.push((n % 10) as u8);
        n /= 10;
    }
    let mut j: usize = digits.len();
    while j > 0 {
        j -= 1;
        s.push((48 + (digits[j] as i32)) as char);
    }
}
