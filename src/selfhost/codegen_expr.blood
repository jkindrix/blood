module blood.codegen_expr;

// Blood Self-Hosted Compiler - Codegen Expressions
//
// This module handles generating LLVM IR for MIR operands and rvalues.

mod ast;
mod common;
mod hir_def;
mod hir_ty;
mod mir_def;
mod mir_types;
mod mir_stmt;
mod mir_term;
mod mir_body;
mod codegen_types;
mod codegen_ctx;
mod codegen_emit;
mod codegen_place;
mod codegen_size;
mod type_intern;

// Per-Rvalue-kind timers for emit_rvalue. emit_rvalue dominates the Assign
// arm (~13s of blocks_ms). Knowing which Rvalue kinds are hottest lets
// future sessions target the worst offender directly.
//
// @unsafe safety note: all `@unsafe { RV_T_* / RV_C_* }` blocks in this file
// access these module-level `static mut` counters. Safety invariants:
//   1. Counters are u64 — atomic reads/writes on x86-64 (no torn values).
//   2. Under parallel codegen (4 workers), racing increments may lose updates.
//      The inaccuracy is acceptable: counters exist for --mem-profile output
//      and are never used for correctness decisions. A lost ++ makes the
//      timing report slightly under-count but never produces wrong code.
//   3. No pointers are dereferenced, so data races cannot cause memory unsafety.
// Do NOT use these counters for anything other than diagnostic reporting.
static mut RV_T_USE_MS: u64 = 0;
static mut RV_T_REF_MS: u64 = 0;
static mut RV_T_BINOP_MS: u64 = 0;
static mut RV_T_AGG_MS: u64 = 0;
static mut RV_T_CAST_MS: u64 = 0;
static mut RV_T_OTHER_MS: u64 = 0;
static mut RV_C_USE: u64 = 0;
static mut RV_C_REF: u64 = 0;
static mut RV_C_BINOP: u64 = 0;
static mut RV_C_AGG: u64 = 0;
static mut RV_C_CAST: u64 = 0;
static mut RV_C_OTHER: u64 = 0;

pub fn rv_t_use_ms() -> u64 { @unsafe { RV_T_USE_MS } }
pub fn rv_t_ref_ms() -> u64 { @unsafe { RV_T_REF_MS } }
pub fn rv_t_binop_ms() -> u64 { @unsafe { RV_T_BINOP_MS } }
pub fn rv_t_agg_ms() -> u64 { @unsafe { RV_T_AGG_MS } }
pub fn rv_t_cast_ms() -> u64 { @unsafe { RV_T_CAST_MS } }
pub fn rv_t_other_ms() -> u64 { @unsafe { RV_T_OTHER_MS } }
pub fn rv_c_use() -> u64 { @unsafe { RV_C_USE } }
pub fn rv_c_ref() -> u64 { @unsafe { RV_C_REF } }
pub fn rv_c_binop() -> u64 { @unsafe { RV_C_BINOP } }
pub fn rv_c_agg() -> u64 { @unsafe { RV_C_AGG } }
pub fn rv_c_cast() -> u64 { @unsafe { RV_C_CAST } }
pub fn rv_c_other() -> u64 { @unsafe { RV_C_OTHER } }

// ============================================================
// Operand Codegen
// ============================================================

/// Generates LLVM IR for an operand, returning the value name.
pub fn emit_operand(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
) -> String {
    match operand {
        &mir_types.Operand.Copy(ref place) => {
            codegen_place.emit_place_load(ctx, place)
        }
        &mir_types.Operand.Move(ref place) => {
            codegen_place.emit_place_load(ctx, place)
        }
        &mir_types.Operand.Constant(ref constant) => {
            emit_constant(ctx, constant)
        }
    }
}

/// Generates LLVM IR for an operand with type information, returning (value, llvm_type).
pub fn emit_operand_typed(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
) -> (String, String) {
    match operand {
        &mir_types.Operand.Copy(ref place) => {
            codegen_place.emit_place_load_with_type(ctx, place)
        }
        &mir_types.Operand.Move(ref place) => {
            codegen_place.emit_place_load_with_type(ctx, place)
        }
        &mir_types.Operand.Constant(ref constant) => {
            let val = emit_constant(ctx, constant);
            let const_hir_ty = type_intern.ty_id_to_type(constant.ty);
            // Check if this FnDef is actually a const or static item
            // (MIR lowering produces FnDef for all path expressions)
            let fn_def_id = match &constant.kind {
                &mir_types.ConstantKind.FnDef(ref did) => Option.Some(did.index),
                _ => Option.None,
            };
            let is_const_item = match fn_def_id {
                Option.Some(did) => ctx.is_const(did),
                Option.None => false,
            };
            let is_static_item = match fn_def_id {
                Option.Some(did) => ctx.is_static(did),
                Option.None => false,
            };
            if is_const_item {
                let did_val = match fn_def_id { Option.Some(d) => d, Option.None => 0 };
                match ctx.get_bridge_const_value(did_val) {
                    Option.Some(bridge_val) => {
                        // Bridge constant: emit inline literal value
                        let ret_ty = codegen_size.type_to_llvm_with_ctx(ctx, &const_hir_ty);
                        let mut val_str = String.new();
                        val_str.push_str(codegen_types.format_i64(bridge_val).as_str());
                        (val_str, ret_ty)
                    }
                    Option.None => {
                        // Regular const item: call the const body function to get the value
                        let ret_ty = codegen_size.type_to_llvm_with_ctx(ctx, &const_hir_ty);
                        let call_result = ctx.fresh_temp_cg();
                        ctx.write_indent();
                        ctx.write_cgname(&call_result);
                        ctx.write(" = call ");
                        ctx.write_string(&ret_ty);
                        ctx.write(" ");
                        ctx.write_string(&val);
                        ctx.write("()\n");
                        (cgname_to_string(&call_result), ret_ty)
                    }
                }
            } else if is_static_item {
                // Static item: load from the global address
                // val already has @ prefix from emit_constant's FnDef handler
                let load_ty = codegen_size.type_to_llvm_with_ctx(ctx, &const_hir_ty);
                let load_result = ctx.fresh_temp_cg();
                ctx.emit_load_cg(&load_result, load_ty.as_str(), val.as_str());
                (cgname_to_string(&load_result), load_ty)
            } else if match fn_def_id { Option.Some(_) => true, Option.None => false } {
                // Regular function reference — construct { fn_ptr, env_ptr } fat pointer.
                // Named functions need a wrapper with (ptr env, params...) -> ret signature.
                let did = match fn_def_id { Option.Some(d) => d, Option.None => 0 };
                let wrapper_name = match ctx.get_or_create_fn_wrapper(did) {
                    Option.Some(name) => name,
                    Option.None => {
                        // Fallback: use original name directly
                        let mut fallback = String.new();
                        fallback.push_str(val.as_str());
                        // Strip leading @ if present
                        let vb = fallback.as_bytes();
                        if vb.len() > 0 && vb[0] == 64 {
                            let mut stripped = String.new();
                            for si in 1usize..vb.len() {
                                stripped.push(vb[si] as char);
                            }
                            stripped
                        } else {
                            fallback
                        }
                    }
                };
                // Build: %tmp1 = insertvalue { ptr, ptr } zeroinitializer, ptr @"wrapper$fnptr", 0
                let ins1 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins1);
                ctx.write(" = insertvalue { ptr, ptr } zeroinitializer, ptr @\"");
                ctx.write_string(&wrapper_name);
                ctx.write("\"");
                ctx.write(", 0\n");
                // %tmp2 = insertvalue { ptr, ptr } %tmp1, ptr null, 1
                let ins2 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins2);
                ctx.write(" = insertvalue { ptr, ptr } ");
                ctx.write_cgname(&ins1);
                ctx.write(", ptr null, 1\n");
                (cgname_to_string(&ins2), common.make_string("{ ptr, ptr }"))
            } else if match &constant.kind { &mir_types.ConstantKind.Float(_) => true, _ => false } {
                // Use TyId-native type resolution to determine f32 vs f64.
                // This is the preferred path: type_to_llvm_fast_id reads the
                // interned type directly without copying (faster, no allocation).
                let float_ty = match codegen_size.type_to_llvm_fast_id(constant.ty) {
                    Option.Some(s) => common.make_string(s),
                    Option.None => common.make_string("double"),
                };
                (val, float_ty)
            } else {
                // Check if the constant has a reference type to a SIZED type
                // (e.g., const 1: &i32). This happens when the type checker
                // unifies an argument with a &T parameter type (e.g.,
                // HashMap.get(key) where key: &K). We must materialize the
                // inner value in a temp alloca and return a pointer to it.
                //
                // For unsized types (&str, &[T]), the constant is already a
                // fat pointer { ptr, i64 } and should NOT be wrapped.
                let is_sized_ref = match &const_hir_ty.kind {
                    &hir_ty.TypeKind.Ref { ref inner, mutable: _ } => {
                        !codegen_types.is_unsized_type(inner.as_ref())
                    }
                    _ => false,
                };
                if is_sized_ref {
                    let inner_ty = match &const_hir_ty.kind {
                        &hir_ty.TypeKind.Ref { ref inner, mutable: _ } => {
                            codegen_size.type_to_llvm_with_ctx(ctx, inner.as_ref())
                        }
                        _ => common.make_string("i64"),
                    };
                    // Alloca a temp, store the value, return pointer
                    let ref_temp = ctx.fresh_temp_cg();
                    ctx.emit_alloca_cg(&ref_temp, inner_ty.as_str());
                    ctx.emit_store_str_cg(inner_ty.as_str(), val.as_str(), &ref_temp);
                    (cgname_to_string(&ref_temp), common.make_string("ptr"))
                } else {
                    let ty = codegen_types.type_to_llvm(&const_hir_ty);
                    (val, ty)
                }
            }
        }
    }
}

/// Generates LLVM IR for a constant, returning the value.
fn emit_constant(
    ctx: &mut codegen_ctx.CodegenCtx,
    constant: &mir_types.Constant,
) -> String {
    match &constant.kind {
        &mir_types.ConstantKind.Int(v) => codegen_types.format_i128(v),
        &mir_types.ConstantKind.Uint(v) => codegen_types.format_u128(v),
        &mir_types.ConstantKind.Bool(b) => {
            if b { common.make_string("1") } else { common.make_string("0") }
        }
        &mir_types.ConstantKind.Char(c) => {
            codegen_types.format_u64(c as u64)
        }
        &mir_types.ConstantKind.Float(bits) => {
            // MIR always stores float bits as f64 representation (u64).
            // LLVM accepts double-precision hex for both float and double types,
            // converting to the target precision automatically.
            codegen_types.f64_bits_to_llvm_hex(bits)
        }
        &mir_types.ConstantKind.String(ref s) => {
            // Build fat pointer: { ptr @.str.N, i64 len }
            let label = ctx.add_string_constant(s);
            let mut result = common.make_string("{ ptr ");
            result.push_str(label.as_str());
            result.push_str(", i64 ");
            let len_str = codegen_types.format_u64(s.len() as u64);
            result.push_str(len_str.as_str());
            result.push_str(" }");
            result
        }
        &mir_types.ConstantKind.ByteString(ref bytes) => {
            // Convert byte string to regular string for storage
            let mut s = String.new();
            for i in 0usize..bytes.len() {
                s.push(bytes[i] as char);
            }
            // Build fat pointer: { ptr @.str.N, i64 len }
            let label = ctx.add_string_constant(&s);
            let mut result = common.make_string("{ ptr ");
            result.push_str(label.as_str());
            result.push_str(", i64 ");
            let len_str = codegen_types.format_u64(bytes.len() as u64);
            result.push_str(len_str.as_str());
            result.push_str(" }");
            result
        }
        &mir_types.ConstantKind.Unit => common.make_string("undef"),
        &mir_types.ConstantKind.FnDef(ref def_id) => {
            // Function pointer - look up the function name
            match ctx.lookup_def_name(def_id.index) {
                Option.Some(name) => {
                    let mut result = common.make_string("@");
                    result.push_str(name.as_str());
                    result
                }
                Option.None => {
                    // Fallback: generate a placeholder name
                    let mut err_msg = common.make_string("function def_id ");
                    err_msg.push_str(codegen_types.format_u64(def_id.index as u64).as_str());
                    err_msg.push_str(" not found in def_names table");
                    ctx.codegen_error(
                        codegen_ctx.CodegenErrorKind.FnLookupFailed,
                        err_msg,
                    );
                    let mut result = common.make_string("@fn_");
                    result.push_str(codegen_types.format_u64(def_id.index as u64).as_str());
                    result
                }
            }
        }
        &mir_types.ConstantKind.ConstDef(ref def_id) => {
            // Const reference - look up and inline the const value
            // For now, generate a reference (full const eval would inline the value)
            match ctx.lookup_def_name(def_id.index) {
                Option.Some(name) => {
                    let mut result = common.make_string("@");
                    result.push_str(name.as_str());
                    result
                }
                Option.None => {
                    // Fallback: generate a placeholder
                    let mut err_msg = common.make_string("const def_id ");
                    err_msg.push_str(codegen_types.format_u64(def_id.index as u64).as_str());
                    err_msg.push_str(" not found in def_names table");
                    ctx.codegen_error(
                        codegen_ctx.CodegenErrorKind.FnLookupFailed,
                        err_msg,
                    );
                    let mut result = common.make_string("@const_");
                    result.push_str(codegen_types.format_u64(def_id.index as u64).as_str());
                    result
                }
            }
        }
        &mir_types.ConstantKind.StaticDef(ref def_id) => {
            // Static reference - look up the static name
            match ctx.lookup_def_name(def_id.index) {
                Option.Some(name) => {
                    let mut result = common.make_string("@");
                    result.push_str(name.as_str());
                    result
                }
                Option.None => {
                    // Fallback: generate a placeholder name
                    let mut err_msg = common.make_string("static def_id ");
                    err_msg.push_str(codegen_types.format_u64(def_id.index as u64).as_str());
                    err_msg.push_str(" not found in def_names table");
                    ctx.codegen_error(
                        codegen_ctx.CodegenErrorKind.StaticLookupFailed,
                        err_msg,
                    );
                    let mut result = common.make_string("@static_");
                    result.push_str(codegen_types.format_u64(def_id.index as u64).as_str());
                    result
                }
            }
        }
        &mir_types.ConstantKind.ZeroSized => common.make_string("undef"),
    }
}


// ============================================================
// Rvalue Codegen
// ============================================================

/// Returns the operand's interned TyId, or None if unavailable.
fn operand_ty_id(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> Option<type_intern.TyId> {
    match operand {
        &mir_types.Operand.Copy(ref place) => ctx.get_local_hir_type(place.local),
        &mir_types.Operand.Move(ref place) => ctx.get_local_hir_type(place.local),
        &mir_types.Operand.Constant(ref c) => Option.Some(c.ty),
    }
}

/// True if operand has a type that, after stripping all refs, is `str`.
/// Catches `&str`, `&&str`, etc. Used to gate the @str_eq routing path
/// against `&[T]` slices, which share `&str`'s LLVM layout `{ ptr, i64 }`
/// but must NOT be byte-compared as strings.
fn operand_is_str_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            let stripped = type_intern.unwrap_all_refs_id(id);
            stripped.index == type_intern.CommonTypes.str_ty().index
        }
        Option.None => false,
    }
}

/// Routes `&str == &str` and `&str != &str` through the `@str_eq` runtime
/// function. The default binop path treats `{ ptr, i64 }` as an aggregate and
/// extracts the first field (ptr), giving pointer-equality semantics — wrong
/// for any &str whose backing buffer is not the same allocation (e.g., a
/// String's heap buffer vs a literal's interned ptr). Returns true if the
/// binop was handled here; the caller should skip the default path.
fn try_emit_binop_str_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_str_ref(ctx, left) || !operand_is_str_ref(ctx, right) {
        return false;
    }
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_str(true, "{ ptr, i64 }", left_val.as_str());
    ctx.call_arg_str(false, "{ ptr, i64 }", right_val.as_str());
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand has type `String` (the heap-owning Adt; not `&String`).
/// `&String` deliberately returns false: its loaded value is `{ ptr, i32 }`
/// (a fat ref to the String alloca), not the `{ ptr, i64, i64 }` aggregate the
/// String-eq path expects to extract from. A separate path could handle the
/// ref-deref case in the future.
fn operand_is_string_value(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    if ctx.string_def_id == 0 { return false; }
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            match type_intern.get_adt_def_id(id) {
                Option.Some(def_id) => def_id.index == ctx.string_def_id,
                Option.None => false,
            }
        }
        Option.None => false,
    }
}

/// Builds a `{ ptr, i64 }` view from a String aggregate's first two fields
/// (data ptr + len), discarding the cap field. Returns the SSA temp holding
/// the constructed view, ready to feed into `@str_eq`.
fn extract_string_str_view(
    ctx: &mut codegen_ctx.CodegenCtx,
    string_val: &str,
) -> codegen_ctx.CgName {
    let data = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&data);
    ctx.write(" = extractvalue { ptr, i64, i64 } ");
    ctx.write(string_val);
    ctx.write(", 0\n");
    let len = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&len);
    ctx.write(" = extractvalue { ptr, i64, i64 } ");
    ctx.write(string_val);
    ctx.write(", 1\n");
    let view0 = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&view0);
    ctx.write(" = insertvalue { ptr, i64 } zeroinitializer, ptr ");
    ctx.write_cgname(&data);
    ctx.write(", 0\n");
    let view = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&view);
    ctx.write(" = insertvalue { ptr, i64 } ");
    ctx.write_cgname(&view0);
    ctx.write(", i64 ");
    ctx.write_cgname(&len);
    ctx.write(", 1\n");
    view
}

/// Routes `String == String` and `String != String` through `@str_eq`. The
/// default binop path treats `{ ptr, i64, i64 }` as an aggregate and extracts
/// the first field (heap data ptr), giving pointer-equality semantics — always
/// wrong for two distinct String allocations regardless of content. Builds a
/// `{ ptr, i64 }` view (data + len, dropping cap) of each operand and dispatches
/// to the same runtime function S98 routes &str equality through. Returns true
/// if the binop was handled here; the caller should skip the default path.
fn try_emit_binop_string_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_string_value(ctx, left) || !operand_is_string_value(ctx, right) {
        return false;
    }
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_view = extract_string_str_view(ctx, left_val.as_str());
    let right_view = extract_string_str_view(ctx, right_val.as_str());
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &left_view);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &right_view);
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand has type `&String` — exactly one Ref layer wrapping
/// `Adt(String)`. Multi-layer refs (`&&String`, etc.) deliberately rejected:
/// the codegen path here loads `{ ptr, i64, i64 }` from the fat ref's ptr
/// field, which would be wrong for `&&String` (whose ptr points to a
/// `{ ptr, i32 }` ref, not a String aggregate). Layered support can be added
/// by chaining loads, but is out of scope for this fix.
fn operand_is_string_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    if ctx.string_def_id == 0 { return false; }
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            if !type_intern.is_ref_id(id) { return false; }
            let inner = type_intern.unwrap_ref_id(id);
            match type_intern.get_adt_def_id(inner) {
                Option.Some(def_id) => def_id.index == ctx.string_def_id,
                Option.None => false,
            }
        }
        Option.None => false,
    }
}

/// Builds a `{ ptr, i64 }` view from a `&String` fat ref (`{ ptr, i32 }`).
/// Two-step deref: extract field 0 (ptr to the String alloca), load the
/// underlying `{ ptr, i64, i64 }` String aggregate, then reuse S99's
/// `extract_string_str_view` to drop the cap field. Mirrors S98's design
/// decision to skip generation validation in the binop path — the runtime's
/// `@str_eq` reads bytes through the data ptr, trusting the ref is live.
fn extract_string_ref_str_view(
    ctx: &mut codegen_ctx.CodegenCtx,
    ref_val: &str,
) -> codegen_ctx.CgName {
    let alloca_ptr = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&alloca_ptr);
    ctx.write(" = extractvalue { ptr, i32 } ");
    ctx.write(ref_val);
    ctx.write(", 0\n");
    let string_val = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&string_val);
    ctx.write(" = load { ptr, i64, i64 }, ptr ");
    ctx.write_cgname(&alloca_ptr);
    ctx.write("\n");
    let string_val_str = cgname_to_string(&string_val);
    extract_string_str_view(ctx, string_val_str.as_str())
}

/// Routes `&String == &String` and `&String != &String` through `@str_eq`.
/// Same root cause as S99 (String == String) but operand shape differs:
/// `&String` loads as a `{ ptr, i32 }` fat ref, not the `{ ptr, i64, i64 }`
/// String aggregate. The default binop path extracts field 0 (the alloca
/// address) and pointer-compares — always wrong because two distinct String
/// allocations have distinct addresses regardless of content. Derefs each
/// operand to load the underlying String, then dispatches via the same
/// `extract_string_str_view` + `@str_eq` pipeline S99 introduced. Returns
/// true if the binop was handled here; the caller should skip the default.
fn try_emit_binop_string_ref_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_string_ref(ctx, left) || !operand_is_string_ref(ctx, right) {
        return false;
    }
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_view = extract_string_ref_str_view(ctx, left_val.as_str());
    let right_view = extract_string_ref_str_view(ctx, right_val.as_str());
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &left_view);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &right_view);
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand is `& &String` — exactly two Ref layers wrapping String.
/// Mutually exclusive with `operand_is_string_ref` (which requires the inner
/// type be Adt(String), not another Ref). Used to gate the @str_eq routing
/// for `& &String` equality, the deepest ref shape S103-B closes.
fn operand_is_string_ref_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    if ctx.string_def_id == 0 { return false; }
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            if !type_intern.is_ref_id(id) { return false; }
            let inner1 = type_intern.unwrap_ref_id(id);
            if !type_intern.is_ref_id(inner1) { return false; }
            let inner2 = type_intern.unwrap_ref_id(inner1);
            match type_intern.get_adt_def_id(inner2) {
                Option.Some(def_id) => def_id.index == ctx.string_def_id,
                Option.None => false,
            }
        }
        Option.None => false,
    }
}

/// Builds a `{ ptr, i64 }` view from a `& &String` outer fat ref. Three-step
/// deref: extract field 0 (ptr to inner fat ref alloca) from the outer
/// `{ ptr, i32 }`, load the inner `{ ptr, i32 }` ref value, then chain into
/// S100's `extract_string_ref_str_view` to do the remaining
/// extract+load+drop-cap. Mirrors S100's choice to skip generation validation
/// in the binop path — `@str_eq` reads bytes through the data ptr trusting
/// the refs are live.
fn extract_string_ref_ref_str_view(
    ctx: &mut codegen_ctx.CodegenCtx,
    ref_ref_val: &str,
) -> codegen_ctx.CgName {
    let inner_ref_alloca = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&inner_ref_alloca);
    ctx.write(" = extractvalue { ptr, i32 } ");
    ctx.write(ref_ref_val);
    ctx.write(", 0\n");
    let inner_ref_val = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&inner_ref_val);
    ctx.write(" = load { ptr, i32 }, ptr ");
    ctx.write_cgname(&inner_ref_alloca);
    ctx.write("\n");
    let inner_ref_val_str = cgname_to_string(&inner_ref_val);
    extract_string_ref_str_view(ctx, inner_ref_val_str.as_str())
}

/// Routes `& &String == & &String` and `& &String != & &String` through
/// `@str_eq`. Same root cause as S100 (`&String == &String`) but operand shape
/// adds one more ref layer: outer `{ ptr, i32 }` whose ptr addresses the
/// inner ref's alloca, which itself loads to another `{ ptr, i32 }` whose ptr
/// addresses the underlying String's alloca. The default binop path would
/// extract the outer field 0 (an alloca address) and pointer-compare — wrong
/// for the same reason S100 was wrong, just one indirection deeper. Returns
/// true if the binop was handled here; the caller should skip the default.
fn try_emit_binop_string_ref_ref_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_string_ref_ref(ctx, left) || !operand_is_string_ref_ref(ctx, right) {
        return false;
    }
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_view = extract_string_ref_ref_str_view(ctx, left_val.as_str());
    let right_view = extract_string_ref_ref_str_view(ctx, right_val.as_str());
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &left_view);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &right_view);
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand is `&[T]` for some T — exactly one Ref layer wrapping a
/// Slice. Multi-layer refs to slices deliberately rejected (mirrors S100's
/// single-Ref-layer choice for `&String`). Used to gate the @str_eq routing
/// for slice equality. The element type is read separately via
/// `slice_ref_elem_size_id` for the byte-count multiplier.
fn operand_is_slice_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            if !type_intern.is_ref_id(id) { return false; }
            let inner = type_intern.unwrap_ref_id(id);
            type_intern.is_slice_id(inner)
        }
        Option.None => false,
    }
}

/// Returns the byte size of the slice element type for a `&[T]` operand.
/// Falls back to 1 if the operand isn't a slice ref (caller should have
/// gated via `operand_is_slice_ref` first; the fallback is defensive).
fn slice_ref_elem_size_id(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> u64 {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            let inner = type_intern.unwrap_ref_id(id);
            match type_intern.get_slice_element(inner) {
                Option.Some(elem_id) => codegen_size.type_size_with_ctx_id(ctx, elem_id),
                Option.None => 1,
            }
        }
        Option.None => 1,
    }
}

/// Builds a `{ ptr, i64 }` view from a `&[T]` slice's loaded value, where the
/// i64 holds the BYTE count (element count * elem_size) suitable for
/// `@str_eq`'s memcmp-equivalent path. The slice's loaded LLVM value is
/// `{ ptr, i64 }` where the i64 packs `(gen << 32) | element_count` — the
/// same convention `&str` uses. The view we feed to `@str_eq` must drop the
/// gen bits because:
///   1. `@str_eq` calls `str_len` on each operand, which gen-validates if
///      gen != 0 by looking up the buffer in the gen registry. Two slice
///      operands pointing at distinct stack arrays have distinct gens, and
///      the registry only tracks specific allocation paths — validation
///      would either spuriously panic with "stale reference detected" or
///      produce a length much larger than the buffer (causing OOB reads).
///   2. With gen masked to 0, `emit_str_gen_validation` short-circuits and
///      `@str_eq`'s loop bound is just the byte count, which is what we
///      want. Live-ref guarantee comes from the binop's MIR-level operand
///      semantics — both operands are dereferenceable at the binop site.
/// Masking via `and i64 raw, 4294967295` mirrors the slice-length extract
/// at codegen_expr.blood:1352. When elem_size is 1 (e.g. `&[u8]`), the
/// multiply is skipped because element count == byte count.
fn extract_slice_str_view(
    ctx: &mut codegen_ctx.CodegenCtx,
    slice_val: &str,
    elem_size: u64,
) -> codegen_ctx.CgName {
    let data = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&data);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write(slice_val);
    ctx.write(", 0\n");
    let raw_count = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&raw_count);
    ctx.write(" = extractvalue { ptr, i64 } ");
    ctx.write(slice_val);
    ctx.write(", 1\n");
    // Mask off packed gen — upper 32 bits hold (gen << 32). After this we
    // have just the element count with gen=0, suitable for @str_eq.
    let count = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&count);
    ctx.write(" = and i64 ");
    ctx.write_cgname(&raw_count);
    ctx.write(", 4294967295\n");
    let bytes = if elem_size == 1u64 {
        count
    } else {
        let byte_count = ctx.fresh_temp_cg();
        let elem_size_str = codegen_types.format_u64(elem_size);
        ctx.write_indent();
        ctx.write_cgname(&byte_count);
        ctx.write(" = mul i64 ");
        ctx.write_cgname(&count);
        ctx.write(", ");
        ctx.write(elem_size_str.as_str());
        ctx.write("\n");
        byte_count
    };
    let view0 = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&view0);
    ctx.write(" = insertvalue { ptr, i64 } zeroinitializer, ptr ");
    ctx.write_cgname(&data);
    ctx.write(", 0\n");
    let view = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&view);
    ctx.write(" = insertvalue { ptr, i64 } ");
    ctx.write_cgname(&view0);
    ctx.write(", i64 ");
    ctx.write_cgname(&bytes);
    ctx.write(", 1\n");
    view
}

/// Routes `&[T] == &[T]` and `&[T] != &[T]` through `@str_eq`. The default
/// binop path treats `{ ptr, i64 }` as an aggregate and extracts the first
/// field (data ptr), giving pointer-equality semantics — wrong for any two
/// distinct slice allocations regardless of content. Multiplies element
/// count by elem_size to produce a byte length, then dispatches via the
/// same runtime function S98 routes &str equality through.
///
/// CORRECTNESS NOTE: bytewise equality is equivalent to element-wise `==`
/// for integer-element slices (u8/i8/.../bool/char/raw ptr). For
/// float-element slices (`&[f32]`/`&[f64]`), this implementation diverges
/// from element-wise `==` at NaN (NaN != NaN element-wise but bytewise-
/// equal) and ±0 (bytewise distinct but element-wise equal). For aggregate-
/// element slices with padding, this implementation may compare uninit
/// padding bytes. Both edges are pre-existing — the prior pointer-equality
/// path was strictly worse because it never returned true for distinct
/// allocations. Future work can dispatch to a per-element loop for
/// non-integer element types if those callers materialize.
fn try_emit_binop_slice_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_slice_ref(ctx, left) || !operand_is_slice_ref(ctx, right) {
        return false;
    }
    let elem_size = slice_ref_elem_size_id(ctx, left);
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_view = extract_slice_str_view(ctx, left_val.as_str(), elem_size);
    let right_view = extract_slice_str_view(ctx, right_val.as_str(), elem_size);
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &left_view);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &right_view);
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand has type `Vec<T>` directly (the heap-owning Adt; not
/// `&Vec<T>`). Matches the value-shape `v == v` case where emit_operand_typed
/// returns a `{ ptr, i64, i64 }` Vec aggregate. `&Vec<T>` deliberately falls
/// to `operand_is_vec_ref` because its loaded value is `{ ptr, i32 }` (fat
/// ref) and needs an extra deref step before the view extract — same
/// split as S99/S100 (String value vs ref).
fn operand_is_vec_value(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    if ctx.vec_def_id == 0 { return false; }
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            match type_intern.get_adt_def_id(id) {
                Option.Some(def_id) => def_id.index == ctx.vec_def_id,
                Option.None => false,
            }
        }
        Option.None => false,
    }
}

/// True if operand has type `&Vec<T>` — exactly one Ref layer wrapping Vec.
/// Mirrors S100's `operand_is_string_ref` shape. Multi-layer refs not
/// handled (low priority — selfhost has zero callers).
fn operand_is_vec_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    if ctx.vec_def_id == 0 { return false; }
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            if !type_intern.is_ref_id(id) { return false; }
            let inner = type_intern.unwrap_ref_id(id);
            match type_intern.get_adt_def_id(inner) {
                Option.Some(def_id) => def_id.index == ctx.vec_def_id,
                Option.None => false,
            }
        }
        Option.None => false,
    }
}

/// Returns the byte size of the element type for a Vec operand. Strips refs
/// to find the underlying `Vec<T>`'s element T, then walks T's LLVM size.
/// Inlined here to avoid a circular import with codegen_builtins (which
/// imports codegen_expr). Falls back to 1 if the operand isn't a Vec; the
/// caller should have gated via `operand_is_vec_value` or `operand_is_vec_ref`
/// first.
fn vec_value_elem_size(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> u64 {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            let unwrapped = type_intern.unwrap_all_refs_id(id);
            match type_intern.get_adt_args(unwrapped) {
                Option.Some(args) => {
                    let interner = type_intern.type_interner();
                    if interner.ty_list_len(args) > 0 {
                        let elem_id = interner.get_ty_list_element(args, 0);
                        codegen_size.type_size_with_ctx_id(ctx, elem_id)
                    } else {
                        1
                    }
                }
                Option.None => 1,
            }
        }
        Option.None => 1,
    }
}

/// Builds a `{ ptr, i64 }` view from a Vec's loaded `{ ptr, i64, i64 }` value
/// (data ptr + len + cap), where the resulting i64 holds BYTE count
/// (len * elem_size) suitable for `@str_eq`'s memcmp-equivalent path. The
/// data field 0 is already `ptr`-typed (matches the LLVM struct layout),
/// so no inttoptr is needed unlike if we were operating on the raw addr the
/// runtime treats as i64. The len field 1 is plain i64 with no packed gen
/// — gen tracking for Vec lives in separate `_data_gen` allocas elsewhere,
/// not in the Vec aggregate, so no gen-mask step like the slice eq path.
/// When elem_size is 1 (e.g. `Vec<u8>`), the multiply is skipped because
/// element count == byte count.
fn extract_vec_str_view(
    ctx: &mut codegen_ctx.CodegenCtx,
    vec_val: &str,
    elem_size: u64,
) -> codegen_ctx.CgName {
    let data = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&data);
    ctx.write(" = extractvalue { ptr, i64, i64 } ");
    ctx.write(vec_val);
    ctx.write(", 0\n");
    let len = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&len);
    ctx.write(" = extractvalue { ptr, i64, i64 } ");
    ctx.write(vec_val);
    ctx.write(", 1\n");
    let bytes = if elem_size == 1u64 {
        len
    } else {
        let byte_count = ctx.fresh_temp_cg();
        let elem_size_str = codegen_types.format_u64(elem_size);
        ctx.write_indent();
        ctx.write_cgname(&byte_count);
        ctx.write(" = mul i64 ");
        ctx.write_cgname(&len);
        ctx.write(", ");
        ctx.write(elem_size_str.as_str());
        ctx.write("\n");
        byte_count
    };
    let view0 = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&view0);
    ctx.write(" = insertvalue { ptr, i64 } zeroinitializer, ptr ");
    ctx.write_cgname(&data);
    ctx.write(", 0\n");
    let view = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&view);
    ctx.write(" = insertvalue { ptr, i64 } ");
    ctx.write_cgname(&view0);
    ctx.write(", i64 ");
    ctx.write_cgname(&bytes);
    ctx.write(", 1\n");
    view
}

/// Routes `Vec<T> == Vec<T>` and `Vec<T> != Vec<T>` through `@str_eq`. The
/// default binop path treats `{ ptr, i64, i64 }` as an aggregate and
/// extracts the first field (data ptr), giving pointer-equality semantics
/// — wrong for any two distinct Vec allocations regardless of content.
/// Multiplies len by elem_size to produce a byte length, then dispatches
/// via the same runtime function S98 routes &str equality through. The
/// `&Vec<T>` ref shape is handled by `try_emit_binop_vec_ref_eq` because
/// its loaded value is `{ ptr, i32 }` (fat ref), not the Vec aggregate.
///
/// CORRECTNESS NOTE: bytewise equality is equivalent to element-wise `==`
/// for integer-element Vecs (u8/i8/.../bool/char/raw ptr). For float-element
/// Vecs (`Vec<f32>`/`Vec<f64>`), this implementation diverges from element-
/// wise `==` at NaN and ±0; for aggregate-element Vecs with padding, it may
/// compare uninit padding bytes. Both edges are pre-existing — the prior
/// pointer-equality path was strictly worse because it never returned true
/// for distinct allocations. Mirrors S102's slice eq partial-fix discipline.
fn try_emit_binop_vec_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_vec_value(ctx, left) || !operand_is_vec_value(ctx, right) {
        return false;
    }
    let elem_size = vec_value_elem_size(ctx, left);
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_view = extract_vec_str_view(ctx, left_val.as_str(), elem_size);
    let right_view = extract_vec_str_view(ctx, right_val.as_str(), elem_size);
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &left_view);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &right_view);
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// Builds a `{ ptr, i64 }` view from a `&Vec<T>` fat ref `{ ptr, i32 }`.
/// Two-step deref: extract field 0 (ptr to the Vec aggregate's storage),
/// load the underlying `{ ptr, i64, i64 }` Vec, then chain into
/// `extract_vec_str_view` to drop cap and produce the byte-length view.
/// Mirrors S100's `extract_string_ref_str_view` shape; like that path,
/// skips gen validation in the binop because the live-ref guarantee comes
/// from MIR-level operand semantics.
fn extract_vec_ref_str_view(
    ctx: &mut codegen_ctx.CodegenCtx,
    ref_val: &str,
    elem_size: u64,
) -> codegen_ctx.CgName {
    let alloca_ptr = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&alloca_ptr);
    ctx.write(" = extractvalue { ptr, i32 } ");
    ctx.write(ref_val);
    ctx.write(", 0\n");
    let vec_val = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&vec_val);
    ctx.write(" = load { ptr, i64, i64 }, ptr ");
    ctx.write_cgname(&alloca_ptr);
    ctx.write("\n");
    let vec_val_str = cgname_to_string(&vec_val);
    extract_vec_str_view(ctx, vec_val_str.as_str(), elem_size)
}

/// Routes `&Vec<T> == &Vec<T>` and `&Vec<T> != &Vec<T>` through `@str_eq`.
/// Same root cause as `try_emit_binop_vec_eq` (S99-family aggregate-extract-
/// first-field) but operand shape differs: `&Vec<T>` loads as `{ ptr, i32 }`
/// fat ref, not the `{ ptr, i64, i64 }` Vec aggregate. The default path
/// extracts field 0 (the alloca address) and pointer-compares — always
/// wrong because two distinct Vec allocations have distinct addresses
/// regardless of content. Derefs each operand to load the underlying Vec,
/// then dispatches via the same `extract_vec_str_view` + `@str_eq` pipeline.
fn try_emit_binop_vec_ref_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_vec_ref(ctx, left) || !operand_is_vec_ref(ctx, right) {
        return false;
    }
    let elem_size = vec_value_elem_size(ctx, left);
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_view = extract_vec_ref_str_view(ctx, left_val.as_str(), elem_size);
    let right_view = extract_vec_ref_str_view(ctx, right_val.as_str(), elem_size);
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", "@str_eq");
    ctx.call_arg_cg(true, "{ ptr, i64 }", &left_view);
    ctx.call_arg_cg(false, "{ ptr, i64 }", &right_view);
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand has a registered user-defined `eq` method (from
/// `impl PartialEq for T` — hand-written or `#[derive(PartialEq)]`)
/// AND the operand type is an Adt. Strips a single outer Ref so `T`
/// (value) and `&T` (single-layer ref) both resolve to the same
/// registered method. Multi-layer `&&T` falls through (mirrors S100/
/// S103-B's single-layer choice for `&String`).
///
/// CRITICAL: The Adt gate excludes primitives even though stdlib's
/// `impl PartialEq for i32 { fn eq(self, other) { *self == *other } }`
/// (and friends) registers an eq method for every primitive. Without
/// this gate, my dispatcher would route i32 == i32 inside the primitive
/// eq body recursively into itself, causing infinite recursion at
/// runtime. Primitives must always fall through to the default
/// emit_binop_typed path (icmp/fcmp). Adt-typed operands (user structs/
/// enums + builtin Adts not handled by S98-S103) are the legitimate
/// targets of user-impl dispatch.
fn operand_is_user_partial_eq(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            let stripped = if type_intern.is_ref_id(id) {
                let inner = type_intern.unwrap_ref_id(id);
                if type_intern.is_ref_id(inner) { return false; }
                inner
            } else {
                id
            };
            match type_intern.get_adt_def_id(stripped) {
                Option.Some(_) => {}
                Option.None => { return false; }
            }
            match ctx.lookup_eq_method(stripped.index) {
                Option.Some(_) => true,
                Option.None => false,
            }
        }
        Option.None => false,
    }
}

/// Materializes an operand as a `{ ptr, i32 }` fat-ref suitable for passing
/// to a user-defined `eq(self: &Self, other: &Self)` method. Returns the
/// SSA name as a String for direct use in `call_arg_str`.
///
/// - `is_ref=true`: operand already loads as `{ ptr, i32 }` — pass through.
/// - `is_ref=false`: spill to a fresh alloca, store the loaded value, build
///   `{ ptr, i32 }` with gen=0. Stack-frame liveness guarantees the alloca
///   is valid for the duration of the eq call. gen=0 makes the user's
///   eq-side derefs skip stale-ref validation; codegen_place.blood:869-874
///   documents the gen=0 sentinel for stack-allocated refs.
fn build_user_eq_arg_str(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
    is_ref: bool,
) -> String {
    let (val, ty) = emit_operand_typed(ctx, operand);
    if is_ref {
        return val;
    }
    let spill = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&spill);
    ctx.write(" = alloca ");
    ctx.write(ty.as_str());
    ctx.write("\n");
    ctx.write_indent();
    ctx.write("store ");
    ctx.write(ty.as_str());
    ctx.write(" ");
    ctx.write(val.as_str());
    ctx.write(", ptr ");
    ctx.write_cgname(&spill);
    ctx.write("\n");
    let step1 = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&step1);
    ctx.write(" = insertvalue { ptr, i32 } zeroinitializer, ptr ");
    ctx.write_cgname(&spill);
    ctx.write(", 0\n");
    let fat_ref = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&fat_ref);
    ctx.write(" = insertvalue { ptr, i32 } ");
    ctx.write_cgname(&step1);
    ctx.write(", i32 0, 1\n");
    cgname_to_string(&fat_ref)
}

/// Routes `==` / `!=` on a user-defined type with `impl PartialEq` to the
/// user's `eq` method directly. Closes the S105 typeck/codegen UX gap where
/// `derive(PartialEq) struct Point + p1 == p2` passes typeck (impl exists)
/// but reaches codegen's S104-B fatal because the default binop path
/// extracts only field 0 of a multi-field aggregate. After this dispatch:
/// the user's `eq(self: &Self, other: &Self) -> bool` is called with both
/// operands materialized as `{ ptr, i32 }` fat-refs. Single-layer ref only
/// — multi-layer `&&T` falls through. Returns true if the binop was handled
/// here; the caller should skip the default path.
fn try_emit_binop_user_partial_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_user_partial_eq(ctx, left) || !operand_is_user_partial_eq(ctx, right) {
        return false;
    }
    let left_ty_id = match operand_ty_id(ctx, left) {
        Option.Some(id) => id,
        Option.None => { return false; }
    };
    let is_ref = type_intern.is_ref_id(left_ty_id);
    let stripped = if is_ref { type_intern.unwrap_ref_id(left_ty_id) } else { left_ty_id };
    let method_def_id = match ctx.lookup_eq_method(stripped.index) {
        Option.Some(d) => d,
        Option.None => { return false; }
    };
    let eq_target = match ctx.lookup_def_name(method_def_id) {
        Option.Some(n) => n,
        Option.None => { return false; }
    };
    let left_arg = build_user_eq_arg_str(ctx, left, is_ref);
    let right_arg = build_user_eq_arg_str(ctx, right, is_ref);
    let mut symbol = common.make_string("@");
    symbol.push_str(eq_target.as_str());
    let result = ctx.fresh_temp_cg();
    ctx.begin_call(Option.Some(&result), "i1", symbol.as_str());
    ctx.call_arg_str(true, "{ ptr, i32 }", left_arg.as_str());
    ctx.call_arg_str(false, "{ ptr, i32 }", right_arg.as_str());
    ctx.end_call();
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand has type Tuple with >= 2 elements. Empty tuples are
/// LLVM `{}` (handled by emit_binop_typed's unit early-return), and
/// single-element tuples are sound under emit_binop_typed's existing
/// single-field-wrapper extract+recurse path. Multi-element tuples are
/// the case where the default path silently picks field 0 — that's
/// what S104-B's fatal catches and what this dispatcher resolves.
fn operand_is_tuple_value(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            match type_intern.type_interner().get(id) {
                &type_intern.InternedTypeKind.Tuple(list_id) => {
                    type_intern.type_interner().ty_list_len(list_id) >= 2
                }
                _ => false,
            }
        }
        Option.None => false,
    }
}

/// True if operand has type Array `[T; N]` for any N (including 0 and 1).
/// Pre-S107 the default emit_binop_typed path's aggregate guard checks
/// `ty_bytes[0] == '{'` which doesn't catch `[N x T]`, so an unrouted
/// Array Eq/Ne reaches `icmp eq [N x T]` and llc rejects with "icmp
/// requires integer operands". Every Array Eq/Ne must come through this
/// dispatcher to avoid an llc-level error.
fn operand_is_array_value(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            match type_intern.type_interner().get(id) {
                &type_intern.InternedTypeKind.Array { element: _, size: _ } => true,
                _ => false,
            }
        }
        Option.None => false,
    }
}

/// Per-element eq dispatch for a Tuple/Array element pair. Recurses
/// into nested Tuples and Arrays so arbitrarily-deep structural nesting
/// (e.g. `((i32, i32), [i64; 4]) == ...`) emits correct element-wise
/// compare. Other element types — primitives + single-field wrappers —
/// fall through to emit_binop_typed which handles them correctly
/// (icmp/fcmp for primitives, extract+recurse for single-field).
///
/// Multi-field aggregate elements that have their own dedicated
/// dispatcher in the outer chain (str/String/&String/&[T]/Vec/&Vec/
/// user-Adt with `impl PartialEq`) are NOT routed through that chain
/// here — they reach emit_binop_typed and hit S104-B's fatal. This is
/// a documented limitation: in practice, tuples and arrays of those
/// types are rare in selfhost source. Future sessions can extend this
/// dispatcher to forward those element types through their dedicated
/// dispatchers, mirroring the top-level chain on raw SSA pairs.
///
/// Returns the i1 SSA name holding the element-equality result.
fn dispatch_eq_element_typed(
    ctx: &mut codegen_ctx.CodegenCtx,
    left_ssa: &str,
    right_ssa: &str,
    elem_ty_id: type_intern.TyId,
    elem_llvm: &str,
) -> codegen_ctx.CgName {
    let interner = type_intern.type_interner();
    match interner.get(elem_ty_id) {
        &type_intern.InternedTypeKind.Tuple(_) => {
            return emit_tuple_eq_typed(ctx, left_ssa, right_ssa, elem_ty_id);
        }
        &type_intern.InternedTypeKind.Array { element: _, size: _ } => {
            return emit_array_eq_typed(ctx, left_ssa, right_ssa, elem_ty_id);
        }
        _ => {}
    }
    let left_str = common.make_string(left_ssa);
    let right_str = common.make_string(right_ssa);
    emit_binop_typed(ctx, &mir_types.MirBinOp.Eq, &left_str, &right_str, elem_llvm, true)
}

/// Element-wise eq for a Tuple via extractvalue + AND-chain. Returns
/// the final i1 SSA. Vacuously-true for empty tuples (nested empty
/// tuple `()` element). Caller is responsible for the outer Eq vs Ne
/// finalization (Ne = xor result, true).
fn emit_tuple_eq_typed(
    ctx: &mut codegen_ctx.CodegenCtx,
    left_ssa: &str,
    right_ssa: &str,
    ty_id: type_intern.TyId,
) -> codegen_ctx.CgName {
    let interner = type_intern.type_interner();
    let list_id = match interner.get(ty_id) {
        &type_intern.InternedTypeKind.Tuple(lid) => lid,
        _ => {
            let placeholder = ctx.fresh_temp_cg();
            ctx.emit_icmp_cg(&placeholder, "eq", "i1", "1", "1");
            return placeholder;
        }
    };
    let len = interner.ty_list_len(list_id);
    let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, ty_id);

    if len == 0 {
        let vacuous = ctx.fresh_temp_cg();
        ctx.emit_icmp_cg(&vacuous, "eq", "i1", "1", "1");
        return vacuous;
    }

    // Build AND-chain. Initial accumulator is the literal `true`; the first
    // iteration emits `and i1 true, %elem0` (LLVM accepts inline booleans).
    // Subsequent iterations chain through fresh SSA temps.
    let mut acc_str = common.make_string("true");
    let mut last_cg: codegen_ctx.CgName = codegen_ctx.CgName.Str(common.make_string("true"));
    for i in 0usize..len {
        let elem_ty_id = interner.get_ty_list_element(list_id, i);
        let elem_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, elem_ty_id);
        let left_i = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&left_i);
        ctx.write(" = extractvalue ");
        ctx.write(llvm_ty.as_str());
        ctx.write(" ");
        ctx.write(left_ssa);
        ctx.write(", ");
        ctx.write(common.format_usize(i).as_str());
        ctx.write("\n");
        let right_i = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&right_i);
        ctx.write(" = extractvalue ");
        ctx.write(llvm_ty.as_str());
        ctx.write(" ");
        ctx.write(right_ssa);
        ctx.write(", ");
        ctx.write(common.format_usize(i).as_str());
        ctx.write("\n");

        let left_i_str = cgname_to_string(&left_i);
        let right_i_str = cgname_to_string(&right_i);
        let elem_eq = dispatch_eq_element_typed(
            ctx,
            left_i_str.as_str(),
            right_i_str.as_str(),
            elem_ty_id,
            elem_llvm.as_str(),
        );

        let next = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&next);
        ctx.write(" = and i1 ");
        ctx.write(acc_str.as_str());
        ctx.write(", ");
        ctx.write_cgname(&elem_eq);
        ctx.write("\n");
        acc_str = cgname_to_string(&next);
        last_cg = next;
    }
    last_cg
}

/// Element-wise eq for an Array `[T; N]` via extractvalue + AND-chain.
/// Returns the final i1 SSA. Vacuously-true for `[T; 0]`. Caller
/// finalizes Eq vs Ne.
fn emit_array_eq_typed(
    ctx: &mut codegen_ctx.CodegenCtx,
    left_ssa: &str,
    right_ssa: &str,
    ty_id: type_intern.TyId,
) -> codegen_ctx.CgName {
    let interner = type_intern.type_interner();
    let (elem_id, size) = match interner.get(ty_id) {
        &type_intern.InternedTypeKind.Array { element, size } => (element, size),
        _ => {
            let placeholder = ctx.fresh_temp_cg();
            ctx.emit_icmp_cg(&placeholder, "eq", "i1", "1", "1");
            return placeholder;
        }
    };
    let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, ty_id);
    let elem_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, elem_id);

    if size == 0 {
        let vacuous = ctx.fresh_temp_cg();
        ctx.emit_icmp_cg(&vacuous, "eq", "i1", "1", "1");
        return vacuous;
    }

    let mut acc_str = common.make_string("true");
    let mut last_cg: codegen_ctx.CgName = codegen_ctx.CgName.Str(common.make_string("true"));
    let mut i: u64 = 0;
    while i < size {
        let left_i = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&left_i);
        ctx.write(" = extractvalue ");
        ctx.write(llvm_ty.as_str());
        ctx.write(" ");
        ctx.write(left_ssa);
        ctx.write(", ");
        ctx.write(common.format_usize(i as usize).as_str());
        ctx.write("\n");
        let right_i = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&right_i);
        ctx.write(" = extractvalue ");
        ctx.write(llvm_ty.as_str());
        ctx.write(" ");
        ctx.write(right_ssa);
        ctx.write(", ");
        ctx.write(common.format_usize(i as usize).as_str());
        ctx.write("\n");

        let left_i_str = cgname_to_string(&left_i);
        let right_i_str = cgname_to_string(&right_i);
        let elem_eq = dispatch_eq_element_typed(
            ctx,
            left_i_str.as_str(),
            right_i_str.as_str(),
            elem_id,
            elem_llvm.as_str(),
        );

        let next = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&next);
        ctx.write(" = and i1 ");
        ctx.write(acc_str.as_str());
        ctx.write(", ");
        ctx.write_cgname(&elem_eq);
        ctx.write("\n");
        acc_str = cgname_to_string(&next);
        last_cg = next;
        i += 1;
    }
    last_cg
}

/// Routes `==` and `!=` on a Tuple value to per-element equality with
/// an AND-chain. Closes the typeck/codegen UX gap where S105 auto-
/// derives PartialEq for tuples whose elements are PartialEq, but the
/// default codegen path silently picks field 0 of a multi-field
/// aggregate (caught by S104-B's fatal pre-S107). Single-layer only —
/// `&Tuple` falls through. Returns true if the binop was handled here.
fn try_emit_binop_tuple_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_tuple_value(ctx, left) || !operand_is_tuple_value(ctx, right) {
        return false;
    }
    let ty_id = match operand_ty_id(ctx, left) {
        Option.Some(id) => id,
        Option.None => { return false; }
    };
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let result = emit_tuple_eq_typed(ctx, left_val.as_str(), right_val.as_str(), ty_id);
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// Routes `==` and `!=` on an Array `[T; N]` to per-index equality
/// with an AND-chain. Pre-S107 the default emit_binop_typed path emits
/// raw `icmp eq [N x T]` which llc rejects (icmp requires integer
/// operands), so every Array Eq/Ne must come through here. Empty
/// arrays (`[T; 0]`) compare vacuously equal.
fn try_emit_binop_array_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_array_value(ctx, left) || !operand_is_array_value(ctx, right) {
        return false;
    }
    let ty_id = match operand_ty_id(ctx, left) {
        Option.Some(id) => id,
        Option.None => { return false; }
    };
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let result = emit_array_eq_typed(ctx, left_val.as_str(), right_val.as_str(), ty_id);
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// True if operand is `&Tuple` — exactly one Ref layer wrapping a Tuple
/// of >= 2 elements. Mutually exclusive with `operand_is_tuple_value`
/// (which requires the operand type itself be Tuple, not Ref). Mirrors
/// S100's String value/ref split per the predicate-split rule:
/// `operand_ty_id` does NOT follow Place projections, so `&Tuple` and
/// `Tuple` need separate predicates and dispatchers.
fn operand_is_tuple_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            if !type_intern.is_ref_id(id) { return false; }
            let inner = type_intern.unwrap_ref_id(id);
            match type_intern.type_interner().get(inner) {
                &type_intern.InternedTypeKind.Tuple(list_id) => {
                    type_intern.type_interner().ty_list_len(list_id) >= 2
                }
                _ => false,
            }
        }
        Option.None => false,
    }
}

/// True if operand is `&[T; N]` — exactly one Ref layer wrapping an
/// Array. Mutually exclusive with `operand_is_array_value`.
fn operand_is_array_ref(ctx: &mut codegen_ctx.CodegenCtx, operand: &mir_types.Operand) -> bool {
    match operand_ty_id(ctx, operand) {
        Option.Some(id) => {
            if !type_intern.is_ref_id(id) { return false; }
            let inner = type_intern.unwrap_ref_id(id);
            match type_intern.type_interner().get(inner) {
                &type_intern.InternedTypeKind.Array { element: _, size: _ } => true,
                _ => false,
            }
        }
        Option.None => false,
    }
}

/// Loads an inner aggregate value from a `{ ptr, i32 }` fat ref. Two-step
/// deref: extract field 0 (ptr to the inner alloca), then load the
/// underlying aggregate. Used by S108's `&Tuple` / `&Array` dispatchers
/// to materialize the value before reusing S107's `emit_tuple_eq_typed`
/// / `emit_array_eq_typed`. `inner_llvm_ty` must be the LLVM type string
/// of the inner aggregate (e.g. `"{ i32, i32 }"` or `"[3 x i32]"`).
fn extract_aggregate_ref_value(
    ctx: &mut codegen_ctx.CodegenCtx,
    ref_val: &str,
    inner_llvm_ty: &str,
) -> codegen_ctx.CgName {
    let alloca_ptr = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&alloca_ptr);
    ctx.write(" = extractvalue { ptr, i32 } ");
    ctx.write(ref_val);
    ctx.write(", 0\n");
    let loaded = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&loaded);
    ctx.write(" = load ");
    ctx.write(inner_llvm_ty);
    ctx.write(", ptr ");
    ctx.write_cgname(&alloca_ptr);
    ctx.write("\n");
    loaded
}

/// Routes `==` and `!=` on a `&Tuple` to per-element equality after
/// dereferencing. Mirrors `try_emit_binop_tuple_eq` (S107) with one
/// extra deref step: extracts the alloca ptr from the `{ ptr, i32 }`
/// fat ref, loads the inner Tuple aggregate, then invokes S107's
/// `emit_tuple_eq_typed` with the unwrapped inner ty_id. Closes the
/// typeck-accepted `&Tuple == &Tuple` shape that previously hit S104-B's
/// fatal because the default path extracts only field 0 of the
/// `{ ptr, i32 }` fat ref. Single-layer only — `& &Tuple` falls through.
fn try_emit_binop_tuple_ref_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_tuple_ref(ctx, left) || !operand_is_tuple_ref(ctx, right) {
        return false;
    }
    let outer_ty_id = match operand_ty_id(ctx, left) {
        Option.Some(id) => id,
        Option.None => { return false; }
    };
    let inner_ty_id = type_intern.unwrap_ref_id(outer_ty_id);
    let inner_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, inner_ty_id);
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_loaded = extract_aggregate_ref_value(ctx, left_val.as_str(), inner_llvm.as_str());
    let right_loaded = extract_aggregate_ref_value(ctx, right_val.as_str(), inner_llvm.as_str());
    let left_loaded_str = cgname_to_string(&left_loaded);
    let right_loaded_str = cgname_to_string(&right_loaded);
    let result = emit_tuple_eq_typed(ctx, left_loaded_str.as_str(), right_loaded_str.as_str(), inner_ty_id);
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// Routes `==` and `!=` on a `&[T; N]` to per-index equality after
/// dereferencing. Mirrors `try_emit_binop_array_eq` (S107) with one
/// extra deref step. Single-layer only — `& &[T; N]` falls through.
fn try_emit_binop_array_ref_eq(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &mir_types.Operand,
    right: &mir_types.Operand,
    dest: &str,
) -> bool {
    let is_eq = match bin_op {
        &mir_types.MirBinOp.Eq => true,
        _ => false,
    };
    let is_ne = match bin_op {
        &mir_types.MirBinOp.Ne => true,
        _ => false,
    };
    if !is_eq && !is_ne {
        return false;
    }
    if !operand_is_array_ref(ctx, left) || !operand_is_array_ref(ctx, right) {
        return false;
    }
    let outer_ty_id = match operand_ty_id(ctx, left) {
        Option.Some(id) => id,
        Option.None => { return false; }
    };
    let inner_ty_id = type_intern.unwrap_ref_id(outer_ty_id);
    let inner_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, inner_ty_id);
    let (left_val, _) = emit_operand_typed(ctx, left);
    let (right_val, _) = emit_operand_typed(ctx, right);
    let left_loaded = extract_aggregate_ref_value(ctx, left_val.as_str(), inner_llvm.as_str());
    let right_loaded = extract_aggregate_ref_value(ctx, right_val.as_str(), inner_llvm.as_str());
    let left_loaded_str = cgname_to_string(&left_loaded);
    let right_loaded_str = cgname_to_string(&right_loaded);
    let result = emit_array_eq_typed(ctx, left_loaded_str.as_str(), right_loaded_str.as_str(), inner_ty_id);
    if is_eq {
        ctx.emit_store_cg("i1", &result, dest);
    } else {
        let neg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&neg);
        ctx.write(" = xor i1 ");
        ctx.write_cgname(&result);
        ctx.write(", true\n");
        ctx.emit_store_cg("i1", &neg, dest);
    }
    true
}

/// Generates LLVM IR for an rvalue, storing result at dest.
pub fn emit_rvalue(
    ctx: &mut codegen_ctx.CodegenCtx,
    dest: &str,
    dest_type: &str,
    rvalue: &mir_types.Rvalue,
) {
    match rvalue {
        &mir_types.Rvalue.Use(ref operand) => {
            let t_arm = blood_clock_millis();
            @unsafe { RV_C_USE += 1; }
            let (val, ty) = emit_operand_typed(ctx, operand);
            // Skip store for unit type {} — it has zero size in LLVM
            if !str_eq(ty.as_str(), "{}") {
                ctx.emit_store(ty.as_str(), val.as_str(), dest);
            }
            @unsafe { RV_T_USE_MS += blood_clock_millis() - t_arm; }
        }
        &mir_types.Rvalue.Ref { ref place, mutable: _ } => {
            let t_arm = blood_clock_millis();
            @unsafe { RV_C_REF += 1; }
            let addr = codegen_place.emit_place_data_ptr(ctx, place);
            // Create generational fat reference: { ptr, gen:i32 }
            // %tmp1 = insertvalue { ptr, i32 } zeroinitializer, ptr %addr, 0
            let tmp1 = ctx.fresh_temp_cg();
            ctx.write("  ");
            ctx.write_cgname(&tmp1);
            ctx.write(" = insertvalue { ptr, i32 } zeroinitializer, ptr ");
            ctx.write(addr.as_str());
            ctx.write(", 0\n");
            // Determine generation for the derived reference.
            // - No projections: use _gen alloca (direct &local)
            // - Field/Index on a value-typed local: inherit _gen alloca
            // - Deref projection or ref-typed local with field: propagate gen
            //   from the source fat ref (extract embedded gen field)
            let mut has_deref_projection = false;
            for pi in 0usize..place.projection.len() {
                match &place.projection[pi] {
                    &mir_types.PlaceElem.Deref => { has_deref_projection = true; }
                    _ => {}
                }
            }
            // For ref-typed locals, field access goes through the stored reference.
            // The _gen alloca tracks the container, not the referenced data.
            if !has_deref_projection && place.projection.len() > 0 {
                let local_llvm_ty = ctx.get_local_type(place.local);
                if str_eq(local_llvm_ty.as_str(), "{ ptr, i32 }") || str_eq(local_llvm_ty.as_str(), "{ ptr, ptr, i32 }") {
                    has_deref_projection = true;
                }
            }
            let tmp2 = ctx.fresh_temp_cg();
            if !has_deref_projection {
                match ctx.get_heap_gen_name(place.local) {
                    Option.Some(gen_name) => {
                        // Load generation from the _gen alloca
                        let gen_tmp = ctx.fresh_temp_cg();
                        ctx.write("  ");
                        ctx.write_cgname(&gen_tmp);
                        ctx.write(" = load i32, ptr ");
                        ctx.write(gen_name.as_str());
                        ctx.write("\n");
                        ctx.write("  ");
                        ctx.write_cgname(&tmp2);
                        ctx.write(" = insertvalue { ptr, i32 } ");
                        ctx.write_cgname(&tmp1);
                        ctx.write(", i32 ");
                        ctx.write_cgname(&gen_tmp);
                        ctx.write(", 1\n");
                    }
                    Option.None => {
                        // Stack-allocated reference: gen=0 sentinel.
                        //
                        // DESIGN INTENT: stack-allocated locals have a lifetime bound
                        // to the enclosing function's stack frame. A `&local` taken
                        // inside the function cannot outlive that frame because Blood
                        // MVS captures values, not references — a linear `&local`
                        // cannot escape into a longer-lived context.
                        //
                        // Runtime behavior: codegen_place.blood's deref path branches
                        // on gen=0 and skips `blood_validate_generation` entirely
                        // (see codegen_place.blood:869-874). This is a zero-overhead
                        // optimization, not a soundness compromise — the stack frame
                        // itself is the lifetime witness.
                        //
                        // Soundness invariant: if a stack `&local` ever escapes into
                        // a longer-lived context, BC-01 (E0503) rejects it at
                        // compile time. The gen=0 here is predicated on that check
                        // having fired for any escape path.
                        ctx.write("  ");
                        ctx.write_cgname(&tmp2);
                        ctx.write(" = insertvalue { ptr, i32 } ");
                        ctx.write_cgname(&tmp1);
                        ctx.write(", i32 0, 1\n");
                    }
                }
            } else {
                // Deref chain: propagate gen from the source fat reference.
                // If the base local is a gen ref ({ ptr, i32 } or { ptr, ptr, i32 }),
                // extract its embedded gen. Otherwise gen=0 (thin pointer).
                let local_ty = ctx.get_local_type(place.local);
                let is_gen_ref = str_eq(local_ty.as_str(), "{ ptr, i32 }");
                let is_dyn_gen_ref = str_eq(local_ty.as_str(), "{ ptr, ptr, i32 }");
                if is_gen_ref || is_dyn_gen_ref {
                    let load_ty = if is_dyn_gen_ref { "{ ptr, ptr, i32 }" } else { "{ ptr, i32 }" };
                    let gen_field_str = if is_dyn_gen_ref { "2" } else { "1" };
                    // Get the local's alloca address, handling heap indirection
                    let local_cg = ctx.local_cg(place.local);
                    let load_src = if ctx.is_region_allocated(place.local) || ctx.is_persistent_allocated(place.local) {
                        let heap_ptr = ctx.fresh_temp_cg();
                        ctx.emit_load_cg2(&heap_ptr, "ptr", &local_cg);
                        heap_ptr
                    } else {
                        local_cg
                    };
                    // Load fat ref and extract gen field
                    let fat_ref = ctx.fresh_temp_cg();
                    ctx.emit_load_cg2(&fat_ref, load_ty, &load_src);
                    let gen_val = ctx.fresh_temp_cg();
                    ctx.write("  ");
                    ctx.write_cgname(&gen_val);
                    ctx.write(" = extractvalue ");
                    ctx.write(load_ty);
                    ctx.write(" ");
                    ctx.write_cgname(&fat_ref);
                    ctx.write(", ");
                    ctx.write(gen_field_str);
                    ctx.write("\n");
                    // Create fat ref with propagated gen
                    ctx.write("  ");
                    ctx.write_cgname(&tmp2);
                    ctx.write(" = insertvalue { ptr, i32 } ");
                    ctx.write_cgname(&tmp1);
                    ctx.write(", i32 ");
                    ctx.write_cgname(&gen_val);
                    ctx.write(", 1\n");
                } else {
                    // Thin pointer or unsized ref at the source of a deref chain:
                    // gen=0 sentinel.
                    //
                    // DESIGN INTENT: thin pointers (`*const T`, `*mut T`) and
                    // unsized references carry no generation field, so any derived
                    // reference through a deref chain cannot inherit a real gen.
                    //
                    // Runtime behavior: deref validation becomes a no-op for this
                    // derived ref. The soundness story is: thin pointers are
                    // @unsafe territory — code touching them has already opted out
                    // of generation tracking by choosing raw pointers. The gen=0
                    // is consistent with that opt-out.
                    //
                    // See also: docs/KNOWN_LIMITATIONS.md "Pillar 1" — thin-ptr
                    // gen=0 is documented as an intentional boundary between the
                    // safe fat-ref path and the @unsafe raw-pointer path.
                    ctx.write("  ");
                    ctx.write_cgname(&tmp2);
                    ctx.write(" = insertvalue { ptr, i32 } ");
                    ctx.write_cgname(&tmp1);
                    ctx.write(", i32 0, 1\n");
                }
            }
            // store { ptr, i32 } %tmp2, ptr %dest
            ctx.emit_store_cg("{ ptr, i32 }", &tmp2, dest);
            @unsafe { RV_T_REF_MS += blood_clock_millis() - t_arm; }
        }
        &mir_types.Rvalue.BinaryOp { operator: ref bin_op, ref left, ref right } => {
            let t_arm = blood_clock_millis();
            @unsafe { RV_C_BINOP += 1; }
            // S98: short-circuit &str equality through @str_eq runtime to avoid
            // the {ptr,i64} aggregate-extract path's pointer-equality miscompile.
            if try_emit_binop_str_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S99: same routing for direct String == String — `{ ptr, i64, i64 }`
            // aggregate extracts to data ptr and pointer-compares; needs byte
            // comparison instead. Builds { ptr, i64 } views and dispatches to
            // the same @str_eq runtime function.
            if try_emit_binop_string_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S100: extends the String-eq family to `&String` operands. Loaded
            // value is `{ ptr, i32 }` (fat ref), not the String aggregate, so
            // the default path pointer-compares two distinct alloca addresses.
            // Derefs each operand to load the underlying String, then runs
            // through the same @str_eq pipeline S99 set up.
            if try_emit_binop_string_ref_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S103-B: closes the multi-layer-ref hole left by S100. `& &String`
            // loads as `{ ptr, i32 }` (outer fat ref) whose ptr addresses the
            // inner ref's alloca, which itself loads as another `{ ptr, i32 }`.
            // Same root cause as S100 but one indirection deeper.
            if try_emit_binop_string_ref_ref_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S102: extends the eq family to slice operands. `&[T]` loads as
            // `{ ptr, i64 }` (data ptr + element count) — same shape as `&str`
            // but with element count instead of byte count. Default path
            // extracts the ptr field and pointer-compares — wrong for distinct
            // allocations. Multiplies count by elem_size to get byte length,
            // builds `{ ptr, i64-bytes }` view, and dispatches via the same
            // @str_eq runtime. Correct for integer-element slices; see
            // try_emit_binop_slice_eq's comment for the float/aggregate caveat.
            if try_emit_binop_slice_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S103-C: extends the eq family to `Vec<T>` value operands. Vec
            // loads as `{ ptr, i64, i64 }` (data + len + cap); default path
            // picks data ptr and pointer-compares — wrong for distinct
            // allocations regardless of content. Multiplies len by elem_size
            // to a byte count, drops cap to match the `{ ptr, i64 }` view,
            // dispatches through @str_eq. Same partial-fix caveat as slice
            // eq for float/aggregate elements.
            if try_emit_binop_vec_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S103-C: handles the `&Vec<T>` shape parallel to vec_eq. The fat
            // ref `{ ptr, i32 }` derefs to the Vec aggregate before reusing
            // the same view-extract + @str_eq pipeline. Mirrors S100's split
            // between String value and `&String` ref handlers.
            if try_emit_binop_vec_ref_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S106: dispatches `==` and `!=` on a user-defined type with an
            // `impl PartialEq` (manual or `#[derive(PartialEq)]`). Looks up
            // the user's `eq` method via the codegen registry; if present,
            // materializes both operands as `{ ptr, i32 }` fat-refs and
            // calls the method directly. Closes the S105 typeck/codegen UX
            // gap where derived/manual PartialEq impls pass typeck but
            // reach S104-B's fatal because the default binop path extracts
            // only field 0 of a multi-field aggregate. Single-layer ref
            // only.
            if try_emit_binop_user_partial_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S107: tuple `(T1, .., Tn) == ..` and `!=`. S105 auto-derives
            // PartialEq for tuples whose elements are PartialEq; pre-S107
            // the multi-field aggregate reached S104-B's fatal. This
            // dispatcher emits per-element extractvalue + recursive eq
            // dispatch (nested tuples/arrays handled by recursion) +
            // AND-chain.
            if try_emit_binop_tuple_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S108: `&Tuple == &Tuple` mirror with one Ref unwrap. The
            // fat-ref `{ ptr, i32 }` derefs to the tuple aggregate before
            // reusing S107's emit_tuple_eq_typed pipeline. Matches the
            // S99/S100 String value/ref split convention.
            if try_emit_binop_tuple_ref_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S107: array `[T; N] == ..` and `!=`. Pre-S107 the default
            // path's aggregate guard checks `{` not `[`, so `[N x T]`
            // reached `icmp eq [N x T]` and llc rejected. This dispatcher
            // mirrors tuple_eq with index-based extractvalue.
            if try_emit_binop_array_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // S108: `&[T; N] == &[T; N]` mirror with one Ref unwrap.
            // Same Ref-deref step as tuple_ref_eq, then reuses S107's
            // emit_array_eq_typed pipeline.
            if try_emit_binop_array_ref_eq(ctx, bin_op, left, right, dest) {
                @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
                return;
            }
            // Get typed operands
            let (left_val, left_ty) = emit_operand_typed(ctx, left);
            let (right_val, right_ty) = emit_operand_typed(ctx, right);
            // Determine signedness from the left operand's type
            let is_signed = operand_is_signed(ctx, left);
            // Coerce right operand to match left type if they differ
            let coerced_right = if !string_eq_str(left_ty.as_str(), right_ty.as_str()) {
                let left_w = llvm_int_bit_width(left_ty.as_str());
                let right_w = llvm_int_bit_width(right_ty.as_str());
                if left_w > 0 && right_w > 0 {
                    // Both are integer types - truncate or extend
                    let cast = ctx.fresh_temp_cg();
                    if right_w > left_w {
                        ctx.emit_cast_cg(&cast, "trunc", right_ty.as_str(), right_val.as_str(), left_ty.as_str());
                    } else {
                        if is_signed {
                            ctx.emit_cast_cg(&cast, "sext", right_ty.as_str(), right_val.as_str(), left_ty.as_str());
                        } else {
                            ctx.emit_cast_cg(&cast, "zext", right_ty.as_str(), right_val.as_str(), left_ty.as_str());
                        }
                    }
                    cgname_to_string(&cast)
                } else {
                    right_val
                }
            } else {
                right_val
            };
            // Use the left operand's type for the binary operation
            let result = emit_binop_typed(ctx, bin_op, &left_val, &coerced_right, left_ty.as_str(), is_signed);
            // For comparison operations, result is i1 (bool)
            if bin_op.is_comparison() {
                ctx.emit_store_cg("i1", &result, dest);
            } else {
                ctx.emit_store_cg(left_ty.as_str(), &result, dest);
            }
            @unsafe { RV_T_BINOP_MS += blood_clock_millis() - t_arm; }
        }
        &mir_types.Rvalue.UnaryOp { operator: ref un_op, ref operand } => {
            let (val, ty) = emit_operand_typed(ctx, operand);
            let result = emit_unop_typed(ctx, un_op, &val, ty.as_str());
            ctx.emit_store_cg(ty.as_str(), &result, dest);
        }
        &mir_types.Rvalue.AddressOf { ref place, mutable: _ } => {
            let addr = codegen_place.emit_place_data_ptr(ctx, place);
            ctx.emit_store("ptr", addr.as_str(), dest);
        }
        &mir_types.Rvalue.ArrayToSlice { ref array_ref, array_len } => {
            // Convert array ref to fat pointer (ptr + len).
            // Slices are represented as { ptr, i64 } in LLVM IR.
            // Gen from the source array ref is packed into upper 32 bits of i64.
            let (arr_val, arr_ty) = emit_operand_typed(ctx, array_ref);

            // Strip gen ref { ptr, i32 } to bare ptr, capturing gen for packing
            let mut data_ptr: String;
            let mut has_gen: bool = false;
            let gen_tmp = ctx.fresh_temp_cg();
            if str_eq(arr_ty.as_str(), "{ ptr, i32 }") {
                let stripped = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&stripped);
                ctx.write(" = extractvalue { ptr, i32 } ");
                ctx.write_string(&arr_val);
                ctx.write(", 0\n");
                data_ptr = cgname_to_string(&stripped);
                // Extract gen from field 1
                ctx.write_indent();
                ctx.write_cgname(&gen_tmp);
                ctx.write(" = extractvalue { ptr, i32 } ");
                ctx.write_string(&arr_val);
                ctx.write(", 1\n");
                has_gen = true;
            } else {
                data_ptr = arr_val;
            }

            // Store pointer at offset 0 of the fat pointer
            let ptr_field = ctx.fresh_temp_cg();
            ctx.begin_gep_str(&ptr_field, "{ ptr, i64 }", dest);
            ctx.gep_ptr_offset(0);
            ctx.gep_field(0);
            ctx.end_gep();
            ctx.emit_store_str_cg("ptr", data_ptr.as_str(), &ptr_field);

            // Store length (with packed gen) at offset 1 of the fat pointer
            let len_field = ctx.fresh_temp_cg();
            ctx.begin_gep_str(&len_field, "{ ptr, i64 }", dest);
            ctx.gep_ptr_offset(0);
            ctx.gep_field(1);
            ctx.end_gep();
            if has_gen {
                // Pack: (zext gen to i64) << 32 | array_len
                let gen_ext = ctx.fresh_temp_cg();
                ctx.write("  ");
                ctx.write_cgname(&gen_ext);
                ctx.write(" = zext i32 ");
                ctx.write_cgname(&gen_tmp);
                ctx.write(" to i64\n");
                let gen_shifted = ctx.fresh_temp_cg();
                ctx.write("  ");
                ctx.write_cgname(&gen_shifted);
                ctx.write(" = shl i64 ");
                ctx.write_cgname(&gen_ext);
                ctx.write(", 32\n");
                let packed = ctx.fresh_temp_cg();
                ctx.write("  ");
                ctx.write_cgname(&packed);
                ctx.write(" = or i64 ");
                ctx.write_cgname(&gen_shifted);
                ctx.write(", ");
                let len_val = codegen_types.format_u64(array_len);
                ctx.write(len_val.as_str());
                ctx.write("\n");
                ctx.emit_store_cg2("i64", &packed, &len_field);
            } else {
                let len_val = codegen_types.format_u64(array_len);
                ctx.emit_store_str_cg("i64", len_val.as_str(), &len_field);
            }
        }
        &mir_types.Rvalue.ZeroInit(ref ty) => {
            // Zero-initialize the destination
            let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, *ty);
            // Skip store for unit type {} — it has zero size in LLVM
            if !str_eq(llvm_ty.as_str(), "{}") {
                let zero = get_zero_value(llvm_ty.as_str());
                ctx.emit_store(llvm_ty.as_str(), zero.as_str(), dest);
            }
        }
        &mir_types.Rvalue.Cast { ref operand, ref target_ty } => {
            let t_arm = blood_clock_millis();
            @unsafe { RV_C_CAST += 1; }
            // Special case: FnDef constant cast to integer. Use the raw function
            // pointer (not the fat-pointer wrapper) so that `fn as u64` gives
            // the direct function address expected by low-level APIs like thread_spawn.
            let mut handled = false;
            match operand {
                &mir_types.Operand.Constant(ref constant) => {
                    match &constant.kind {
                        &mir_types.ConstantKind.FnDef(ref def_id) => {
                            let tgt_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, *target_ty);
                            let tgt_is_int = !string_starts_with(tgt_llvm.as_str(), "ptr") &&
                                             !string_starts_with(tgt_llvm.as_str(), "{") &&
                                             !string_starts_with(tgt_llvm.as_str(), "float") &&
                                             !string_starts_with(tgt_llvm.as_str(), "double");
                            if tgt_is_int {
                                // Emit: ptrtoint ptr @fn_name to i64
                                let fn_val = emit_constant(ctx, constant);
                                let result = ctx.fresh_temp_cg();
                                ctx.emit_cast_cg(&result, "ptrtoint", "ptr", fn_val.as_str(), tgt_llvm.as_str());
                                ctx.emit_store_cg(tgt_llvm.as_str(), &result, dest);
                                handled = true;
                            }
                        }
                        _ => {}
                    }
                }
                _ => {}
            }
            // DynTrait coercion: T -> dyn Trait or &T -> &dyn Trait
            if !handled {
                let tgt_interned = type_intern.type_interner().get(*target_ty);
                let mut dyn_trait_id: Option<u32> = Option.None;
                match tgt_interned {
                    &type_intern.InternedTypeKind.DynTrait { trait_id, auto_traits: _ } => {
                        dyn_trait_id = Option.Some(trait_id.index);
                    }
                    &type_intern.InternedTypeKind.Ref { inner, mutable: _ } => {
                        let inner_kind = type_intern.type_interner().get(inner);
                        match inner_kind {
                            &type_intern.InternedTypeKind.DynTrait { trait_id, auto_traits: _ } => {
                                dyn_trait_id = Option.Some(trait_id.index);
                            }
                            _ => {}
                        }
                    }
                    _ => {}
                }
                match dyn_trait_id {
                    Option.Some(trait_def_id) => {
                        let (val, src_ty) = emit_operand_typed(ctx, operand);
                        // Extract concrete type DefId from source for vtable lookup
                        let src_ty_id: Option<type_intern.TyId> = match operand {
                            &mir_types.Operand.Copy(ref place) => ctx.get_local_hir_type(place.local),
                            &mir_types.Operand.Move(ref place) => ctx.get_local_hir_type(place.local),
                            &mir_types.Operand.Constant(ref c) => Option.Some(c.ty),
                        };
                        let mut concrete_def_id: Option<u32> = Option.None;
                        match src_ty_id {
                            Option.Some(stid) => {
                                let src_interned = type_intern.type_interner().get(stid);
                                match src_interned {
                                    &type_intern.InternedTypeKind.Adt { def_id, args: _ } => {
                                        concrete_def_id = Option.Some(def_id.index);
                                    }
                                    &type_intern.InternedTypeKind.Ref { inner, mutable: _ } => {
                                        let inner_src = type_intern.type_interner().get(inner);
                                        match inner_src {
                                            &type_intern.InternedTypeKind.Adt { def_id, args: _ } => {
                                                concrete_def_id = Option.Some(def_id.index);
                                            }
                                            _ => {}
                                        }
                                    }
                                    _ => {}
                                }
                            }
                            Option.None => {}
                        }
                        match concrete_def_id {
                            Option.Some(type_def_id) => {
                                match ctx.lookup_vtable_name(trait_def_id, type_def_id) {
                                    Option.Some(vtable_name) => {
                                        // Build data pointer and extract/look up gen
                                        let mut data_ptr: String;
                                        let gen_cg = ctx.fresh_temp_cg();
                                        if str_eq(src_ty.as_str(), "ptr") {
                                            data_ptr = val;
                                            // Look up gen at runtime
                                            let addr_i64 = ctx.fresh_temp_cg();
                                            ctx.write("  ");
                                            ctx.write_cgname(&addr_i64);
                                            ctx.write(" = ptrtoint ptr ");
                                            ctx.write_string(&data_ptr);
                                            ctx.write(" to i64\n");
                                            ctx.begin_call(Option.Some(&gen_cg), "i32", "@blood_get_generation");
                                            ctx.call_arg_cg(true, "i64", &addr_i64);
                                            ctx.end_call();
                                        } else if str_eq(src_ty.as_str(), "{ ptr, i32 }") {
                                            // Gen ref: extract data pointer (field 0) and gen (field 1)
                                            let inner_ptr = ctx.fresh_temp_cg();
                                            ctx.write_indent();
                                            ctx.write_cgname(&inner_ptr);
                                            ctx.write(" = extractvalue { ptr, i32 } ");
                                            ctx.write_string(&val);
                                            ctx.write(", 0\n");
                                            data_ptr = cgname_to_string(&inner_ptr);
                                            ctx.write("  ");
                                            ctx.write_cgname(&gen_cg);
                                            ctx.write(" = extractvalue { ptr, i32 } ");
                                            ctx.write_string(&val);
                                            ctx.write(", 1\n");
                                        } else {
                                            // Value type: alloca + store, use alloca as ptr. Gen=0 (stack).
                                            let alloca = ctx.fresh_temp_cg();
                                            ctx.emit_alloca_cg(&alloca, src_ty.as_str());
                                            ctx.emit_store_str_cg(src_ty.as_str(), val.as_str(), &alloca);
                                            data_ptr = cgname_to_string(&alloca);
                                            ctx.write("  ");
                                            ctx.write_cgname(&gen_cg);
                                            ctx.write(" = add i32 0, 0\n");
                                        }
                                        // insertvalue { ptr, ptr, i32 } zeroinitializer, ptr %data, 0
                                        let fat1 = ctx.fresh_temp_cg();
                                        ctx.write_indent();
                                        ctx.write_cgname(&fat1);
                                        ctx.write(" = insertvalue { ptr, ptr, i32 } zeroinitializer, ptr ");
                                        ctx.write_string(&data_ptr);
                                        ctx.write(", 0\n");
                                        // insertvalue { ptr, ptr, i32 } %fat1, ptr @vtable_name, 1
                                        let fat2 = ctx.fresh_temp_cg();
                                        ctx.write_indent();
                                        ctx.write_cgname(&fat2);
                                        ctx.write(" = insertvalue { ptr, ptr, i32 } ");
                                        ctx.write_cgname(&fat1);
                                        ctx.write(", ptr @");
                                        ctx.write_string(vtable_name);
                                        ctx.write(", 1\n");
                                        // insertvalue { ptr, ptr, i32 } %fat2, i32 gen, 2
                                        let fat3 = ctx.fresh_temp_cg();
                                        ctx.write_indent();
                                        ctx.write_cgname(&fat3);
                                        ctx.write(" = insertvalue { ptr, ptr, i32 } ");
                                        ctx.write_cgname(&fat2);
                                        ctx.write(", i32 ");
                                        ctx.write_cgname(&gen_cg);
                                        ctx.write(", 2\n");
                                        // Store fat pointer to destination
                                        ctx.emit_store_cg("{ ptr, ptr, i32 }", &fat3, dest);
                                        handled = true;
                                    }
                                    Option.None => {}
                                }
                            }
                            Option.None => {}
                        }
                    }
                    Option.None => {}
                }
            }
            // General cast path
            if !handled {
                let (val, src_ty) = emit_operand_typed(ctx, operand);
                let tgt_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, *target_ty);
                // Use the type-aware cast if we have source type info.
                // For Copy/Move operands, look up the local's HIR type so we get
                // correct sign-awareness (zext for unsigned, sext for signed).
                let src_ty_opt = match operand {
                    &mir_types.Operand.Constant(ref constant) => Option.Some(type_intern.ty_id_to_type(constant.ty)),
                    &mir_types.Operand.Copy(ref place) => {
                        match ctx.get_local_hir_type(place.local) {
                            Option.Some(ty_id) => Option.Some(type_intern.ty_id_to_type(ty_id)),
                            Option.None => Option.None,
                        }
                    }
                    &mir_types.Operand.Move(ref place) => {
                        match ctx.get_local_hir_type(place.local) {
                            Option.Some(ty_id) => Option.Some(type_intern.ty_id_to_type(ty_id)),
                            Option.None => Option.None,
                        }
                    }
                };
                let target_hir_ty = type_intern.ty_id_to_type(*target_ty);
                // If the actual operand LLVM type differs from the HIR-derived type,
                // use the actual type to avoid type mismatches (e.g., extractvalue
                // { ptr, i32 } on a value that is actually ptr).
                let src_hir_llvm = match &src_ty_opt {
                    &Option.Some(ref src_type) => ctx.type_to_llvm_with_ctx(src_type),
                    &Option.None => common.make_string(""),
                };
                let use_llvm_path = !string_eq_str(src_hir_llvm.as_str(), "") &&
                    !string_eq_str(src_hir_llvm.as_str(), src_ty.as_str());
                let result = if use_llvm_path {
                    // Actual LLVM type differs from HIR type — use actual types
                    emit_cast_from_llvm_types(ctx, &val, src_ty.as_str(), tgt_llvm.as_str())
                } else {
                    match src_ty_opt {
                        Option.Some(ref src_type) => emit_cast_with_types(ctx, &val, src_type, &target_hir_ty),
                        Option.None => {
                            // Fallback: construct approximate source type from LLVM type
                            emit_cast_from_llvm_types(ctx, &val, src_ty.as_str(), tgt_llvm.as_str())
                        }
                    }
                };
                ctx.emit_store_cg(tgt_llvm.as_str(), &result, dest);
            }
            @unsafe { RV_T_CAST_MS += blood_clock_millis() - t_arm; }
        }
        &mir_types.Rvalue.Aggregate { ref kind, ref operands } => {
            let t_arm = blood_clock_millis();
            @unsafe { RV_C_AGG += 1; }
            emit_aggregate(ctx, dest, dest_type, kind, operands);
            @unsafe { RV_T_AGG_MS += blood_clock_millis() - t_arm; }
        }
        &mir_types.Rvalue.Len(ref place) => {
            // For slices - load the length field
            let mut ptr = codegen_place.emit_place_data_ptr(ctx, place);
            // emit_place_data_ptr already dereferences heap-allocated locals
            // (region/persistent). Only need explicit deref for Ref-typed locals
            // on the stack (where alloca holds a reference value, not a data pointer).
            if place.projection.len() == 0 {
                match ctx.get_local_hir_type(place.local) {
                    Option.Some(ty_id) => {
                        if type_intern.is_ref_id(ty_id) && !ctx.is_region_allocated(place.local) && !ctx.is_persistent_allocated(place.local) {
                            let deref = ctx.fresh_temp_cg();
                            ctx.emit_load_cg(&deref, "ptr", ptr.as_str());
                            ptr = cgname_to_string(&deref);
                        }
                    }
                    Option.None => {}
                }
            }
            let len_ptr = ctx.fresh_temp_cg();
            ctx.begin_gep_str(&len_ptr, "{ ptr, i64 }", ptr.as_str());
            ctx.gep_ptr_offset(0);
            ctx.gep_field(1);
            ctx.end_gep();
            let raw_val = ctx.fresh_temp_cg();
            ctx.emit_load_cg2(&raw_val, "i64", &len_ptr);
            // Mask to lower 32 bits — upper 32 bits contain the packed generation
            let len_val = ctx.fresh_temp_cg();
            let raw_str = cgname_to_string(&raw_val);
            ctx.emit_binop_cg(&len_val, "and", "i64", raw_str.as_str(), "4294967295");
            ctx.emit_store_cg("i64", &len_val, dest);
        }
        &mir_types.Rvalue.Discriminant(ref place) => {
            // Load discriminant field of enum
            let mut ptr = codegen_place.emit_place_data_ptr(ctx, place);
            // Auto-deref for Ref-typed locals: the alloca (or heap slot) holds a pointer
            // to the actual enum data, not the enum itself. Load through the pointer first.
            if place.projection.len() == 0 {
                match ctx.get_local_hir_type(place.local) {
                    Option.Some(ty_id) => {
                        if type_intern.is_ref_id(ty_id) {
                            let deref = ctx.fresh_temp_cg();
                            ctx.emit_load_cg(&deref, "ptr", ptr.as_str());
                            ptr = cgname_to_string(&deref);
                        }
                    }
                    Option.None => {}
                }
            }

            // Try to look up enum layout for correct discriminant type.
            // For projected places (e.g., tuple_local[Field(0)]), walk through
            // projections to find the actual enum type, not the local's type.
            let mut discr_ty = common.make_string("i64");
            let mut enum_llvm_ty = common.make_string("{ i64, i64 }");
            let mut found_enum = false;

            let place_ty_id = if place.projection.len() > 0 {
                match codegen_place.walk_all_projections(ctx, place) {
                    Option.Some(ty_id) => Option.Some(ty_id),
                    Option.None => ctx.get_local_hir_type(place.local),
                }
            } else {
                ctx.get_local_hir_type(place.local)
            };

            match place_ty_id {
                Option.Some(ty_id) => {
                    // Extract the enum DefId, unwrapping through Ref/Ptr via interner.
                    let enum_def_idx = type_intern.resolve_adt_def_id_id(ty_id);
                    match enum_def_idx {
                        Option.Some(def_idx) => {
                            match ctx.lookup_enum(def_idx) {
                                Option.Some(layout) => {
                                    discr_ty = layout.discriminant_type.clone();
                                    enum_llvm_ty = layout.llvm_type.clone();
                                    found_enum = true;
                                }
                                Option.None => {}
                            }
                        }
                        Option.None => {}
                    }
                }
                Option.None => {}
            }

            if found_enum {
                // GEP to discriminant field (index 0) of the enum type
                let discr_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&discr_ptr, enum_llvm_ty.as_str(), ptr.as_str());
                ctx.gep_ptr_offset(0);
                ctx.gep_field(0);
                ctx.end_gep();
                let discr_val = ctx.fresh_temp_cg();
                ctx.emit_load_cg2(&discr_val, discr_ty.as_str(), &discr_ptr);
                // Extend discriminant to destination type if needed (dest is typically i64)
                if string_eq_str(discr_ty.as_str(), "i64") {
                    ctx.emit_store_cg(discr_ty.as_str(), &discr_val, dest);
                } else {
                    // Zero-extend discriminant to i64 for use in switch
                    let extended = ctx.fresh_temp_cg();
                    ctx.emit_cast_cg2(&extended, "zext", discr_ty.as_str(), &discr_val, "i64");
                    ctx.emit_store_cg("i64", &extended, dest);
                }
            } else {
                // ICE: Enum not found in ADT registry during discriminant read.
                // All enums must be registered before codegen so their discriminant
                // type and layout are known. An unregistered enum here indicates a
                // missing registration in the codegen ADT setup pass.
                ctx.write("    ; ICE: discriminant read on unregistered enum, local=");
                ctx.write(codegen_types.format_u64(place.local.index as u64).as_str());
                ctx.write("\n");
                ctx.write("    ; ICE: This is a compiler bug (codegen_expr: discriminant load fallback)\n");
                ctx.write("    call void @llvm.trap()\n");
                ctx.emit_unreachable();
            }
        }
    }
}

/// Gets the zero value for an LLVM type.
fn get_zero_value(llvm_ty: &str) -> String {
    if string_starts_with(llvm_ty, "float") {
        common.make_string("0.0")
    } else if string_starts_with(llvm_ty, "double") {
        common.make_string("0.0")
    } else if string_starts_with(llvm_ty, "ptr") {
        common.make_string("null")
    } else if string_starts_with(llvm_ty, "{") {
        common.make_string("zeroinitializer")
    } else if string_starts_with(llvm_ty, "[") {
        common.make_string("zeroinitializer")
    } else {
        common.make_string("0")
    }
}

/// Emits a cast based only on LLVM type strings.
fn emit_cast_from_llvm_types(
    ctx: &mut codegen_ctx.CodegenCtx,
    val: &String,
    src_ty: &str,
    tgt_ty: &str,
) -> codegen_ctx.CgName {
    // Quick check: if same type, just return value
    if string_eq_str(src_ty, tgt_ty) {
        return codegen_ctx.CgName.Str(val.clone());
    }

    let result = ctx.fresh_temp_cg();

    let src_is_float = string_starts_with(src_ty, "float") || string_starts_with(src_ty, "double");
    let tgt_is_float = string_starts_with(tgt_ty, "float") || string_starts_with(tgt_ty, "double");
    let src_is_ptr = string_starts_with(src_ty, "ptr");
    let tgt_is_ptr = string_starts_with(tgt_ty, "ptr");
    // Fat pointers (structs like { ptr, i64 }) should also be treated as ptr-like
    let src_is_fat_ptr = string_starts_with(src_ty, "{");

    if src_is_float && tgt_is_float {
        // Float to float
        let src_size = if string_starts_with(src_ty, "float") { 4u64 } else { 8u64 };
        let tgt_size = if string_starts_with(tgt_ty, "float") { 4u64 } else { 8u64 };
        if tgt_size < src_size {
            ctx.emit_cast_cg(&result, "fptrunc", src_ty, val.as_str(), tgt_ty);
        } else if tgt_size > src_size {
            ctx.emit_cast_cg(&result, "fpext", src_ty, val.as_str(), tgt_ty);
        } else {
            return codegen_ctx.CgName.Str(val.clone());
        }
    } else if !src_is_float && tgt_is_float {
        // Int to float (default signed)
        ctx.emit_cast_cg(&result, "sitofp", src_ty, val.as_str(), tgt_ty);
    } else if src_is_float && !tgt_is_float {
        // Float to int (default signed)
        ctx.emit_cast_cg(&result, "fptosi", src_ty, val.as_str(), tgt_ty);
    } else if src_is_fat_ptr && tgt_is_ptr {
        // Fat pointer to thin pointer: extract the data pointer (field 0)
        ctx.write_indent();
        ctx.write_cgname(&result);
        ctx.write(" = extractvalue ");
        ctx.write(src_ty);
        ctx.write(" ");
        ctx.write_string(val);
        ctx.write(", 0\n");
    } else if src_is_fat_ptr && !tgt_is_ptr {
        // Fat pointer to int: extract ptr, then ptrtoint
        let extracted = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&extracted);
        ctx.write(" = extractvalue ");
        ctx.write(src_ty);
        ctx.write(" ");
        ctx.write_string(val);
        ctx.write(", 0\n");
        ctx.emit_cast_cg2(&result, "ptrtoint", "ptr", &extracted, tgt_ty);
    } else if src_is_ptr && !tgt_is_ptr {
        // Pointer to int
        ctx.emit_cast_cg(&result, "ptrtoint", src_ty, val.as_str(), tgt_ty);
    } else if !src_is_ptr && !src_is_fat_ptr && tgt_is_ptr {
        // Int to pointer (but not fat pointer source)
        ctx.emit_cast_cg(&result, "inttoptr", src_ty, val.as_str(), tgt_ty);
    } else if src_is_ptr && tgt_is_ptr {
        // Pointer to pointer - bitcast
        ctx.emit_cast_cg(&result, "bitcast", src_ty, val.as_str(), tgt_ty);
    } else {
        // Int to int - determine by size
        let src_size = get_int_type_size(src_ty);
        let tgt_size = get_int_type_size(tgt_ty);
        if tgt_size == 1 && src_size > 1 {
            // Numeric → bool: use icmp ne 0 (not truncate, which gives low bit)
            ctx.write_indent();
            ctx.write_cgname(&result);
            ctx.write(" = icmp ne ");
            ctx.write(src_ty);
            ctx.write(" ");
            ctx.write_string(val);
            ctx.write(", 0\n");
        } else if tgt_size < src_size {
            ctx.emit_cast_cg(&result, "trunc", src_ty, val.as_str(), tgt_ty);
        } else if tgt_size > src_size {
            // Default to sign extend
            ctx.emit_cast_cg(&result, "sext", src_ty, val.as_str(), tgt_ty);
        } else {
            return codegen_ctx.CgName.Str(val.clone());
        }
    }

    result
}

/// Gets the size in bits of an LLVM integer type (e.g., "i32" -> 32).
fn get_int_type_size(llvm_ty: &str) -> u64 {
    let bytes = llvm_ty.as_bytes();
    if bytes.len() < 2 {
        return 64; // Default
    }
    if bytes[0] != 105 {
        return 64; // Not 'i'
    }
    // Parse number after 'i'
    let mut n: u64 = 0;
    for i in 1usize..bytes.len() {
        let b = bytes[i];
        if b >= 48 && b <= 57 {
            n = n * 10 + ((b - 48) as u64);
        } else {
            break;
        }
    }
    if n == 0 { 64 } else { n }
}

/// Returns the bit width for an LLVM integer type string (e.g., "i32" -> 32).
/// Checks if an LLVM type string is a struct or array type (starts with '{' or '[').
fn is_struct_or_array_type(ty: &String) -> bool {
    let bytes = ty.as_bytes();
    if bytes.len() > 0 {
        bytes[0] == 123 || bytes[0] == 91 // '{' or '['
    } else {
        false
    }
}

/// Returns true if the LLVM type looks like a Vec/container type whose first
/// field is a data pointer. These types have layout { ptr, ... } and require
/// loading the data pointer before indexing into the heap-allocated array.
/// Build a location string for panic messages: "fn_name:line"
fn build_panic_location(ctx: &mut codegen_ctx.CodegenCtx) -> String {
    let mut loc = String.new();
    match &ctx.current_fn {
        &Option.Some(ref name) => { loc.push_str(name.as_str()); }
        &Option.None => { loc.push_str("<unknown>"); }
    }
    loc.push(':');
    match &ctx.current_span {
        &Option.Some(ref span) => {
            loc.push_str(codegen_types.format_u64(span.line as u64).as_str());
        }
        &Option.None => { loc.push_str("0"); }
    }
    loc
}

/// Returns 0 for non-integer types.
fn llvm_int_bit_width(ty: &str) -> u32 {
    let bytes = ty.as_bytes();
    if bytes.len() < 2 {
        return 0;
    }
    if bytes[0] != 105 { // 'i'
        return 0;
    }
    // Parse the number after 'i'
    let mut val: u32 = 0;
    for idx in 1usize..bytes.len() {
        let b = bytes[idx];
        if b >= 48 && b <= 57 {
            val = val * 10 + ((b - 48) as u32);
        } else {
            return 0; // Non-digit character means not a simple integer type
        }
    }
    val
}

/// Extracts the first field type from a struct type string.
/// E.g., "{ i8 }" -> "i8", "{ i64, ptr }" -> "i64".
/// Returns "i64" as fallback if parsing fails.
fn extract_first_field_type(struct_ty: &str) -> String {
    let bytes = struct_ty.as_bytes();
    // Find start: skip "{ " (or just past '{')
    let mut start: usize = 0;
    let mut i: usize = 0;
    while i < bytes.len() {
        if bytes[i] == 123 {
            // '{'
            start = i + 1;
            // Skip whitespace
            while start < bytes.len() && bytes[start] == 32 {
                start += 1;
            }
            break;
        }
        i += 1;
    }
    // Find end: first ',', ' }', or '}'
    let mut end: usize = start;
    while end < bytes.len() {
        if bytes[end] == 44 || bytes[end] == 125 {
            // ',' or '}'
            break;
        }
        end += 1;
    }
    // Trim trailing whitespace
    while end > start && bytes[end - 1] == 32 {
        end -= 1;
    }
    if end > start {
        let mut result = String.new();
        let mut j: usize = start;
        while j < end {
            result.push(bytes[j] as char);
            j += 1;
        }
        result
    } else {
        common.make_string("i64")
    }
}

/// Counts the number of top-level fields in a struct type string.
/// E.g., "{ i8 }" -> 1, "{ i64, ptr }" -> 2, "{ i8, [17 x i8] }" -> 2.
/// Returns 0 for non-struct types.
fn count_struct_fields(ty: &String) -> u32 {
    let bytes = ty.as_bytes();
    if bytes.len() < 2 || bytes[0] != 123 {
        return 0;
    }
    // Count commas at nesting depth 0 (inside the outermost braces)
    let mut count: u32 = 1; // At least 1 field if it's a struct
    let mut depth: u32 = 0;
    for i in 1usize..bytes.len() {
        let b = bytes[i];
        if b == 123 || b == 91 {
            // '{' or '['
            depth += 1;
        } else if b == 125 || b == 93 {
            // '}' or ']'
            if depth > 0 {
                depth -= 1;
            } else {
                break; // End of outermost struct
            }
        } else if b == 44 && depth == 0 {
            // ',' at top level
            count += 1;
        }
    }
    // Handle empty struct "{}"
    if bytes.len() == 2 && bytes[0] == 123 && bytes[1] == 125 {
        return 0;
    }
    count
}

/// Compares string with &str.
fn string_eq_str(s: &str, other: &str) -> bool {
    let s_bytes = s.as_bytes();
    let other_bytes = other.as_bytes();
    if s_bytes.len() != other_bytes.len() {
        return false;
    }
    for i in 0usize..s_bytes.len() {
        if s_bytes[i] != other_bytes[i] {
            return false;
        }
    }
    true
}

/// Emits a binary operation, returning the result value.
/// Uses i64 as the default type and assumes signed (legacy behavior).
fn emit_binop(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &String,
    right: &String,
) -> codegen_ctx.CgName {
    emit_binop_typed(ctx, bin_op, left, right, "i64", true)
}

/// Emits a division-by-zero check before a div/rem instruction.
/// Branches to a panic block if the divisor is zero.
/// Skipped inside unchecked(overflow) { } blocks.
fn emit_div_zero_check(ctx: &mut codegen_ctx.CodegenCtx, llvm_ty: &str, divisor: &str) {
    if ctx.is_check_suppressed(&ast.UncheckedCheck.Overflow) {
        return;
    }
    let is_zero = ctx.fresh_temp_cg();
    ctx.emit_icmp_cg(&is_zero, "eq", llvm_ty, divisor, "0");

    let panic_label = ctx.fresh_label_cg();
    let ok_label = ctx.fresh_label_cg();
    ctx.emit_cond_br_cg(&is_zero, &panic_label, &ok_label);

    ctx.emit_label_cg(&panic_label);
    ctx.write_indent();
    ctx.write("call void @blood_panic_div_zero()\n");
    ctx.emit_unreachable();

    ctx.emit_label_cg(&ok_label);
}

/// Emits a binary operation with explicit type, returning the result value.
/// Handles both integer and floating-point operations based on the type.
/// The `signed` parameter indicates whether the operands are signed integers
/// (used for choosing sdiv vs udiv, srem vs urem, slt vs ult, etc.).
pub fn emit_binop_typed(
    ctx: &mut codegen_ctx.CodegenCtx,
    bin_op: &mir_types.MirBinOp,
    left: &String,
    right: &String,
    llvm_ty: &str,
    signed: bool,
) -> codegen_ctx.CgName {
    // If the type is an aggregate (struct), extract the first field for comparison.
    // LLVM icmp/binops don't work on aggregate types.
    let ty_bytes = llvm_ty.as_bytes();
    // Special case: {} (unit/empty struct) has no fields — arithmetic on unit is a no-op.
    // This happens when a non-resumptive handler op body has integer literals that get
    // unified to unit type (BLK-04). Return undef so the caller emits `store {} undef`.
    if ty_bytes.len() == 2 && ty_bytes[0] == 123 && ty_bytes[1] == 125 {
        return codegen_ctx.CgName.Str(common.make_string("undef"));
    }
    if ty_bytes.len() > 0 && ty_bytes[0] == 123 {
        // Aggregate type. The recursive extract-first-field path is only
        // sound for single-field wrappers (e.g. `{ i32 }` from
        // `struct Wrapper { x: i32 }`); for multi-field aggregates it
        // silently miscompiles equality by comparing only the first field.
        // The S98–S108 dispatch chain in the BinaryOp Rvalue routes every
        // known eq-family aggregate (str / String / &String / & &String /
        // &[T] / Vec<T> / &Vec<T>, plus user Adts with `impl PartialEq`,
        // plus value- and single-ref-shape tuples and arrays) through
        // their respective handlers before reaching here. If a
        // multi-field aggregate Eq/Ne arrives at this point the dispatcher
        // missed it — typically Option/Result ==, tuple/array of aggregate
        // elements (str/String/Vec/&UserAdt), closure ==, HashMap ==,
        // multi-layer refs (`& &Tuple`, `& &[T; N]`), or a fat-ref of a
        // user Adt that lacks `impl<T: PartialEq> PartialEq for &T`.
        // Diagnose instead of falling through, so the silent miscompile
        // surfaces as an error.
        let llvm_ty_string = common.make_string(llvm_ty);
        let n_fields = count_struct_fields(&llvm_ty_string);
        let is_eq_or_ne = match bin_op {
            &mir_types.MirBinOp.Eq => true,
            &mir_types.MirBinOp.Ne => true,
            _ => false,
        };
        if is_eq_or_ne && n_fields > 1 {
            let mut msg = common.make_string("equality on multi-field aggregate type `");
            msg.push_str(llvm_ty);
            msg.push_str("` is not supported (the default codegen path would silently compare only the first field)");
            let note = common.make_string("Built-in eq-family types (str / String / &String / & &String / &[T] / Vec<T> / &Vec<T>) are routed through @str_eq upstream; reaching this point for one of those is a compiler bug. User Adts with `impl PartialEq` (manual or `#[derive(PartialEq)]`) dispatch through the operator since S106. Tuples and arrays (value or single-ref shape) with primitive or nested Tuple/Array elements dispatch since S107/S108. Remaining gaps: Option/Result == (use `match`), tuple/array of aggregate elements (str/String/Vec/&UserAdt), closure ==, HashMap ==, multi-layer refs (`& &Tuple`, `& &[T; N]`), and fat-refs of user Adts (`&UserStruct == &UserStruct` requires a blanket `impl<T: PartialEq> PartialEq for &T` not yet in stdlib).");
            ctx.codegen_error_with_note_fatal(
                codegen_ctx.CodegenErrorKind.UnsupportedOperation,
                msg,
                note,
            );
            // Emit a placeholder i1 result so subsequent codegen consumes
            // a valid SSA name; the fatal flag will cause generate_module
            // to return a failed result and halt the build before this
            // placeholder reaches the linker.
            let placeholder = ctx.fresh_temp_cg();
            ctx.emit_icmp_cg(&placeholder, "ne", "i64", "0", "0");
            return placeholder;
        }
        // Single-field wrapper or non-Eq/Ne op: extract field 0 and recurse.
        let inner_ty = extract_first_field_type(llvm_ty);
        let left_elem_cg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&left_elem_cg);
        ctx.write(" = extractvalue ");
        ctx.write(llvm_ty);
        ctx.write(" ");
        ctx.write_string(left);
        ctx.write(", 0\n");
        let left_elem = cgname_to_string(&left_elem_cg);
        let right_elem_cg = ctx.fresh_temp_cg();
        ctx.write_indent();
        ctx.write_cgname(&right_elem_cg);
        ctx.write(" = extractvalue ");
        ctx.write(llvm_ty);
        ctx.write(" ");
        ctx.write_string(right);
        ctx.write(", 0\n");
        let right_elem = cgname_to_string(&right_elem_cg);
        return emit_binop_typed(ctx, bin_op, &left_elem, &right_elem, inner_ty.as_str(), signed);
    }

    let result = ctx.fresh_temp_cg();
    let l = left.as_str();
    let r = right.as_str();

    // Check if this is a floating-point type
    let is_float = string_starts_with(llvm_ty, "float") || string_starts_with(llvm_ty, "double");

    if is_float {
        // Floating-point operations
        match bin_op {
            &mir_types.MirBinOp.Add => ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, r),
            &mir_types.MirBinOp.Sub => ctx.emit_binop_cg(&result, "fsub", llvm_ty, l, r),
            &mir_types.MirBinOp.Mul => ctx.emit_binop_cg(&result, "fmul", llvm_ty, l, r),
            &mir_types.MirBinOp.Div => ctx.emit_binop_cg(&result, "fdiv", llvm_ty, l, r),
            &mir_types.MirBinOp.Rem => ctx.emit_binop_cg(&result, "frem", llvm_ty, l, r),
            // Floating-point comparisons use ordered comparisons (NaN returns false)
            &mir_types.MirBinOp.Eq => ctx.emit_fcmp_cg(&result, "oeq", llvm_ty, l, r),
            &mir_types.MirBinOp.Ne => ctx.emit_fcmp_cg(&result, "one", llvm_ty, l, r),
            &mir_types.MirBinOp.Lt => ctx.emit_fcmp_cg(&result, "olt", llvm_ty, l, r),
            &mir_types.MirBinOp.Le => ctx.emit_fcmp_cg(&result, "ole", llvm_ty, l, r),
            &mir_types.MirBinOp.Gt => ctx.emit_fcmp_cg(&result, "ogt", llvm_ty, l, r),
            &mir_types.MirBinOp.Ge => ctx.emit_fcmp_cg(&result, "oge", llvm_ty, l, r),
            // Bitwise operations don't apply to floats - emit error
            &mir_types.MirBinOp.BitAnd => {
                ctx.codegen_error_with_note(
                    codegen_ctx.CodegenErrorKind.UnsupportedOperation,
                    common.make_string("bitwise AND on float type"),
                    common.make_string("bitwise operations require integer operands; cast to integer first"),
                );
                ctx.write("    ; ERROR: bitwise AND on float\n");
                ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, "0.0");
            }
            &mir_types.MirBinOp.BitOr => {
                ctx.codegen_error_with_note(
                    codegen_ctx.CodegenErrorKind.UnsupportedOperation,
                    common.make_string("bitwise OR on float type"),
                    common.make_string("bitwise operations require integer operands; cast to integer first"),
                );
                ctx.write("    ; ERROR: bitwise OR on float\n");
                ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, "0.0");
            }
            &mir_types.MirBinOp.BitXor => {
                ctx.codegen_error_with_note(
                    codegen_ctx.CodegenErrorKind.UnsupportedOperation,
                    common.make_string("bitwise XOR on float type"),
                    common.make_string("bitwise operations require integer operands; cast to integer first"),
                );
                ctx.write("    ; ERROR: bitwise XOR on float\n");
                ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, "0.0");
            }
            &mir_types.MirBinOp.Shl => {
                ctx.write("    ; ERROR: shift left on float\n");
                ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, "0.0");
            }
            &mir_types.MirBinOp.Shr => {
                ctx.write("    ; ERROR: shift right on float\n");
                ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, "0.0");
            }
            // Checked operations - floats don't have overflow, treat as unchecked
            &mir_types.MirBinOp.AddChecked => ctx.emit_binop_cg(&result, "fadd", llvm_ty, l, r),
            &mir_types.MirBinOp.SubChecked => ctx.emit_binop_cg(&result, "fsub", llvm_ty, l, r),
            &mir_types.MirBinOp.MulChecked => ctx.emit_binop_cg(&result, "fmul", llvm_ty, l, r),
        }
    } else {
        // Integer operations with correct signedness
        let is_unsigned = !signed;

        match bin_op {
            &mir_types.MirBinOp.Add => ctx.emit_binop_cg(&result, "add", llvm_ty, l, r),
            &mir_types.MirBinOp.Sub => ctx.emit_binop_cg(&result, "sub", llvm_ty, l, r),
            &mir_types.MirBinOp.Mul => ctx.emit_binop_cg(&result, "mul", llvm_ty, l, r),
            &mir_types.MirBinOp.Div => {
                emit_div_zero_check(ctx, llvm_ty, r);
                if is_unsigned {
                    ctx.emit_binop_cg(&result, "udiv", llvm_ty, l, r);
                } else {
                    ctx.emit_binop_cg(&result, "sdiv", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.Rem => {
                emit_div_zero_check(ctx, llvm_ty, r);
                if is_unsigned {
                    ctx.emit_binop_cg(&result, "urem", llvm_ty, l, r);
                } else {
                    ctx.emit_binop_cg(&result, "srem", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.BitAnd => ctx.emit_binop_cg(&result, "and", llvm_ty, l, r),
            &mir_types.MirBinOp.BitOr => ctx.emit_binop_cg(&result, "or", llvm_ty, l, r),
            &mir_types.MirBinOp.BitXor => ctx.emit_binop_cg(&result, "xor", llvm_ty, l, r),
            &mir_types.MirBinOp.Shl => ctx.emit_binop_cg(&result, "shl", llvm_ty, l, r),
            &mir_types.MirBinOp.Shr => {
                if is_unsigned {
                    ctx.emit_binop_cg(&result, "lshr", llvm_ty, l, r);
                } else {
                    ctx.emit_binop_cg(&result, "ashr", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.Eq => ctx.emit_icmp_cg(&result, "eq", llvm_ty, l, r),
            &mir_types.MirBinOp.Ne => ctx.emit_icmp_cg(&result, "ne", llvm_ty, l, r),
            &mir_types.MirBinOp.Lt => {
                if is_unsigned {
                    ctx.emit_icmp_cg(&result, "ult", llvm_ty, l, r);
                } else {
                    ctx.emit_icmp_cg(&result, "slt", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.Le => {
                if is_unsigned {
                    ctx.emit_icmp_cg(&result, "ule", llvm_ty, l, r);
                } else {
                    ctx.emit_icmp_cg(&result, "sle", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.Gt => {
                if is_unsigned {
                    ctx.emit_icmp_cg(&result, "ugt", llvm_ty, l, r);
                } else {
                    ctx.emit_icmp_cg(&result, "sgt", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.Ge => {
                if is_unsigned {
                    ctx.emit_icmp_cg(&result, "uge", llvm_ty, l, r);
                } else {
                    ctx.emit_icmp_cg(&result, "sge", llvm_ty, l, r);
                }
            }
            // Checked operations - use LLVM overflow intrinsics and trap on overflow
            &mir_types.MirBinOp.AddChecked => {
                if is_unsigned {
                    emit_checked_binop(ctx, &result, "uadd", llvm_ty, l, r);
                } else {
                    emit_checked_binop(ctx, &result, "sadd", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.SubChecked => {
                if is_unsigned {
                    emit_checked_binop(ctx, &result, "usub", llvm_ty, l, r);
                } else {
                    emit_checked_binop(ctx, &result, "ssub", llvm_ty, l, r);
                }
            }
            &mir_types.MirBinOp.MulChecked => {
                if is_unsigned {
                    emit_checked_binop(ctx, &result, "umul", llvm_ty, l, r);
                } else {
                    emit_checked_binop(ctx, &result, "smul", llvm_ty, l, r);
                }
            }
        }
    }

    result
}

/// Emits a checked binary operation using LLVM overflow intrinsics.
/// On overflow, traps with @llvm.trap().
///
/// Uses intrinsics like @llvm.sadd.with.overflow.i64, @llvm.ssub.with.overflow.i64, etc.
/// These return { iN, i1 } where the second element is the overflow flag.
fn emit_checked_binop(
    ctx: &mut codegen_ctx.CodegenCtx,
    result: &codegen_ctx.CgName,
    intrinsic_base: &str,
    llvm_ty: &str,
    left: &str,
    right: &str,
) {
    // Build the intrinsic name: @llvm.sadd.with.overflow.i64
    let mut intrinsic_name = common.make_string("@llvm.");
    intrinsic_name.push_str(intrinsic_base);
    intrinsic_name.push_str(".with.overflow.");
    intrinsic_name.push_str(llvm_ty);

    // Build the return type: { i64, i1 }
    let mut ret_ty = common.make_string("{ ");
    ret_ty.push_str(llvm_ty);
    ret_ty.push_str(", i1 }");

    // Call the intrinsic
    let overflow_result = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&overflow_result);
    ctx.write(" = call ");
    ctx.write_string(&ret_ty);
    ctx.write(" ");
    ctx.write_string(&intrinsic_name);
    ctx.write("(");
    ctx.write(llvm_ty);
    ctx.write(" ");
    ctx.write(left);
    ctx.write(", ");
    ctx.write(llvm_ty);
    ctx.write(" ");
    ctx.write(right);
    ctx.write(")\n");

    // Extract the result value
    ctx.write_indent();
    ctx.write_cgname(result);
    ctx.write(" = extractvalue ");
    ctx.write_string(&ret_ty);
    ctx.write(" ");
    ctx.write_cgname(&overflow_result);
    ctx.write(", 0\n");

    // Extract the overflow flag
    let overflow_flag = ctx.fresh_temp_cg();
    ctx.write_indent();
    ctx.write_cgname(&overflow_flag);
    ctx.write(" = extractvalue ");
    ctx.write_string(&ret_ty);
    ctx.write(" ");
    ctx.write_cgname(&overflow_result);
    ctx.write(", 1\n");

    // Emit conditional trap on overflow using basic blocks
    let trap_label = ctx.fresh_label_cg();
    let continue_label = ctx.fresh_label_cg();

    ctx.emit_cond_br_cg(&overflow_flag, &trap_label, &continue_label);

    // Trap block
    ctx.emit_label_cg(&trap_label);
    ctx.indent();
    ctx.write("    call void @llvm.trap()\n");
    ctx.emit_unreachable();
    ctx.dedent();

    // Continue block
    ctx.emit_label_cg(&continue_label);
}

/// Checks if a string starts with a prefix.
fn string_starts_with(s: &str, prefix: &str) -> bool {
    let s_bytes = s.as_bytes();
    let prefix_bytes = prefix.as_bytes();
    if prefix_bytes.len() > s_bytes.len() {
        return false;
    }
    for i in 0usize..prefix_bytes.len() {
        if s_bytes[i] != prefix_bytes[i] {
            return false;
        }
    }
    true
}

/// Determines whether an operand is signed, using local signedness tracking
/// for Copy/Move operands and HIR type info for constants.
fn operand_is_signed(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
) -> bool {
    match operand {
        &mir_types.Operand.Copy(ref place) => {
            ctx.is_local_signed(place.local)
        }
        &mir_types.Operand.Move(ref place) => {
            ctx.is_local_signed(place.local)
        }
        &mir_types.Operand.Constant(ref constant) => {
            let const_hir_ty = type_intern.ty_id_to_type(constant.ty);
            codegen_types.is_signed(&const_hir_ty)
        }
    }
}

/// Emits a unary operation, returning the result value.
fn emit_unop(
    ctx: &mut codegen_ctx.CodegenCtx,
    un_op: &mir_types.MirUnOp,
    operand: &String,
) -> codegen_ctx.CgName {
    emit_unop_typed(ctx, un_op, operand, "i64")
}

/// Emits a unary operation with explicit type, returning the result value.
/// Handles both integer and floating-point operations.
fn emit_unop_typed(
    ctx: &mut codegen_ctx.CodegenCtx,
    un_op: &mir_types.MirUnOp,
    operand: &String,
    llvm_ty: &str,
) -> codegen_ctx.CgName {
    let result = ctx.fresh_temp_cg();
    let v = operand.as_str();

    // Check if this is a floating-point type
    let is_float = string_starts_with(llvm_ty, "float") || string_starts_with(llvm_ty, "double");

    match un_op {
        &mir_types.MirUnOp.Neg => {
            if is_float {
                // fneg is a unary operator: %res = fneg <ty> <val>
                ctx.write_indent();
                ctx.write_cgname(&result);
                ctx.write(" = fneg ");
                ctx.write(llvm_ty);
                ctx.write(" ");
                ctx.write(v);
                ctx.write("\n");
            } else {
                ctx.emit_binop_cg(&result, "sub", llvm_ty, "0", v);
            }
        }
        &mir_types.MirUnOp.Not => {
            if is_float {
                // Not doesn't make sense for floats - emit error
                ctx.codegen_error_with_note(
                    codegen_ctx.CodegenErrorKind.UnsupportedOperation,
                    common.make_string("bitwise NOT on float type"),
                    common.make_string("bitwise operations require integer operands; cast to integer first"),
                );
                ctx.write("    ; ERROR: bitwise NOT on float\n");
                ctx.emit_binop_cg(&result, "fadd", llvm_ty, v, "0.0");
            } else {
                ctx.emit_binop_cg(&result, "xor", llvm_ty, v, "-1");
            }
        }
    }

    result
}

/// Emits a cast operation, returning the result value.
/// Takes the source type and target type to determine the correct cast instruction.
fn emit_cast_with_types(
    ctx: &mut codegen_ctx.CodegenCtx,
    val: &String,
    source_ty: &hir_ty.Type,
    target_ty: &hir_ty.Type,
) -> codegen_ctx.CgName {
    let src_llvm = ctx.type_to_llvm_with_ctx(source_ty);
    let tgt_llvm = ctx.type_to_llvm_with_ctx(target_ty);
    let result = ctx.fresh_temp_cg();

    // Determine the cast instruction based on types
    let src_is_int = codegen_types.is_integer(source_ty);
    let tgt_is_int = codegen_types.is_integer(target_ty);
    let src_is_float = codegen_types.is_float(source_ty);
    let tgt_is_float = codegen_types.is_float(target_ty);
    let src_is_signed = codegen_types.is_signed(source_ty);
    let src_is_ptr = codegen_types.is_pointer_like(source_ty);
    let tgt_is_ptr = codegen_types.is_pointer_like(target_ty);

    let src_size = codegen_size.type_size_with_ctx(ctx, source_ty);
    let tgt_size = codegen_size.type_size_with_ctx(ctx, target_ty);

    if src_is_int && tgt_is_int {
        // Integer to integer cast
        if codegen_types.is_bool(target_ty) && !codegen_types.is_bool(source_ty) {
            // Numeric → bool: use icmp ne 0 (not truncate, which gives low bit)
            ctx.write_indent();
            ctx.write_cgname(&result);
            ctx.write(" = icmp ne ");
            ctx.write_string(&src_llvm);
            ctx.write(" ");
            ctx.write_string(val);
            ctx.write(", 0\n");
        } else if tgt_size < src_size {
            ctx.emit_cast_cg(&result, "trunc", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        } else if tgt_size > src_size {
            if src_is_signed {
                ctx.emit_cast_cg(&result, "sext", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
            } else {
                ctx.emit_cast_cg(&result, "zext", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
            }
        } else {
            // Same size - bitcast or just copy
            return codegen_ctx.CgName.Str(val.clone());
        }
    } else if src_is_float && tgt_is_float {
        // Float to float cast
        if tgt_size < src_size {
            ctx.emit_cast_cg(&result, "fptrunc", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        } else if tgt_size > src_size {
            ctx.emit_cast_cg(&result, "fpext", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        } else {
            return codegen_ctx.CgName.Str(val.clone());
        }
    } else if src_is_int && tgt_is_float {
        // Integer to float
        if src_is_signed {
            ctx.emit_cast_cg(&result, "sitofp", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        } else {
            ctx.emit_cast_cg(&result, "uitofp", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        }
    } else if src_is_float && tgt_is_int {
        // Float to integer
        let tgt_is_signed = codegen_types.is_signed(target_ty);
        if tgt_is_signed {
            ctx.emit_cast_cg(&result, "fptosi", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        } else {
            ctx.emit_cast_cg(&result, "fptoui", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        }
    } else if src_is_ptr && tgt_is_int {
        // Pointer to integer
        // If source is a fat pointer (e.g. fn type { ptr, ptr }), extract field 0 first
        let src_bytes = src_llvm.as_bytes();
        let src_is_fat = src_bytes.len() > 0 && src_bytes[0] == 123;  // '{'
        if src_is_fat {
            let extracted = ctx.fresh_temp_cg();
            ctx.write_indent();
            ctx.write_cgname(&extracted);
            ctx.write(" = extractvalue ");
            ctx.write_string(&src_llvm);
            ctx.write(" ");
            ctx.write_string(val);
            ctx.write(", 0\n");
            let ext_str = cgname_to_string(&extracted);
            ctx.emit_cast_cg(&result, "ptrtoint", "ptr", ext_str.as_str(), tgt_llvm.as_str());
        } else {
            ctx.emit_cast_cg(&result, "ptrtoint", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
        }
    } else if src_is_int && tgt_is_ptr {
        // Integer to pointer
        ctx.emit_cast_cg(&result, "inttoptr", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
    } else if src_is_ptr && tgt_is_ptr {
        // Pointer to pointer
        // Check if source is a fat pointer (struct) being cast to thin pointer
        let src_bytes = src_llvm.as_bytes();
        let tgt_bytes = tgt_llvm.as_bytes();
        let src_is_fat = src_bytes.len() > 0 && src_bytes[0] == 123;  // '{'
        let tgt_is_thin = tgt_bytes.len() > 0 && tgt_bytes[0] == 112; // 'p' for "ptr"
        if src_is_fat && tgt_is_thin {
            // Fat pointer to thin pointer: extract the data pointer (field 0)
            ctx.write_indent();
            ctx.write_cgname(&result);
            ctx.write(" = extractvalue ");
            ctx.write_string(&src_llvm);
            ctx.write(" ");
            ctx.write_string(val);
            ctx.write(", 0\n");
        } else if src_is_fat {
            // Fat pointer to fat pointer: just copy
            return codegen_ctx.CgName.Str(val.clone());
        } else {
            // Thin pointer to pointer: bitcast or just copy if same
            if string_eq_str(src_llvm.as_str(), tgt_llvm.as_str()) {
                return codegen_ctx.CgName.Str(val.clone());
            } else if str_eq(tgt_llvm.as_str(), "{ ptr, i32 }") {
                // Cast from thin pointer to fat reference: wrap with gen=0.
                //
                // DESIGN INTENT: the cast itself is an @unsafe operation (Ptr→Ref
                // requires an @unsafe context per cast_requires_unsafe_context in
                // typeck_expr.blood). The user has explicitly opted into raw-ptr
                // semantics by writing the cast; wrapping with gen=0 preserves the
                // runtime's convention that "no tracked gen" ⇒ validation skipped.
                //
                // If the target of the cast is a real tracked heap region, the
                // user should capture the reference directly via `&value` rather
                // than cast a raw pointer — only then will the gen field reflect
                // the actual allocation's generation.
                //
                // Soundness: this site is reachable only through an @unsafe block,
                // so the gen=0 is consistent with the user's explicit opt-out.
                let ins1 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins1);
                ctx.write(" = insertvalue { ptr, i32 } zeroinitializer, ptr ");
                ctx.write_string(val);
                ctx.write(", 0\n");
                ctx.write_indent();
                ctx.write_cgname(&result);
                ctx.write(" = insertvalue { ptr, i32 } ");
                ctx.write_cgname(&ins1);
                ctx.write(", i32 0, 1\n");
            } else {
                ctx.emit_cast_cg(&result, "bitcast", src_llvm.as_str(), val.as_str(), tgt_llvm.as_str());
            }
        }
    } else {
        // Fallback: delegate to LLVM-type-based cast logic which correctly
        // handles int-to-int (trunc/sext), fat pointer extraction, etc.
        // This path is reached when HIR types are Infer/Param (unresolved).
        return emit_cast_from_llvm_types(ctx, val, src_llvm.as_str(), tgt_llvm.as_str());
    }

    result
}

/// Gets the LLVM type string for an operand without emitting any IR.
fn operand_llvm_type(
    ctx: &mut codegen_ctx.CodegenCtx,
    operand: &mir_types.Operand,
) -> String {
    match operand {
        &mir_types.Operand.Copy(ref place) => {
            ctx.get_local_type(place.local)
        }
        &mir_types.Operand.Move(ref place) => {
            ctx.get_local_type(place.local)
        }
        &mir_types.Operand.Constant(ref constant) => {
            codegen_size.type_to_llvm_with_ctx_id(ctx, constant.ty)
        }
    }
}

/// Builds an LLVM struct type string from operand types (for tuples, records, closures).
/// Returns e.g. "{ i32, i64, ptr }".
fn build_tuple_llvm_type(
    ctx: &mut codegen_ctx.CodegenCtx,
    operands: &Vec<mir_types.Operand>,
) -> String {
    let mut result = common.make_string("{ ");
    for i in 0usize..operands.len() {
        if i > 0 {
            result.push_str(", ");
        }
        let ty = operand_llvm_type(ctx, &operands[i]);
        result.push_str(ty.as_str());
    }
    result.push_str(" }");
    result
}

/// Estimates the size in bytes of an LLVM type string.
/// Used for env struct allocation; always safe to over-estimate.
fn llvm_type_size_estimate(ty: &str) -> u64 {
    if string_eq_str(ty, "i1") { 1 }
    else if string_eq_str(ty, "i8") { 1 }
    else if string_eq_str(ty, "i16") { 2 }
    else if string_eq_str(ty, "i32") { 4 }
    else if string_eq_str(ty, "i64") { 8 }
    else if string_eq_str(ty, "i128") { 16 }
    else if string_eq_str(ty, "ptr") { 8 }
    else if string_eq_str(ty, "float") { 4 }
    else if string_eq_str(ty, "double") { 8 }
    else if string_starts_with(ty, "{ ptr, ptr }") { 16 }
    else if string_starts_with(ty, "{ ptr, i64 }") { 16 }
    else { 8 } // safe default for unknown types
}

/// Emits an ADT aggregate (struct or enum variant) using the ADT registry.
fn emit_aggregate_adt(
    ctx: &mut codegen_ctx.CodegenCtx,
    dest: &str,
    dest_type: &str,
    def_id: u32,
    variant_idx: u32,
    operands: &Vec<mir_types.Operand>,
    type_args: &Vec<hir_ty.Type>,
) {
    // Try struct first
    match ctx.lookup_struct(def_id) {
        Option.Some(layout) => {
            // Check if any field has an unresolved Param/Infer HIR type
            let has_params = layout_has_param_fields(layout);
            // Collect base field types from registry
            let mut field_types: Vec<String> = Vec.new();
            for fi in 0usize..layout.fields.len() {
                field_types.push(layout.fields[fi].llvm_type.clone());
            }
            let struct_ty = layout.llvm_type.clone();
            // If the struct has param/infer fields and concrete type args are available,
            // compute concrete field types by substituting type args for param fields.
            if has_params && type_args.len() > 0 {
                // Collect field hir_type TyIds for dedup scanning
                let mut field_hir_tys: Vec<Option<type_intern.TyId>> = Vec.new();
                for fj in 0usize..layout.fields.len() {
                    field_hir_tys.push(layout.fields[fj].hir_type);
                }
                let mut param_idx: usize = 0;
                for fj in 0usize..layout.fields.len() {
                    let is_param = match &layout.fields[fj].hir_type {
                        &Option.Some(ht_id) => {
                            type_intern.is_param_or_infer_id(ht_id)
                        }
                        &Option.None => false,
                    };
                    if is_param {
                        // Check if a previous field has the same TyVarId
                        let cur_var = get_field_var_index(&field_hir_tys, fj);
                        let prev_pos = find_previous_param_pos(&field_hir_tys, fj, cur_var);
                        let arg_idx = match &prev_pos {
                            &Option.Some(pos) => pos,
                            &Option.None => {
                                let idx = param_idx;
                                param_idx += 1;
                                idx
                            }
                        };
                        if arg_idx < type_args.len() {
                            field_types[fj] = codegen_size.type_to_llvm_with_ctx(ctx, &type_args[arg_idx]);
                        }
                    }
                }
            }
            // Rebuild struct_ty from field_types if params were substituted
            let struct_ty = if has_params && type_args.len() > 0 {
                let mut s = common.make_string("{ ");
                for si in 0usize..field_types.len() {
                    if si > 0 {
                        s.push_str(", ");
                    }
                    s.push_str(field_types[si].as_str());
                }
                s.push_str(" }");
                s
            } else {
                struct_ty
            };
            // Store each field using actual types from the struct layout.
            // If the operand type differs from the field type (e.g., i64 vs i32),
            // emit a trunc or zext to match the target field width.
            // Union: all fields at GEP index 0 (overlapping memory).
            let is_union_adt = layout.is_union;
            for i in 0usize..operands.len() {
                let typed = emit_operand_typed(ctx, &operands[i]);
                let operand_val = typed.0;
                let operand_ty = typed.1;
                let field_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&field_ptr, struct_ty.as_str(), dest);
                ctx.gep_ptr_offset(0);
                let gep_field_idx: u32 = if is_union_adt { 0 } else { i as u32 };
                ctx.gep_field(gep_field_idx);
                ctx.end_gep();
                // Use actual field type from the struct layout.
                // If the field index exceeds the known field types, this is
                // a compiler bug — the aggregate has more operands than the
                // struct layout has fields.
                let field_ty_str = if i < field_types.len() {
                    field_types[i].as_str()
                } else {
                    ctx.write("    ; ICE: aggregate field ");
                    ctx.write(codegen_types.format_u64(i as u64).as_str());
                    ctx.write(" exceeds field_types.len()=");
                    ctx.write(codegen_types.format_u64(field_types.len() as u64).as_str());
                    ctx.write("\n");
                    ctx.write("    ; ICE: This is a compiler bug (codegen_expr: field type fallback)\n");
                    ctx.write("    call void @llvm.trap()\n");
                    ctx.emit_unreachable();
                    "i64" // dead code — satisfies type checker
                };
                // Check if operand type matches field type
                if string_eq_str(operand_ty.as_str(), field_ty_str) {
                    ctx.emit_store_str_cg(field_ty_str, operand_val.as_str(), &field_ptr);
                } else {
                    let src_w = llvm_int_bit_width(operand_ty.as_str());
                    let dst_w = llvm_int_bit_width(field_ty_str);
                    if src_w > dst_w && dst_w > 0 {
                        // Wider to narrower: truncate
                        let cast_tmp = ctx.fresh_temp_cg();
                        ctx.emit_cast_cg(&cast_tmp, "trunc", operand_ty.as_str(), operand_val.as_str(), field_ty_str);
                        ctx.emit_store_cg2(field_ty_str, &cast_tmp, &field_ptr);
                    } else if src_w < dst_w && src_w > 0 {
                        // Narrower to wider: zero-extend
                        let cast_tmp = ctx.fresh_temp_cg();
                        ctx.emit_cast_cg(&cast_tmp, "zext", operand_ty.as_str(), operand_val.as_str(), field_ty_str);
                        ctx.emit_store_cg2(field_ty_str, &cast_tmp, &field_ptr);
                    } else if src_w > 0 && string_eq_str(field_ty_str, "ptr") {
                        // Integer to pointer: inttoptr
                        let cast_tmp = ctx.fresh_temp_cg();
                        ctx.emit_cast_cg(&cast_tmp, "inttoptr", operand_ty.as_str(), operand_val.as_str(), "ptr");
                        ctx.emit_store_cg2("ptr", &cast_tmp, &field_ptr);
                    } else if dst_w > 0 && string_eq_str(operand_ty.as_str(), "ptr") {
                        // Pointer to integer: ptrtoint
                        let cast_tmp = ctx.fresh_temp_cg();
                        ctx.emit_cast_cg(&cast_tmp, "ptrtoint", "ptr", operand_val.as_str(), field_ty_str);
                        ctx.emit_store_cg2(field_ty_str, &cast_tmp, &field_ptr);
                    } else {
                        // Other mismatch (e.g., i64 vs struct type from unresolved inference).
                        // Store with the operand's own type so the IR is valid.
                        ctx.emit_store_str_cg(operand_ty.as_str(), operand_val.as_str(), &field_ptr);
                    }
                }
            }
            return;
        }
        Option.None => {}
    }
    // Try enum
    match ctx.lookup_enum(def_id) {
        Option.Some(layout) => {
            // Use dest_type (from alloca) for GEP consistency with the alloca type.
            // layout.llvm_type may be wrong for generic enums (keyed by def_id only,
            // so Option<ConstInfo> and Option<&T> share the same cached layout).
            let enum_ty = if dest_type.len() > 2 {
                common.make_string(dest_type)
            } else {
                layout.llvm_type.clone()
            };
            let discr_ty = layout.discriminant_type.clone();
            // Find the variant's payload type and field types
            let mut payload_ty = common.make_string("{}");
            let mut variant_field_types: Vec<String> = Vec.new();
            for vi in 0usize..layout.variants.len() {
                if layout.variants[vi].variant_idx == variant_idx {
                    payload_ty = layout.variants[vi].payload_llvm_type.clone();
                    for vfi in 0usize..layout.variants[vi].fields.len() {
                        variant_field_types.push(layout.variants[vi].fields[vfi].llvm_type.clone());
                    }
                }
            }

            // Store discriminant at field 0 of the enum type
            let discr_ptr = ctx.fresh_temp_cg();
            ctx.begin_gep_str(&discr_ptr, enum_ty.as_str(), dest);
            ctx.gep_ptr_offset(0);
            ctx.gep_field(0);
            ctx.end_gep();
            let discr_val = codegen_types.format_u64(variant_idx as u64);
            ctx.emit_store_str_cg(discr_ty.as_str(), discr_val.as_str(), &discr_ptr);

            // Store payload fields only if there are operands
            if operands.len() > 0 {
                // Get pointer to payload area (field 1 of enum type)
                let data_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&data_ptr, enum_ty.as_str(), dest);
                ctx.gep_ptr_offset(0);
                ctx.gep_field(1);
                ctx.end_gep();

                // Store each operand field using the variant's payload type
                for i in 0usize..operands.len() {
                    let typed = emit_operand_typed(ctx, &operands[i]);
                    let operand_val = typed.0;
                    let operand_ty = typed.1;
                    let field_ptr = ctx.fresh_temp_cg();
                    ctx.begin_gep(&field_ptr, payload_ty.as_str(), &data_ptr);
                    ctx.gep_ptr_offset(0);
                    ctx.gep_field(i as u32);
                    ctx.end_gep();
                    // Use actual field type if available, with type conversion if needed
                    let field_ty_str = if i < variant_field_types.len() {
                        variant_field_types[i].as_str()
                    } else {
                        "i64"
                    };
                    // Check if operand type matches field type
                    if string_eq_str(operand_ty.as_str(), field_ty_str) {
                        ctx.emit_store_str_cg(field_ty_str, operand_val.as_str(), &field_ptr);
                    } else {
                        let src_w = llvm_int_bit_width(operand_ty.as_str());
                        let dst_w = llvm_int_bit_width(field_ty_str);
                        if src_w > dst_w && dst_w > 0 {
                            // Wider to narrower: truncate
                            let cast_tmp = ctx.fresh_temp_cg();
                            ctx.emit_cast_cg(&cast_tmp, "trunc", operand_ty.as_str(), operand_val.as_str(), field_ty_str);
                            ctx.emit_store_cg2(field_ty_str, &cast_tmp, &field_ptr);
                        } else if src_w < dst_w && src_w > 0 {
                            // Narrower to wider: zero-extend
                            let cast_tmp = ctx.fresh_temp_cg();
                            ctx.emit_cast_cg(&cast_tmp, "zext", operand_ty.as_str(), operand_val.as_str(), field_ty_str);
                            ctx.emit_store_cg2(field_ty_str, &cast_tmp, &field_ptr);
                        } else if src_w > 0 && string_eq_str(field_ty_str, "ptr") {
                            // Integer to pointer: inttoptr
                            let cast_tmp = ctx.fresh_temp_cg();
                            ctx.emit_cast_cg(&cast_tmp, "inttoptr", operand_ty.as_str(), operand_val.as_str(), "ptr");
                            ctx.emit_store_cg2("ptr", &cast_tmp, &field_ptr);
                        } else if dst_w > 0 && string_eq_str(operand_ty.as_str(), "ptr") {
                            // Pointer to integer: ptrtoint
                            let cast_tmp = ctx.fresh_temp_cg();
                            ctx.emit_cast_cg(&cast_tmp, "ptrtoint", "ptr", operand_val.as_str(), field_ty_str);
                            ctx.emit_store_cg2(field_ty_str, &cast_tmp, &field_ptr);
                        } else {
                            // Other mismatch (e.g., aggregate type from nested enum).
                            // Store with the operand's own type so the IR is valid.
                            ctx.emit_store_str_cg(operand_ty.as_str(), operand_val.as_str(), &field_ptr);
                        }
                    }
                }
            }
            return;
        }
        Option.None => {}
    }
    // Fallback: ADT not in registry (builtin generic enum like Option<T>, Result<T,E>).
    // Emit as enum: store i32 discriminant, then payload at alignment-correct offset.
    let mut vals: Vec<String> = Vec.new();
    let mut tys: Vec<String> = Vec.new();
    for k in 0usize..operands.len() {
        let typed = emit_operand_typed(ctx, &operands[k]);
        vals.push(typed.0);
        tys.push(typed.1);
    }

    // Store i32 discriminant at byte 0
    ctx.emit_store("i32", codegen_types.format_u64(variant_idx as u64).as_str(), dest);

    // Store payload fields after discriminant, respecting alignment
    if vals.len() > 0 {
        // Build payload struct type from operand types
        let mut payload_ty = common.make_string("{ ");
        for pi in 0usize..tys.len() {
            if pi > 0 {
                payload_ty.push_str(", ");
            }
            payload_ty.push_str(tys[pi].as_str());
        }
        payload_ty.push_str(" }");

        // Compute payload byte offset: i32 (4 bytes) + padding for alignment
        let payload_align = codegen_size.llvm_type_alignment(payload_ty.as_str());
        let discrim_size: u64 = 4;
        let padding = (payload_align - (discrim_size % payload_align)) % payload_align;
        let byte_offset = discrim_size + padding;

        let payload_ptr = ctx.fresh_temp_cg();
        ctx.begin_gep_str(&payload_ptr, "i8", dest);
        ctx.gep_ptr_offset(byte_offset);
        ctx.end_gep();

        // Store each field in the payload
        for i in 0usize..vals.len() {
            let field_ptr = ctx.fresh_temp_cg();
            ctx.begin_gep(&field_ptr, payload_ty.as_str(), &payload_ptr);
            ctx.gep_ptr_offset(0);
            ctx.gep_field(i as u32);
            ctx.end_gep();
            ctx.emit_store_str_cg(tys[i].as_str(), vals[i].as_str(), &field_ptr);
        }
    }
}

/// Checks if any field in a struct layout has a Param or Infer HIR type.
fn layout_has_param_fields(layout: &codegen_ctx.StructLayout) -> bool {
    for i in 0usize..layout.fields.len() {
        match &layout.fields[i].hir_type {
            &Option.Some(ht_id) => {
                if type_intern.is_param_or_infer_id(ht_id) {
                    return true;
                }
            }
            &Option.None => {}
        }
    }
    false
}

/// Gets the TyVarId.index for a field's HIR type if it's Param or Infer.
/// Returns u32::MAX for non-param types.
fn get_field_var_index(
    field_hir_tys: &Vec<Option<type_intern.TyId>>,
    idx: usize,
) -> u32 {
    match &field_hir_tys[idx] {
        &Option.Some(ty_id) => {
            let kind = type_intern.type_interner().get(ty_id);
            match kind {
                &type_intern.InternedTypeKind.Param(var_id) => var_id.index,
                &type_intern.InternedTypeKind.Infer(var_id) => var_id.index,
                _ => 4294967295,
            }
        }
        &Option.None => 4294967295,
    }
}

/// Finds the arg index of a previous field with the same TyVarId.
/// Scans fields [0..field_idx) and counts unique param vars to determine
/// what arg position the first occurrence of var_index was assigned.
fn find_previous_param_pos(
    field_hir_tys: &Vec<Option<type_intern.TyId>>,
    field_idx: usize,
    var_index: u32,
) -> Option<usize> {
    if var_index == 4294967295 {
        return Option.None;
    }
    let mut unique_count: usize = 0;
    for prev in 0usize..field_idx {
        let prev_var = get_field_var_index(field_hir_tys, prev);
        if prev_var == var_index {
            // Found a previous field with the same var — return its position
            return Option.Some(unique_count);
        }
        if prev_var != 4294967295 {
            // Different param var — check if it's a first occurrence
            let mut is_dup = false;
            for pp in 0usize..prev {
                if get_field_var_index(field_hir_tys, pp) == prev_var {
                    is_dup = true;
                }
            }
            if !is_dup {
                unique_count += 1;
            }
        }
    }
    // No previous field with same var
    Option.None
}

/// Emits an aggregate construction.
fn emit_aggregate(
    ctx: &mut codegen_ctx.CodegenCtx,
    dest: &str,
    dest_type: &str,
    kind: &mir_types.AggregateKind,
    operands: &Vec<mir_types.Operand>,
) {
    match kind {
        &mir_types.AggregateKind.Tuple => {
            // Build the tuple LLVM type from operand types
            let tuple_llvm = build_tuple_llvm_type(ctx, operands);
            for i in 0usize..operands.len() {
                let typed = emit_operand_typed(ctx, &operands[i]);
                let field_val = typed.0;
                let field_ty = typed.1;
                let field_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&field_ptr, tuple_llvm.as_str(), dest);
                ctx.gep_ptr_offset(0);
                ctx.gep_field(i as u32);
                ctx.end_gep();
                ctx.emit_store_str_cg(field_ty.as_str(), field_val.as_str(), &field_ptr);
            }
        }
        &mir_types.AggregateKind.Array(ref elem_ty) => {
            let mut elem_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, *elem_ty);
            // If the element type is unresolved (Infer → i64 fallback), use
            // the actual type from the first operand instead.
            if operands.len() > 0 {
                let (first_val, first_ty) = emit_operand_typed(ctx, &operands[0]);
                if !str_eq(first_ty.as_str(), elem_llvm.as_str()) {
                    elem_llvm = first_ty.clone();
                }
                let elem_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&elem_ptr, elem_llvm.as_str(), dest);
                ctx.gep_ptr_offset(0);
                ctx.end_gep();
                ctx.emit_store_str_cg(elem_llvm.as_str(), first_val.as_str(), &elem_ptr);
            }
            for i in 1usize..operands.len() {
                let elem_val = emit_operand(ctx, &operands[i]);
                let elem_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&elem_ptr, elem_llvm.as_str(), dest);
                ctx.gep_ptr_offset(i as u64);
                ctx.end_gep();
                ctx.emit_store_str_cg(elem_llvm.as_str(), elem_val.as_str(), &elem_ptr);
            }
        }
        &mir_types.AggregateKind.Adt { ref def_id, variant_idx, ref type_args } => {
            // Convert TyId type_args to hir_ty.Type for emit_aggregate_adt
            let mut hir_type_args: Vec<hir_ty.Type> = Vec.new();
            for ta in 0usize..type_args.len() {
                hir_type_args.push(type_intern.ty_id_to_type(type_args[ta]));
            }
            emit_aggregate_adt(ctx, dest, dest_type, def_id.index, variant_idx, operands, &hir_type_args);
            // Frozen<T>: persist value to Tier 3 and freeze
            let is_frozen = ctx.frozen_def_id != 0 && def_id.index == ctx.frozen_def_id;
            if is_frozen {
                let frozen_size = codegen_size.llvm_type_size(dest_type) as u64;
                let persisted = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&persisted);
                ctx.write(" = call ptr @blood_persist(ptr ");
                ctx.write(dest);
                ctx.write(", i64 ");
                ctx.write_string(&codegen_types.format_u64(frozen_size));
                ctx.write(")\n");
                let freeze_ok = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&freeze_ok);
                ctx.write(" = call i1 @blood_freeze(ptr ");
                ctx.write_cgname(&persisted);
                ctx.write(")\n");
                // GAP-2 deep-freeze (A1 Phase 2): pass a layout descriptor
                // matching the persisted Frozen<T> shape. Two cases:
                //   (a) T is stored INLINE (primitive / small struct fitting in
                //       Frozen's field): the persisted memory has T's layout at
                //       offset 0 — walk T's own heap-owning fields.
                //   (b) T is stored INDIRECTLY as a heap pointer (large struct or
                //       any heap type): Frozen<T>'s LLVM shape is { ptr } while
                //       sizeof(T) is larger — emit a kind=3 wrapper descriptor
                //       that dereferences the pointer and recurses into T's own
                //       layout.
                let inner_ty_idx: u32 = if type_args.len() > 0 { type_args[0].index } else { 0u32 };
                let layout_label: String = if type_args.len() > 0 {
                    let t_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, type_args[0]);
                    let t_size = codegen_size.llvm_type_size(t_llvm.as_str());
                    if frozen_size < t_size {
                        // Indirect: create the indirect wrapper whose single
                        // entry points at the inner T's own layout. The
                        // populate_all_layouts pass at emit time will fill in
                        // T's entries.
                        let inner_label = ctx.add_layout_descriptor(inner_ty_idx);
                        ctx.add_indirect_layout_wrapper(inner_ty_idx, inner_label)
                    } else {
                        ctx.add_layout_descriptor(inner_ty_idx)
                    }
                } else {
                    ctx.add_layout_descriptor(inner_ty_idx)
                };
                let fields_ok = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&fields_ok);
                ctx.write(" = call i1 @blood_freeze_fields(ptr ");
                ctx.write_cgname(&persisted);
                ctx.write(", ptr ");
                ctx.write_string(&layout_label);
                ctx.write(")\n");
                // Copy persisted data back to the Frozen struct's alloca
                ctx.write_indent();
                ctx.write("call void @llvm.memcpy.p0.p0.i64(ptr ");
                ctx.write(dest);
                ctx.write(", ptr ");
                ctx.write_cgname(&persisted);
                ctx.write(", i64 ");
                ctx.write_string(&codegen_types.format_u64(frozen_size));
                ctx.write(", i1 false)\n");
            }
        }
        &mir_types.AggregateKind.Record => {
            // Extensible records - store fields with actual types
            let record_llvm = build_tuple_llvm_type(ctx, operands);
            for i in 0usize..operands.len() {
                let typed = emit_operand_typed(ctx, &operands[i]);
                let field_val = typed.0;
                let field_ty = typed.1;
                let field_ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&field_ptr, record_llvm.as_str(), dest);
                ctx.gep_ptr_offset(0);
                ctx.gep_field(i as u32);
                ctx.end_gep();
                ctx.emit_store_str_cg(field_ty.as_str(), field_val.as_str(), &field_ptr);
            }
        }
        &mir_types.AggregateKind.Closure { ref def_id } => {
            // Closures: construct { ptr fn_ptr, ptr env_ptr } fat pointer
            // Build closure function name from def_id
            let mut closure_fn_name = common.make_string("blood_closure_");
            let id_str = codegen_types.format_u64(def_id.index as u64);
            closure_fn_name.push_str(id_str.as_str());

            if operands.len() == 0 {
                // Non-capturing closure: env_ptr is null
                // %tmp1 = insertvalue { ptr, ptr } zeroinitializer, ptr @"closure_fn", 0
                let ins1 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins1);
                ctx.write(" = insertvalue { ptr, ptr } zeroinitializer, ptr @\"");
                ctx.write_string(&closure_fn_name);
                ctx.write("\", 0\n");
                // %tmp2 = insertvalue { ptr, ptr } %tmp1, ptr null, 1
                let ins2 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins2);
                ctx.write(" = insertvalue { ptr, ptr } ");
                ctx.write_cgname(&ins1);
                ctx.write(", ptr null, 1\n");
                // store { ptr, ptr } %tmp2, ptr dest
                let ins2_str = cgname_to_string(&ins2);
                ctx.emit_store("{ ptr, ptr }", ins2_str.as_str(), dest);
            } else {
                // Capturing closure: allocate env struct, store captures, build fat pointer

                // Build env struct LLVM type from capture operand types
                let env_llvm = build_tuple_llvm_type(ctx, operands);

                // Compute env struct size by summing element sizes (rounded up to 8-byte
                // alignment per element to match LLVM's default struct layout)
                let mut env_size: u64 = 0;
                for si in 0usize..operands.len() {
                    let elem_ty = operand_llvm_type(ctx, &operands[si]);
                    let elem_size = llvm_type_size_estimate(elem_ty.as_str());
                    env_size += elem_size;
                }
                if env_size == 0 {
                    env_size = 8; // minimum allocation size
                }
                let size_str = codegen_types.format_u64(env_size);

                // Allocate env struct on heap: %alloc_i64 = call i64 @__blood_alloc(i64 size)
                let alloc_i64 = ctx.fresh_temp_cg();
                ctx.begin_call(Option.Some(&alloc_i64), "i64", "@__blood_alloc");
                ctx.call_arg_str(true, "i64", size_str.as_str());
                ctx.end_call();

                // Convert i64 to ptr: %env_ptr = inttoptr i64 %alloc_i64 to ptr
                let env_ptr = ctx.fresh_temp_cg();
                ctx.emit_cast_cg2(&env_ptr, "inttoptr", "i64", &alloc_i64, "ptr");

                // Store each capture operand into the env struct
                for i in 0usize..operands.len() {
                    let typed = emit_operand_typed(ctx, &operands[i]);
                    let cap_val = typed.0;
                    let cap_ty = typed.1;
                    let cap_ptr = ctx.fresh_temp_cg();
                    ctx.begin_gep(&cap_ptr, env_llvm.as_str(), &env_ptr);
                    ctx.gep_ptr_offset(0);
                    ctx.gep_field(i as u32);
                    ctx.end_gep();
                    ctx.emit_store_str_cg(cap_ty.as_str(), cap_val.as_str(), &cap_ptr);
                }

                // Build fat pointer: { ptr @closure_fn, ptr %env_ptr }
                let ins1 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins1);
                ctx.write(" = insertvalue { ptr, ptr } zeroinitializer, ptr @\"");
                ctx.write_string(&closure_fn_name);
                ctx.write("\", 0\n");
                let ins2 = ctx.fresh_temp_cg();
                ctx.write_indent();
                ctx.write_cgname(&ins2);
                ctx.write(" = insertvalue { ptr, ptr } ");
                ctx.write_cgname(&ins1);
                ctx.write(", ptr ");
                ctx.write_cgname(&env_ptr);
                ctx.write(", 1\n");
                // Store the fat pointer to destination
                let ins2_str = cgname_to_string(&ins2);
                ctx.emit_store("{ ptr, ptr }", ins2_str.as_str(), dest);
            }
        }
        &mir_types.AggregateKind.Range { ref element, inclusive: _ } => {
            // Ranges: store start and end with element type
            let elem_llvm = codegen_size.type_to_llvm_with_ctx_id(ctx, *element);
            // Range struct is { elem_type, elem_type } (start, end)
            let mut range_llvm = common.make_string("{ ");
            for fi in 0usize..operands.len() {
                if fi > 0 {
                    range_llvm.push_str(", ");
                }
                range_llvm.push_str(elem_llvm.as_str());
            }
            range_llvm.push_str(" }");

            for i in 0usize..operands.len() {
                let val = emit_operand(ctx, &operands[i]);
                let ptr = ctx.fresh_temp_cg();
                ctx.begin_gep_str(&ptr, range_llvm.as_str(), dest);
                ctx.gep_ptr_offset(0);
                ctx.gep_field(i as u32);
                ctx.end_gep();
                ctx.emit_store_str_cg(elem_llvm.as_str(), val.as_str(), &ptr);
            }
        }
    }
}

// ============================================================
// String Helpers
// ============================================================


/// Converts a CgName to String for use at boundaries where String is required.
fn cgname_to_string(name: &codegen_ctx.CgName) -> String {
    match name {
        &codegen_ctx.CgName.Temp(n) => {
            let mut s = common.make_string("%tmp");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Local(n) => {
            let mut s = common.make_string("%_");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Label(n) => {
            let mut s = common.make_string("label");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Block(n) => {
            let mut s = common.make_string("bb");
            let ns = codegen_types.format_u64(n as u64);
            s.push_str(ns.as_str());
            s
        }
        &codegen_ctx.CgName.Str(ref s) => {
            s.clone()
        }
    }
}
