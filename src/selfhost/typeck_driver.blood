// Blood Self-Hosted Compiler - Type Checking Driver
//
// This module provides the entry point for type checking a lowered HIR.
// It coordinates the TypeChecker from typeck.blood with the expression
// checking from typeck_expr.blood to check all function bodies.
//
// Pipeline integration:
//   AST -> lower_program() -> LoweringCtx -> check_types() -> TypeCheckResult
//
// The type checking driver:
// 1. Collects type information from all items (structs, enums, functions)
// 2. Type checks each function body
// 3. Returns type errors or success

mod common;
mod hir_def;
mod hir_ty;
mod hir_item;
mod hir_expr;
mod hir;
mod hir_lower_ctx;
mod unify;
mod typeck;
mod typeck_expr;
mod typeck_info;
mod typeck_linearity;
mod interner;
mod type_intern;
mod typeck_types;
mod typeck_dispatch;
mod hashmap;

// ============================================================
// Body Info Cache — O(1) lookup for body → item metadata
// ============================================================

/// Cached metadata for a body, extracted from items once.
struct BodyItemInfo {
    /// Return type of the function/method/const containing this body.
    pub return_ty_index: u32,
    /// DefId.index of the item containing this body.
    pub def_id_index: u32,
    /// Whether this body belongs to a handler return clause.
    pub is_handler_return: bool,
}

/// Builds a body_id → BodyItemInfo cache by scanning items once.
/// Returns a HashMap keyed on body_id.index.
fn build_body_item_cache(items: &Vec<hir_lower_ctx.ItemEntry>) -> hashmap.HashMapU64U32 {
    // We encode BodyItemInfo into the HashMap values by storing the item index.
    // Then we can look up the item directly. This avoids needing a custom HashMap.
    // Key: body_id.index as u64, Value: item_index as u32.
    let mut map = hashmap.HashMapU64U32.new();

    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                match &fn_def.body_id {
                    &Option.Some(ref bid) => {
                        map.insert(bid.index as u64, i as u32);
                    }
                    &Option.None => {}
                }
            }
            &hir_item.ItemKind.Impl(ref impl_def) => {
                for j in 0usize..impl_def.items.len() {
                    match &impl_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    map.insert(bid.index as u64, i as u32);
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Const(ref assoc_const) => {
                            match &assoc_const.body_id {
                                &Option.Some(ref bid) => {
                                    map.insert(bid.index as u64, i as u32);
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                    }
                }
            }
            &hir_item.ItemKind.Const(ref const_def) => {
                map.insert(const_def.body_id.index as u64, i as u32);
            }
            &hir_item.ItemKind.Static(ref static_def) => {
                map.insert(static_def.body_id.index as u64, i as u32);
            }
            &hir_item.ItemKind.Trait(ref trait_def) => {
                for j in 0usize..trait_def.items.len() {
                    match &trait_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    map.insert(bid.index as u64, i as u32);
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                        &hir_item.AssocItem.Const(_) => {}
                    }
                }
            }
            &hir_item.ItemKind.Handler(ref handler_def) => {
                // Handler op bodies
                for j in 0usize..handler_def.op_impls.len() {
                    map.insert(handler_def.op_impls[j].body_id.index as u64, i as u32);
                }
                // Handler return clause body
                match &handler_def.return_clause {
                    &Option.Some(ref rc) => {
                        map.insert(rc.body_id.index as u64, i as u32);
                    }
                    &Option.None => {}
                }
            }
            &hir_item.ItemKind.Effect(_) => {}
            &hir_item.ItemKind.Struct(_) => {}
            &hir_item.ItemKind.Enum(_) => {}
            &hir_item.ItemKind.TypeAlias(_) => {}
            &hir_item.ItemKind.Module(_) => {}
            &hir_item.ItemKind.Macro(_) => {}
            &hir_item.ItemKind.Foreign(_) => {}
        }
    }
    map
}

/// O(1) lookup for return type given a body_id.
fn find_return_type_cached(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) -> type_intern.TyId {
    match cache.get(target_body_id.index as u64) {
        Option.Some(item_idx) => {
            let entry = &items[item_idx as usize];
            match &entry.item.kind {
                &hir_item.ItemKind.Fn(ref fn_def) => fn_def.sig.return_ty,
                &hir_item.ItemKind.Impl(ref impl_def) => {
                    for j in 0usize..impl_def.items.len() {
                        match &impl_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return assoc_fn.sig.return_ty;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            &hir_item.AssocItem.Const(ref assoc_const) => {
                                match &assoc_const.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return assoc_const.ty;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            &hir_item.AssocItem.Type(_) => {}
                        }
                    }
                    type_intern.CommonTypes.unit()
                }
                &hir_item.ItemKind.Const(ref const_def) => const_def.ty,
                &hir_item.ItemKind.Static(ref static_def) => static_def.ty,
                &hir_item.ItemKind.Trait(ref trait_def) => {
                    for j in 0usize..trait_def.items.len() {
                        match &trait_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return assoc_fn.sig.return_ty;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            _ => {}
                        }
                    }
                    type_intern.CommonTypes.unit()
                }
                &hir_item.ItemKind.Handler(ref handler_def) => {
                    // Check return clause body
                    match &handler_def.return_clause {
                        &Option.Some(ref rc) => {
                            if rc.body_id.index == target_body_id.index {
                                return type_intern.CommonTypes.unit();
                            }
                        }
                        &Option.None => {}
                    }
                    // Check op implementation bodies — look up effect op return type
                    for j in 0usize..handler_def.op_impls.len() {
                        if handler_def.op_impls[j].body_id.index == target_body_id.index {
                            let op_def_id = handler_def.op_impls[j].op_def_id;
                            return find_effect_op_return_type(items, op_def_id);
                        }
                    }
                    type_intern.CommonTypes.unit()
                }
                _ => type_intern.CommonTypes.unit(),
            }
        }
        Option.None => type_intern.CommonTypes.unit(),
    }
}

/// O(1) lookup for whether a body is a handler return clause.
fn is_handler_return_cached(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) -> bool {
    match cache.get(target_body_id.index as u64) {
        Option.Some(item_idx) => {
            let entry = &items[item_idx as usize];
            match &entry.item.kind {
                &hir_item.ItemKind.Handler(ref handler_def) => {
                    match &handler_def.return_clause {
                        &Option.Some(ref rc) => rc.body_id.index == target_body_id.index,
                        &Option.None => false,
                    }
                }
                _ => false,
            }
        }
        Option.None => false,
    }
}

/// O(1) lookup for the DefId of the item containing a body.
fn find_def_id_cached(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) -> u32 {
    match cache.get(target_body_id.index as u64) {
        Option.Some(item_idx) => {
            let entry = &items[item_idx as usize];
            match &entry.item.kind {
                &hir_item.ItemKind.Impl(ref impl_def) => {
                    // For impl methods, need the specific method's DefId
                    for j in 0usize..impl_def.items.len() {
                        match &impl_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return assoc_fn.def_id.index;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            &hir_item.AssocItem.Const(ref assoc_const) => {
                                match &assoc_const.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return assoc_const.def_id.index;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            &hir_item.AssocItem.Type(_) => {}
                        }
                    }
                    0
                }
                &hir_item.ItemKind.Handler(ref handler_def) => {
                    // Return clause: use body_id.index as DefId
                    match &handler_def.return_clause {
                        &Option.Some(ref rc) => {
                            if rc.body_id.index == target_body_id.index {
                                return rc.body_id.index;
                            }
                        }
                        &Option.None => {}
                    }
                    // Op bodies: use op_def_id
                    for j in 0usize..handler_def.op_impls.len() {
                        if handler_def.op_impls[j].body_id.index == target_body_id.index {
                            return handler_def.op_impls[j].op_def_id.index;
                        }
                    }
                    0
                }
                &hir_item.ItemKind.Trait(ref trait_def) => {
                    for j in 0usize..trait_def.items.len() {
                        match &trait_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return assoc_fn.def_id.index;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            _ => {}
                        }
                    }
                    entry.item.def_id.index
                }
                _ => entry.item.def_id.index,
            }
        }
        Option.None => 0,
    }
}

/// O(1) lookup for effect row DefIds of the function containing a body.
fn find_effect_row_cached(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) -> Vec<u32> {
    match cache.get(target_body_id.index as u64) {
        Option.Some(item_idx) => {
            let entry = &items[item_idx as usize];
            match &entry.item.kind {
                &hir_item.ItemKind.Fn(ref fn_def) => {
                    collect_effect_def_ids(&fn_def.sig.effects)
                }
                &hir_item.ItemKind.Impl(ref impl_def) => {
                    for j in 0usize..impl_def.items.len() {
                        match &impl_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            let mut row = collect_effect_def_ids(&assoc_fn.sig.effects);
                                            // If impl method has no effect annotation, inherit from trait method
                                            if row.len() == 0 {
                                                match &impl_def.trait_ref {
                                                    &Option.Some(ref tref) => {
                                                        row = find_trait_method_effects(items, tref.def_id.index, assoc_fn.name.symbol);
                                                    }
                                                    &Option.None => {}
                                                }
                                            }
                                            return row;
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            _ => {}
                        }
                    }
                    Vec.new()
                }
                &hir_item.ItemKind.Trait(ref trait_def) => {
                    for j in 0usize..trait_def.items.len() {
                        match &trait_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return collect_effect_def_ids(&assoc_fn.sig.effects);
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            _ => {}
                        }
                    }
                    Vec.new()
                }
                &hir_item.ItemKind.Handler(ref handler_def) => {
                    // Handler op bodies can perform the handled effect (re-perform)
                    // plus any explicitly forwarded effects.
                    let mut row: Vec<u32> = Vec.new();
                    row.push(handler_def.handled_effect.def_id.index);
                    for fi in 0usize..handler_def.forwarded_effects.len() {
                        row.push(handler_def.forwarded_effects[fi].def_id.index);
                    }
                    row
                }
                _ => Vec.new(),
            }
        }
        Option.None => Vec.new(),
    }
}

// ============================================================
// Type Check Result
// ============================================================

/// Result of type checking a crate.
pub struct TypeCheckResult {
    /// Whether type checking succeeded.
    pub success: bool,
    /// Type errors encountered.
    pub errors: Vec<typeck.TypeError>,
    /// The substitution table from type inference.
    /// Contains resolved type variables that must be applied during MIR lowering.
    pub subst_table: unify.SubstTable,
    /// Builtin DefId-to-runtime-name mapping for codegen.
    /// Maps synthetic type checker DefIds to runtime function names.
    pub builtin_def_names: Vec<typeck.BuiltinDefName>,
    /// Method resolution side table from type checking.
    /// Maps expression span starts to resolved method DefIds for MIR lowering.
    pub method_resolutions: Vec<common.MethodResEntry>,
    /// Field resolution side table from type checking.
    /// Maps field access expression span starts to resolved field indices.
    pub field_resolutions: Vec<common.FieldResEntry>,
    /// Trait default method remappings for codegen.
    /// When a trait default method is used by an impl, calls within the body
    /// targeting abstract trait methods must be redirected to concrete impl methods.
    pub default_method_remaps: Vec<common.DefaultMethodRemap>,
    /// Array-to-slice coercion side table from type checking.
    /// Records expressions that need &[T; N] to &[T] conversion during MIR lowering.
    pub coercion_entries: Vec<common.CoercionEntry>,
    /// Type-generic call info for monomorphization.
    /// Records calls to type-generic functions with resolved concrete type bindings.
    pub type_generic_calls: Vec<common.TypeGenericCallInfo>,
    /// Pending method calls that remained unresolved after type checking.
    /// Used to identify which generic functions need monomorphization.
    pub pending_method_calls: Vec<common.PendingMethodCall>,
    /// Flat impl method table for resolving trait methods during monomorphization.
    pub impl_method_table: Vec<common.ImplMethodEntry>,
}

impl TypeCheckResult {
    /// Creates a successful result with a substitution table, builtin name mappings,
    /// and method resolution side table.
    pub fn ok(
        subst_table: unify.SubstTable,
        builtin_def_names: Vec<typeck.BuiltinDefName>,
        method_resolutions: Vec<common.MethodResEntry>,
        field_resolutions: Vec<common.FieldResEntry>,
        default_method_remaps: Vec<common.DefaultMethodRemap>,
        coercion_entries: Vec<common.CoercionEntry>,
        type_generic_calls: Vec<common.TypeGenericCallInfo>,
        pending_method_calls: Vec<common.PendingMethodCall>,
        impl_method_table: Vec<common.ImplMethodEntry>,
    ) -> TypeCheckResult {
        TypeCheckResult {
            success: true,
            errors: Vec.new(),
            subst_table: subst_table,
            builtin_def_names: builtin_def_names,
            method_resolutions: method_resolutions,
            field_resolutions: field_resolutions,
            default_method_remaps: default_method_remaps,
            coercion_entries: coercion_entries,
            type_generic_calls: type_generic_calls,
            pending_method_calls: pending_method_calls,
            impl_method_table: impl_method_table,
        }
    }

    /// Creates a failed result with errors, a substitution table, and method resolutions.
    pub fn failed(
        errors: Vec<typeck.TypeError>,
        subst_table: unify.SubstTable,
        method_resolutions: Vec<common.MethodResEntry>,
        field_resolutions: Vec<common.FieldResEntry>,
    ) -> TypeCheckResult {
        TypeCheckResult {
            success: false,
            errors: errors,
            subst_table: subst_table,
            builtin_def_names: Vec.new(),
            method_resolutions: method_resolutions,
            field_resolutions: field_resolutions,
            default_method_remaps: Vec.new(),
            coercion_entries: Vec.new(),
            type_generic_calls: Vec.new(),
            pending_method_calls: Vec.new(),
            impl_method_table: Vec.new(),
        }
    }

    /// Returns true if type checking passed.
    pub fn is_ok(self: &Self) -> bool {
        self.success
    }

    /// Returns the number of errors.
    pub fn error_count(self: &Self) -> usize {
        self.errors.len()
    }
}

/// Clones a TypeCheckResult's data to the system heap.
/// Called with NO active region so all allocations go to calloc.
/// The source data (in typeck_region) can then be freed.
pub fn clone_typeck_result_to_heap(src: &TypeCheckResult) -> TypeCheckResult {
    // Clone SubstTable (Vecs of integer-indexed structs + HashMaps)
    let subst = unify.clone_subst_table(&src.subst_table);

    // Clone Vecs of plain integer structs
    let mut methods: Vec<common.MethodResEntry> = Vec.with_capacity(src.method_resolutions.len());
    for i in 0usize..src.method_resolutions.len() {
        let e = &src.method_resolutions[i];
        methods.push(common.MethodResEntry { body_def_id: e.body_def_id, span_start: e.span_start, def_id_index: e.def_id_index });
    }

    let mut fields: Vec<common.FieldResEntry> = Vec.with_capacity(src.field_resolutions.len());
    for i in 0usize..src.field_resolutions.len() {
        let e = &src.field_resolutions[i];
        fields.push(common.FieldResEntry { body_def_id: e.body_def_id, span_start: e.span_start, field_idx: e.field_idx });
    }

    let mut coercions: Vec<common.CoercionEntry> = Vec.with_capacity(src.coercion_entries.len());
    for i in 0usize..src.coercion_entries.len() {
        let e = &src.coercion_entries[i];
        coercions.push(common.CoercionEntry { body_def_id: e.body_def_id, span_start: e.span_start, array_len: e.array_len });
    }

    // Clone DefaultMethodRemap (has nested Vec<CallRemapEntry>)
    let mut remaps: Vec<common.DefaultMethodRemap> = Vec.with_capacity(src.default_method_remaps.len());
    for i in 0usize..src.default_method_remaps.len() {
        let e = &src.default_method_remaps[i];
        let mut cr: Vec<common.CallRemapEntry> = Vec.with_capacity(e.call_remaps.len());
        for j in 0usize..e.call_remaps.len() {
            cr.push(common.CallRemapEntry { from_def_id: e.call_remaps[j].from_def_id, to_def_id: e.call_remaps[j].to_def_id });
        }
        remaps.push(common.DefaultMethodRemap { body_def_id: e.body_def_id, call_remaps: cr });
    }

    // Clone TypeGenericCallInfo (has nested Vec<TypeMonoBinding>)
    let mut tgc: Vec<common.TypeGenericCallInfo> = Vec.with_capacity(src.type_generic_calls.len());
    for i in 0usize..src.type_generic_calls.len() {
        let e = &src.type_generic_calls[i];
        let mut bindings: Vec<common.TypeMonoBinding> = Vec.with_capacity(e.type_bindings.len());
        for j in 0usize..e.type_bindings.len() {
            bindings.push(common.TypeMonoBinding { ty_var_index: e.type_bindings[j].ty_var_index, concrete_ty_id: e.type_bindings[j].concrete_ty_id });
        }
        tgc.push(common.TypeGenericCallInfo { call_span_start: e.call_span_start, callee_def_id: e.callee_def_id, type_bindings: bindings });
    }

    // Clone PendingMethodCall
    let mut pending: Vec<common.PendingMethodCall> = Vec.with_capacity(src.pending_method_calls.len());
    for i in 0usize..src.pending_method_calls.len() {
        let e = &src.pending_method_calls[i];
        pending.push(common.PendingMethodCall { body_def_id: e.body_def_id, span_start: e.span_start, receiver_var: e.receiver_var, method_symbol: e.method_symbol, method_name_str: common.make_string(e.method_name_str.as_str()), return_ty_var: e.return_ty_var });
    }

    // Clone ImplMethodEntry
    let mut impl_methods: Vec<common.ImplMethodEntry> = Vec.with_capacity(src.impl_method_table.len());
    for i in 0usize..src.impl_method_table.len() {
        let e = &src.impl_method_table[i];
        impl_methods.push(common.ImplMethodEntry { self_ty_id: e.self_ty_id, method_name: e.method_name, method_name_str: common.make_string(e.method_name_str.as_str()), method_def_id: e.method_def_id });
    }

    // Clone BuiltinDefName (has String — deep clone)
    let mut builtins: Vec<typeck.BuiltinDefName> = Vec.with_capacity(src.builtin_def_names.len());
    for i in 0usize..src.builtin_def_names.len() {
        let e = &src.builtin_def_names[i];
        builtins.push(typeck.BuiltinDefName { def_id_index: e.def_id_index, runtime_name: common.make_string(e.runtime_name.as_str()) });
    }

    TypeCheckResult {
        success: src.success,
        errors: Vec.new(),
        subst_table: subst,
        builtin_def_names: builtins,
        method_resolutions: methods,
        field_resolutions: fields,
        default_method_remaps: remaps,
        coercion_entries: coercions,
        type_generic_calls: tgc,
        pending_method_calls: pending,
        impl_method_table: impl_methods,
    }
}

// ============================================================
// Main Entry Point
// ============================================================

/// Type check a lowered HIR crate.
///
/// Takes the lowering context which contains all items and bodies,
/// and returns a TypeCheckResult indicating success or failure.
pub fn check_types(ctx: &hir_lower_ctx.LoweringCtx) -> TypeCheckResult {
    let mut checker = typeck.TypeChecker.new();

    // Phase 1: Collect type information from items
    // (For now, we skip this since we don't have item signatures stored separately)

    // Build body → item cache for O(1) lookups
    let body_cache = build_body_item_cache(&ctx.items);

    // Phase 2: Type check all function bodies
    for i in 0usize..ctx.bodies.len() {
        let body_entry = &ctx.bodies[i];
        let mut return_ty = find_return_type_cached(&ctx.items, body_entry.body_id, &body_cache);
        let is_handler_ret = is_handler_return_cached(&ctx.items, body_entry.body_id, &body_cache);
        if is_handler_ret {
            return_ty = checker.fresh_infer();
        }
        checker.current_body_def_id = find_def_id_cached(&ctx.items, body_entry.body_id, &body_cache);
        checker.current_effect_row = find_effect_row_cached(&ctx.items, body_entry.body_id, &body_cache);
        checker.current_effect_type_args = find_effect_type_args_cached(&ctx.items, body_entry.body_id, &body_cache);
        unify_handler_op_params_cached(&mut checker, &ctx.items, &body_entry.body, body_entry.body_id, &body_cache);
        setup_handler_op_context_cached(&mut checker, &ctx.items, body_entry.body_id, &body_cache);
        // Mark handler return bodies after setup_handler_op_context (which resets resume_ty)
        if is_handler_ret {
            checker.resume_ty = Option.Some(return_ty);
        }
        check_body(&mut checker, &body_entry.body, return_ty);
    }

    // Phase 3: Deferred resolution for Infer-receiver calls and field accesses
    resolve_pending_methods(&mut checker);
    resolve_pending_field_accesses(&mut checker);

    // Return result with substitution table for type resolution in MIR lowering
    if checker.has_errors() {
        TypeCheckResult.failed(checker.errors, checker.subst_table, checker.method_resolutions, checker.field_resolutions)
    } else {
        TypeCheckResult.ok(checker.subst_table, checker.builtin_def_names, checker.method_resolutions, checker.field_resolutions, checker.default_method_remaps, checker.coercion_entries, checker.type_generic_calls, Vec.new(), Vec.new())
    }
}

/// Type check using a LowerResult (for driver integration).
///
/// This is the preferred entry point when integrating with the driver,
/// since the driver has LowerResult not LoweringCtx.
pub fn check_lower_result(result: &hir_lower_ctx.LowerResult, skip_modules: &Vec<bool>) -> TypeCheckResult {
    // Start the type checker's TyVarId counter where HIR lowering left off
    // to avoid collisions between HIR inference variables and type checker variables.
    let mut checker = typeck.TypeChecker.new_from(result.next_ty_var);

    // Pass builtin type info from HIR lowering
    checker.next_def_id = result.next_def_id;
    checker.builtin_string_def = copy_opt_def_id(&result.builtin_string_def);
    checker.builtin_vec_def = copy_opt_def_id(&result.builtin_vec_def);
    checker.builtin_option_def = copy_opt_def_id(&result.builtin_option_def);
    checker.builtin_box_def = copy_opt_def_id(&result.builtin_box_def);
    checker.builtin_hashmap_def = copy_opt_def_id(&result.builtin_hashmap_def);
    checker.builtin_result_def = copy_opt_def_id(&result.builtin_result_def);

    // Find persist builtin DefId from builtin_fn_defs
    for bfi in 0usize..result.builtin_fn_defs.len() {
        let entry = &result.builtin_fn_defs[bfi];
        if string_eq(&entry.runtime_name, "persist") {
            checker.persist_def_id_index = Option.Some(entry.def_id_index);
        }
    }

    // Phase 1: Collect type information from items
    collect_item_signatures(&mut checker, &result.items);

    // Phase 1a1: Detect builtin traits by name
    detect_deref_trait(&mut checker, &result.items, &result.interner);
    detect_freeze_trait(&mut checker, &result.items, &result.interner);

    // Phase 1a2: Register synthetic impl blocks for dyn Trait types
    // so that lookup_method can resolve methods on dyn Trait receivers.
    checker.register_dyn_trait_impls();

    // Phase 1b: Register builtin method signatures for String, Vec, Option, etc.
    // Pass the interner from HIR lowering so method name symbols match.
    register_builtin_signatures(&mut checker, &result.interner);

    // Phase 1b2: Register builtin constructor signatures (String.new, Vec.new, etc.)
    // This enables type inference to resolve return types for constructor calls.
    register_builtin_constructor_signatures(&mut checker, &result.builtin_fn_defs);

    // Phase 1c: Register builtin enum info (Option, Result) for exhaustiveness checking
    register_builtin_enums(
        &mut checker,
        &result.interner,
        &result.builtin_option_some_def,
        &result.builtin_option_none_def,
        &result.builtin_result_ok_def,
        &result.builtin_result_err_def,
    );

    // Phase 1d: Definition-time dispatch ambiguity check (DIS-04).
    let ambiguities = typeck_dispatch.check_all_dispatch_ambiguity(&checker.impls);
    for ai in 0usize..ambiguities.len() {
        let amb = &ambiguities[ai];
        let m2 = &checker.impls[amb.impl2_idx].methods[amb.method2_idx];
        let m1 = &checker.impls[amb.impl1_idx].methods[amb.method1_idx];
        if amb.is_diamond {
            checker.error_with_spanned_note(
                typeck_types.TypeErrorKind.DiamondConflict,
                m2.span,
                common.make_string("conflicts with method from different trait"),
                m1.span,
            );
        } else {
            checker.error_with_spanned_note(
                typeck_types.TypeErrorKind.AmbiguousDispatch,
                m2.span,
                common.make_string("conflicts with this method"),
                m1.span,
            );
        }
    }

    // Phase 1e: Type stability check (DIS-03, DISPATCH.md §4).
    let instabilities = typeck_dispatch.check_type_stability(&checker.impls);
    for si in 0usize..instabilities.len() {
        let inst = &instabilities[si];
        let m2 = &checker.impls[inst.impl2_idx].methods[inst.method2_idx];
        let m1 = &checker.impls[inst.impl1_idx].methods[inst.method1_idx];
        checker.error_with_spanned_note(
            typeck_types.TypeErrorKind.TypeInstability,
            m2.span,
            common.make_string("return type incompatible with this method"),
            m1.span,
        );
    }

    // Build body → item cache for O(1) lookups (eliminates O(n²) item scans)
    let body_cache = build_body_item_cache(&result.items);

    // Phase 2: Type check main file bodies (determines success/failure).
    let body_limit = result.main_body_count;
    for i in 0usize..body_limit {
        let body_entry = &result.bodies[i];
        let mut return_ty = find_return_type_cached(&result.items, body_entry.body_id, &body_cache);
        let is_handler_ret = is_handler_return_cached(&result.items, body_entry.body_id, &body_cache);
        if is_handler_ret {
            return_ty = checker.fresh_infer();
        }
        let found_def_id = find_def_id_cached(&result.items, body_entry.body_id, &body_cache);
        checker.current_body_def_id = found_def_id;
        checker.current_effect_row = find_effect_row_cached(&result.items, body_entry.body_id, &body_cache);
        checker.current_effect_type_args = find_effect_type_args_cached(&result.items, body_entry.body_id, &body_cache);
        unify_handler_op_params_cached(&mut checker, &result.items, &body_entry.body, body_entry.body_id, &body_cache);
        setup_handler_op_context_cached(&mut checker, &result.items, body_entry.body_id, &body_cache);
        if is_handler_ret {
            checker.resume_ty = Option.Some(return_ty);
        }
        check_body(&mut checker, &body_entry.body, return_ty);
    }

    // Capture main-file error count before checking external bodies.
    let main_error_count = checker.errors.len();

    // Phase 2b: Type check external module bodies to record method resolutions.
    // These bodies are MIR-lowered and code-generated, so their method calls
    // must be resolved. Errors from external bodies are discarded since each
    // module is authoritative only when compiled as the main file.
    // Unchanged modules (whose codegen is also skipped) can be skipped here —
    // their cached .o files contain the correct code, and their method/field
    // resolutions are not needed when MIR lowering also skips them.
    let mut j: usize = body_limit;
    while j < result.bodies.len() {
        let body_entry = &result.bodies[j];
        if skip_modules.len() > 0 {
            let mi = body_entry.module_index as usize;
            if mi < skip_modules.len() && skip_modules[mi] {
                j += 1;
                continue;
            }
        }
        let mut return_ty = find_return_type_cached(&result.items, body_entry.body_id, &body_cache);
        let is_handler_ret_ext = is_handler_return_cached(&result.items, body_entry.body_id, &body_cache);
        if is_handler_ret_ext {
            return_ty = checker.fresh_infer();
        }
        let found_def_id = find_def_id_cached(&result.items, body_entry.body_id, &body_cache);
        checker.current_body_def_id = found_def_id;
        checker.current_effect_row = find_effect_row_cached(&result.items, body_entry.body_id, &body_cache);
        checker.current_effect_type_args = find_effect_type_args_cached(&result.items, body_entry.body_id, &body_cache);
        unify_handler_op_params_cached(&mut checker, &result.items, &body_entry.body, body_entry.body_id, &body_cache);
        setup_handler_op_context_cached(&mut checker, &result.items, body_entry.body_id, &body_cache);
        if is_handler_ret_ext {
            checker.resume_ty = Option.Some(return_ty);
        }
        check_body(&mut checker, &body_entry.body, return_ty);
        j += 1;
    }

    // Discard errors from external bodies by truncating back to main error count.
    while checker.errors.len() > main_error_count {
        checker.errors.pop();
    }

    // Phase 3: Deferred resolution for Infer-receiver calls and field accesses
    resolve_pending_methods(&mut checker);
    resolve_pending_field_accesses(&mut checker);

    // Phase 4: Build impl method table and collect unresolved pending method calls
    // for type-generic monomorphization.
    let impl_method_table = build_impl_method_table(&mut checker, &result.interner);
    let unresolved_pending = collect_unresolved_pending_methods(&mut checker, &result.interner);

    // Return result with substitution table for type resolution in MIR lowering
    if checker.has_errors() {
        TypeCheckResult.failed(checker.errors, checker.subst_table, checker.method_resolutions, checker.field_resolutions)
    } else {
        TypeCheckResult.ok(checker.subst_table, checker.builtin_def_names, checker.method_resolutions, checker.field_resolutions, checker.default_method_remaps, checker.coercion_entries, checker.type_generic_calls, unresolved_pending, impl_method_table)
    }
}

/// Builds a flat table of impl methods for type-generic monomorphization.
/// Scans all registered impls and extracts (self_ty, method_name, method_def_id) tuples.
fn build_impl_method_table(checker: &mut typeck.TypeChecker, hir_interner: &interner.StringInterner) -> Vec<common.ImplMethodEntry> {
    let mut table: Vec<common.ImplMethodEntry> = Vec.new();
    for i in 0usize..checker.impls.len() {
        let impl_info = &checker.impls[i];
        let self_ty_id = impl_info.self_ty.index;
        for mi in 0usize..impl_info.methods.len() {
            // Resolve method name to string for cross-interner comparison during mono
            let name_str = match hir_interner.resolve(impl_info.methods[mi].name) {
                Option.Some(s) => common.make_string(s.as_str()),
                Option.None => common.make_string(""),
            };
            table.push(common.ImplMethodEntry.new(
                self_ty_id,
                impl_info.methods[mi].name,
                name_str,
                impl_info.methods[mi].def_id.index,
            ));
        }
    }
    table
}

/// Collects pending method calls that remained unresolved after resolve_pending_methods.
fn collect_unresolved_pending_methods(checker: &mut typeck.TypeChecker, hir_interner: &interner.StringInterner) -> Vec<common.PendingMethodCall> {
    let mut unresolved: Vec<common.PendingMethodCall> = Vec.new();
    for i in 0usize..checker.pending_method_calls.len() {
        let pmc = &checker.pending_method_calls[i];
        if !is_already_resolved(checker, pmc.body_def_id, pmc.span_start) {
            let name_str = match hir_interner.resolve(pmc.method_symbol) {
                Option.Some(s) => common.make_string(s.as_str()),
                Option.None => common.make_string(""),
            };
            unresolved.push(common.PendingMethodCall.new(
                pmc.body_def_id, pmc.span_start, pmc.receiver_var, pmc.method_symbol, name_str, pmc.return_ty_var,
            ));
        }
    }
    unresolved
}

/// Detects the Deref trait by name and registers Deref impl target types.
fn detect_deref_trait(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    interner: &interner.StringInterner,
) {
    // First pass: find the Deref trait definition by name
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Trait(_) => {
                match interner.resolve(entry.item.name.symbol) {
                    Option.Some(name) => {
                        if string_eq(name, "Deref") {
                            checker.deref_trait_def_id = Option.Some(entry.def_id);
                        }
                    }
                    Option.None => {}
                }
            }
            _ => {}
        }
    }

    // Second pass: find impl Deref blocks and extract Target type + deref method
    match &checker.deref_trait_def_id {
        &Option.Some(ref deref_def_id) => {
            let deref_idx = deref_def_id.index;
            for i in 0usize..items.len() {
                let entry = &items[i];
                match &entry.item.kind {
                    &hir_item.ItemKind.Impl(ref impl_def) => {
                        match &impl_def.trait_ref {
                            &Option.Some(ref trait_ref) => {
                                if trait_ref.def_id.index == deref_idx {
                                    // This is an impl Deref block
                                    // Extract Target associated type
                                    for j in 0usize..impl_def.items.len() {
                                        match &impl_def.items[j] {
                                            &hir_item.AssocItem.Type(ref assoc_type) => {
                                                let is_target = match interner.resolve(assoc_type.name.symbol) {
                                                    Option.Some(n) => string_eq(n, "Target"),
                                                    Option.None => false,
                                                };
                                                if is_target {
                                                    match &assoc_type.default_ty {
                                                        &Option.Some(ref target_ty) => {
                                                            // Get the ADT DefId from self_ty
                                                            let self_ty_interner = type_intern.type_interner();
                                                            match self_ty_interner.get(impl_def.self_ty) {
                                                                &type_intern.InternedTypeKind.Adt { def_id, args: _ } => {
                                                                    checker.deref_target_types.insert(
                                                                        def_id.index as u64,
                                                                        target_ty.index as u64,
                                                                    );
                                                                }
                                                                _ => {}
                                                            }
                                                        }
                                                        &Option.None => {}
                                                    }
                                                }
                                            }
                                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                                let is_deref = match interner.resolve(assoc_fn.name.symbol) {
                                                    Option.Some(n) => string_eq(n, "deref"),
                                                    Option.None => false,
                                                };
                                                if is_deref {
                                                    let self_ty_interner = type_intern.type_interner();
                                                    match self_ty_interner.get(impl_def.self_ty) {
                                                        &type_intern.InternedTypeKind.Adt { def_id, args: _ } => {
                                                            checker.deref_method_ids.insert(
                                                                def_id.index as u64,
                                                                assoc_fn.def_id.index as u64,
                                                            );
                                                        }
                                                        _ => {}
                                                    }
                                                }
                                            }
                                            _ => {}
                                        }
                                    }
                                }
                            }
                            &Option.None => {}
                        }
                    }
                    _ => {}
                }
            }
        }
        &Option.None => {}
    }
}

/// Detects the Freeze marker trait by name.
fn detect_freeze_trait(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    interner: &interner.StringInterner,
) {
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Trait(_) => {
                match interner.resolve(entry.item.name.symbol) {
                    Option.Some(name) => {
                        if string_eq(name, "Freeze") {
                            checker.freeze_trait_def_id = Option.Some(entry.def_id);
                        }
                    }
                    Option.None => {}
                }
            }
            _ => {}
        }
    }
}

/// Collects type signatures from HIR items.
///
/// This populates the type checker with information about struct, enum,
/// and function definitions so it can resolve types during body checking.
fn collect_item_signatures(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                // Register function signature
                checker.register_fn_sig(entry.def_id, &fn_def.sig);
            }
            &hir_item.ItemKind.Struct(ref struct_def) => {
                // Register struct definition
                checker.register_struct(entry.def_id, entry.item.name.symbol, struct_def);
            }
            &hir_item.ItemKind.Enum(ref enum_def) => {
                // Register enum definition
                checker.register_enum(entry.def_id, entry.item.name.symbol, enum_def);
            }
            &hir_item.ItemKind.Const(ref const_def) => {
                // Register constant definition
                checker.register_const(entry.def_id, entry.item.name.symbol, const_def.ty);
            }
            &hir_item.ItemKind.Static(ref static_def) => {
                // Register static definition
                checker.register_static(entry.def_id, entry.item.name.symbol, static_def.ty, static_def.mutable);
            }
            &hir_item.ItemKind.Impl(ref impl_def) => {
                // Register impl block for method resolution
                register_impl(checker, entry.def_id, impl_def, items);
            }
            // Other items don't need registration for basic type checking
            &hir_item.ItemKind.TypeAlias(_) => {}
            &hir_item.ItemKind.Trait(ref trait_def) => {
                register_trait(checker, entry.def_id, entry.item.name.symbol, trait_def);
            }
            &hir_item.ItemKind.Effect(ref effect_def) => {
                register_effect(checker, entry.def_id, entry.item.name.symbol, effect_def);
            }
            &hir_item.ItemKind.Handler(ref handler_def) => {
                // Register handler kind (1 = deep, 0 = shallow) for linearity checking
                let is_deep: u32 = match &handler_def.kind {
                    &common.HandlerKind.Deep => 1,
                    &common.HandlerKind.Shallow => 0,
                };
                checker.handler_kind_hash.insert(entry.def_id.index as u64, is_deep);
                // Register handler → effect mapping for effect-row dispatch
                checker.handler_effect_hash.insert(entry.def_id.index as u64, handler_def.handled_effect.def_id.index);
                // Register handler's effect type args (F-02 fix)
                let mut handler_eff_args: Vec<type_intern.TyId> = Vec.new();
                for hea in 0usize..handler_def.handled_effect.args.len() {
                    handler_eff_args.push(type_intern.type_to_ty_id(&handler_def.handled_effect.args[hea]));
                }
                let hea_idx = checker.handler_effect_type_args_store.len() as u32;
                checker.handler_effect_type_args_store.push(handler_eff_args);
                checker.handler_effect_type_args_hash.insert(entry.def_id.index as u64, hea_idx);
            }
            &hir_item.ItemKind.Module(_) => {}
            &hir_item.ItemKind.Macro(_) => {}
            &hir_item.ItemKind.Foreign(ref foreign_def) => {
                register_foreign_fns(checker, foreign_def);
            }
        }
    }
}

/// Registers function signatures from a foreign (bridge) definition.
///
/// This processes ForeignFn items and registers their typed signatures
/// so the type checker can validate calls to builtin/FFI functions.
fn register_foreign_fns(
    checker: &mut typeck.TypeChecker,
    foreign_def: &hir_item.ForeignDef,
) {
    for i in 0usize..foreign_def.items.len() {
        match &foreign_def.items[i] {
            &hir_item.ForeignItem.Fn(ref foreign_fn) => {
                let mut param_tys: Vec<type_intern.TyId> = Vec.new();
                for j in 0usize..foreign_fn.param_tys.len() {
                    param_tys.push(type_intern.TyId.new(foreign_fn.param_tys[j].index));
                }
                checker.register_fn_sig_direct(
                    foreign_fn.def_id,
                    param_tys,
                    foreign_fn.return_ty,
                    0,
                );
            }
            &hir_item.ForeignItem.Static(ref foreign_static) => {
                checker.register_static(
                    foreign_static.def_id,
                    foreign_static.name.symbol,
                    foreign_static.ty,
                    foreign_static.mutable,
                );
            }
            &hir_item.ForeignItem.OpaqueType(_) => {}
        }
    }
}

/// Registers a trait definition for type checking.
fn register_trait(
    checker: &mut typeck.TypeChecker,
    def_id: hir_def.DefId,
    name: common.Symbol,
    trait_def: &hir_item.TraitDef,
) {
    let num_generics = count_type_params(&trait_def.generics.params);
    let mut methods: Vec<typeck.TraitMethodInfo> = Vec.new();
    let mut assoc_types: Vec<typeck_info.AssocTypeInfo> = Vec.new();

    for i in 0usize..trait_def.items.len() {
        match &trait_def.items[i] {
            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                let mut param_tys: Vec<type_intern.TyId> = Vec.new();
                let mut takes_self_ref = false;
                let mut takes_self_mut = false;

                for j in 0usize..assoc_fn.sig.params.len() {
                    if j == 0 && assoc_fn.sig.params[j].is_self {
                        takes_self_ref = true;
                        takes_self_mut = assoc_fn.sig.params[j].mutable;
                    } else {
                        param_tys.push(assoc_fn.sig.params[j].ty);
                    }
                }

                let num_method_generics = count_type_params(&assoc_fn.sig.generics.params);
                let method_info = typeck.TraitMethodInfo.new(
                    assoc_fn.def_id,
                    assoc_fn.name.symbol,
                    param_tys,
                    assoc_fn.sig.return_ty,
                    takes_self_ref,
                    takes_self_mut,
                    assoc_fn.has_default,
                    num_method_generics,
                );
                methods.push(method_info);

                // Register fn signature for default methods so type checker
                // can resolve calls inside the default body.
                if assoc_fn.has_default {
                    checker.register_fn_sig(assoc_fn.def_id, &assoc_fn.sig);
                }
            }
            &hir_item.AssocItem.Type(ref assoc_type) => {
                let has_default = match &assoc_type.default_ty {
                    &Option.Some(_) => true,
                    &Option.None => false,
                };
                assoc_types.push(typeck_info.AssocTypeInfo.new(assoc_type.name.symbol, has_default));
            }
            &hir_item.AssocItem.Const(_) => {}
        }
    }

    let mut supertrait_ids: Vec<hir_def.DefId> = Vec.new();
    for si in 0usize..trait_def.supertraits.len() {
        supertrait_ids.push(trait_def.supertraits[si].def_id);
    }
    let trait_info = typeck.TraitInfo.new(def_id, name, num_generics, methods, assoc_types, supertrait_ids);
    checker.register_trait(def_id, trait_info);

    // Register a synthetic ImplInfo for the trait's Self type so that
    // default method bodies can resolve calls to other trait methods.
    // Within a trait, Self = Adt { def_id: trait_def_id, args: [] }.
    let interner = type_intern.type_interner();
    let empty_args = interner.intern_ty_list(&Vec.new());
    let trait_self_ty = interner.mk_adt(hir_def.DefId.new(def_id.index), empty_args);
    let mut impl_methods: Vec<typeck.MethodInfo> = Vec.new();
    for k in 0usize..trait_def.items.len() {
        match &trait_def.items[k] {
            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                let mut pm_tys: Vec<type_intern.TyId> = Vec.new();
                let mut takes_sr = false;
                let mut takes_sm = false;
                for pj in 0usize..assoc_fn.sig.params.len() {
                    if pj == 0 && assoc_fn.sig.params[pj].is_self {
                        takes_sr = true;
                        takes_sm = assoc_fn.sig.params[pj].mutable;
                    } else {
                        pm_tys.push(assoc_fn.sig.params[pj].ty);
                    }
                }
                let eff_ids = extract_effect_def_ids(&assoc_fn.sig.effects);
                let tp_bounds = extract_type_param_bounds(&assoc_fn.sig.generics);
                let mi = typeck.MethodInfo.new(
                    assoc_fn.def_id,
                    assoc_fn.name.symbol,
                    pm_tys,
                    assoc_fn.sig.return_ty,
                    takes_sr,
                    takes_sm,
                    eff_ids,
                    tp_bounds,
                    assoc_fn.name.span,
                );
                impl_methods.push(mi);
            }
            &hir_item.AssocItem.Type(_) => {}
            &hir_item.AssocItem.Const(_) => {}
        }
    }
    let trait_impl = typeck.ImplInfo.new(
        def_id,
        trait_self_ty,
        num_generics,
        impl_methods,
    );
    checker.register_impl(trait_impl);
}

/// Registers an impl block for method resolution.
fn register_impl(
    checker: &mut typeck.TypeChecker,
    def_id: hir_def.DefId,
    impl_def: &hir_item.ImplDef,
    items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    // Count impl-level generics (e.g., T in impl<T> Foo<T>).
    // Methods in generic impls inherit these type parameters, so their fn_sigs
    // must reflect the combined count to avoid false "cannot infer type" errors.
    let impl_num_generics = count_type_params(&impl_def.generics.params);

    // Extract method info from associated items
    let mut methods: Vec<typeck.MethodInfo> = Vec.new();
    for i in 0usize..impl_def.items.len() {
        match &impl_def.items[i] {
            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                // Extract parameter types from signature (skipping self param)
                let mut param_tys: Vec<type_intern.TyId> = Vec.new();
                let mut takes_self_ref = false;
                let mut takes_self_mut = false;

                // Check if first param is self
                if assoc_fn.sig.params.len() > 0 {
                    // Check first param for self pattern
                    // For now, assume first param might be self and check params
                    for j in 0usize..assoc_fn.sig.params.len() {
                        // Skip self parameter (index 0) if this looks like a method
                        // In HIR, self is encoded in the first parameter
                        if j == 0 && assoc_fn.sig.params[j].is_self {
                            takes_self_ref = true;
                            takes_self_mut = assoc_fn.sig.params[j].mutable;
                        } else {
                            param_tys.push(assoc_fn.sig.params[j].ty);
                        }
                    }
                }

                let eff_ids = extract_effect_def_ids(&assoc_fn.sig.effects);
                let tp_bounds = extract_type_param_bounds(&assoc_fn.sig.generics);
                let method_info = typeck.MethodInfo.new(
                    assoc_fn.def_id,
                    assoc_fn.name.symbol,
                    param_tys,
                    assoc_fn.sig.return_ty,
                    takes_self_ref,
                    takes_self_mut,
                    eff_ids,
                    tp_bounds,
                    assoc_fn.name.span,
                );
                methods.push(method_info);

                // Also register the full function signature in fn_sigs so that
                // infer_path can find associated functions by DefId. Without this,
                // calls like Counter.new(10) would fail to resolve the return type,
                // leaving downstream method call receivers as Infer variables.
                checker.register_fn_sig(assoc_fn.def_id, &assoc_fn.sig);

                // If the impl has generics, mark this method as being in a generic
                // impl so get_fn_generic_status treats it as generic.
                if impl_num_generics > 0 {
                    checker.generic_impl_method_defs.push(assoc_fn.def_id.index);
                }
            }
            &hir_item.AssocItem.Type(_) => {
                // Associated types don't need registration for basic method resolution
            }
            &hir_item.AssocItem.Const(_) => {
                // Associated consts don't need registration for basic method resolution
            }
        }
    }

    // If this impl is for a trait, inject default methods not overridden in the impl
    match &impl_def.trait_ref {
        &Option.Some(ref trait_ref) => {
            inject_default_methods(checker, &mut methods, trait_ref, items);
        }
        &Option.None => {}
    }

    // Create and register impl info
    let num_generics = count_type_params(&impl_def.generics.params);
    let impl_bounds = extract_type_param_bounds(&impl_def.generics);
    let mut impl_info = match &impl_def.trait_ref {
        &Option.Some(ref trait_ref) => {
            typeck.ImplInfo.new_trait(
                def_id,
                impl_def.self_ty,
                num_generics,
                trait_ref.def_id,
                methods,
            )
        }
        &Option.None => {
            typeck.ImplInfo.new(
                def_id,
                impl_def.self_ty,
                num_generics,
                methods,
            )
        }
    };
    impl_info.impl_bounds = impl_bounds;
    checker.register_impl(impl_info);
}

/// Injects default methods from a trait into an impl's method list.
/// For each default method in the trait that is not overridden in the impl,
/// a MethodInfo entry is created so lookup_method() can find it.
///
/// Also builds a call remapping table: when a default method body calls
/// other trait methods (e.g. self.name()), those calls resolve to the
/// trait's abstract method DefId. At codegen time, these must be redirected
/// to the concrete impl's method DefIds.
fn inject_default_methods(
    checker: &mut typeck.TypeChecker,
    methods: &mut Vec<typeck.MethodInfo>,
    trait_ref: &hir_ty.TraitRef,
    items: &Vec<hir_lower_ctx.ItemEntry>,
) {
    // Look up the trait definition
    match checker.get_trait(trait_ref.def_id) {
        Option.Some(trait_info) => {
            // For each trait method with a default implementation
            for ti in 0usize..trait_info.methods.len() {
                let trait_method = &trait_info.methods[ti];
                if trait_method.has_default {
                    // Check if this method is already overridden in the impl
                    let mut already_overridden = false;
                    for mi in 0usize..methods.len() {
                        if methods[mi].name.index == trait_method.name.index {
                            already_overridden = true;
                        }
                    }

                    if !already_overridden {
                        // Copy parameter types (TyId — trivial u32 copy)
                        let mut param_tys: Vec<type_intern.TyId> = Vec.new();
                        for pi in 0usize..trait_method.param_tys.len() {
                            param_tys.push(type_intern.TyId.new(trait_method.param_tys[pi].index));
                        }

                        // Create a MethodInfo for the default method
                        let method_info = typeck.MethodInfo.new(
                            trait_method.def_id,
                            trait_method.name,
                            param_tys,
                            type_intern.TyId.new(trait_method.return_ty.index),
                            trait_method.takes_self_ref,
                            trait_method.takes_self_mut,
                            Vec.new(),
                            Vec.new(),
                            common.Span { start: 0, end: 0, line: 0, column: 0 },
                        );
                        methods.push(method_info);

                        // Build call remapping table for this default method.
                        // For each trait method that IS overridden in the impl,
                        // map the trait method DefId to the impl method DefId.
                        let mut call_remaps: Vec<common.CallRemapEntry> = Vec.new();
                        for ri in 0usize..trait_info.methods.len() {
                            let other_trait_method = &trait_info.methods[ri];
                            // Find the impl method that overrides this trait method
                            for imi in 0usize..methods.len() {
                                if methods[imi].name.index == other_trait_method.name.index
                                    && methods[imi].def_id.index != other_trait_method.def_id.index
                                {
                                    // This impl method overrides the trait method
                                    call_remaps.push(common.CallRemapEntry.new(
                                        other_trait_method.def_id.index,
                                        methods[imi].def_id.index,
                                    ));
                                }
                            }
                        }

                        if call_remaps.len() > 0 {
                            checker.default_method_remaps.push(
                                common.DefaultMethodRemap.new(
                                    trait_method.def_id.index,
                                    call_remaps,
                                ),
                            );
                        }
                    }
                }
            }
        }
        Option.None => {
            // Trait not found — can happen if trait is in external module
        }
    }
}

/// Registers an effect definition for type checking.
fn register_effect(
    checker: &mut typeck.TypeChecker,
    def_id: hir_def.DefId,
    name: common.Symbol,
    effect_def: &hir_item.EffectDef,
) {
    let num_generics = count_type_params(&effect_def.generics.params);

    // Collect operation names
    let mut op_names: Vec<common.Symbol> = Vec.new();
    let mut operations: Vec<typeck.EffectOpInfo> = Vec.new();

    for i in 0usize..effect_def.operations.len() {
        let effect_op = &effect_def.operations[i];
        op_names.push(effect_op.name.symbol);

        // Convert parameter types at HIR boundary
        let mut param_tys: Vec<type_intern.TyId> = Vec.new();
        for j in 0usize..effect_op.param_tys.len() {
            param_tys.push(type_intern.TyId.new(effect_op.param_tys[j].index));
        }

        let num_op_generics = count_type_params(&effect_op.generics.params);
        let op_info = typeck.EffectOpInfo.new_with_generics(
            effect_op.def_id,
            effect_op.name.symbol,
            param_tys,
            effect_op.return_ty,
            num_op_generics,
        );
        operations.push(op_info);
    }

    // Collect type param TyVarIds for substitution in infer_perform
    let mut type_param_var_ids: Vec<u32> = Vec.new();
    for gp in 0usize..effect_def.generics.params.len() {
        match &effect_def.generics.params[gp] {
            &hir_ty.GenericParam.TypeParam(ref tp) => {
                type_param_var_ids.push(tp.var_id.index);
            }
            _ => {}
        }
    }

    let mut info = typeck.EffectInfo.new(
        def_id,
        name,
        num_generics,
        op_names,
        operations,
    );
    info.type_param_var_ids = type_param_var_ids;
    checker.register_effect(def_id, info);
}

// ============================================================
// Generic Parameter Counting
// ============================================================

/// Counts only type parameters in a generics param list, excluding
/// lifetime parameters and const parameters.
fn count_type_params(params: &Vec<hir_ty.GenericParam>) -> u32 {
    let mut count: u32 = 0;
    for i in 0usize..params.len() {
        match &params[i] {
            &hir_ty.GenericParam.TypeParam(_) => {
                count += 1;
            }
            &hir_ty.GenericParam.LifetimeParam(_) => {}
            &hir_ty.GenericParam.ConstParam(_) => {}
        }
    }
    count
}

// ============================================================
// Body Return Type Lookup
// ============================================================

/// Finds the return type for a body by looking up the corresponding function item.
///
/// Searches the items list for a function whose body_id matches the target,
/// and returns its signature's return type directly (no substitution needed —
/// TypeParam nodes unify naturally through the type checker).
/// Falls back to unit type if no matching function is found.
fn find_return_type_for_body(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) -> type_intern.TyId {
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                match &fn_def.body_id {
                    &Option.Some(ref bid) => {
                        if bid.index == target_body_id.index {
                            return fn_def.sig.return_ty;
                        }
                    }
                    &Option.None => {}
                }
            }
            &hir_item.ItemKind.Impl(ref impl_def) => {
                // Check associated functions in impl blocks
                for j in 0usize..impl_def.items.len() {
                    match &impl_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return assoc_fn.sig.return_ty;
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                        &hir_item.AssocItem.Const(ref assoc_const) => {
                            match &assoc_const.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return assoc_const.ty;
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                    }
                }
            }
            // Other item kinds don't have function bodies
            &hir_item.ItemKind.Struct(_) => {}
            &hir_item.ItemKind.Enum(_) => {}
            &hir_item.ItemKind.TypeAlias(_) => {}
            &hir_item.ItemKind.Const(ref const_def) => {
                if const_def.body_id.index == target_body_id.index {
                    return const_def.ty;
                }
            }
            &hir_item.ItemKind.Static(ref static_def) => {
                if static_def.body_id.index == target_body_id.index {
                    return static_def.ty;
                }
            }
            &hir_item.ItemKind.Trait(ref trait_def) => {
                // Check default method bodies in trait definitions
                for j in 0usize..trait_def.items.len() {
                    match &trait_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return assoc_fn.sig.return_ty;
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                        &hir_item.AssocItem.Const(_) => {}
                    }
                }
            }
            &hir_item.ItemKind.Effect(_) => {}
            &hir_item.ItemKind.Handler(ref handler_def) => {
                // Check return clause body
                match &handler_def.return_clause {
                    &Option.Some(ref rc) => {
                        if rc.body_id.index == target_body_id.index {
                            return type_intern.CommonTypes.unit();
                        }
                    }
                    &Option.None => {}
                }
                // Check op implementation bodies — look up effect op return type
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == target_body_id.index {
                        let op_def_id = handler_def.op_impls[j].op_def_id;
                        return find_effect_op_return_type(items, op_def_id);
                    }
                }
            }
            &hir_item.ItemKind.Module(_) => {}
            &hir_item.ItemKind.Macro(_) => {}
            &hir_item.ItemKind.Foreign(_) => {}
        }
    }
    // No matching function found. This can occur for extern functions or
    // functions not yet lowered. Default to unit — the caller relies on
    // type inference to unify the actual return type later.
    type_intern.CommonTypes.unit()
}

/// Looks up the return type of an effect operation by its DefId.
/// Returns unit if the effect operation is not found. This fallback
/// can mask missing effect definitions — callers should verify the
/// operation exists before relying on this return type.
fn find_effect_op_return_type(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    op_def_id: hir_def.DefId,
) -> type_intern.TyId {
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Effect(ref effect_def) => {
                for j in 0usize..effect_def.operations.len() {
                    let effect_op = &effect_def.operations[j];
                    if effect_op.def_id.index == op_def_id.index {
                        return effect_op.return_ty;
                    }
                }
            }
            _ => {}
        }
    }
    // Effect operation not found. This may indicate a missing effect
    // definition or an incorrect DefId. Default to unit — typeck will
    // catch any resulting type mismatch at the call site.
    type_intern.CommonTypes.unit()
}

/// Looks up the parameter types of an effect operation for a handler op body.
/// Returns None if not a handler op body, or Some(Vec of param types).
fn find_op_param_types_for_body(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) -> Option<Vec<type_intern.TyId>> {
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == target_body_id.index {
                        let op_def_id = handler_def.op_impls[j].op_def_id;
                        let effect_ref = &handler_def.handled_effect;
                        // Find the effect op param types, substituting handler type args
                        for ei in 0usize..items.len() {
                            match &items[ei].item.kind {
                                &hir_item.ItemKind.Effect(ref effect_def) => {
                                    if items[ei].item.def_id.index == effect_ref.def_id.index {
                                        // Build substitution: effect type param TyVarId → handler arg TyId
                                        let mut subst_var_ids: Vec<u32> = Vec.new();
                                        let mut subst_ty_ids: Vec<type_intern.TyId> = Vec.new();
                                        let mut pi: usize = 0;
                                        for gp in 0usize..effect_def.generics.params.len() {
                                            match &effect_def.generics.params[gp] {
                                                &hir_ty.GenericParam.TypeParam(ref tp) => {
                                                    if pi < effect_ref.args.len() {
                                                        subst_var_ids.push(tp.var_id.index);
                                                        subst_ty_ids.push(type_intern.type_to_ty_id(&effect_ref.args[pi]));
                                                    }
                                                    pi += 1;
                                                }
                                                _ => {}
                                            }
                                        }
                                        // Find the matching op and return substituted param types
                                        for k in 0usize..effect_def.operations.len() {
                                            let effect_op = &effect_def.operations[k];
                                            if effect_op.def_id.index == op_def_id.index {
                                                let mut param_tys: Vec<type_intern.TyId> = Vec.new();
                                                for p in 0usize..effect_op.param_tys.len() {
                                                    let raw_ty = type_intern.TyId.new(effect_op.param_tys[p].index);
                                                    // Substitute if it's an Infer matching an effect type param
                                                    let interner = type_intern.type_interner();
                                                    let substituted = match interner.get(raw_ty) {
                                                        &type_intern.InternedTypeKind.Infer(ref var_id) => {
                                                            let mut result = raw_ty;
                                                            for si in 0usize..subst_var_ids.len() {
                                                                if subst_var_ids[si] == var_id.index {
                                                                    result = subst_ty_ids[si];
                                                                }
                                                            }
                                                            result
                                                        }
                                                        _ => raw_ty,
                                                    };
                                                    param_tys.push(substituted);
                                                }
                                                return Option.Some(param_tys);
                                            }
                                        }
                                    }
                                }
                                _ => {}
                            }
                        }
                        return Option.None;
                    }
                }
            }
            _ => {}
        }
    }
    Option.None
}

/// Returns the number of handler state fields for a handler op body.
fn find_handler_state_count_for_body(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) -> usize {
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == target_body_id.index {
                        return handler_def.state.len();
                    }
                }
            }
            _ => {}
        }
    }
    0
}

/// Cached version: skips item scan for non-handler bodies.
fn unify_handler_op_params_cached(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    body: &hir_expr.Body,
    body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) {
    // Only handler bodies need this work
    match cache.get(body_id.index as u64) {
        Option.Some(item_idx) => {
            match &items[item_idx as usize].item.kind {
                &hir_item.ItemKind.Handler(_) => {
                    // Fall through to full handler processing
                    unify_handler_op_params(checker, items, body, body_id);
                }
                _ => {}
            }
        }
        Option.None => {}
    }
}

/// Cached version: skips item scan for non-handler bodies.
fn setup_handler_op_context_cached(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) {
    // Reset to defaults
    checker.resume_ty = Option.None;
    checker.in_shallow_handler = false;
    checker.resume_count = 0;
    checker.handler_state_types.clear();

    // Only handler bodies need the full scan
    match cache.get(target_body_id.index as u64) {
        Option.Some(item_idx) => {
            match &items[item_idx as usize].item.kind {
                &hir_item.ItemKind.Handler(_) => {
                    // Fall through to full handler processing
                    setup_handler_op_context(checker, items, target_body_id);
                }
                _ => {}
            }
        }
        Option.None => {}
    }
}

/// Unify handler op parameter types with their effect-declared types.
/// This resolves the `Type.infer()` variables created in `lower_op_impl`
/// so that the op body's parameter locals have correct types during type checking.
///
/// For generic effects (e.g., `effect Emit<T>`), also unifies the effect's type
/// parameters with the handler's concrete type arguments (e.g., T → i32 when
/// handling `Emit<i32>`), so that op param types resolve transitively.
fn unify_handler_op_params(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    body: &hir_expr.Body,
    body_id: hir_def.BodyId,
) {
    // Handler's effect type args are substituted into op param types by
    // find_op_param_types_for_body, so we don't unify the shared effect
    // type parameter (which would poison it for other handlers).
    match find_op_param_types_for_body(items, body_id) {
        Option.Some(ref param_tys) => {
            let state_count = find_handler_state_count_for_body(items, body_id);
            for k in 0usize..param_tys.len() {
                let local_idx = state_count + k;
                if local_idx < body.locals.len() {
                    let span = body.locals[local_idx].span;
                    // body.locals[].ty is now TyId
                    let local_ty_id = body.locals[local_idx].ty;
                    checker.unify(local_ty_id, type_intern.TyId.new(param_tys[k].index), span);
                }
            }
        }
        Option.None => {}
    }
}

/// Unifies effect-level type parameters with the handler's concrete type arguments.
/// For example, if handling `Emit<i32>` where `effect Emit<T>`, this unifies T → i32.
fn unify_effect_type_params_for_body(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    body_id: hir_def.BodyId,
) {
    // Find the handler that owns this body
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == body_id.index {
                        let effect_ref = &handler_def.handled_effect;
                        if effect_ref.args.len() == 0 {
                            return;
                        }
                        // Find the effect definition to get its type param TyVarIds
                        for ei in 0usize..items.len() {
                            match &items[ei].item.kind {
                                &hir_item.ItemKind.Effect(ref effect_def) => {
                                    if items[ei].item.def_id.index == effect_ref.def_id.index {
                                        // Unify each effect type param with the handler's arg
                                        let mut pi: usize = 0;
                                        for gp in 0usize..effect_def.generics.params.len() {
                                            match &effect_def.generics.params[gp] {
                                                &hir_ty.GenericParam.TypeParam(ref tp) => {
                                                    if pi < effect_ref.args.len() {
                                                        let param_ty_id = type_intern.type_interner().mk_infer(tp.var_id);
                                                        let arg_ty_id = type_intern.type_to_ty_id(&effect_ref.args[pi]);
                                                        checker.unify(param_ty_id, arg_ty_id, items[i].item.span);
                                                    }
                                                    pi += 1;
                                                }
                                                _ => {}
                                            }
                                        }
                                        return;
                                    }
                                }
                                _ => {}
                            }
                        }
                        return;
                    }
                }
            }
            _ => {}
        }
    }
}

/// Returns true if the given body belongs to a handler return clause.
/// Handler return clause bodies should not be constrained to return unit —
/// they determine the overall type of the `with ... handle` expression.
fn is_handler_return_body(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) -> bool {
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                match &handler_def.return_clause {
                    &Option.Some(ref rc) => {
                        if rc.body_id.index == target_body_id.index {
                            return true;
                        }
                    }
                    &Option.None => {}
                }
            }
            _ => {}
        }
    }
    false
}

/// Finds the effect row DefIds for the function containing a given body.
/// Returns a Vec<u32> of effect DefIds declared in the function's effect row.
fn find_effect_row_for_body(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) -> Vec<u32> {
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                match &fn_def.body_id {
                    &Option.Some(ref bid) => {
                        if bid.index == target_body_id.index {
                            return collect_effect_def_ids(&fn_def.sig.effects);
                        }
                    }
                    &Option.None => {}
                }
            }
            &hir_item.ItemKind.Impl(ref impl_def) => {
                for j in 0usize..impl_def.items.len() {
                    match &impl_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return collect_effect_def_ids(&assoc_fn.sig.effects);
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                        &hir_item.AssocItem.Const(_) => {}
                    }
                }
            }
            _ => {}
        }
    }
    Vec.new()
}

/// Sets up the type checker's resume context for a handler op body.
/// For handler op bodies, this sets:
///   - resume_ty: the effect op's return type (what resume() should produce)
///   - in_shallow_handler: true if the handler is shallow
///   - resume_count: 0 (reset for each body)
/// For non-handler bodies, this resets all three fields.
fn setup_handler_op_context(
    checker: &mut typeck.TypeChecker,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) {
    // Reset to defaults
    checker.resume_ty = Option.None;
    checker.in_shallow_handler = false;
    checker.resume_count = 0;
    checker.handler_state_types.clear();

    // Search for handler that owns this body
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == target_body_id.index {
                        // Found the handler op body — set shallow flag
                        match &handler_def.kind {
                            &common.HandlerKind.Shallow => {
                                checker.in_shallow_handler = true;
                            }
                            &common.HandlerKind.Deep => {
                                checker.in_shallow_handler = false;
                            }
                        }

                        // Record handler state field types for linearity checking
                        for si in 0usize..handler_def.state.len() {
                            checker.handler_state_types.push(handler_def.state[si].ty);
                        }

                        // Find the effect op return type via op_def_id,
                        // substituting handler type args for effect type params.
                        let op_def_id = handler_def.op_impls[j].op_def_id;
                        let effect_ref = &handler_def.handled_effect;
                        for ei in 0usize..items.len() {
                            match &items[ei].item.kind {
                                &hir_item.ItemKind.Effect(ref effect_def) => {
                                    if items[ei].item.def_id.index == effect_ref.def_id.index {
                                        for k in 0usize..effect_def.operations.len() {
                                            let effect_op = &effect_def.operations[k];
                                            if effect_op.def_id.index == op_def_id.index {
                                                let ret_ty = effect_op.return_ty;
                                                // Substitute effect type params in return type
                                                if effect_ref.args.len() > 0 {
                                                    let interner = type_intern.type_interner();
                                                    match interner.get(ret_ty) {
                                                        &type_intern.InternedTypeKind.Infer(ref var_id) => {
                                                            let mut pi2: usize = 0;
                                                            for gp2 in 0usize..effect_def.generics.params.len() {
                                                                match &effect_def.generics.params[gp2] {
                                                                    &hir_ty.GenericParam.TypeParam(ref tp2) => {
                                                                        if tp2.var_id.index == var_id.index && pi2 < effect_ref.args.len() {
                                                                            checker.resume_ty = Option.Some(type_intern.type_to_ty_id(&effect_ref.args[pi2]));
                                                                            return;
                                                                        }
                                                                        pi2 += 1;
                                                                    }
                                                                    _ => {}
                                                                }
                                                            }
                                                        }
                                                        _ => {}
                                                    }
                                                }
                                                checker.resume_ty = Option.Some(ret_ty);
                                                return;
                                            }
                                        }
                                    }
                                }
                                _ => {}
                            }
                        }
                        // op_def_id not found in any effect — leave resume_ty as None
                        return;
                    }
                }
            }
            _ => {}
        }
    }
    // Not a handler op body — defaults already set
}

/// Helper to extract effect DefIds from an EffectRow.
fn collect_effect_def_ids(row: &hir_ty.EffectRow) -> Vec<u32> {
    let mut result: Vec<u32> = Vec.new();
    for i in 0usize..row.effects.len() {
        result.push(row.effects[i].def_id.index);
    }
    result
}

/// Collects effect type arguments from an EffectRow (parallel to collect_effect_def_ids).
/// Finds effect type args for a body (parallel to find_effect_row_cached).
fn find_effect_type_args_cached(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
    cache: &hashmap.HashMapU64U32,
) -> Vec<Vec<type_intern.TyId>> {
    match cache.get(target_body_id.index as u64) {
        Option.Some(item_idx) => {
            let entry = &items[item_idx as usize];
            match &entry.item.kind {
                &hir_item.ItemKind.Fn(ref fn_def) => {
                    collect_effect_type_args(&fn_def.sig.effects)
                }
                &hir_item.ItemKind.Impl(ref impl_def) => {
                    for j in 0usize..impl_def.items.len() {
                        match &impl_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        if bid.index == target_body_id.index {
                                            return collect_effect_type_args(&assoc_fn.sig.effects);
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            _ => {}
                        }
                    }
                    Vec.new()
                }
                &hir_item.ItemKind.Handler(ref handler_def) => {
                    // Handled effect type args + forwarded effect type args
                    let mut result: Vec<Vec<type_intern.TyId>> = Vec.new();
                    let mut handled_args: Vec<type_intern.TyId> = Vec.new();
                    for ai in 0usize..handler_def.handled_effect.args.len() {
                        handled_args.push(type_intern.type_to_ty_id(&handler_def.handled_effect.args[ai]));
                    }
                    result.push(handled_args);
                    for fi in 0usize..handler_def.forwarded_effects.len() {
                        let mut fwd_args: Vec<type_intern.TyId> = Vec.new();
                        for ai in 0usize..handler_def.forwarded_effects[fi].args.len() {
                            fwd_args.push(type_intern.type_to_ty_id(&handler_def.forwarded_effects[fi].args[ai]));
                        }
                        result.push(fwd_args);
                    }
                    result
                }
                _ => Vec.new(),
            }
        }
        Option.None => Vec.new(),
    }
}

fn collect_effect_type_args(row: &hir_ty.EffectRow) -> Vec<Vec<type_intern.TyId>> {
    let mut result: Vec<Vec<type_intern.TyId>> = Vec.new();
    for i in 0usize..row.effects.len() {
        let mut args: Vec<type_intern.TyId> = Vec.new();
        for j in 0usize..row.effects[i].args.len() {
            args.push(type_intern.type_to_ty_id(&row.effects[i].args[j]));
        }
        result.push(args);
    }
    result
}

/// Looks up a trait method's effect row by trait DefId and method name.
fn find_trait_method_effects(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    trait_def_id: u32,
    method_name: common.Symbol,
) -> Vec<u32> {
    for i in 0usize..items.len() {
        if items[i].def_id.index == trait_def_id {
            match &items[i].item.kind {
                &hir_item.ItemKind.Trait(ref trait_def) => {
                    for j in 0usize..trait_def.items.len() {
                        match &trait_def.items[j] {
                            &hir_item.AssocItem.Fn(ref trait_fn) => {
                                if trait_fn.name.symbol.index == method_name.index {
                                    return collect_effect_def_ids(&trait_fn.sig.effects);
                                }
                            }
                            _ => {}
                        }
                    }
                }
                _ => {}
            }
            break;
        }
    }
    Vec.new()
}

/// Finds the DefId for the function containing a given body.
/// Returns 0 if no matching function found.
fn find_def_id_for_body(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    target_body_id: hir_def.BodyId,
) -> u32 {
    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                match &fn_def.body_id {
                    &Option.Some(ref bid) => {
                        if bid.index == target_body_id.index {
                            return entry.item.def_id.index;
                        }
                    }
                    &Option.None => {}
                }
            }
            &hir_item.ItemKind.Impl(ref impl_def) => {
                // Check associated functions in impl blocks
                for j in 0usize..impl_def.items.len() {
                    match &impl_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return assoc_fn.def_id.index;
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                        &hir_item.AssocItem.Const(ref assoc_const) => {
                            match &assoc_const.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return assoc_const.def_id.index;
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                    }
                }
            }
            // Other item kinds don't have function bodies
            &hir_item.ItemKind.Struct(_) => {}
            &hir_item.ItemKind.Enum(_) => {}
            &hir_item.ItemKind.TypeAlias(_) => {}
            &hir_item.ItemKind.Const(ref const_def) => {
                if const_def.body_id.index == target_body_id.index {
                    return entry.item.def_id.index;
                }
            }
            &hir_item.ItemKind.Static(ref static_def) => {
                if static_def.body_id.index == target_body_id.index {
                    return entry.item.def_id.index;
                }
            }
            &hir_item.ItemKind.Trait(ref trait_def) => {
                // Check default method bodies in trait definitions
                for j in 0usize..trait_def.items.len() {
                    match &trait_def.items[j] {
                        &hir_item.AssocItem.Fn(ref assoc_fn) => {
                            match &assoc_fn.body_id {
                                &Option.Some(ref bid) => {
                                    if bid.index == target_body_id.index {
                                        return assoc_fn.def_id.index;
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                        &hir_item.AssocItem.Type(_) => {}
                        &hir_item.AssocItem.Const(_) => {}
                    }
                }
            }
            &hir_item.ItemKind.Effect(_) => {}
            &hir_item.ItemKind.Handler(ref handler_def) => {
                // Check return clause body
                // Use body_id.index as the DefId to match driver.find_fn_for_body
                // which returns DefId.new(target_body_id.index) for return clause bodies.
                match &handler_def.return_clause {
                    &Option.Some(ref rc) => {
                        if rc.body_id.index == target_body_id.index {
                            return rc.body_id.index;
                        }
                    }
                    &Option.None => {}
                }
                // Check op implementation bodies
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == target_body_id.index {
                        return handler_def.op_impls[j].op_def_id.index;
                    }
                }
            }
            &hir_item.ItemKind.Module(_) => {}
            &hir_item.ItemKind.Macro(_) => {}
            &hir_item.ItemKind.Foreign(_) => {}
        }
    }
    // Default to body_id's index if no matching function found.
    // This must match the fallback in driver.blood's MIR lowering
    // to ensure method resolution lookups use consistent keys.
    target_body_id.index
}

// ============================================================
// Linearity Checking
// ============================================================

/// Tracks ownership qualifier and usage count for a local variable.
struct LinearEntry {
    local_idx: u32,
    is_linear: bool,
    is_affine: bool,
    use_count: u32,
    def_span: common.Span,
}

/// Checks linearity constraints on a function body after type checking.
fn check_linearity(checker: &mut typeck.TypeChecker, body: &hir_expr.Body) {
    // Collect locals with ownership qualifiers
    let mut entries: Vec<LinearEntry> = Vec.new();
    for li in 0usize..body.locals.len() {
        let local = &body.locals[li];
        let local_ty_id = local.ty;
        let resolved_id = checker.resolve(local_ty_id);
        let resolved_ty = type_intern.ty_id_to_type(resolved_id);
        match &resolved_ty.kind {
            &hir_ty.TypeKind.Ownership { ref qualifier, inner: _ } => {
                let is_lin = match qualifier {
                    &hir_ty.OwnershipQualifier.Linear => true,
                    &hir_ty.OwnershipQualifier.Affine => false,
                };
                let is_aff = match qualifier {
                    &hir_ty.OwnershipQualifier.Linear => false,
                    &hir_ty.OwnershipQualifier.Affine => true,
                };
                let entry = LinearEntry {
                    local_idx: local.id.index,
                    is_linear: is_lin,
                    is_affine: is_aff,
                    use_count: 0,
                    def_span: local.span,
                };
                entries.push(entry);
            }
            _ => {}
        }
    }

    // If no ownership-qualified locals, skip usage scanning
    if entries.len() == 0 {
        return;
    }

    // Count usages by scanning the body expression
    count_usages_expr(&mut entries, &body.expr);

    // Report violations
    for ei in 0usize..entries.len() {
        let entry = &entries[ei];
        // Function parameters: the call site handles consumption — the function
        // binding IS the final consumption point. Parameters may read (field access)
        // or further consume, but are not REQUIRED to consume within the body.
        let is_param: bool = entry.local_idx < body.param_count;
        if entry.is_linear {
            if is_param {
                // Parameters: only reject double consumption (use_count > 1)
                if entry.use_count > 1 {
                    checker.error_with_note(typeck.TypeErrorKind.LinearUsedMultipleTimes, entry.def_span,
                        common.make_string("linear values must be used exactly once; this value was used multiple times"));
                }
            } else {
                // Local bindings: must be consumed exactly once
                if entry.use_count == 0 {
                    checker.error_with_note(typeck.TypeErrorKind.LinearNotUsed, entry.def_span,
                        common.make_string("linear values must be used exactly once"));
                } else if entry.use_count > 1 {
                    checker.error_with_note(typeck.TypeErrorKind.LinearUsedMultipleTimes, entry.def_span,
                        common.make_string("linear values must be used exactly once; this value was used multiple times"));
                }
            }
        } else if entry.is_affine {
            if entry.use_count > 1 {
                checker.error_with_note(typeck.TypeErrorKind.AffineUsedMultipleTimes, entry.def_span,
                    common.make_string("affine values can be used at most once; this value was used multiple times"));
            }
        }
    }
}

/// Increments use_count for a local if it's tracked.
fn record_linear_use(entries: &mut Vec<LinearEntry>, local_idx: u32) {
    for i in 0usize..entries.len() {
        if entries[i].local_idx == local_idx {
            entries[i].use_count = entries[i].use_count + 1;
            return;
        }
    }
}

/// Returns true if the expression is a direct Local reference.
fn is_local_expr(expr: &hir_expr.Expr) -> bool {
    match &expr.kind {
        &hir_expr.ExprKind.Local(_) => true,
        _ => false,
    }
}

/// Counts usages of tracked locals in an expression.
fn count_usages_expr(entries: &mut Vec<LinearEntry>, expr: &hir_expr.Expr) {
    match &expr.kind {
        &hir_expr.ExprKind.Local(ref local_id) => {
            record_linear_use(entries, local_id.index);
        }
        &hir_expr.ExprKind.Binary { ref left, ref right, operator: _ } => {
            count_usages_expr(entries, left.as_ref());
            count_usages_expr(entries, right.as_ref());
        }
        &hir_expr.ExprKind.Unary { ref operand, ref operator } => {
            // Borrowing (&x, &mut x) does NOT consume a linear value — only by-value use does.
            // Skip counting the operand when taking a reference.
            match operator {
                &common.UnaryOp.Ref => {}
                &common.UnaryOp.RefMut => {}
                _ => {
                    count_usages_expr(entries, operand.as_ref());
                }
            }
        }
        &hir_expr.ExprKind.Call { ref callee, ref args } => {
            count_usages_expr(entries, callee.as_ref());
            for i in 0usize..args.len() {
                count_usages_expr(entries, &args[i]);
            }
        }
        &hir_expr.ExprKind.MethodCall { ref receiver, method: _, method_def: _, type_args: _, ref args } => {
            count_usages_expr(entries, receiver.as_ref());
            for i in 0usize..args.len() {
                count_usages_expr(entries, &args[i]);
            }
        }
        &hir_expr.ExprKind.If { ref condition, ref then_branch, ref else_branch } => {
            count_usages_expr(entries, condition.as_ref());
            match else_branch {
                &Option.Some(ref eb) => {
                    // Branch-aware counting: walk each branch independently.
                    // Save pre-branch counts, walk then, record deltas,
                    // restore, walk else, take max of deltas.
                    // This correctly handles: if cond { commit(tx) } else { rollback(tx) }
                    // as exactly ONE use (mutually exclusive branches).
                    let mut saved: Vec<u32> = Vec.with_capacity(entries.len());
                    for si in 0usize..entries.len() {
                        saved.push(entries[si].use_count);
                    }
                    count_usages_expr(entries, then_branch.as_ref());
                    let mut then_deltas: Vec<u32> = Vec.with_capacity(entries.len());
                    for si in 0usize..entries.len() {
                        then_deltas.push(entries[si].use_count - saved[si]);
                        entries[si].use_count = saved[si]; // restore
                    }
                    count_usages_expr(entries, eb.as_ref());
                    // Final count = pre + max(then_delta, else_delta)
                    for si in 0usize..entries.len() {
                        let else_delta = entries[si].use_count - saved[si];
                        let max_delta = if then_deltas[si] > else_delta { then_deltas[si] } else { else_delta };
                        entries[si].use_count = saved[si] + max_delta;
                    }
                }
                &Option.None => {
                    // No else: walk then branch directly (conservative count)
                    count_usages_expr(entries, then_branch.as_ref());
                }
            }
        }
        &hir_expr.ExprKind.Block(ref block) => {
            count_usages_block(entries, block);
        }
        &hir_expr.ExprKind.Match { ref scrutinee, ref arms } => {
            count_usages_expr(entries, scrutinee.as_ref());
            // Branch-aware: walk each arm independently, take max deltas.
            if arms.len() > 0 {
                let mut saved: Vec<u32> = Vec.with_capacity(entries.len());
                for si in 0usize..entries.len() {
                    saved.push(entries[si].use_count);
                }
                let mut max_deltas: Vec<u32> = Vec.with_capacity(entries.len());
                for si in 0usize..entries.len() {
                    max_deltas.push(0);
                }
                for ai in 0usize..arms.len() {
                    // Restore to pre-match state for each arm
                    for si in 0usize..entries.len() {
                        entries[si].use_count = saved[si];
                    }
                    count_usages_expr(entries, &arms[ai].body);
                    for si in 0usize..entries.len() {
                        let delta = entries[si].use_count - saved[si];
                        if delta > max_deltas[si] {
                            max_deltas[si] = delta;
                        }
                    }
                }
                // Apply max deltas
                for si in 0usize..entries.len() {
                    entries[si].use_count = saved[si] + max_deltas[si];
                }
            }
        }
        &hir_expr.ExprKind.Assign { ref target, ref val } => {
            count_usages_expr(entries, target.as_ref());
            count_usages_expr(entries, val.as_ref());
        }
        &hir_expr.ExprKind.Return(ref opt_val) => {
            match opt_val {
                &Option.Some(ref v) => {
                    count_usages_expr(entries, v.as_ref());
                }
                &Option.None => {}
            }
        }
        &hir_expr.ExprKind.Field { ref base, field: _ } => {
            // Field access is a read — does NOT consume linear values.
            // Skip counting direct local references (h.fd is a read, not a consumption).
            // Recurse into complex bases to count linear values in subexpressions.
            if !is_local_expr(base.as_ref()) {
                count_usages_expr(entries, base.as_ref());
            }
        }
        &hir_expr.ExprKind.Index { ref base, ref idx } => {
            count_usages_expr(entries, base.as_ref());
            count_usages_expr(entries, idx.as_ref());
        }
        &hir_expr.ExprKind.AddrOf { mutable: _, ref expr } => {
            // AddrOf is a borrow — does NOT consume linear values
            // (same semantics as Unary { operator: Ref })
        }
        &hir_expr.ExprKind.Cast { ref expr, ty: _ } => {
            count_usages_expr(entries, expr.as_ref());
        }
        &hir_expr.ExprKind.Loop { label: _, ref body } => {
            count_usages_expr(entries, body.as_ref());
        }
        &hir_expr.ExprKind.WithHandle { ref handler, ref body } => {
            count_usages_expr(entries, handler.as_ref());
            count_usages_expr(entries, body.as_ref());
        }
        &hir_expr.ExprKind.Perform { effect_def: _, op_def: _, ref args } => {
            for i in 0usize..args.len() {
                count_usages_expr(entries, &args[i]);
            }
        }
        &hir_expr.ExprKind.Closure { captures: _, params: _, return_ty: _, effects: _, ref body } => {
            count_usages_expr(entries, body.as_ref());
        }
        &hir_expr.ExprKind.Region { name: _, ref stmts, ref expr } => {
            for i in 0usize..stmts.len() {
                match &stmts[i] {
                    &hir_expr.Stmt.Expr { ref expr, has_semi: _ } => {
                        count_usages_expr(entries, expr);
                    }
                    &hir_expr.Stmt.Let { pattern: _, ty: _, ref init, span: _ } => {
                        match init {
                            &Option.Some(ref init_expr) => {
                                count_usages_expr(entries, init_expr);
                            }
                            &Option.None => {}
                        }
                    }
                    &hir_expr.Stmt.Item(_) => {}
                }
            }
            match expr {
                &Option.Some(ref e) => {
                    count_usages_expr(entries, e.as_ref());
                }
                &Option.None => {}
            }
        }
        &hir_expr.ExprKind.ForIter { label: _, pattern: _, ref iter, ref body } => {
            count_usages_expr(entries, iter.as_ref());
            count_usages_expr(entries, body.as_ref());
        }
        &hir_expr.ExprKind.Struct { path: _, ref fields, ref base } => {
            for i in 0usize..fields.len() {
                count_usages_expr(entries, &fields[i].val);
            }
            match base {
                &Option.Some(ref b) => {
                    count_usages_expr(entries, b.as_ref());
                }
                &Option.None => {}
            }
        }
        _ => {
            // Literal, Path, Error, Break, Continue, Resume, etc. — no local usage to track
        }
    }
}

/// Counts usages of tracked locals in a block.
fn count_usages_block(entries: &mut Vec<LinearEntry>, block: &hir_expr.Block) {
    for i in 0usize..block.stmts.len() {
        match &block.stmts[i] {
            &hir_expr.Stmt.Expr { ref expr, has_semi: _ } => {
                count_usages_expr(entries, expr);
            }
            &hir_expr.Stmt.Let { pattern: _, ty: _, ref init, span: _ } => {
                match init {
                    &Option.Some(ref init_expr) => {
                        count_usages_expr(entries, init_expr);
                    }
                    &Option.None => {}
                }
            }
            &hir_expr.Stmt.Item(_) => {}
        }
    }
    match &block.expr {
        &Option.Some(ref e) => {
            count_usages_expr(entries, e.as_ref());
        }
        &Option.None => {}
    }
}

// ============================================================
// Body Type Checking
// ============================================================

/// Type checks a single function body.
///
/// The return_ty comes from the function signature (not from body locals).
fn check_body(checker: &mut typeck.TypeChecker, body: &hir_expr.Body, return_ty: type_intern.TyId) {
    // Clear locals for this body
    checker.clear_locals();

    // Register all locals from the body using base-offset indexing.
    // HIR lowering allocates LocalIds globally (not per-body), so a body's
    // locals may have non-zero starting indices. We compute the minimum
    // LocalId as a base offset, then index locals relative to that base.
    // This avoids O(n²) padding when many bodies have incrementing IDs.
    let mut base: u32 = 0;
    if body.locals.len() > 0 {
        base = body.locals[0].id.index;
        for i in 1usize..body.locals.len() {
            let lid = body.locals[i].id.index;
            if lid < base {
                base = lid;
            }
        }
    }
    checker.local_base = base;

    // Find max local ID to pre-size the vector
    let mut max_id: u32 = base;
    for i in 0usize..body.locals.len() {
        let lid = body.locals[i].id.index;
        if lid > max_id {
            max_id = lid;
        }
    }
    let needed = (max_id - base + 1) as usize;
    // Pre-fill with dummy locals
    for pad in 0usize..needed {
        checker.add_local(
            type_intern.CommonTypes.error(),
            false,
            common.Span.new(0, 0, 1, 1),
        );
    }
    // Place real locals at their offset positions
    for i in 0usize..body.locals.len() {
        let local = &body.locals[i];
        let offset_idx = (local.id.index - base) as usize;
        checker.locals[offset_idx] = typeck.LocalInfo.new(
            local.ty,
            local.mutable,
            local.span,
        );
    }

    // Set return type from the function signature
    checker.set_return_ty(return_ty);

    // Type check the body expression
    let body_ty = typeck_expr.infer_expr(checker, &body.expr);

    // Unify body type with return type
    match &checker.return_ty {
        &Some(ret_ty) => {
            let ret_ty_id = type_intern.TyId.new(ret_ty.index);
            checker.unify(body_ty, ret_ty_id, body.expr.span);
            // Directional effect check: body's fn-typed value must not have more
            // effects than the declared return type. unify accepts bidirectionally
            // (pure ⊆ {IO}), but returning effectful where pure is declared is unsound.
            if !typeck_expr.check_effect_subtyping(checker, body_ty, ret_ty_id) {
                checker.error(typeck.TypeErrorKind.TypeMismatch, body.expr.span);
            }
        }
        &None => {}
    }

    // Resolve deferred trait bound checks now that inference is complete
    checker.flush_pending_bound_checks();

    // Check for unresolved inference variables in non-generic function let-bindings.
    // In non-generic functions, all inference variables should be resolved after
    // type checking. Generic functions use Infer for type parameters, so they
    // are skipped (the call site check catches undetermined vars there).
    // Handler bodies and other non-function contexts (status 0) are also skipped.
    let fn_generic_status = get_fn_generic_status(checker);
    // fn_generic_status: 0 = not a function (handler/unknown), 1 = non-generic fn, 2 = generic fn
    // Incrementally update the resolved numeric cache with new entries only.
    // This avoids O(n²) full re-scanning of all numeric_infer_ids each body.
    while checker.resolved_numeric_cursor < checker.numeric_infer_ids.len() {
        let var_id = hir_def.TyVarId.new(checker.numeric_infer_ids[checker.resolved_numeric_cursor]);
        let ty_id = type_intern.type_interner().mk_infer(var_id);
        let resolved_id = checker.resolve(ty_id);
        let resolved_kind = type_intern.type_interner().get(resolved_id);
        match resolved_kind {
            &type_intern.InternedTypeKind.Infer(resolved_var) => {
                checker.resolved_numeric_cache.push(resolved_var.index);
            }
            _ => {}
        }
        checker.resolved_numeric_cursor += 1;
    }

    if fn_generic_status == 1 {
        let mut li: usize = 0;
        while li < body.locals.len() {
            let local = &body.locals[li];
            let offset_idx = (local.id.index - checker.local_base) as usize;
            if offset_idx < checker.locals.len() {
                // checker.locals[].ty is now TyId; resolve and bridge to hir_ty for diagnostic
                let resolved_id = checker.resolve(type_intern.TyId.new(checker.locals[offset_idx].ty.index));
                let resolved = type_intern.ty_id_to_type(resolved_id);
                if type_contains_non_numeric_infer(&resolved, &checker.resolved_numeric_cache) {
                    checker.error_with_note(typeck_types.TypeErrorKind.CannotInfer, local.span,
                        common.make_string("cannot infer type; add a type annotation"));
                    // Only report once per body
                    li = body.locals.len();
                }
            }
            li += 1;
        }
    }

    // Run linearity checking: scan locals for ownership qualifiers,
    // count usages in body expression, report violations.
    // Inline implementation to avoid potential codegen issues with the module.
    check_linearity(checker, body);

    // Clear return type
    checker.clear_return_ty();
}

/// Returns the generic status of the current function being type-checked.
/// 0 = not a known function (handler body, unknown body — skip check)
/// 1 = non-generic function (check for unresolved infer vars)
/// 2 = generic function (skip — uses Infer for type params)
fn get_fn_generic_status(checker: &mut typeck.TypeChecker) -> i32 {
    // Handler op bodies have resume_ty set; skip undetermined-var check for them.
    // Their parameter types may contain generic Infer vars from effect definitions.
    match &checker.resume_ty {
        &Option.Some(_) => { return 0; }
        &Option.None => {}
    }
    let def_idx = checker.current_body_def_id as usize;
    if def_idx < checker.fn_sigs.len() {
        match &checker.fn_sigs[def_idx] {
            &Option.Some(ref sig) => {
                if sig.num_generics > 0 {
                    return 2;
                }
                // Check if this method belongs to a generic impl (impl<T>).
                // Such methods inherit type parameters even though their own
                // signature has num_generics == 0.
                let def_id_u32 = checker.current_body_def_id;
                for gi in 0usize..checker.generic_impl_method_defs.len() {
                    if checker.generic_impl_method_defs[gi] == def_id_u32 {
                        return 2;
                    }
                }
                return 1;
            }
            &Option.None => {}
        }
    }
    // No fn_sig found — this is a handler body, const body, or other non-function body
    0
}

/// Checks if a resolved type contains Infer variables that are NOT from numeric literals.
/// Numeric Infer variables (from unsuffixed int/float literals) will be defaulted during
/// MIR lowering and should not be flagged as undetermined.
fn type_contains_non_numeric_infer(ty: &hir_ty.Type, numeric_ids: &Vec<u32>) -> bool {
    match &ty.kind {
        &hir_ty.TypeKind.Infer(var_id) => {
            // Check if this Infer is from a numeric literal
            let id = var_id.index;
            for i in 0usize..numeric_ids.len() {
                if numeric_ids[i] == id {
                    return false;
                }
            }
            true
        }
        &hir_ty.TypeKind.Ref { ref inner, mutable: _ } => type_contains_non_numeric_infer(inner.as_ref(), numeric_ids),
        &hir_ty.TypeKind.Adt { def_id: _, ref args } => {
            for i in 0usize..args.len() {
                if type_contains_non_numeric_infer(&args[i], numeric_ids) {
                    return true;
                }
            }
            false
        }
        &hir_ty.TypeKind.Tuple(ref types) => {
            for i in 0usize..types.len() {
                if type_contains_non_numeric_infer(&types[i], numeric_ids) {
                    return true;
                }
            }
            false
        }
        &hir_ty.TypeKind.Fn { ref params, ref ret, effects: _ } => {
            for i in 0usize..params.len() {
                if type_contains_non_numeric_infer(&params[i], numeric_ids) {
                    return true;
                }
            }
            type_contains_non_numeric_infer(ret.as_ref(), numeric_ids)
        }
        _ => false,
    }
}

// ============================================================
// Deferred Method Resolution
// ============================================================

/// Resolves pending method calls whose receivers were Infer variables.
/// Uses a fixpoint loop: resolving one call may produce a return type
/// that allows another receiver to become concrete.
fn resolve_pending_methods(checker: &mut typeck.TypeChecker) {
    let mut resolved_count: usize = 1;
    while resolved_count > 0 {
        resolved_count = 0;
        for i in 0usize..checker.pending_method_calls.len() {
            let body_def_id = checker.pending_method_calls[i].body_def_id;
            let span_start = checker.pending_method_calls[i].span_start;
            let receiver_var = checker.pending_method_calls[i].receiver_var;
            let method_symbol = checker.pending_method_calls[i].method_symbol;
            let return_ty_var = checker.pending_method_calls[i].return_ty_var;

            // Skip if already resolved in a previous iteration
            if is_already_resolved(checker, body_def_id, span_start) {
                continue;
            }

            // Try to resolve the receiver type variable
            // Create TyId for the Infer variable
            let interner = type_intern.type_interner();
            let infer_ty_id = interner.intern(type_intern.InternedTypeKind.Infer(
                hir_def.TyVarId.new(receiver_var)
            ));
            let receiver_ty_id = checker.resolve(infer_ty_id);
            let stripped_id = typeck_expr.strip_refs_id(receiver_ty_id);

            // Check if still an Infer variable
            let stripped_kind = interner.get(stripped_id);
            let still_infer = match stripped_kind {
                &type_intern.InternedTypeKind.Infer(_) => true,
                _ => false,
            };

            if !still_infer {
                // Receiver is now concrete - look up the method
                match checker.lookup_method(stripped_id, method_symbol) {
                    Option.Some(ref lookup_result) => {
                        let method_def_id_index = checker.get_method_from_lookup(lookup_result).def_id.index;
                        let method_return_ty_id = type_intern.TyId.new(checker.get_method_from_lookup(lookup_result).return_ty.index);
                        let impl_num_generics = checker.get_impl_from_lookup(lookup_result).num_generics;
                        let impl_self_ty_id = type_intern.TyId.new(checker.get_impl_from_lookup(lookup_result).self_ty.index);

                        // Record the resolution with the body's DefId for scoping
                        checker.current_body_def_id = body_def_id;
                        checker.record_method_resolution(span_start, method_def_id_index);

                        // Unify return type with actual method return type
                        let mut subst = unify.TypeParamSubst.new();
                        if impl_num_generics > 0 {
                            // Bridge: extract_type_params_from_self_ty still takes &hir_ty.Type
                            let impl_self_type = type_intern.ty_id_to_type(impl_self_ty_id);
                            let stripped_type = type_intern.ty_id_to_type(stripped_id);
                            unify.extract_type_params_from_self_ty(
                                &impl_self_type, &stripped_type, &mut subst
                            );
                        }
                        let actual_ret_id = unify.substitute_type_params_id(
                            method_return_ty_id, &subst
                        );
                        let return_infer_id = interner.intern(type_intern.InternedTypeKind.Infer(
                            hir_def.TyVarId.new(return_ty_var)
                        ));
                        checker.unify(return_infer_id, actual_ret_id, common.Span.dummy());

                        resolved_count += 1;
                    }
                    Option.None => {
                        // Method not found even with concrete receiver — skip
                    }
                }
            }
        }
    }
    // Count unresolved pending calls
    let mut unresolved: usize = 0;
    for j in 0usize..checker.pending_method_calls.len() {
        let body_def_id = checker.pending_method_calls[j].body_def_id;
        let span_start = checker.pending_method_calls[j].span_start;
        if !is_already_resolved(checker, body_def_id, span_start) {
            unresolved += 1;
        }
    }
    // Pending methods resolved
}

/// Checks if a method call at the given span_start has already been resolved.
fn is_already_resolved(checker: &mut typeck.TypeChecker, body_def_id: u32, span_start: usize) -> bool {
    let key = ((body_def_id as u64) << 32) | (span_start as u64);
    checker.method_res_hash.contains_key(key)
}

/// Resolves pending field accesses that were deferred because the base type was Infer.
/// Similar to resolve_pending_methods: iterates until no more can be resolved.
fn resolve_pending_field_accesses(checker: &mut typeck.TypeChecker) {
    let interner = type_intern.type_interner();
    let mut resolved_count: usize = 1;
    while resolved_count > 0 {
        resolved_count = 0;
        for i in 0usize..checker.pending_field_accesses.len() {
            let body_def_id = checker.pending_field_accesses[i].body_def_id;
            let span_start = checker.pending_field_accesses[i].span_start;
            let base_var = checker.pending_field_accesses[i].base_var;
            let field_symbol = checker.pending_field_accesses[i].field_symbol;
            let field_ty_var = checker.pending_field_accesses[i].field_ty_var;
            let field_name_span_start = checker.pending_field_accesses[i].field_name_span_start;

            // Skip if already resolved (field resolution recorded)
            if is_field_already_resolved(checker, body_def_id, field_name_span_start) {
                continue;
            }

            // Try to resolve the base type variable
            let infer_ty_id = interner.intern(type_intern.InternedTypeKind.Infer(
                hir_def.TyVarId.new(base_var)
            ));
            let base_ty_id = checker.resolve(infer_ty_id);
            let stripped_id = typeck_expr.strip_refs_id(base_ty_id);
            let stripped_kind = interner.get(stripped_id);

            let still_infer = match stripped_kind {
                &type_intern.InternedTypeKind.Infer(_) => true,
                _ => false,
            };

            if !still_infer {
                // Base is now concrete — resolve the field
                checker.current_body_def_id = body_def_id;
                let field_infer_id = interner.intern(type_intern.InternedTypeKind.Infer(
                    hir_def.TyVarId.new(field_ty_var)
                ));

                match stripped_kind {
                    &type_intern.InternedTypeKind.Adt(ref def_id, ref args) => {
                        match checker.get_struct_field_ty(*def_id, field_symbol) {
                            Some(field_ty) => {
                                // Record field index
                                match checker.get_struct_field_idx(*def_id, field_symbol) {
                                    Option.Some(idx) => {
                                        checker.record_field_resolution(field_name_span_start, idx);
                                    }
                                    Option.None => {}
                                }
                                // Substitute type params if generic
                                let args_len = interner.ty_list_len(*args);
                                let actual_field_ty = if args_len > 0 {
                                    let mut subst = unify.TypeParamSubst.new();
                                    match checker.get_struct(*def_id) {
                                        Option.Some(ref si) => {
                                            for ai in 0usize..args_len {
                                                let arg_id = interner.get_ty_list_element(*args, ai);
                                                if ai < si.type_param_var_ids.len() {
                                                    subst.add_id(si.type_param_var_ids[ai], arg_id);
                                                } else {
                                                    subst.add_id(ai as u32, arg_id);
                                                }
                                            }
                                        }
                                        Option.None => {
                                            for ai in 0usize..args_len {
                                                let arg_id = interner.get_ty_list_element(*args, ai);
                                                subst.add_id(ai as u32, arg_id);
                                            }
                                        }
                                    }
                                    unify.substitute_type_params_id(field_ty, &subst)
                                } else {
                                    field_ty
                                };
                                checker.unify(field_infer_id, actual_field_ty, common.Span.dummy());
                                resolved_count += 1;
                            }
                            Option.None => {
                                // Field not found on concrete type — error
                            }
                        }
                    }
                    &type_intern.InternedTypeKind.Record(ref fields_id, ref row_var) => {
                        let field_list = interner.get_record_field_list(*fields_id);
                        let mut found = false;
                        for fi in 0usize..field_list.fields.len() {
                            if field_list.fields[fi].name.index == field_symbol.index {
                                checker.record_field_resolution(field_name_span_start, fi as u32);
                                let field_ty_id = field_list.fields[fi].ty;
                                checker.unify(field_infer_id, field_ty_id, common.Span.dummy());
                                found = true;
                                resolved_count += 1;
                            }
                        }
                        if !found {
                            match row_var {
                                &Option.Some(_) => {
                                    // Row variable present — field may exist in extended row
                                    resolved_count += 1;
                                }
                                &Option.None => {
                                    // No row variable — field not found, skip (error at original site)
                                }
                            }
                        }
                    }
                    &type_intern.InternedTypeKind.Tuple(ref types) => {
                        // Tuple field by name doesn't make sense — skip
                    }
                    _ => {
                        // Other type — can't resolve field, skip
                    }
                }
            }
        }
    }
}

/// Checks if a field access at the given name_span_start has already been resolved.
fn is_field_already_resolved(checker: &mut typeck.TypeChecker, body_def_id: u32, name_span_start: usize) -> bool {
    for i in 0usize..checker.field_resolutions.len() {
        if checker.field_resolutions[i].body_def_id == body_def_id &&
           checker.field_resolutions[i].span_start == name_span_start {
            return true;
        }
    }
    false
}

// ============================================================
// Builtin Method Registration
// ============================================================

/// Copies an Option<DefId> by value (for passing through references).
fn copy_opt_def_id(opt: &Option<hir_def.DefId>) -> Option<hir_def.DefId> {
    match opt {
        &Option.Some(ref d) => Option.Some(hir_def.DefId.new(d.index)),
        &Option.None => Option.None,
    }
}

/// Helper: create a reference type &T.
fn make_ref_ty(inner: type_intern.TyId) -> type_intern.TyId {
    let interner = type_intern.type_interner();
    interner.intern(type_intern.InternedTypeKind.Ref { inner: inner, mutable: false })
}

/// Helper: create an ADT type with the given DefId and type args.
fn make_adt(def_id: hir_def.DefId, args: Vec<type_intern.TyId>) -> type_intern.TyId {
    let interner = type_intern.type_interner();
    let args_list = interner.intern_ty_list(&args);
    interner.intern(type_intern.InternedTypeKind.Adt { def_id: def_id, args: args_list })
}

/// Helper: create a type parameter Param(n).
fn make_param(n: u32) -> type_intern.TyId {
    let interner = type_intern.type_interner();
    interner.intern(type_intern.InternedTypeKind.Param(hir_def.TyVarId.new(n)))
}

/// Extracts effect DefId indices from an HIR EffectRow.
fn extract_effect_def_ids(effects: &hir_ty.EffectRow) -> Vec<u32> {
    let mut ids: Vec<u32> = Vec.new();
    for i in 0usize..effects.effects.len() {
        ids.push(effects.effects[i].def_id.index);
    }
    ids
}

/// Extracts per-type-parameter trait bound DefIds from HIR Generics.
/// Returns a Vec<Vec<u32>> indexed by type param ordinal.
fn extract_type_param_bounds(generics: &hir_ty.Generics) -> Vec<Vec<u32>> {
    // Count type params to size the result
    let mut num_params: usize = 0;
    for i in 0usize..generics.params.len() {
        match &generics.params[i] {
            &hir_ty.GenericParam.TypeParam(_) => { num_params += 1; }
            _ => {}
        }
    }
    // Initialize with empty vecs
    let mut result: Vec<Vec<u32>> = Vec.new();
    for i in 0usize..num_params {
        result.push(Vec.new());
    }
    // Build TyVarId → ordinal mapping
    let mut var_to_ordinal: Vec<u32> = Vec.new();
    let mut var_ids: Vec<u32> = Vec.new();
    let mut ordinal: u32 = 0;
    for i in 0usize..generics.params.len() {
        match &generics.params[i] {
            &hir_ty.GenericParam.TypeParam(ref tp) => {
                var_ids.push(tp.var_id.index);
                var_to_ordinal.push(ordinal);
                ordinal += 1;
            }
            _ => {}
        }
    }
    // Extract trait bounds from where predicates
    for i in 0usize..generics.where_predicates.len() {
        match &generics.where_predicates[i] {
            &hir_ty.WherePredicate.TypeBound { ref ty, ref bounds, span: _ } => {
                // Find which type param this predicate binds
                match &ty.kind {
                    &hir_ty.TypeKind.Param(var_id) => {
                        // Look up ordinal for this TyVarId
                        for vi in 0usize..var_ids.len() {
                            if var_ids[vi] == var_id.index {
                                let ord = var_to_ordinal[vi] as usize;
                                // Add each trait bound's DefId
                                for bi in 0usize..bounds.len() {
                                    result[ord].push(bounds[bi].def_id.index);
                                }
                                break;
                            }
                        }
                    }
                    _ => {}
                }
            }
            _ => {}
        }
    }
    result
}

/// Helper: add a method to the methods list and record its runtime function name.
/// The interner must be the same interner used during HIR lowering so that
/// method name symbols match.
fn add_method(
    checker: &mut typeck.TypeChecker,
    methods: &mut Vec<typeck.MethodInfo>,
    name: &str,
    runtime_name: &str,
    params: Vec<type_intern.TyId>,
    ret: type_intern.TyId,
    self_mut: bool,
    interner: &interner.StringInterner,
) {
    let def_id = checker.alloc_def_id();
    // Use the same interner as HIR lowering to get matching Symbol indices.
    // All builtin method names are pre-interned, so find() will always succeed.
    let found = interner.find(name);
    let sym = found.unwrap();
    methods.push(typeck.MethodInfo.new(def_id, sym, params, ret, true, self_mut, Vec.new(), Vec.new(), common.Span { start: 0, end: 0, line: 0, column: 0 }));
    // Record mapping from synthetic DefId to runtime function name for codegen
    checker.builtin_def_names.push(
        typeck.BuiltinDefName.new(def_id.index, common.make_string(runtime_name)),
    );
}

/// Registers builtin method signatures for all builtin types.
/// The interner parameter must be the same interner used during HIR lowering
/// so that method name symbols match between HIR and type checking.
fn register_builtin_signatures(checker: &mut typeck.TypeChecker, interner: &interner.StringInterner) {
    // String methods
    match checker.builtin_string_def {
        Option.Some(def_id) => {
            register_string_methods(checker, def_id, interner);
        }
        Option.None => {}
    }

    // Vec methods
    match checker.builtin_vec_def {
        Option.Some(def_id) => {
            register_vec_methods(checker, def_id, interner);
        }
        Option.None => {}
    }

    // Option methods
    match checker.builtin_option_def {
        Option.Some(def_id) => {
            register_option_methods(checker, def_id, interner);
        }
        Option.None => {}
    }

    // Box methods
    match checker.builtin_box_def {
        Option.Some(def_id) => {
            register_box_methods(checker, def_id, interner);
        }
        Option.None => {}
    }

    // HashMap methods
    match checker.builtin_hashmap_def {
        Option.Some(def_id) => {
            register_hashmap_methods(checker, def_id, interner);
        }
        Option.None => {}
    }

    // Result methods
    match checker.builtin_result_def {
        Option.Some(def_id) => {
            register_result_methods(checker, def_id, interner);
        }
        Option.None => {}
    }

    // Primitive str methods
    register_str_methods(checker, interner);

    // Slice methods
    register_slice_methods(checker, interner);
}

/// Registers String methods: len, is_empty, push_str, push, as_str, clone,
/// contains, starts_with, ends_with, as_bytes.
fn register_string_methods(checker: &mut typeck.TypeChecker, string_def: hir_def.DefId, interner: &interner.StringInterner) {
    let self_ty = make_adt(string_def, Vec.new());
    let mut methods: Vec<typeck.MethodInfo> = Vec.new();

    // len(&self) -> usize
    add_method(checker, &mut methods, "len", "string_len", Vec.new(), type_intern.CommonTypes.usize_ty(), false, interner);

    // is_empty(&self) -> bool
    add_method(checker, &mut methods, "is_empty", "string_is_empty", Vec.new(), type_intern.CommonTypes.bool_ty(), false, interner);

    // push_str(&mut self, &str) -> ()
    let mut push_str_params: Vec<type_intern.TyId> = Vec.new();
    push_str_params.push(make_ref_ty(type_intern.CommonTypes.str_ty()));
    add_method(checker, &mut methods, "push_str", "string_push_str", push_str_params, type_intern.CommonTypes.unit(), true, interner);

    // push(&mut self, char) -> ()
    let mut push_params: Vec<type_intern.TyId> = Vec.new();
    push_params.push(type_intern.CommonTypes.char_ty());
    add_method(checker, &mut methods, "push", "string_push", push_params, type_intern.CommonTypes.unit(), true, interner);

    // as_str(&self) -> &str
    add_method(checker, &mut methods, "as_str", "string_as_str", Vec.new(), make_ref_ty(type_intern.CommonTypes.str_ty()), false, interner);

    // clone(&self) -> String
    add_method(checker, &mut methods, "clone", "string_clone", Vec.new(), make_adt(string_def, Vec.new()), false, interner);

    // contains(&self, &str) -> bool
    let mut contains_params: Vec<type_intern.TyId> = Vec.new();
    contains_params.push(make_ref_ty(type_intern.CommonTypes.str_ty()));
    add_method(checker, &mut methods, "contains", "string_contains", contains_params, type_intern.CommonTypes.bool_ty(), false, interner);

    // starts_with(&self, &str) -> bool
    let mut sw_params: Vec<type_intern.TyId> = Vec.new();
    sw_params.push(make_ref_ty(type_intern.CommonTypes.str_ty()));
    add_method(checker, &mut methods, "starts_with", "string_starts_with", sw_params, type_intern.CommonTypes.bool_ty(), false, interner);

    // ends_with(&self, &str) -> bool
    let mut ew_params: Vec<type_intern.TyId> = Vec.new();
    ew_params.push(make_ref_ty(type_intern.CommonTypes.str_ty()));
    add_method(checker, &mut methods, "ends_with", "string_ends_with", ew_params, type_intern.CommonTypes.bool_ty(), false, interner);

    // as_bytes(&self) -> &[u8]
    let ty_interner = type_intern.type_interner();
    let u8_slice = ty_interner.intern(type_intern.InternedTypeKind.Slice { element: type_intern.CommonTypes.u8_ty() });
    add_method(checker, &mut methods, "as_bytes", "string_as_bytes", Vec.new(), make_ref_ty(u8_slice), false, interner);

    // Register the impl
    let impl_def = checker.alloc_def_id();
    let impl_info = typeck.ImplInfo.new(impl_def, self_ty, 0, methods);
    checker.register_impl(impl_info);
}

/// Registers Vec<T> methods: push, pop, len, is_empty, get, last, clear,
/// remove, insert, contains, clone.
fn register_vec_methods(checker: &mut typeck.TypeChecker, vec_def: hir_def.DefId, interner: &interner.StringInterner) {
    let mut self_args: Vec<type_intern.TyId> = Vec.new();
    self_args.push(make_param(0));
    let self_ty = make_adt(vec_def, self_args);
    let mut methods: Vec<typeck.MethodInfo> = Vec.new();

    // push(&mut self, T) -> ()
    let mut push_params: Vec<type_intern.TyId> = Vec.new();
    push_params.push(make_param(0));
    add_method(checker, &mut methods, "push", "vec_push", push_params, type_intern.CommonTypes.unit(), true, interner);

    // pop(&mut self) -> Option<T>
    let option_def = checker.builtin_option_def;
    match option_def {
        Option.Some(opt_def) => {
            let mut opt_args: Vec<type_intern.TyId> = Vec.new();
            opt_args.push(make_param(0));
            add_method(checker, &mut methods, "pop", "vec_pop", Vec.new(), make_adt(opt_def, opt_args), true, interner);
        }
        Option.None => {
            add_method(checker, &mut methods, "pop", "vec_pop", Vec.new(), make_param(0), true, interner);
        }
    }

    // len(&self) -> usize
    add_method(checker, &mut methods, "len", "vec_len", Vec.new(), type_intern.CommonTypes.usize_ty(), false, interner);

    // is_empty(&self) -> bool
    add_method(checker, &mut methods, "is_empty", "vec_is_empty", Vec.new(), type_intern.CommonTypes.bool_ty(), false, interner);

    // get(&self, usize) -> Option<&T>
    match option_def {
        Option.Some(opt_def) => {
            let mut get_params: Vec<type_intern.TyId> = Vec.new();
            get_params.push(type_intern.CommonTypes.usize_ty());
            let mut opt_args: Vec<type_intern.TyId> = Vec.new();
            opt_args.push(make_ref_ty(make_param(0)));
            add_method(checker, &mut methods, "get", "vec_get", get_params, make_adt(opt_def, opt_args), false, interner);
        }
        Option.None => {
            let mut get_params: Vec<type_intern.TyId> = Vec.new();
            get_params.push(type_intern.CommonTypes.usize_ty());
            add_method(checker, &mut methods, "get", "vec_get", get_params, make_ref_ty(make_param(0)), false, interner);
        }
    }

    // last(&self) -> Option<&T>
    match option_def {
        Option.Some(opt_def) => {
            let mut opt_args: Vec<type_intern.TyId> = Vec.new();
            opt_args.push(make_ref_ty(make_param(0)));
            add_method(checker, &mut methods, "last", "vec_last", Vec.new(), make_adt(opt_def, opt_args), false, interner);
        }
        Option.None => {
            add_method(checker, &mut methods, "last", "vec_last", Vec.new(), make_ref_ty(make_param(0)), false, interner);
        }
    }

    // clear(&mut self) -> ()
    add_method(checker, &mut methods, "clear", "vec_clear", Vec.new(), type_intern.CommonTypes.unit(), true, interner);

    // remove(&mut self, usize) -> T
    let mut remove_params: Vec<type_intern.TyId> = Vec.new();
    remove_params.push(type_intern.CommonTypes.usize_ty());
    add_method(checker, &mut methods, "remove", "vec_remove", remove_params, make_param(0), true, interner);

    // insert(&mut self, usize, T) -> ()
    let mut insert_params: Vec<type_intern.TyId> = Vec.new();
    insert_params.push(type_intern.CommonTypes.usize_ty());
    insert_params.push(make_param(0));
    add_method(checker, &mut methods, "insert", "vec_insert", insert_params, type_intern.CommonTypes.unit(), true, interner);

    // contains(&self, &T) -> bool
    let mut contains_params: Vec<type_intern.TyId> = Vec.new();
    contains_params.push(make_ref_ty(make_param(0)));
    add_method(checker, &mut methods, "contains", "vec_contains", contains_params, type_intern.CommonTypes.bool_ty(), false, interner);

    // clone(&self) -> Vec<T>
    let mut clone_args: Vec<type_intern.TyId> = Vec.new();
    clone_args.push(make_param(0));
    add_method(checker, &mut methods, "clone", "vec_clone", Vec.new(), make_adt(vec_def, clone_args), false, interner);

    // Register the impl
    let impl_def = checker.alloc_def_id();
    let impl_info = typeck.ImplInfo.new(impl_def, self_ty, 1, methods);
    checker.register_impl(impl_info);
}

/// Registers Option<T> methods: is_some, is_none, unwrap, unwrap_or, expect, as_ref, clone.
fn register_option_methods(checker: &mut typeck.TypeChecker, option_def: hir_def.DefId, interner: &interner.StringInterner) {
    let mut self_args: Vec<type_intern.TyId> = Vec.new();
    self_args.push(make_param(0));
    let self_ty = make_adt(option_def, self_args);
    let mut methods: Vec<typeck.MethodInfo> = Vec.new();

    // is_some(&self) -> bool
    add_method(checker, &mut methods, "is_some", "option_is_some", Vec.new(), type_intern.CommonTypes.bool_ty(), false, interner);

    // is_none(&self) -> bool
    add_method(checker, &mut methods, "is_none", "option_is_none", Vec.new(), type_intern.CommonTypes.bool_ty(), false, interner);

    // unwrap(self) -> T
    add_method(checker, &mut methods, "unwrap", "option_unwrap", Vec.new(), make_param(0), false, interner);

    // unwrap_or(self, T) -> T
    let mut unwrap_or_params: Vec<type_intern.TyId> = Vec.new();
    unwrap_or_params.push(make_param(0));
    add_method(checker, &mut methods, "unwrap_or", "option_unwrap_or", unwrap_or_params, make_param(0), false, interner);

    // expect(self, &str) -> T
    let mut expect_params: Vec<type_intern.TyId> = Vec.new();
    expect_params.push(make_ref_ty(type_intern.CommonTypes.str_ty()));
    add_method(checker, &mut methods, "expect", "option_expect", expect_params, make_param(0), false, interner);

    // as_ref(&self) -> Option<&T>
    let mut as_ref_args: Vec<type_intern.TyId> = Vec.new();
    as_ref_args.push(make_ref_ty(make_param(0)));
    add_method(checker, &mut methods, "as_ref", "option_as_ref", Vec.new(), make_adt(option_def, as_ref_args), false, interner);

    // clone(&self) -> Option<T>
    let mut clone_args: Vec<type_intern.TyId> = Vec.new();
    clone_args.push(make_param(0));
    add_method(checker, &mut methods, "clone", "option_clone", Vec.new(), make_adt(option_def, clone_args), false, interner);

    // Register the impl
    let impl_def = checker.alloc_def_id();
    let impl_info = typeck.ImplInfo.new(impl_def, self_ty, 1, methods);
    checker.register_impl(impl_info);
}

