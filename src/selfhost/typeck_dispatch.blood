module blood.typeck_dispatch;

// Blood Self-Hosted Compiler - Method Dispatch Resolution
//
// Implements method resolution for multiple dispatch:
// 1. Collect all impl blocks with matching method name
// 2. Filter by receiver type compatibility
// 3. Rank by specificity
// 4. Report ambiguity if tied

mod common;
mod hashmap;
mod hir_def;
mod hir_ty;
mod type_intern;
mod typeck_info;

// ============================================================
// Method Candidates
// ============================================================

/// A method candidate found during resolution.
pub struct MethodCandidate {
    /// The DefId of the method.
    pub def_id: hir_def.DefId,
    /// The DefId of the impl block containing this method.
    pub impl_id: hir_def.DefId,
    /// The self type of the impl block.
    pub self_ty: type_intern.TyId,
    /// Specificity score (higher = more specific).
    pub specificity: u32,
    /// Whether this is from a trait impl.
    pub is_trait_impl: bool,
}

impl MethodCandidate {
    /// Creates a new method candidate.
    pub fn new(
        def_id: hir_def.DefId,
        impl_id: hir_def.DefId,
        self_ty: type_intern.TyId,
        specificity: u32,
        is_trait_impl: bool,
    ) -> MethodCandidate {
        MethodCandidate {
            def_id: def_id,
            impl_id: impl_id,
            self_ty: self_ty,
            specificity: specificity,
            is_trait_impl: is_trait_impl,
        }
    }
}

// ============================================================
// Dispatch Result
// ============================================================

/// Result of method dispatch resolution.
pub enum DispatchResult {
    /// A single best candidate was found.
    Found(MethodCandidate),
    /// Multiple candidates with equal specificity.
    Ambiguous {
        candidates: Vec<MethodCandidate>,
    },
    /// No matching candidate found.
    NotFound,
}

// ============================================================
// Dispatch Resolver
// ============================================================

/// Resolves method dispatch given a set of candidates.
pub struct DispatchResolver {
    /// All collected candidates.
    pub candidates: Vec<MethodCandidate>,
}

impl DispatchResolver {
    /// Creates a new resolver.
    pub fn new() -> DispatchResolver {
        DispatchResolver {
            candidates: Vec.new(),
        }
    }

    /// Adds a candidate.
    pub fn add_candidate(self: &mut Self, candidate: MethodCandidate) {
        self.candidates.push(candidate);
    }

    /// Resolves to the best candidate.
    pub fn resolve(self: &Self) -> DispatchResult {
        if self.candidates.len() == 0 {
            return DispatchResult.NotFound;
        }

        if self.candidates.len() == 1 {
            // Single candidate — return it directly
            let c = &self.candidates[0];
            return DispatchResult.Found(MethodCandidate.new(
                hir_def.DefId.new(c.def_id.index),
                hir_def.DefId.new(c.impl_id.index),
                type_intern.TyId.new(c.self_ty.index),
                c.specificity,
                c.is_trait_impl,
            ));
        }

        // Find the candidate with highest specificity
        let mut best_idx: usize = 0;
        let mut best_specificity: u32 = self.candidates[0].specificity;
        let mut tie_count: u32 = 1;

        for i in 1usize..self.candidates.len() {
            if self.candidates[i].specificity > best_specificity {
                best_idx = i;
                best_specificity = self.candidates[i].specificity;
                tie_count = 1;
            } else if self.candidates[i].specificity == best_specificity {
                tie_count += 1;
            }
        }

        if tie_count > 1 {
            // Ambiguous — collect all tied candidates
            let mut tied: Vec<MethodCandidate> = Vec.new();
            for j in 0usize..self.candidates.len() {
                if self.candidates[j].specificity == best_specificity {
                    let c = &self.candidates[j];
                    tied.push(MethodCandidate.new(
                        hir_def.DefId.new(c.def_id.index),
                        hir_def.DefId.new(c.impl_id.index),
                        type_intern.TyId.new(c.self_ty.index),
                        c.specificity,
                        c.is_trait_impl,
                    ));
                }
            }
            DispatchResult.Ambiguous { candidates: tied }
        } else {
            let c = &self.candidates[best_idx];
            DispatchResult.Found(MethodCandidate.new(
                hir_def.DefId.new(c.def_id.index),
                hir_def.DefId.new(c.impl_id.index),
                type_intern.TyId.new(c.self_ty.index),
                c.specificity,
                c.is_trait_impl,
            ))
        }
    }
}

// ============================================================
// Object Safety Checking
// ============================================================

/// Object safety violation kind.
pub enum ObjectSafetyViolation {
    /// Method has generic type parameters ([No-Generic-Self]).
    GenericSelfMethod,
    /// Method takes self by value ([No-Self-By-Value]).
    SelfByValue,
    /// Method returns Self by value ([No-Self-Return]).
    SelfReturn,
    /// Associated type has no default and is not bound ([Assoc-Type-Bound]).
    UnboundAssocType,
}

/// Result of object safety checking.
pub enum ObjectSafetyResult {
    /// Trait is object-safe.
    Safe,
    /// Trait is not object-safe.
    Unsafe(ObjectSafetyViolation),
}

/// Checks if a trait is object-safe per DISPATCH.md §10.7.
///
/// A trait is object-safe when all its methods can be represented as
/// function pointers in a vtable. Returns Safe or Unsafe with the violation.
///
/// Rules checked:
/// 1. [No-Generic-Self] — No method has generic type parameters
/// 2. [No-Self-By-Value] — No method takes self by value (must take &self or &mut self)
/// 3. [No-Self-Return] — No method returns Self by value
/// 4. [Assoc-Type-Bound] — All associated types have defaults or are bound
pub fn check_trait_object_safety(
    trait_info: &typeck_info.TraitInfo,
) -> ObjectSafetyResult {
    let trait_def_id = trait_info.def_id;

    // Check each method
    let num_methods: u32 = trait_info.methods.len() as u32;
    for i in 0u32..num_methods {
        let method = &trait_info.methods[i as usize];

        // Rule 1: [No-Generic-Self]
        // Generic methods require monomorphization, which is incompatible
        // with vtable dispatch (vtable slots have fixed signatures).
        if method.num_method_generics > 0 {
            return ObjectSafetyResult.Unsafe(ObjectSafetyViolation.GenericSelfMethod);
        }

        // Rule 2: [No-Self-By-Value]
        // Check all non-receiver parameters for bare Self.
        // Self behind a reference is OK (known size).
        let num_params: u32 = method.param_tys.len() as u32;
        for p in 0u32..num_params {
            if type_contains_self(method.param_tys[p as usize], trait_def_id) {
                return ObjectSafetyResult.Unsafe(ObjectSafetyViolation.SelfByValue);
            }
        }

        // Rule 3: [No-Self-Return]
        // Check if return type contains Self not behind a reference.
        if type_contains_self(method.return_ty, trait_def_id) {
            return ObjectSafetyResult.Unsafe(ObjectSafetyViolation.SelfReturn);
        }
    }

    // Rule 4: [Assoc-Type-Bound]
    // All associated types must have defaults for the trait to be object-safe.
    // Without a default, the vtable caller cannot determine the associated type.
    let num_assoc: u32 = trait_info.assoc_types.len() as u32;
    for j in 0u32..num_assoc {
        let at = &trait_info.assoc_types[j as usize];
        if !at.has_default {
            return ObjectSafetyResult.Unsafe(ObjectSafetyViolation.UnboundAssocType);
        }
    }

    ObjectSafetyResult.Safe
}

/// Checks if a type contains Self not behind a reference.
/// Self in trait HIR is lowered as Adt(trait_def_id), so we check both
/// Param (generic) and Adt matching the trait's own DefId.
/// Recursively checks tuples and ADT type arguments.
fn type_contains_self(ty: type_intern.TyId, trait_def_id: hir_def.DefId) -> bool {
    let interner = type_intern.type_interner();
    let kind = interner.get(ty);
    match kind {
        &type_intern.InternedTypeKind.Param(_) => true,
        &type_intern.InternedTypeKind.Adt { def_id, args } => {
            // Self in trait methods is lowered as Adt(trait_def_id) with no args
            if def_id.index == trait_def_id.index {
                return true;
            }
            // Otherwise check type arguments recursively
            let len = interner.ty_list_len(args);
            for k in 0usize..len {
                let arg = interner.get_ty_list_element(args, k);
                if type_contains_self(arg, trait_def_id) {
                    return true;
                }
            }
            false
        }
        &type_intern.InternedTypeKind.Tuple(list_id) => {
            let len = interner.ty_list_len(list_id);
            for k in 0usize..len {
                let elem = interner.get_ty_list_element(list_id, k);
                if type_contains_self(elem, trait_def_id) {
                    return true;
                }
            }
            false
        }
        // Self behind a reference or pointer is OK (known size)
        &type_intern.InternedTypeKind.Ref { inner: _, mutable: _ } => false,
        &type_intern.InternedTypeKind.Ptr { inner: _, mutable: _ } => false,
        _ => false,
    }
}

// ============================================================
// Specificity Calculation
// ============================================================

/// Maximum recursion depth for dispatch type traversal.
/// Guards against infinite recursion from cyclic type definitions.
fn max_dispatch_depth() -> u32 { 64 }

/// Computes specificity score for a type.
/// Concrete types are more specific than generic ones.
/// Scores: 10 = most specific (concrete primitive/never),
///         0 = least specific (unresolved inference variable or error).
pub fn compute_specificity(ty: type_intern.TyId) -> u32 {
    compute_specificity_bounded(ty, 0)
}

/// Depth-bounded specificity computation.
/// Returns 0 (least specific) if depth limit is exceeded, preventing
/// infinite recursion on cyclic type structures.
fn compute_specificity_bounded(ty: type_intern.TyId, depth: u32) -> u32 {
    if depth >= max_dispatch_depth() {
        return 0;
    }
    let interner = type_intern.type_interner();
    let kind = interner.get(ty);
    match kind {
        &type_intern.InternedTypeKind.Primitive(_) => 10,
        &type_intern.InternedTypeKind.Never => 10,
        &type_intern.InternedTypeKind.Adt { def_id: _, args: _ } => 8,
        &type_intern.InternedTypeKind.Array { element: _, size: _ } => 9,
        &type_intern.InternedTypeKind.Slice { element: _ } => 9,
        &type_intern.InternedTypeKind.Range { element: _, inclusive: _ } => 9,
        &type_intern.InternedTypeKind.Tuple(_) => 7,
        &type_intern.InternedTypeKind.Record { fields: _, row_var: _ } => 7,
        &type_intern.InternedTypeKind.Fn { params: _, ret: _, effects: _ } => 6,
        &type_intern.InternedTypeKind.Closure { def_id: _, params: _, ret: _ } => 6,
        &type_intern.InternedTypeKind.Ref { inner, mutable: _ } => {
            compute_specificity_bounded(inner, depth + 1)
        }
        &type_intern.InternedTypeKind.Ptr { inner, mutable: _ } => {
            compute_specificity_bounded(inner, depth + 1)
        }
        &type_intern.InternedTypeKind.Ownership { qualifier: _, inner } => {
            compute_specificity_bounded(inner, depth + 1)
        }
        &type_intern.InternedTypeKind.DynTrait { trait_id: _, auto_traits: _ } => 3,
        &type_intern.InternedTypeKind.Forall { params: _, body: _ } => 2,
        &type_intern.InternedTypeKind.Param(_) => 1,
        &type_intern.InternedTypeKind.Infer(_) => 0,
        &type_intern.InternedTypeKind.Error => 0,
    }
}

// ============================================================
// Subtype-Based Specificity (DIS-01)
// ============================================================

/// Maximum recursion depth for subtype checking.
fn max_subtype_depth() -> u32 { 64 }

/// Checks if type `a` is a subtype of type `b` (a is at least as specific as b).
///
/// Implements structural subtyping with variance:
/// - Covariant: &T (immutable), slices, arrays, tuples
/// - Invariant: &mut T
/// - Contravariant: fn parameters (reversed), covariant fn return
/// - Never <: everything (bottom type)
/// - Infer/Param on b side → true (type variables accept anything)
/// - ADT: same def_id + pairwise subtype on args
pub fn is_subtype_id(a: type_intern.TyId, b: type_intern.TyId, depth: u32) -> bool {
    if depth >= max_subtype_depth() {
        return false;
    }

    // Same type → always subtype
    if a.index == b.index {
        return true;
    }

    let interner = type_intern.type_interner();
    let ka = interner.get(a);
    let kb = interner.get(b);

    // Never is subtype of everything
    match ka {
        &type_intern.InternedTypeKind.Never => { return true; }
        _ => {}
    }
    // Nothing is subtype of Never (except Never itself, handled above)
    match kb {
        &type_intern.InternedTypeKind.Never => { return false; }
        _ => {}
    }

    // Type variables on b side accept anything during dispatch
    match kb {
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        _ => {}
    }

    // Strip Ownership wrappers from both sides before structural comparison
    match kb {
        &type_intern.InternedTypeKind.Ownership { qualifier: _, inner: b_inner } => {
            return is_subtype_id(a, b_inner, depth + 1);
        }
        _ => {}
    }

    // Structural variance rules
    match ka {
        &type_intern.InternedTypeKind.Primitive(pa) => {
            match kb {
                &type_intern.InternedTypeKind.Primitive(pb) => pa == pb,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ref { inner: a_inner, mutable: a_mut } => {
            match kb {
                &type_intern.InternedTypeKind.Ref { inner: b_inner, mutable: b_mut } => {
                    if a_mut && !b_mut {
                        // &mut T can be used where &T is expected (covariant)
                        is_subtype_id(a_inner, b_inner, depth + 1)
                    } else if !a_mut && b_mut {
                        // &T is NOT subtype of &mut T
                        false
                    } else if a_mut && b_mut {
                        // &mut T is invariant — require exact inner match
                        types_equal_id(a_inner, b_inner, depth + 1)
                    } else {
                        // Both immutable — covariant
                        is_subtype_id(a_inner, b_inner, depth + 1)
                    }
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ptr { inner: a_inner, mutable: a_mut } => {
            match kb {
                &type_intern.InternedTypeKind.Ptr { inner: b_inner, mutable: b_mut } => {
                    if a_mut == b_mut {
                        if a_mut {
                            types_equal_id(a_inner, b_inner, depth + 1)
                        } else {
                            is_subtype_id(a_inner, b_inner, depth + 1)
                        }
                    } else {
                        false
                    }
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Adt { def_id: a_def, args: a_args } => {
            match kb {
                &type_intern.InternedTypeKind.Adt { def_id: b_def, args: b_args } => {
                    if a_def.index != b_def.index {
                        return false;
                    }
                    let a_len = interner.ty_list_len(a_args);
                    let b_len = interner.ty_list_len(b_args);
                    if a_len != b_len {
                        return false;
                    }
                    for i in 0usize..a_len {
                        let a_arg = interner.get_ty_list_element(a_args, i);
                        let b_arg = interner.get_ty_list_element(b_args, i);
                        if !is_subtype_id(a_arg, b_arg, depth + 1) {
                            return false;
                        }
                    }
                    true
                }
                // Concrete ADT is subtype of Param/Infer (handled above)
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Tuple(a_list) => {
            match kb {
                &type_intern.InternedTypeKind.Tuple(b_list) => {
                    let a_len = interner.ty_list_len(a_list);
                    let b_len = interner.ty_list_len(b_list);
                    if a_len != b_len {
                        return false;
                    }
                    for i in 0usize..a_len {
                        let a_elem = interner.get_ty_list_element(a_list, i);
                        let b_elem = interner.get_ty_list_element(b_list, i);
                        if !is_subtype_id(a_elem, b_elem, depth + 1) {
                            return false;
                        }
                    }
                    true
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Array { element: a_elem, size: a_size } => {
            match kb {
                &type_intern.InternedTypeKind.Array { element: b_elem, size: b_size } => {
                    a_size == b_size && is_subtype_id(a_elem, b_elem, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Slice { element: a_elem } => {
            match kb {
                &type_intern.InternedTypeKind.Slice { element: b_elem } => {
                    is_subtype_id(a_elem, b_elem, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Fn { params: a_params, ret: a_ret, effects: _ } => {
            match kb {
                &type_intern.InternedTypeKind.Fn { params: b_params, ret: b_ret, effects: _ } => {
                    let a_len = interner.ty_list_len(a_params);
                    let b_len = interner.ty_list_len(b_params);
                    if a_len != b_len {
                        return false;
                    }
                    // Contravariant in parameters: b_param <: a_param
                    for i in 0usize..a_len {
                        let a_p = interner.get_ty_list_element(a_params, i);
                        let b_p = interner.get_ty_list_element(b_params, i);
                        if !is_subtype_id(b_p, a_p, depth + 1) {
                            return false;
                        }
                    }
                    // Covariant in return type
                    is_subtype_id(a_ret, b_ret, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ownership { qualifier: _, inner: a_inner } => {
            // Strip ownership wrapper and recurse
            is_subtype_id(a_inner, b, depth + 1)
        }
        &type_intern.InternedTypeKind.Param(_) => {
            // Param on the `a` side: a type variable is NOT more specific than a concrete type.
            // Param <: Param if same id (handled by index equality above).
            // Param <: concrete → false (generic is less specific than concrete).
            match kb {
                &type_intern.InternedTypeKind.Param(_) => false,
                &type_intern.InternedTypeKind.Infer(_) => true,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Infer(_) => {
            // Infer is the least specific — subtype of Infer/Param only
            match kb {
                &type_intern.InternedTypeKind.Infer(_) => true,
                &type_intern.InternedTypeKind.Param(_) => true,
                _ => false,
            }
        }
        _ => false,
    }
}

/// Checks structural equality of two interned types (depth-bounded).
fn types_equal_id(a: type_intern.TyId, b: type_intern.TyId, depth: u32) -> bool {
    if a.index == b.index {
        return true;
    }
    if depth >= max_subtype_depth() {
        return false;
    }
    let interner = type_intern.type_interner();
    let ka = interner.get(a);
    let kb = interner.get(b);
    match ka {
        &type_intern.InternedTypeKind.Primitive(pa) => {
            match kb {
                &type_intern.InternedTypeKind.Primitive(pb) => pa == pb,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Adt { def_id: a_def, args: a_args } => {
            match kb {
                &type_intern.InternedTypeKind.Adt { def_id: b_def, args: b_args } => {
                    if a_def.index != b_def.index {
                        return false;
                    }
                    let a_len = interner.ty_list_len(a_args);
                    let b_len = interner.ty_list_len(b_args);
                    if a_len != b_len {
                        return false;
                    }
                    for i in 0usize..a_len {
                        let a_arg = interner.get_ty_list_element(a_args, i);
                        let b_arg = interner.get_ty_list_element(b_args, i);
                        if !types_equal_id(a_arg, b_arg, depth + 1) {
                            return false;
                        }
                    }
                    true
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ref { inner: a_inner, mutable: a_mut } => {
            match kb {
                &type_intern.InternedTypeKind.Ref { inner: b_inner, mutable: b_mut } => {
                    a_mut == b_mut && types_equal_id(a_inner, b_inner, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Tuple(a_list) => {
            match kb {
                &type_intern.InternedTypeKind.Tuple(b_list) => {
                    let a_len = interner.ty_list_len(a_list);
                    let b_len = interner.ty_list_len(b_list);
                    if a_len != b_len {
                        return false;
                    }
                    for i in 0usize..a_len {
                        let a_elem = interner.get_ty_list_element(a_list, i);
                        let b_elem = interner.get_ty_list_element(b_list, i);
                        if !types_equal_id(a_elem, b_elem, depth + 1) {
                            return false;
                        }
                    }
                    true
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Never => {
            match kb {
                &type_intern.InternedTypeKind.Never => true,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Param(a_id) => {
            match kb {
                &type_intern.InternedTypeKind.Param(b_id) => a_id.index == b_id.index,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Infer(a_id) => {
            match kb {
                &type_intern.InternedTypeKind.Infer(b_id) => a_id.index == b_id.index,
                _ => false,
            }
        }
        _ => false,
    }
}

// ============================================================
// Effect Row Comparison
// ============================================================

/// Checks if two effect rows are equal (same set of effect DefIds).
/// Empty rows (pure) are equal to each other. Order does not matter.
fn effect_rows_equal(a: &Vec<u32>, b: &Vec<u32>) -> bool {
    if a.len() != b.len() {
        return false;
    }
    // For small effect sets (typical case), O(n²) is fine
    for i in 0usize..a.len() {
        let mut found = false;
        for j in 0usize..b.len() {
            if a[i] == b[j] {
                found = true;
                break;
            }
        }
        if !found {
            return false;
        }
    }
    true
}

/// Checks if effect row `a` is a subset of `b` (a subsumes b).
/// pure <: {E1} <: {E1, E2} — fewer effects is more specific.
fn effect_row_subsumes(a: &Vec<u32>, b: &Vec<u32>) -> bool {
    // Every effect in a must be in b
    for i in 0usize..a.len() {
        let mut found = false;
        for j in 0usize..b.len() {
            if a[i] == b[j] {
                found = true;
                break;
            }
        }
        if !found {
            return false;
        }
    }
    true
}

// ============================================================
// Constraint-Based Specificity
// ============================================================

/// Checks if a set of trait bound DefIds is a superset of another.
fn bounds_superset(sup: &Vec<u32>, sub: &Vec<u32>) -> bool {
    for i in 0usize..sub.len() {
        let mut found = false;
        for j in 0usize..sup.len() {
            if sub[i] == sup[j] {
                found = true;
                break;
            }
        }
        if !found {
            return false;
        }
    }
    true
}

/// Checks if m1 is more constrained than m2 per DISPATCH.md §3.7.2.
/// m1 is more constrained if, for every type param position, m1's bounds
/// are a superset of m2's bounds, and at least one is strictly greater.
fn constraint_more_specific(m1: &typeck_info.MethodInfo, m2: &typeck_info.MethodInfo) -> bool {
    // Both must have type_param_bounds to compare
    if m1.type_param_bounds.len() == 0 && m2.type_param_bounds.len() == 0 {
        return false;
    }
    // Compare corresponding type param bounds
    let max_params = if m1.type_param_bounds.len() > m2.type_param_bounds.len() {
        m1.type_param_bounds.len()
    } else {
        m2.type_param_bounds.len()
    };
    let mut all_at_least: bool = true;
    let mut some_strictly: bool = false;
    for i in 0usize..max_params {
        let b1 = if i < m1.type_param_bounds.len() { &m1.type_param_bounds[i] } else { &m1.type_param_bounds[0] };
        let b2 = if i < m2.type_param_bounds.len() { &m2.type_param_bounds[i] } else { &m2.type_param_bounds[0] };
        // Handle when we're outside range — treat as empty
        let empty: Vec<u32> = Vec.new();
        let bounds1 = if i < m1.type_param_bounds.len() { b1 } else { &empty };
        let bounds2 = if i < m2.type_param_bounds.len() { b2 } else { &empty };
        // m1's bounds must be a superset of m2's bounds for this param
        if !bounds_superset(bounds1, bounds2) {
            all_at_least = false;
            break;
        }
        // Strictly more constrained if m1 has more bounds
        if bounds1.len() > bounds2.len() {
            some_strictly = true;
        }
    }
    all_at_least && some_strictly
}

// ============================================================
// Definition-Time Ambiguity Detection
// ============================================================

/// Checks if two types could potentially unify to the same concrete type.
/// Type variables (Param, Infer) unify with anything.
fn types_could_unify(a: type_intern.TyId, b: type_intern.TyId, depth: u32) -> bool {
    if depth >= max_dispatch_depth() {
        return false;
    }
    if a.index == b.index {
        return true;
    }
    let interner = type_intern.type_interner();
    let ka = interner.get(a);
    let kb = interner.get(b);
    match ka {
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        _ => {}
    }
    match kb {
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        _ => {}
    }
    match ka {
        &type_intern.InternedTypeKind.Primitive(p1) => {
            match kb {
                &type_intern.InternedTypeKind.Primitive(p2) => p1 == p2,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Never => {
            match kb {
                &type_intern.InternedTypeKind.Never => true,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Adt { def_id: d1, args: a1 } => {
            match kb {
                &type_intern.InternedTypeKind.Adt { def_id: d2, args: _ } => {
                    d1.index == d2.index
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Tuple(list1) => {
            match kb {
                &type_intern.InternedTypeKind.Tuple(list2) => {
                    let len1 = interner.ty_list_len(list1);
                    let len2 = interner.ty_list_len(list2);
                    if len1 != len2 { return false; }
                    for i in 0usize..len1 {
                        let e1 = interner.get_ty_list_element(list1, i);
                        let e2 = interner.get_ty_list_element(list2, i);
                        if !types_could_unify(e1, e2, depth + 1) {
                            return false;
                        }
                    }
                    true
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ref { inner: i1, mutable: m1 } => {
            match kb {
                &type_intern.InternedTypeKind.Ref { inner: i2, mutable: m2 } => {
                    m1 == m2 && types_could_unify(i1, i2, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ptr { inner: i1, mutable: m1 } => {
            match kb {
                &type_intern.InternedTypeKind.Ptr { inner: i2, mutable: m2 } => {
                    m1 == m2 && types_could_unify(i1, i2, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Array { element: e1, size: s1 } => {
            match kb {
                &type_intern.InternedTypeKind.Array { element: e2, size: s2 } => {
                    s1 == s2 && types_could_unify(e1, e2, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Slice { element: e1 } => {
            match kb {
                &type_intern.InternedTypeKind.Slice { element: e2 } => {
                    types_could_unify(e1, e2, depth + 1)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Fn { params: p1, ret: r1, effects: _ } => {
            match kb {
                &type_intern.InternedTypeKind.Fn { params: p2, ret: r2, effects: _ } => {
                    let len1 = interner.ty_list_len(p1);
                    let len2 = interner.ty_list_len(p2);
                    if len1 != len2 { return false; }
                    for i in 0usize..len1 {
                        let e1 = interner.get_ty_list_element(p1, i);
                        let e2 = interner.get_ty_list_element(p2, i);
                        if !types_could_unify(e1, e2, depth + 1) {
                            return false;
                        }
                    }
                    types_could_unify(r1, r2, depth + 1)
                }
                _ => false,
            }
        }
        _ => false,
    }
}

/// Checks if method m1 is strictly more specific than m2.
/// m1 is more specific if all its parameter types are subtypes of m2's
/// and at least one is strictly more specific (subtype but not supertype).
/// Per DISPATCH.md §7.3, effect rows serve as a tiebreaker: when types
/// are equal, fewer effects (pure <: effectful) is more specific.
pub fn is_more_specific(m1: &typeck_info.MethodInfo, m2: &typeck_info.MethodInfo) -> bool {
    if m1.param_tys.len() != m2.param_tys.len() {
        return false;
    }
    let mut all_at_least: bool = true;
    let mut some_strictly: bool = false;
    for i in 0usize..m1.param_tys.len() {
        let p1 = m1.param_tys[i];
        let p2 = m2.param_tys[i];
        // p1 must be a subtype of p2 (at least as specific)
        if !is_subtype_id(p1, p2, 0) {
            all_at_least = false;
            break;
        }
        // Strictly more specific if p1 <: p2 but not p2 <: p1
        if !is_subtype_id(p2, p1, 0) {
            some_strictly = true;
        }
    }
    if !all_at_least {
        return false;
    }
    if some_strictly {
        return true;
    }
    // Types are equal — use constraint specificity as tiebreaker (DISPATCH.md §3.7).
    // m1 is more specific if its type param bounds are a strict superset of m2's.
    if constraint_more_specific(m1, m2) {
        return true;
    }
    // Effect subsumption as final tiebreaker (DISPATCH.md §7.3).
    // m1 is more specific if its effect row is a strict subset of m2's.
    if effect_row_subsumes(&m1.effect_def_ids, &m2.effect_def_ids)
        && !effect_row_subsumes(&m2.effect_def_ids, &m1.effect_def_ids) {
        return true;
    }
    false
}

/// An ambiguity found between two methods.
pub struct AmbiguityInfo {
    /// Impl index of the first method.
    pub impl1_idx: usize,
    /// Method index within the first impl.
    pub method1_idx: usize,
    /// Impl index of the second method.
    pub impl2_idx: usize,
    /// Method index within the second impl.
    pub method2_idx: usize,
    /// Whether this is a diamond conflict (different traits).
    pub is_diamond: bool,
}

/// Checks all registered impls for definition-time dispatch ambiguity.
/// Returns a list of ambiguities found.
pub fn check_all_dispatch_ambiguity(
    impls: &Vec<typeck_info.ImplInfo>,
) -> Vec<AmbiguityInfo> {
    let mut results: Vec<AmbiguityInfo> = Vec.new();
    let sentinel: usize = 0xFFFFFFFF;

    // Build name-grouped index: parallel Vecs + linked list per name.
    let mut e_impl: Vec<usize> = Vec.new();
    let mut e_meth: Vec<usize> = Vec.new();
    let mut e_next: Vec<usize> = Vec.new();
    let mut name_heads: hashmap.HashMapU64U64 = hashmap.HashMapU64U64.new();
    let mut unique_names: Vec<u64> = Vec.new();

    for i in 0usize..impls.len() {
        for mi in 0usize..impls[i].methods.len() {
            let name_key = impls[i].methods[mi].name.index as u64;
            let idx = e_impl.len();
            let prev = name_heads.get(name_key);
            e_impl.push(i);
            e_meth.push(mi);
            match prev {
                Option.Some(h) => e_next.push(h as usize),
                Option.None => {
                    e_next.push(sentinel);
                    unique_names.push(name_key);
                },
            }
            name_heads.insert(name_key, idx as u64);
        }
    }

    // For each name group, compare all pairs
    for ni in 0usize..unique_names.len() {
        let head_opt = name_heads.get(unique_names[ni]);
        let head = match head_opt {
            Option.Some(h) => h as usize,
            Option.None => { continue; },
        };

        // Walk outer entry
        let mut a = head;
        while a != sentinel {
            let i = e_impl[a];
            let mi = e_meth[a];
            let m1 = &impls[i].methods[mi];

            // Walk inner entry (entries after a in the chain)
            let mut b = e_next[a];
            while b != sentinel {
                let j = e_impl[b];
                let mj = e_meth[b];
                let m2 = &impls[j].methods[mj];

                // Ensure consistent ordering (lower impl/method first)
                let i1 = if i < j || (i == j && mi < mj) { i } else { j };
                let mi1 = if i < j || (i == j && mi < mj) { mi } else { mj };
                let i2 = if i < j || (i == j && mi < mj) { j } else { i };
                let mi2 = if i < j || (i == j && mi < mj) { mj } else { mi };
                let ma = if i < j || (i == j && mi < mj) { m1 } else { m2 };
                let mb = if i < j || (i == j && mi < mj) { m2 } else { m1 };

                if types_match_self(impls[i1].self_ty, impls[i2].self_ty)
                    && ma.param_tys.len() == mb.param_tys.len()
                    && effect_rows_equal(&ma.effect_def_ids, &mb.effect_def_ids)
                    && !is_more_specific(ma, mb) && !is_more_specific(mb, ma) {
                    let mut overlap = true;
                    for k in 0usize..ma.param_tys.len() {
                        if !types_could_unify(ma.param_tys[k], mb.param_tys[k], 0) {
                            overlap = false;
                            break;
                        }
                    }
                    if overlap {
                        let diamond = impls[i1].is_trait_impl()
                            && impls[i2].is_trait_impl()
                            && impls[i1].trait_def_id_index != impls[i2].trait_def_id_index;
                        results.push(AmbiguityInfo {
                            impl1_idx: i1,
                            method1_idx: mi1,
                            impl2_idx: i2,
                            method2_idx: mi2,
                            is_diamond: diamond,
                        });
                    }
                }

                b = e_next[b];
            }
            a = e_next[a];
        }
    }
    results
}

/// A type instability found between two methods.
pub struct TypeInstabilityInfo {
    /// Impl index of the first method.
    pub impl1_idx: usize,
    /// Method index within the first impl.
    pub method1_idx: usize,
    /// Impl index of the second method.
    pub impl2_idx: usize,
    /// Method index within the second impl.
    pub method2_idx: usize,
}

/// Checks all registered impls for type stability violations (DISPATCH.md §4).
/// Two methods are type-unstable if their input types overlap but their
/// return types are incompatible — meaning the return type cannot be
/// determined from the input types alone at compile time.
pub fn check_type_stability(
    impls: &Vec<typeck_info.ImplInfo>,
) -> Vec<TypeInstabilityInfo> {
    let mut results: Vec<TypeInstabilityInfo> = Vec.new();
    let sentinel: usize = 0xFFFFFFFF;

    // Build name-grouped index: parallel Vecs + linked list per name.
    let mut e_impl: Vec<usize> = Vec.new();
    let mut e_meth: Vec<usize> = Vec.new();
    let mut e_next: Vec<usize> = Vec.new();
    let mut name_heads: hashmap.HashMapU64U64 = hashmap.HashMapU64U64.new();
    let mut unique_names: Vec<u64> = Vec.new();

    for i in 0usize..impls.len() {
        for mi in 0usize..impls[i].methods.len() {
            let name_key = impls[i].methods[mi].name.index as u64;
            let idx = e_impl.len();
            let prev = name_heads.get(name_key);
            e_impl.push(i);
            e_meth.push(mi);
            match prev {
                Option.Some(h) => e_next.push(h as usize),
                Option.None => {
                    e_next.push(sentinel);
                    unique_names.push(name_key);
                },
            }
            name_heads.insert(name_key, idx as u64);
        }
    }

    // For each name group, compare all pairs
    for ni in 0usize..unique_names.len() {
        let head_opt = name_heads.get(unique_names[ni]);
        let head = match head_opt {
            Option.Some(h) => h as usize,
            Option.None => { continue; },
        };

        let mut a = head;
        while a != sentinel {
            let i = e_impl[a];
            let mi = e_meth[a];
            let m1 = &impls[i].methods[mi];

            let mut b = e_next[a];
            while b != sentinel {
                let j = e_impl[b];
                let mj = e_meth[b];
                let m2 = &impls[j].methods[mj];

                let i1 = if i < j || (i == j && mi < mj) { i } else { j };
                let mi1 = if i < j || (i == j && mi < mj) { mi } else { mj };
                let i2 = if i < j || (i == j && mi < mj) { j } else { i };
                let mi2 = if i < j || (i == j && mi < mj) { mj } else { mi };
                let ma = if i < j || (i == j && mi < mj) { m1 } else { m2 };
                let mb = if i < j || (i == j && mi < mj) { m2 } else { m1 };

                if types_match_self(impls[i1].self_ty, impls[i2].self_ty)
                    && ma.param_tys.len() == mb.param_tys.len()
                    && effect_rows_equal(&ma.effect_def_ids, &mb.effect_def_ids) {
                    let mut overlap = true;
                    for k in 0usize..ma.param_tys.len() {
                        if !types_could_unify(ma.param_tys[k], mb.param_tys[k], 0) {
                            overlap = false;
                            break;
                        }
                    }
                    if overlap && !return_types_compatible(ma.return_ty, mb.return_ty) {
                        results.push(TypeInstabilityInfo {
                            impl1_idx: i1,
                            method1_idx: mi1,
                            impl2_idx: i2,
                            method2_idx: mi2,
                        });
                    }
                }

                b = e_next[b];
            }
            a = e_next[a];
        }
    }
    results
}

/// Checks if two return types are compatible for type stability.
/// Compatible means: structurally equal, or both are type parameters
/// (which will be determined by their input positions at call sites).
fn return_types_compatible(a: type_intern.TyId, b: type_intern.TyId) -> bool {
    if a.index == b.index {
        return true;
    }
    let interner = type_intern.type_interner();
    let ka = interner.get(a);
    let kb = interner.get(b);
    // Type params/infer are compatible with each other (both determined by inputs)
    let a_is_param = match ka {
        &type_intern.InternedTypeKind.Param(_) => true,
        &type_intern.InternedTypeKind.Infer(_) => true,
        _ => false,
    };
    let b_is_param = match kb {
        &type_intern.InternedTypeKind.Param(_) => true,
        &type_intern.InternedTypeKind.Infer(_) => true,
        _ => false,
    };
    if a_is_param && b_is_param {
        return true;
    }
    // A concrete type is compatible with a param (concrete specialization)
    if a_is_param || b_is_param {
        return true;
    }
    // Structural check: use the unification-oriented predicate `types_could_unify`
    // rather than strict `types_equal_id`. The two methods we're comparing come
    // from different impls, which instantiate their own type parameters with
    // DIFFERENT TyVarIds (even though they are structurally the same). Strict
    // equality on Param indices produces false positives — e.g., `Vec<T₁>` from
    // an inherent impl is compared against `Vec<T₂>` from a trait impl, both
    // structurally identical but with different Param indices. `types_could_unify`
    // correctly treats Adt/Adt same-def_id, same-arity as compatible regardless
    // of inner param identities.
    //
    // This fix closes E0603 ("type instability") for `impl<T> Clone for Vec<T>`
    // patterns where an inherent method and a trait impl method have the same
    // name and overlapping input types — the return types ARE compatible up to
    // alpha-renaming. See .tmp/BUGS_OPEN.md §E0603 for the investigation log.
    types_could_unify(a, b, 0)
}

/// Checks if two self types match for dispatch purposes.
/// This mirrors the logic in typeck.blood types_match_for_impl_id.
fn types_match_self(a: type_intern.TyId, b: type_intern.TyId) -> bool {
    if a.index == b.index {
        return true;
    }
    let interner = type_intern.type_interner();
    let ka = interner.get(a);
    let kb = interner.get(b);
    // Param/Infer match anything (generic impls)
    match ka {
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        _ => {}
    }
    match kb {
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        _ => {}
    }
    match ka {
        &type_intern.InternedTypeKind.Adt { def_id: d1, args: _ } => {
            match kb {
                &type_intern.InternedTypeKind.Adt { def_id: d2, args: _ } => d1.index == d2.index,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Primitive(p1) => {
            match kb {
                &type_intern.InternedTypeKind.Primitive(p2) => p1 == p2,
                _ => false,
            }
        }
        _ => false,
    }
}
