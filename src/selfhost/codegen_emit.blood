module blood.codegen_emit;

// Blood Self-Hosted Compiler - Codegen IR Emission Methods
//
// LLVM IR instruction emission methods for CodegenCtx.
// These are cross-file impl methods — the CodegenCtx struct is defined
// in codegen_ctx.blood, and these methods extend it with IR emission
// primitives (store, load, alloca, GEP, branch, call, switch, etc.).

mod codegen_ctx;
mod codegen_types;
mod common;

impl codegen_ctx.CodegenCtx {

    // ======== LLVM IR Emission Helpers ========

    /// Emits a function definition header.
    pub fn emit_fn_header(
        self: &mut codegen_ctx.CodegenCtx,
        name: &str,
        params: &Vec<(String, String)>,
        return_ty: &str,
    ) {
        self.write("define ");
        self.write(return_ty);
        self.write(" @");
        self.write(name);
        self.write("(");

        for i in 0usize..params.len() {
            if i > 0 {
                self.write(", ");
            }
            let param = &params[i];
            self.write_string(&param.0);
            self.write(" ");
            self.write_string(&param.1);
        }

        self.write(")");
        // Attach debug metadata if available
        if self.debug_subprogram_id > 0 {
            self.write(" !dbg !");
            self.write(codegen_types.format_u64(self.debug_subprogram_id as u64).as_str());
        }
        self.write(" {\n");
    }

    /// Emits a function definition footer.
    pub fn emit_fn_footer(self: &mut codegen_ctx.CodegenCtx) {
        self.write("}\n\n");
    }

    /// Emits a store instruction.
    pub fn emit_store(self: &mut codegen_ctx.CodegenCtx, ty: &str, val: &str, ptr: &str) {
        self.write_indent();
        self.write("store ");
        self.write(ty);
        self.write(" ");
        self.write(val);
        self.write(", ptr ");
        self.write(ptr);
        self.write(", align 8");
        self.end_insn();
    }

    /// Emits a getelementptr instruction.


    /// Emits a GEP instruction with CgName result and CgName ptr.
    pub fn emit_gep_cg(
        self: &mut codegen_ctx.CodegenCtx,
        result: &codegen_ctx.CgName,
        base_ty: &str,
        ptr: &codegen_ctx.CgName,
        indices: &Vec<String>,
    ) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = getelementptr ");
        self.write(base_ty);
        self.write(", ptr ");
        self.write_cgname(ptr);

        for i in 0usize..indices.len() {
            if i == 0 {
                self.write(", i64 ");
            } else {
                let ref idx = indices[i];
                let bytes = idx.as_bytes();
                if bytes.len() > 0 && bytes[0] == 37 {
                    self.write(", i64 ");
                } else {
                    self.write(", i32 ");
                }
            }
            self.write_string(&indices[i]);
        }

        self.write("\n");
    }

    /// Emits a ret instruction.
    pub fn emit_ret(self: &mut codegen_ctx.CodegenCtx, ty: &str, val: Option<&str>) {
        self.write_indent();
        self.write("ret ");
        self.write(ty);
        match val {
            Option.Some(v) => {
                self.write(" ");
                self.write(v);
            }
            Option.None => {}
        }
        self.end_insn();
    }

    /// Emits a label.
    pub fn emit_label(self: &mut codegen_ctx.CodegenCtx, label: &str) {
        self.write(label);
        self.write(":\n");
    }

    /// Emits an unreachable instruction.
    pub fn emit_unreachable(self: &mut codegen_ctx.CodegenCtx) {
        self.write_indent();
        self.write("unreachable");
        self.end_insn();
    }

    // ======== CgName-Based Emit Methods (Zero Allocation) ========

    /// Emits an alloca instruction using CgName for result.
    pub fn emit_alloca_cg(self: &mut codegen_ctx.CodegenCtx, result: &codegen_ctx.CgName, ty: &str) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = alloca ");
        self.write(ty);
        self.end_insn();
    }

    /// Defers an alloca instruction to be emitted in the entry block.
    /// Used for handler state shadow allocas that are created during basic block
    /// codegen but must dominate all uses (LLVM requires allocas in the entry block).
    pub fn defer_entry_alloca_cg(self: &mut codegen_ctx.CodegenCtx, result: &codegen_ctx.CgName, ty: &str) {
        let mut ir = common.make_string("  ");
        match result {
            &codegen_ctx.CgName.Temp(n) => {
                ir.push_str("%tmp");
                ir.push_str(codegen_types.format_u64(n as u64).as_str());
            }
            _ => {
                ir.push_str("%unknown");
            }
        }
        ir.push_str(" = alloca ");
        ir.push_str(ty);
        ir.push_str("\n");
        self.deferred_entry_allocas.push(ir);
    }

    /// Emits a load instruction using CgName for result and &str for ptr.
    pub fn emit_load_cg(self: &mut codegen_ctx.CodegenCtx, result: &codegen_ctx.CgName, ty: &str, ptr: &str) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = load ");
        self.write(ty);
        self.write(", ptr ");
        self.write(ptr);
        self.write(", align 8");
        self.end_insn();
    }

    /// Emits a load instruction using CgName for both result and ptr.
    pub fn emit_load_cg2(self: &mut codegen_ctx.CodegenCtx, result: &codegen_ctx.CgName, ty: &str, ptr: &codegen_ctx.CgName) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = load ");
        self.write(ty);
        self.write(", ptr ");
        self.write_cgname(ptr);
        self.write(", align 8");
        self.end_insn();
    }

    /// Emits a store instruction using CgName for val.
    pub fn emit_store_cg(self: &mut codegen_ctx.CodegenCtx, ty: &str, val: &codegen_ctx.CgName, ptr: &str) {
        self.write_indent();
        self.write("store ");
        self.write(ty);
        self.write(" ");
        self.write_cgname(val);
        self.write(", ptr ");
        self.write(ptr);
        self.write(", align 8");
        self.write("\n");
    }

    /// Emits a store instruction using CgName for both val and ptr.
    pub fn emit_store_cg2(self: &mut codegen_ctx.CodegenCtx, ty: &str, val: &codegen_ctx.CgName, ptr: &codegen_ctx.CgName) {
        self.write_indent();

        self.write("store ");
        self.write(ty);
        self.write(" ");
        self.write_cgname(val);
        self.write(", ptr ");
        self.write_cgname(ptr);
        self.write(", align 8");
        self.end_insn();
    }

    /// Emits a store with &str val and CgName ptr.
    pub fn emit_store_str_cg(self: &mut codegen_ctx.CodegenCtx, ty: &str, val: &str, ptr: &codegen_ctx.CgName) {
        self.write_indent();
        self.write("store ");
        self.write(ty);
        self.write(" ");
        self.write(val);
        self.write(", ptr ");
        self.write_cgname(ptr);
        self.write(", align 8");
        self.end_insn();
    }

    /// Emits a binary operation using CgName for result.
    pub fn emit_binop_cg(
        self: &mut codegen_ctx.CodegenCtx,
        result: &codegen_ctx.CgName,
        opcode: &str,
        ty: &str,
        left: &str,
        right: &str,
    ) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = ");
        self.write(opcode);
        self.write(" ");
        self.write(ty);
        self.write(" ");
        self.write(left);
        self.write(", ");
        self.write(right);
        self.end_insn();
    }

    /// Emits a binary operation using CgName for result and both operands.
    pub fn emit_binop_cg3(
        self: &mut codegen_ctx.CodegenCtx,
        result: &codegen_ctx.CgName,
        opcode: &str,
        ty: &str,
        left: &codegen_ctx.CgName,
        right: &codegen_ctx.CgName,
    ) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = ");
        self.write(opcode);
        self.write(" ");
        self.write(ty);
        self.write(" ");
        self.write_cgname(left);
        self.write(", ");
        self.write_cgname(right);
        self.end_insn();
    }

    /// Emits an icmp instruction using CgName for result.
    pub fn emit_icmp_cg(
        self: &mut codegen_ctx.CodegenCtx,
        result: &codegen_ctx.CgName,
        cond: &str,
        ty: &str,
        left: &str,
        right: &str,
    ) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = icmp ");
        self.write(cond);
        self.write(" ");
        self.write(ty);
        self.write(" ");
        self.write(left);
        self.write(", ");
        self.write(right);
        self.end_insn();
    }

    /// Emits an icmp instruction using CgName for result and left operand.
    pub fn emit_icmp_cg2(
        self: &mut codegen_ctx.CodegenCtx,
        result: &codegen_ctx.CgName,
        cond: &str,
        ty: &str,
        left: &codegen_ctx.CgName,
        right: &str,
    ) {
        self.write_indent();
        self.write_cgname(result);
        self.write(" = icmp ");
        self.write(cond);
        self.write(" ");
        self.write(ty);
        self.write(" ");
        self.write_cgname(left);
        self.write(", ");
        self.write(right);
        self.end_insn();
    }

    /// Emits an fcmp instruction using CgName for result.
    pub fn emit_fcmp_cg(
        self: &mut codegen_ctx.CodegenCtx,
        result: &codegen_ctx.CgName,
        cond: &str,
        ty: &str,
        left: &str,
        right: &str,
    ) {
        self.write_indent();
