module blood.derive;

// Blood Self-Hosted Compiler - Derive Macro Expansion
//
// Implements `#[derive(Trait1, Trait2, ...)]` attribute expansion.
// For each derive request, synthesizes an AST-level `ImplBlock` and feeds
// it through the normal `lower_impl_decl` pipeline so it lowers, typechecks,
// and codegens identically to a user-written impl.
//
// Synthetic spans: AST nodes carry `SpannedSymbol`s whose `span` must point
// to source bytes equal to the expected identifier. Since derive produces
// names that don't appear in source (e.g., "hash", "self", "state"), we
// append a fixed block of identifier strings to `ctx.source` once per
// module, record the offsets in `SyntheticSpans`, and use those spans in
// the synthesized AST.
//
// Supported derives (S67 Phase B):
// - Hash: fn hash(self: &Self, state: &mut u64) — per-field self.F.hash(state)
// - PartialEq: fn eq(self: &Self, other: &Self) -> bool — ANDed field equality

mod common;
mod hir;
mod hir_def;
mod hir_item;
mod hir_lower_ctx;
mod ast;

// ============================================================
// Derive Kinds
// ============================================================

/// The kind of trait to derive.
pub enum DeriveKind {
    /// Clone: fn clone(&self) -> Self
    Clone,
    /// Debug: fn fmt(&self, ...) -> ...
    Debug,
    /// PartialEq: fn eq(&self, other: &Self) -> bool
    PartialEq,
    /// Eq: marker trait (requires PartialEq)
    Eq,
    /// Default: fn default() -> Self
    Default,
    /// Hash: fn hash(&self, state: &mut u64)
    Hash,
}

impl DeriveKind {
    /// Returns the trait name.
    pub fn trait_name(self: &DeriveKind) -> &str {
        match self {
            &DeriveKind.Clone => "Clone",
            &DeriveKind.Debug => "Debug",
            &DeriveKind.PartialEq => "PartialEq",
            &DeriveKind.Eq => "Eq",
            &DeriveKind.Default => "Default",
            &DeriveKind.Hash => "Hash",
        }
    }

    /// Parses a derive kind from a name string.
    pub fn from_name(name: &str) -> Option<DeriveKind> {
        if str_equals(name, "Clone") {
            return Option.Some(DeriveKind.Clone);
        }
        if str_equals(name, "Debug") {
            return Option.Some(DeriveKind.Debug);
        }
        if str_equals(name, "PartialEq") {
            return Option.Some(DeriveKind.PartialEq);
        }
        if str_equals(name, "Eq") {
            return Option.Some(DeriveKind.Eq);
        }
        if str_equals(name, "Default") {
            return Option.Some(DeriveKind.Default);
        }
        if str_equals(name, "Hash") {
            return Option.Some(DeriveKind.Hash);
        }
        Option.None
    }
}

/// Byte-wise string equality (matching the convention used elsewhere in the
/// compiler; `==` on `&str` is not yet a supported operation).
fn str_equals(a: &str, b: &str) -> bool {
    if a.len() != b.len() {
        return false;
    }
    let ab = a.as_bytes();
    let bb = b.as_bytes();
    let mut i: usize = 0;
    while i < a.len() {
        if ab[i] != bb[i] {
            return false;
        }
        i += 1;
    }
    true
}

// ============================================================
// Derive Request
// ============================================================

/// A request to derive a trait implementation for a given type.
pub struct DeriveRequest {
    /// The kind of trait to derive.
    pub kind: DeriveKind,
    /// The DefId of the target struct/enum.
    pub target_def: hir_def.DefId,
    /// The name span of the target type (used as `self_ty` name).
    pub target_name_span: common.Span,
    /// The span of the `#[derive(...)]` attribute (used for diagnostic locations).
    pub span: common.Span,
}

// ============================================================
// Synthetic Ident Table
// ============================================================

/// A single synthetic identifier: both a span that `span_to_string`
/// returns the expected text for, AND a pre-interned HIR Symbol.
///
/// The symbol is needed because some lowering paths read
/// `SpannedSymbol.symbol` directly (e.g., `is_self_param_name` checks
/// `symbol.index == 19` for "self"). The parser-interner symbol index
/// in synthesized AST is meaningless, so we pre-intern via HIR and
/// use that index.
pub struct SynIdent {
    pub sym: common.Symbol,
    pub span: common.Span,
}

/// Table of pre-interned identifiers needed by synthesized AST. Lazily
/// initialized via `ensure_synth_spans` on first use per lowering context.
///
/// The `left_payload_idents` and `right_payload_idents` pools hold the per-field
/// ref-binding names used by enum tuple-variant pattern synthesis. Hash uses
/// only the left pool (one set of ref bindings per variant). PartialEq uses both
/// pools (self-side and other-side bindings in the same pattern).
/// Pool size is 8, capping supported tuple-variant arity at 8 fields.
pub struct SyntheticSpans {
    pub hash_method: SynIdent,
    pub eq_method: SynIdent,
    pub clone_method: SynIdent,
    pub default_method: SynIdent,
    pub self_id: SynIdent,
    pub other_id: SynIdent,
    pub state_id: SynIdent,
    pub self_ty: SynIdent,
    pub u64_ty: SynIdent,
    pub bool_ty: SynIdent,
    pub hash_trait: SynIdent,
    pub partialeq_trait: SynIdent,
    pub eq_trait: SynIdent,
    pub clone_trait: SynIdent,
    pub default_trait: SynIdent,
    pub left_payload_idents: Vec<SynIdent>,
    pub right_payload_idents: Vec<SynIdent>,
    pub initialized: bool,
}

impl SyntheticSpans {
    /// Create an uninitialized table. Fields hold zero values until
    /// `ensure_synth_spans` runs.
    pub fn zero() -> SyntheticSpans {
        let z_ident = SynIdent {
            sym: common.Symbol { index: 0 },
            span: common.Span { start: 0, end: 0, line: 0, column: 0 },
        };
        SyntheticSpans {
            hash_method: z_ident,
            eq_method: z_ident,
            clone_method: z_ident,
            default_method: z_ident,
            self_id: z_ident,
            other_id: z_ident,
            state_id: z_ident,
            self_ty: z_ident,
            u64_ty: z_ident,
            bool_ty: z_ident,
            hash_trait: z_ident,
            partialeq_trait: z_ident,
            eq_trait: z_ident,
            clone_trait: z_ident,
            default_trait: z_ident,
            left_payload_idents: Vec.new(),
            right_payload_idents: Vec.new(),
            initialized: false,
        }
    }
}

// MAX_TUPLE_VARIANT_ARITY = 8 (matches payload-pool size in SyntheticSpans).
// Enums with a tuple variant exceeding this are skipped by the enum derive
// expanders. Record variants are unsupported regardless of field count.

/// Extends `ctx.source` with identifier text and pre-interns each name in
/// the HIR interner. Idempotent.
pub fn ensure_synth_spans(
    ctx: &mut hir_lower_ctx.LoweringCtx,
    spans: &mut SyntheticSpans,
) {
    if spans.initialized {
        return;
    }
    spans.hash_method = register_syn(ctx, "hash");
    spans.eq_method = register_syn(ctx, "eq");
    spans.clone_method = register_syn(ctx, "clone");
    spans.default_method = register_syn(ctx, "default");
    spans.self_id = register_syn(ctx, "self");
    spans.other_id = register_syn(ctx, "other");
    spans.state_id = register_syn(ctx, "state");
    spans.self_ty = register_syn(ctx, "Self");
    spans.u64_ty = register_syn(ctx, "u64");
    spans.bool_ty = register_syn(ctx, "bool");
    spans.hash_trait = register_syn(ctx, "Hash");
    spans.partialeq_trait = register_syn(ctx, "PartialEq");
    spans.eq_trait = register_syn(ctx, "Eq");
    spans.clone_trait = register_syn(ctx, "Clone");
    spans.default_trait = register_syn(ctx, "Default");
    // Pre-intern 8 left-side and 8 right-side payload binding names for enum
    // tuple-variant patterns: __l0..__l7, __r0..__r7. Cap matches MAX_TUPLE
    // _VARIANT_ARITY. PartialEq uses both sides; Hash uses only left.
    spans.left_payload_idents.push(register_syn(ctx, "__l0"));
    spans.left_payload_idents.push(register_syn(ctx, "__l1"));
    spans.left_payload_idents.push(register_syn(ctx, "__l2"));
    spans.left_payload_idents.push(register_syn(ctx, "__l3"));
    spans.left_payload_idents.push(register_syn(ctx, "__l4"));
    spans.left_payload_idents.push(register_syn(ctx, "__l5"));
    spans.left_payload_idents.push(register_syn(ctx, "__l6"));
    spans.left_payload_idents.push(register_syn(ctx, "__l7"));
    spans.right_payload_idents.push(register_syn(ctx, "__r0"));
    spans.right_payload_idents.push(register_syn(ctx, "__r1"));
    spans.right_payload_idents.push(register_syn(ctx, "__r2"));
    spans.right_payload_idents.push(register_syn(ctx, "__r3"));
    spans.right_payload_idents.push(register_syn(ctx, "__r4"));
    spans.right_payload_idents.push(register_syn(ctx, "__r5"));
    spans.right_payload_idents.push(register_syn(ctx, "__r6"));
    spans.right_payload_idents.push(register_syn(ctx, "__r7"));
    spans.initialized = true;
}

fn register_syn(ctx: &mut hir_lower_ctx.LoweringCtx, s: &str) -> SynIdent {
    let span = append_syn_string(&mut ctx.source, s);
    let sym = ctx.intern(s);
    SynIdent { sym: sym, span: span }
}

/// Appends `s` followed by a space separator to `source` and returns the
/// span covering `s` (exclusive of the separator).
fn append_syn_string(source: &mut String, s: &str) -> common.Span {
    let start = source.len();
    source.push_str(s);
    let end = source.len();
    source.push(' ');
    common.Span { start: start, end: end, line: 0, column: 0 }
}

// ============================================================
// AST Synthesis Helpers
// ============================================================

/// Build a SpannedSymbol from a pre-interned SynIdent.
fn syn_sym(ident: &SynIdent) -> common.SpannedSymbol {
    common.SpannedSymbol { symbol: ident.sym, span: ident.span }
}

/// Build a SpannedSymbol from a raw source span. Used for struct-field names
/// whose spans already exist in source and don't need pre-interning.
/// HIR-level re-interning via `span_to_string` + `ctx.intern` handles the
/// symbol resolution; the index stored here is irrelevant past lowering.
fn syn_sym_span(span: common.Span) -> common.SpannedSymbol {
    common.SpannedSymbol {
        symbol: common.Symbol { index: 0 },
        span: span,
    }
}

/// Build a single-segment type path from a pre-interned SynIdent: `Name`.
fn syn_path_type(ident: &SynIdent, overall_span: common.Span) -> ast.Type {
    let seg = ast.TypePathSegment {
        name: syn_sym(ident),
        args: Option.None,
    };
    let mut segs: Vec<ast.TypePathSegment> = Vec.new();
    segs.push(seg);
    let path = ast.TypePath { segments: segs, span: overall_span };
    ast.Type { kind: ast.TypeKind.Path(path), span: overall_span }
}

/// Build a single-segment type path from a raw source span (the target
/// type's declared name). The span is later re-interned by `lower_type`.
fn syn_type_path_from_span(name_span: common.Span, overall_span: common.Span) -> ast.TypePath {
    let seg = ast.TypePathSegment {
        name: syn_sym_span(name_span),
        args: Option.None,
    };
    let mut segs: Vec<ast.TypePathSegment> = Vec.new();
    segs.push(seg);
    ast.TypePath { segments: segs, span: overall_span }
}

/// Build a type path segment from a raw span (struct target name). The
/// source span directly matches the struct's declared name and is later
/// re-interned by `lower_type`.
fn syn_path_type_from_span(name_span: common.Span, overall_span: common.Span) -> ast.Type {
    let path = syn_type_path_from_span(name_span, overall_span);
    ast.Type { kind: ast.TypeKind.Path(path), span: overall_span }
}

/// Build `&inner` or `&mut inner`.
fn syn_ref_type(inner: ast.Type, is_mut: bool, span: common.Span) -> ast.Type {
    ast.Type {
        kind: ast.TypeKind.Reference {
            lifetime: Option.None,
            is_mut: is_mut,
            inner: Box.new(inner),
        },
        span: span,
    }
}

/// Build a simple identifier pattern `name` (not by-ref, not mutable). The
/// pattern's span must equal the identifier's span because
/// `extract_param_symbol_from_ast` reads `pattern.span` (not
/// `pattern.name.span`) to recover the identifier text during body lowering.
fn syn_pat_ident(ident: &SynIdent) -> ast.Pattern {
    ast.Pattern {
        kind: ast.PatternKind.Ident {
            by_ref: false,
            is_mut: false,
            name: syn_sym(ident),
            subpattern: Option.None,
        },
        span: ident.span,
    }
}

/// Build a function parameter `name: ty`.
fn syn_param(ident: &SynIdent, ty: ast.Type, span: common.Span) -> ast.Param {
    ast.Param {
        qualifier: Option.None,
        pattern: syn_pat_ident(ident),
        ty: ty,
        span: span,
    }
}

/// Build a single-segment path expression from a pre-interned SynIdent: `name`.
fn syn_path_expr(ident: &SynIdent, span: common.Span) -> ast.Expr {
    let seg = ast.ExprPathSegment {
        name: syn_sym(ident),
        args: Option.None,
    };
    let mut segs: Vec<ast.ExprPathSegment> = Vec.new();
    segs.push(seg);
    let path = ast.ExprPath { segments: segs, span: span };
    ast.Expr { kind: ast.ExprKind.Path(path), span: span }
}

/// Build a field access expression: `base.field`. The field span is read
/// directly from the struct's field declaration and re-interned during
/// lowering, so no pre-interned symbol is required.
fn syn_field_expr(base: ast.Expr, field_name_span: common.Span, span: common.Span) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.Field {
            base: Box.new(base),
            field: ast.FieldAccess.Named(syn_sym_span(field_name_span)),
        },
        span: span,
    }
}

/// Build a method call: `receiver.method(args...)`.
fn syn_method_call(
    receiver: ast.Expr,
    method_ident: &SynIdent,
    args: Vec<ast.CallArg>,
    span: common.Span,
) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.MethodCall {
            receiver: Box.new(receiver),
            method: syn_sym(method_ident),
            type_args: Option.None,
            args: args,
        },
        span: span,
    }
}

/// Build a positional call argument with no name label.
fn syn_call_arg(val: ast.Expr, span: common.Span) -> ast.CallArg {
    ast.CallArg { name: Option.None, val: val, span: span }
}

/// Build a function/variant call: `callee(args...)`.
fn syn_call_expr(callee: ast.Expr, args: Vec<ast.CallArg>, span: common.Span) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.Call {
            callee: Box.new(callee),
            args: args,
        },
        span: span,
    }
}

/// Build a two-segment path expression `EnumName.VariantName` from raw
/// source spans. Used as a unit-variant constructor expression
/// (`Color.Red`) and as the callee for tuple-variant constructors
/// (`Color.Gray(...)`). HIR's path resolver re-interns by span; the
/// stored Symbol indices are placeholder zeros.
fn syn_variant_path_expr(
    enum_name_span: common.Span,
    variant_name_span: common.Span,
    overall_span: common.Span,
) -> ast.Expr {
    let seg_enum = ast.ExprPathSegment {
        name: syn_sym_span(enum_name_span),
        args: Option.None,
    };
    let seg_variant = ast.ExprPathSegment {
        name: syn_sym_span(variant_name_span),
        args: Option.None,
    };
    let mut segs: Vec<ast.ExprPathSegment> = Vec.new();
    segs.push(seg_enum);
    segs.push(seg_variant);
    let path = ast.ExprPath { segments: segs, span: overall_span };
    ast.Expr { kind: ast.ExprKind.Path(path), span: overall_span }
}

/// Build a binary expression `left op right`.
fn syn_binary(op: common.BinOp, left: ast.Expr, right: ast.Expr, span: common.Span) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.Binary {
            operator: op,
            left: Box.new(left),
            right: Box.new(right),
        },
        span: span,
    }
}

/// Build a boolean literal `true` or `false`.
fn syn_bool_lit(value: bool, span: common.Span) -> ast.Expr {
    let lit = ast.Literal {
        kind: ast.LiteralKind.Bool(value),
        span: span,
    };
    ast.Expr { kind: ast.ExprKind.Literal(lit), span: span }
}

/// Build an integer literal with an explicit numeric suffix, e.g. `42u32`.
fn syn_int_lit_suffixed(val: u128, suffix: ast.IntSuffix, span: common.Span) -> ast.Expr {
    let lit = ast.Literal {
        kind: ast.LiteralKind.Int { val: val, suffix: Option.Some(suffix) },
        span: span,
    };
    ast.Expr { kind: ast.ExprKind.Literal(lit), span: span }
}

/// Build a float literal with an explicit suffix, e.g. `0.0f32`. The value
/// is passed in its IEEE-754 bit representation (matching ast.LiteralKind.Float).
fn syn_float_lit_suffixed(bits: u64, suffix: ast.FloatSuffix, span: common.Span) -> ast.Expr {
    let lit = ast.Literal {
        kind: ast.LiteralKind.Float { bits: bits, suffix: Option.Some(suffix) },
        span: span,
    };
    ast.Expr { kind: ast.ExprKind.Literal(lit), span: span }
}

/// Build a character literal, e.g. `'\0'`.
fn syn_char_lit(c: char, span: common.Span) -> ast.Expr {
    let lit = ast.Literal {
        kind: ast.LiteralKind.Char(c),
        span: span,
    };
    ast.Expr { kind: ast.ExprKind.Literal(lit), span: span }
}

/// Build a tuple literal expression `(e0, e1, ...)`.
fn syn_tuple_expr(fields: Vec<ast.Expr>, span: common.Span) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.Tuple(fields),
        span: span,
    }
}

/// Build a record-struct literal expression `Path { ... }` wrapping an
/// already-constructed Vec of RecordExprFields. Caller is responsible for
/// building each field (avoids having to move `ast.Expr` out of an indexed
/// Vec, which Blood's borrow semantics don't permit element-wise).
fn syn_record_expr(
    path: ast.TypePath,
    record_fields: Vec<ast.RecordExprField>,
    span: common.Span,
) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.Record {
            path: Option.Some(path),
            fields: record_fields,
            base: Option.None,
        },
        span: span,
    }
}

/// Build a block expression `{ stmts...; trailing }` usable as an Expr.
fn syn_block_expr(
    statements: Vec<ast.Statement>,
    trailing: Option<ast.Expr>,
    span: common.Span,
) -> ast.Expr {
    let trailing_boxed = match trailing {
        Option.Some(e) => Option.Some(Box.new(e)),
        Option.None => Option.None,
    };
    let block = ast.Block {
        statements: statements,
        expr: trailing_boxed,
        span: span,
    };
    ast.Expr { kind: ast.ExprKind.Block(block), span: span }
}

/// Build a match expression `match scrutinee { arms... }`.
fn syn_match_expr(
    scrutinee: ast.Expr,
    arms: Vec<ast.MatchArm>,
    span: common.Span,
) -> ast.Expr {
    ast.Expr {
        kind: ast.ExprKind.Match {
            scrutinee: Box.new(scrutinee),
            arms: arms,
        },
        span: span,
    }
}

/// Build a match arm `pattern => body,` (no guard).
fn syn_match_arm(
    pattern: ast.Pattern,
    body: ast.Expr,
    span: common.Span,
) -> ast.MatchArm {
    ast.MatchArm {
        pattern: pattern,
        guard: Option.None,
        body: body,
        span: span,
    }
}

// ============================================================
// Default-expansion Helpers
// ============================================================

/// If `name_str` is a recognized primitive type with a canonical zero /
/// empty default, returns a literal expression for that default.
///
/// Primitive-typed expression paths (`i32.default()`, `bool.default()`)
/// do not resolve in Blood's HIR lowering because primitive names are
/// not registered as expression-path targets. The derive expander
/// bypasses that by emitting the literal directly. The stdlib
/// `impl Default for <primitive>` blocks remain callable from
/// user-written generic code with a `T: Default` bound.
///
/// Returns `None` for non-primitive names (user types, String) so the
/// caller can fall back to a `FieldTypeName.default()` call.
fn primitive_default_expr(name_str: &str, span: common.Span) -> Option<ast.Expr> {
    if str_equals(name_str, "bool") {
        return Option.Some(syn_bool_lit(false, span));
    }
    if str_equals(name_str, "char") {
        return Option.Some(syn_char_lit('\0', span));
    }
    if str_equals(name_str, "i8") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.I8, span));
    }
    if str_equals(name_str, "i16") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.I16, span));
    }
    if str_equals(name_str, "i32") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.I32, span));
    }
    if str_equals(name_str, "i64") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.I64, span));
    }
    if str_equals(name_str, "i128") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.I128, span));
    }
    if str_equals(name_str, "isize") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.Isize, span));
    }
    if str_equals(name_str, "u8") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.U8, span));
    }
    if str_equals(name_str, "u16") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.U16, span));
    }
    if str_equals(name_str, "u32") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.U32, span));
    }
    if str_equals(name_str, "u64") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.U64, span));
    }
    if str_equals(name_str, "u128") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.U128, span));
    }
    if str_equals(name_str, "usize") {
        return Option.Some(syn_int_lit_suffixed(0u128, ast.IntSuffix.Usize, span));
    }
    if str_equals(name_str, "f32") {
        return Option.Some(syn_float_lit_suffixed(0u64, ast.FloatSuffix.F32, span));
    }
    if str_equals(name_str, "f64") {
        return Option.Some(syn_float_lit_suffixed(0u64, ast.FloatSuffix.F64, span));
    }
    Option.None
}

/// Synthesize `FieldTypeName.default()` for a non-primitive path-shaped
/// field type. The callee is built as a two-segment expression path
/// `FieldTypeName.default`, analogous to `syn_variant_path_expr`, then
/// applied with no arguments.
///
/// Returns `None` for non-Path types (references, arrays, slices,
/// tuples, function types, etc.) and for zero-segment paths — those
/// cases bubble up and cause the overall Default expansion to skip with
/// an E0901 diagnostic.
fn syn_field_default_call(
    field_ty: &ast.Type,
    default_method: &SynIdent,
    attr_span: common.Span,
) -> Option<ast.Expr> {
    match &field_ty.kind {
        &ast.TypeKind.Path(ref tp) => {
            if tp.segments.len() == 0usize {
                return Option.None;
            }
            let first_seg_name_span = tp.segments[0].name.span;
            let callee = syn_variant_path_expr(
                first_seg_name_span,
                default_method.span,
                attr_span,
            );
            Option.Some(syn_call_expr(callee, Vec.new(), attr_span))
        }
        _ => Option.None,
    }
}

/// Build the default expression for a single field. Primitive-typed
/// fields get a literal zero / `false` / `'\0'`; path-typed fields get
/// a `TypeName.default()` call; everything else returns `None` (which
/// propagates as an expansion failure).
fn build_field_default_expr(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    field_ty: &ast.Type,
    attr_span: common.Span,
) -> Option<ast.Expr> {
    match &field_ty.kind {
        &ast.TypeKind.Path(ref tp) => {
            if tp.segments.len() == 1usize {
                let first_seg_name_span = tp.segments[0].name.span;
                let name_str = ctx.span_to_string(first_seg_name_span);
                let prim = primitive_default_expr(name_str.as_str(), attr_span);
                match prim {
                    Option.Some(_) => return prim,
                    Option.None => {}
                }
            }
        }
        _ => {}
    }
    syn_field_default_call(field_ty, &spans.default_method, attr_span)
}

// ============================================================
// Pattern Synthesis Helpers
// ============================================================

/// Build a wildcard pattern `_`.
fn syn_pat_wildcard(span: common.Span) -> ast.Pattern {
    ast.Pattern { kind: ast.PatternKind.Wildcard, span: span }
}

/// Build a reference pattern `&inner` or `&mut inner`.
fn syn_pat_ref(inner: ast.Pattern, is_mut: bool, span: common.Span) -> ast.Pattern {
    ast.Pattern {
        kind: ast.PatternKind.Ref {
            is_mut: is_mut,
            inner: Box.new(inner),
        },
        span: span,
    }
}

/// Build a tuple pattern `(p0, p1, ...)`.
fn syn_pat_tuple(fields: Vec<ast.Pattern>, span: common.Span) -> ast.Pattern {
    ast.Pattern {
        kind: ast.PatternKind.Tuple {
            fields: fields,
            rest_pos: Option.None,
        },
        span: span,
    }
}

/// Build a by-ref identifier pattern `ref name` (immutable binding).
/// The pattern's outer span equals the identifier's span so that
/// `extract_param_symbol_from_ast` (which reads `pattern.span` rather than
/// `pattern.name.span`) recovers the correct identifier text.
fn syn_pat_ident_by_ref(ident: &SynIdent) -> ast.Pattern {
    ast.Pattern {
        kind: ast.PatternKind.Ident {
            by_ref: true,
            is_mut: false,
            name: syn_sym(ident),
            subpattern: Option.None,
        },
        span: ident.span,
    }
}

/// Build a two-segment TypePath `EnumName.VariantName` using raw source
/// spans. The HIR `lower_type_path` re-interns via `span_to_string`, so the
/// stored Symbol indices are irrelevant and filled with zero.
fn syn_variant_type_path(
    enum_name_span: common.Span,
    variant_name_span: common.Span,
    overall_span: common.Span,
) -> ast.TypePath {
    let seg_enum = ast.TypePathSegment {
        name: syn_sym_span(enum_name_span),
        args: Option.None,
    };
    let seg_variant = ast.TypePathSegment {
        name: syn_sym_span(variant_name_span),
        args: Option.None,
    };
    let mut segs: Vec<ast.TypePathSegment> = Vec.new();
    segs.push(seg_enum);
    segs.push(seg_variant);
    ast.TypePath { segments: segs, span: overall_span }
}

/// Build a single-segment path pattern for a unit enum variant:
/// `EnumName.VariantName`.
fn syn_pat_variant_path(
    enum_name_span: common.Span,
    variant_name_span: common.Span,
    overall_span: common.Span,
) -> ast.Pattern {
    let path = syn_variant_type_path(enum_name_span, variant_name_span, overall_span);
    ast.Pattern { kind: ast.PatternKind.Path(path), span: overall_span }
}

/// Build a tuple-struct pattern for a tuple enum variant:
/// `EnumName.VariantName(p0, p1, ...)`.
fn syn_pat_variant_tuple_struct(
    enum_name_span: common.Span,
    variant_name_span: common.Span,
    field_patterns: Vec<ast.Pattern>,
    overall_span: common.Span,
) -> ast.Pattern {
    let path = syn_variant_type_path(enum_name_span, variant_name_span, overall_span);
    ast.Pattern {
        kind: ast.PatternKind.TupleStruct {
            path: path,
            fields: field_patterns,
            rest_pos: Option.None,
        },
        span: overall_span,
    }
}

// ============================================================
// Attribute Extraction
// ============================================================

/// Returns true if the attribute's single-segment path spells "derive".
fn is_derive_attribute(ctx: &hir_lower_ctx.LoweringCtx, attr: &ast.Attribute) -> bool {
    if attr.path.len() != 1 {
        return false;
    }
    let path_str = ctx.span_to_string(attr.path[0].span);
    str_equals(path_str.as_str(), "derive")
}

/// Extracts derive requests from an ADT (struct or enum) declaration's
/// attributes. Each `#[derive(Trait1, Trait2)]` yields one request per
/// listed trait. Unknown trait names emit E0102 at the name's span
/// listing the supported derive kinds.
pub fn extract_derive_requests(
    ctx: &mut hir_lower_ctx.LoweringCtx,
    attrs: &Vec<ast.Attribute>,
    target_def: hir_def.DefId,
    target_name_span: common.Span,
) -> Vec<DeriveRequest> {
    let mut requests: Vec<DeriveRequest> = Vec.new();

    for i in 0usize..attrs.len() {
        let attr = &attrs[i];
        if !is_derive_attribute(ctx, attr) {
            continue;
        }
        match &attr.args {
            &Option.Some(ref args) => {
                match args {
                    &ast.AttributeArgs.List(ref arg_list) => {
                        for j in 0usize..arg_list.len() {
                            match &arg_list[j] {
                                &ast.AttributeArg.Ident(ref name) => {
                                    let name_str = ctx.span_to_string(name.span);
                                    let kind_opt = DeriveKind.from_name(name_str.as_str());
                                    match kind_opt {
                                        Option.Some(kind) => {
                                            requests.push(DeriveRequest {
                                                kind: kind,
                                                target_def: target_def,
                                                target_name_span: target_name_span,
                                                span: attr.span,
                                            });
                                        }
                                        Option.None => {
                                            let mut msg = String.new();
                                            msg.push_str("unknown derive trait `");
                                            msg.push_str(name_str.as_str());
                                            msg.push_str("` (supported: Clone, Debug, PartialEq, Eq, Default, Hash)");
                                            ctx.error(hir.DiagnosticCode.E0102, msg, name.span);
                                        }
                                    }
                                }
                                &ast.AttributeArg.KeyValue { key: _, val: _ } => {}
                                &ast.AttributeArg.Lit(_) => {}
                                &ast.AttributeArg.Call { name: _, arg: _ } => {}
                            }
                        }
                    }
                    &ast.AttributeArgs.Eq(_) => {}
                }
            }
            &Option.None => {}
        }
    }

    requests
}

// ============================================================
// Expansion
// ============================================================

/// Copy the spans of all record-struct field names. Returns `None` if the
/// target isn't a record struct (tuple/unit/enum support deferred).
fn collect_record_field_spans(
    ctx: &hir_lower_ctx.LoweringCtx,
    target_def: hir_def.DefId,
) -> Option<Vec<common.Span>> {
    match ctx.get_item(target_def) {
        Option.Some(entry) => {
            match &entry.item.kind {
                &hir_item.ItemKind.Struct(ref sd) => {
                    match &sd.body {
                        &hir_item.StructBody.Record(ref fs) => {
                            let mut spans: Vec<common.Span> = Vec.new();
                            for i in 0usize..fs.len() {
                                spans.push(fs[i].name.span);
                            }
                            Option.Some(spans)
                        }
                        &hir_item.StructBody.Tuple(_) => Option.None,
                        &hir_item.StructBody.Unit => Option.None,
                    }
                }
                _ => Option.None,
            }
        }
        Option.None => Option.None,
    }
}

// ============================================================
// Enum Variant Info
// ============================================================

/// Derive-visible classification of an enum variant's body. Record-variant
/// derive support is deferred; `collect_enum_variant_info` returns `None` if
/// any variant is a record.
pub enum VariantKindInfo {
    Unit,
    Tuple(usize),
}

/// Per-variant info needed to synthesize enum derive bodies.
pub struct VariantInfo {
    /// Span of the variant's declared name (used in synthesized patterns).
    pub name_span: common.Span,
    /// Discriminant index, used as the u32 input to Hash for each arm.
    pub discriminant: u32,
    /// Variant body classification.
    pub kind: VariantKindInfo,
}

/// Collect variant info from an enum HIR item. Returns `None` if:
/// - Target is not an enum.
/// - Any variant is a record variant (deferred).
/// - Any tuple variant exceeds `MAX_TUPLE_VARIANT_ARITY` fields.
fn collect_enum_variant_info(
    ctx: &hir_lower_ctx.LoweringCtx,
    target_def: hir_def.DefId,
) -> Option<Vec<VariantInfo>> {
    match ctx.get_item(target_def) {
        Option.Some(entry) => {
            match &entry.item.kind {
                &hir_item.ItemKind.Enum(ref ed) => {
                    let mut info: Vec<VariantInfo> = Vec.with_capacity(ed.variants.len());
                    for i in 0usize..ed.variants.len() {
                        let v = &ed.variants[i];
                        let kind_info = match &v.kind {
                            &hir_item.VariantKind.Unit => VariantKindInfo.Unit,
                            &hir_item.VariantKind.Tuple(ref tys) => {
                                if tys.len() > 8 {
                                    return Option.None;
                                }
                                VariantKindInfo.Tuple(tys.len())
                            }
                            &hir_item.VariantKind.Record(_) => return Option.None,
                        };
                        info.push(VariantInfo {
                            name_span: v.name.span,
                            discriminant: v.discriminant,
                            kind: kind_info,
                        });
                    }
                    Option.Some(info)
                }
                _ => Option.None,
            }
        }
        Option.None => Option.None,
    }
}

/// Synthesize `impl Hash for Target { fn hash(self: &Self, state: &mut u64) {
/// self.F0.hash(state); self.F1.hash(state); ... } }` for a record struct.
pub fn expand_hash_for_struct(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let field_spans = match collect_record_field_spans(ctx, req.target_def) {
        Option.Some(v) => v,
        Option.None => return Option.None,
    };

    let attr_span = req.span;

    // Body: one statement per field — `self.<field>.hash(state);`
    let mut stmts: Vec<ast.Statement> = Vec.new();
    for i in 0usize..field_spans.len() {
        let self_expr = syn_path_expr(&spans.self_id, attr_span);
        let field_expr = syn_field_expr(self_expr, field_spans[i], attr_span);
        let state_expr = syn_path_expr(&spans.state_id, attr_span);
        let mut args: Vec<ast.CallArg> = Vec.new();
        args.push(syn_call_arg(state_expr, attr_span));
        let call = syn_method_call(field_expr, &spans.hash_method, args, attr_span);
        stmts.push(ast.Statement.Expr { expr: call, has_semi: true });
    }

    let body = ast.Block {
        statements: stmts,
        expr: Option.None,
        span: attr_span,
    };

    // Params: `self: &Self`, `state: &mut u64`.
    let self_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let state_param_ty = syn_ref_type(syn_path_type(&spans.u64_ty, attr_span), true, attr_span);
    let mut params: Vec<ast.Param> = Vec.new();
    params.push(syn_param(&spans.self_id, self_param_ty, attr_span));
    params.push(syn_param(&spans.state_id, state_param_ty, attr_span));

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.hash_method),
        type_params: Option.None,
        params: params,
        return_type: Option.None,
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.hash_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

/// Synthesize `impl PartialEq for Target { fn eq(self: &Self, other: &Self)
/// -> bool { self.F0 == other.F0 && self.F1 == other.F1 && ... } }` for a
/// record struct. Empty structs produce `true`.
pub fn expand_partial_eq_for_struct(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let field_spans = match collect_record_field_spans(ctx, req.target_def) {
        Option.Some(v) => v,
        Option.None => return Option.None,
    };

    let attr_span = req.span;

    // Body expression: AND of `self.Fi == other.Fi` for each field.
    // Start with `true`, then AND in each field comparison.
    let mut acc: ast.Expr = syn_bool_lit(true, attr_span);
    for i in 0usize..field_spans.len() {
        let self_expr = syn_path_expr(&spans.self_id, attr_span);
        let self_field = syn_field_expr(self_expr, field_spans[i], attr_span);
        let other_expr = syn_path_expr(&spans.other_id, attr_span);
        let other_field = syn_field_expr(other_expr, field_spans[i], attr_span);
        let eq_expr = syn_binary(common.BinOp.Eq, self_field, other_field, attr_span);
        // Combine: acc = acc && eq_expr. For i==0, acc is `true && x == y` which
        // simplifies during typeck/codegen; the literal `true` keeps the shape
        // uniform without a special-case for the first field.
        acc = syn_binary(common.BinOp.And, acc, eq_expr, attr_span);
    }

    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(acc)),
        span: attr_span,
    };

    // Params: `self: &Self`, `other: &Self`.
    let self_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let other_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let mut params: Vec<ast.Param> = Vec.new();
    params.push(syn_param(&spans.self_id, self_param_ty, attr_span));
    params.push(syn_param(&spans.other_id, other_param_ty, attr_span));

    // Return type: bool.
    let return_ty = syn_path_type(&spans.bool_ty, attr_span);

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.eq_method),
        type_params: Option.None,
        params: params,
        return_type: Option.Some(return_ty),
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.partialeq_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

// ============================================================
// Clone Expansion (record struct)
// ============================================================

/// Synthesize `impl Clone for Target { fn clone(self: &Self) -> Self {
/// Target { f0: self.f0.clone(), f1: self.f1.clone(), ... } } }` for a
/// record struct. Unit and tuple structs return `None` (deferred — the
/// same decision point that `collect_record_field_spans` enforces for
/// Hash/PartialEq).
pub fn expand_clone_for_struct(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let field_spans = match collect_record_field_spans(ctx, req.target_def) {
        Option.Some(v) => v,
        Option.None => return Option.None,
    };

    let attr_span = req.span;

    // Build `{ f0: self.f0.clone(), f1: self.f1.clone(), ... }` as a record
    // literal whose path targets the derived type.
    let mut record_fields: Vec<ast.RecordExprField> = Vec.with_capacity(field_spans.len());
    for i in 0usize..field_spans.len() {
        let self_expr = syn_path_expr(&spans.self_id, attr_span);
        let self_field = syn_field_expr(self_expr, field_spans[i], attr_span);
        let clone_call = syn_method_call(
            self_field,
            &spans.clone_method,
            Vec.new(),
            attr_span,
        );
        record_fields.push(ast.RecordExprField {
            name: syn_sym_span(field_spans[i]),
            val: Option.Some(clone_call),
            span: attr_span,
        });
    }

    let target_type_path = syn_type_path_from_span(req.target_name_span, attr_span);
    let body_expr = syn_record_expr(target_type_path, record_fields, attr_span);

    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(body_expr)),
        span: attr_span,
    };

    // Params: `self: &Self`.
    let self_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let mut params: Vec<ast.Param> = Vec.new();
    params.push(syn_param(&spans.self_id, self_param_ty, attr_span));

    // Return type: `Self`.
    let return_ty = syn_path_type(&spans.self_ty, attr_span);

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.clone_method),
        type_params: Option.None,
        params: params,
        return_type: Option.Some(return_ty),
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.clone_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

// ============================================================
// Enum Expansion
// ============================================================

/// Returns true if the target DefId is an enum item.
fn target_is_enum(ctx: &hir_lower_ctx.LoweringCtx, target_def: hir_def.DefId) -> bool {
    match ctx.get_item(target_def) {
        Option.Some(entry) => {
            match &entry.item.kind {
                &hir_item.ItemKind.Enum(_) => true,
                _ => false,
            }
        }
        Option.None => false,
    }
}

/// Build per-variant match arm for Hash: a pattern that matches the variant
/// (with ref bindings for tuple payload fields) and a body that hashes the
/// discriminant as u32 then each payload field.
fn build_hash_variant_arm(
    spans: &SyntheticSpans,
    target_name_span: common.Span,
    variant: &VariantInfo,
    attr_span: common.Span,
) -> ast.MatchArm {
    // Pattern: &EnumName.VariantName or &EnumName.VariantName(ref __l0, ref __l1, ...).
    let inner_pat = match &variant.kind {
        &VariantKindInfo.Unit => {
            syn_pat_variant_path(target_name_span, variant.name_span, attr_span)
        }
        &VariantKindInfo.Tuple(arity) => {
            let mut field_pats: Vec<ast.Pattern> = Vec.with_capacity(arity);
            for i in 0usize..arity {
                field_pats.push(syn_pat_ident_by_ref(&spans.left_payload_idents[i]));
            }
            syn_pat_variant_tuple_struct(target_name_span, variant.name_span, field_pats, attr_span)
        }
    };
    let ref_pat = syn_pat_ref(inner_pat, false, attr_span);

    // Body: { <disc>u32.hash(state); [field_i.hash(state);]* }.
    let mut stmts: Vec<ast.Statement> = Vec.new();
    let disc_lit = syn_int_lit_suffixed(variant.discriminant as u128, ast.IntSuffix.U32, attr_span);
    let mut disc_args: Vec<ast.CallArg> = Vec.new();
    disc_args.push(syn_call_arg(syn_path_expr(&spans.state_id, attr_span), attr_span));
    let disc_call = syn_method_call(disc_lit, &spans.hash_method, disc_args, attr_span);
    stmts.push(ast.Statement.Expr { expr: disc_call, has_semi: true });
    match &variant.kind {
        &VariantKindInfo.Unit => {}
        &VariantKindInfo.Tuple(arity) => {
            for i in 0usize..arity {
                let field_expr = syn_path_expr(&spans.left_payload_idents[i], attr_span);
                let mut args: Vec<ast.CallArg> = Vec.new();
                args.push(syn_call_arg(syn_path_expr(&spans.state_id, attr_span), attr_span));
                let field_call = syn_method_call(field_expr, &spans.hash_method, args, attr_span);
                stmts.push(ast.Statement.Expr { expr: field_call, has_semi: true });
            }
        }
    }
    let arm_body = syn_block_expr(stmts, Option.None, attr_span);

    syn_match_arm(ref_pat, arm_body, attr_span)
}

/// Synthesize `impl Hash for Target { fn hash(self: &Self, state: &mut u64) {
/// match self { per-variant arms } } }` for an enum. Supports unit and tuple
/// variants up to MAX_TUPLE_VARIANT_ARITY.
pub fn expand_hash_for_enum(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let variants = match collect_enum_variant_info(ctx, req.target_def) {
        Option.Some(v) => v,
        Option.None => return Option.None,
    };

    let attr_span = req.span;

    // Match scrutinee: `self` (an &Self binding).
    let scrutinee = syn_path_expr(&spans.self_id, attr_span);

    // Build one arm per variant. No catch-all arm: variants are exhaustive.
    let mut arms: Vec<ast.MatchArm> = Vec.with_capacity(variants.len());
    for i in 0usize..variants.len() {
        arms.push(build_hash_variant_arm(spans, req.target_name_span, &variants[i], attr_span));
    }

    let match_expr = syn_match_expr(scrutinee, arms, attr_span);

    // Wrap the match in a block (required because the fn has unit return
    // type; the match is the block's trailing expression).
    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(match_expr)),
        span: attr_span,
    };

    // Params: `self: &Self`, `state: &mut u64`.
    let self_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let state_param_ty = syn_ref_type(syn_path_type(&spans.u64_ty, attr_span), true, attr_span);
    let mut params: Vec<ast.Param> = Vec.new();
    params.push(syn_param(&spans.self_id, self_param_ty, attr_span));
    params.push(syn_param(&spans.state_id, state_param_ty, attr_span));

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.hash_method),
        type_params: Option.None,
        params: params,
        return_type: Option.None,
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.hash_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

/// Build the same-variant match arm for PartialEq: a tuple pattern `(left,
/// right)` where both sides bind to the same variant with paired ref
/// bindings, and a body that ANDs `*__l0 == *__r0 && ...` (seeded with
/// `true` for uniform shape and zero-field variants).
fn build_partial_eq_variant_arm(
    spans: &SyntheticSpans,
    target_name_span: common.Span,
    variant: &VariantInfo,
    attr_span: common.Span,
) -> ast.MatchArm {
    // Left pattern: EnumName.VariantName[(ref __l0, ...)]
    let left_inner = match &variant.kind {
        &VariantKindInfo.Unit => {
            syn_pat_variant_path(target_name_span, variant.name_span, attr_span)
        }
        &VariantKindInfo.Tuple(arity) => {
            let mut fs: Vec<ast.Pattern> = Vec.with_capacity(arity);
            for i in 0usize..arity {
                fs.push(syn_pat_ident_by_ref(&spans.left_payload_idents[i]));
            }
            syn_pat_variant_tuple_struct(target_name_span, variant.name_span, fs, attr_span)
        }
    };
    let left_pat = syn_pat_ref(left_inner, false, attr_span);

    // Right pattern: EnumName.VariantName[(ref __r0, ...)]
    let right_inner = match &variant.kind {
        &VariantKindInfo.Unit => {
            syn_pat_variant_path(target_name_span, variant.name_span, attr_span)
        }
        &VariantKindInfo.Tuple(arity) => {
            let mut fs: Vec<ast.Pattern> = Vec.with_capacity(arity);
            for i in 0usize..arity {
                fs.push(syn_pat_ident_by_ref(&spans.right_payload_idents[i]));
            }
            syn_pat_variant_tuple_struct(target_name_span, variant.name_span, fs, attr_span)
        }
    };
    let right_pat = syn_pat_ref(right_inner, false, attr_span);

    // Tuple pattern: (left, right).
    let mut tuple_fs: Vec<ast.Pattern> = Vec.with_capacity(2);
    tuple_fs.push(left_pat);
    tuple_fs.push(right_pat);
    let tuple_pat = syn_pat_tuple(tuple_fs, attr_span);

    // Body: true [&& *__l_i == *__r_i]*.
    let mut acc: ast.Expr = syn_bool_lit(true, attr_span);
    match &variant.kind {
        &VariantKindInfo.Unit => {}
        &VariantKindInfo.Tuple(arity) => {
            for i in 0usize..arity {
                let l_expr = syn_path_expr(&spans.left_payload_idents[i], attr_span);
                let r_expr = syn_path_expr(&spans.right_payload_idents[i], attr_span);
                let l_deref = ast.Expr {
                    kind: ast.ExprKind.Unary {
                        operator: common.UnaryOp.Deref,
                        operand: Box.new(l_expr),
                    },
                    span: attr_span,
                };
                let r_deref = ast.Expr {
                    kind: ast.ExprKind.Unary {
                        operator: common.UnaryOp.Deref,
                        operand: Box.new(r_expr),
                    },
                    span: attr_span,
                };
                let eq_expr = syn_binary(common.BinOp.Eq, l_deref, r_deref, attr_span);
                acc = syn_binary(common.BinOp.And, acc, eq_expr, attr_span);
            }
        }
    }

    syn_match_arm(tuple_pat, acc, attr_span)
}

/// Synthesize `impl PartialEq for Target { fn eq(self: &Self, other: &Self)
/// -> bool { match (self, other) { same-variant arms ..., _ => false } } }`
/// for an enum.
pub fn expand_partial_eq_for_enum(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let variants = match collect_enum_variant_info(ctx, req.target_def) {
        Option.Some(v) => v,
        Option.None => return Option.None,
    };

    let attr_span = req.span;

    // Scrutinee: (self, other).
    let mut tuple_fields: Vec<ast.Expr> = Vec.with_capacity(2);
    tuple_fields.push(syn_path_expr(&spans.self_id, attr_span));
    tuple_fields.push(syn_path_expr(&spans.other_id, attr_span));
    let scrutinee = syn_tuple_expr(tuple_fields, attr_span);

    // Per-variant same-same arms plus a wildcard fallthrough. The wildcard
    // covers every mixed-variant `(&Self.A, &Self.B)` pair — it's unreachable
    // for 0- or 1-variant enums but cheap and keeps the match shape uniform.
    let mut arms: Vec<ast.MatchArm> = Vec.with_capacity(variants.len() + 1);
    for i in 0usize..variants.len() {
        arms.push(build_partial_eq_variant_arm(spans, req.target_name_span, &variants[i], attr_span));
    }
    arms.push(syn_match_arm(
        syn_pat_wildcard(attr_span),
        syn_bool_lit(false, attr_span),
        attr_span,
    ));

    let match_expr = syn_match_expr(scrutinee, arms, attr_span);

    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(match_expr)),
        span: attr_span,
    };

    // Params: `self: &Self`, `other: &Self`.
    let self_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let other_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let mut params: Vec<ast.Param> = Vec.new();
    params.push(syn_param(&spans.self_id, self_param_ty, attr_span));
    params.push(syn_param(&spans.other_id, other_param_ty, attr_span));

    let return_ty = syn_path_type(&spans.bool_ty, attr_span);

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.eq_method),
        type_params: Option.None,
        params: params,
        return_type: Option.Some(return_ty),
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.partialeq_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

// ============================================================
// Clone Expansion (enum)
// ============================================================

/// Build per-variant match arm for Clone: pattern `&Enum.V[(ref __l_i*)]`
/// with body `Enum.V[(__l_i.clone(), ...)]` reconstructing the variant.
fn build_clone_variant_arm(
    spans: &SyntheticSpans,
    target_name_span: common.Span,
    variant: &VariantInfo,
    attr_span: common.Span,
) -> ast.MatchArm {
    // Pattern: &Enum.V or &Enum.V(ref __l0, ref __l1, ...).
    let inner_pat = match &variant.kind {
        &VariantKindInfo.Unit => {
            syn_pat_variant_path(target_name_span, variant.name_span, attr_span)
        }
        &VariantKindInfo.Tuple(arity) => {
            let mut field_pats: Vec<ast.Pattern> = Vec.with_capacity(arity);
            for i in 0usize..arity {
                field_pats.push(syn_pat_ident_by_ref(&spans.left_payload_idents[i]));
            }
            syn_pat_variant_tuple_struct(target_name_span, variant.name_span, field_pats, attr_span)
        }
    };
    let ref_pat = syn_pat_ref(inner_pat, false, attr_span);

    // Body: Enum.V or Enum.V(__l0.clone(), __l1.clone(), ...).
    let arm_body = match &variant.kind {
        &VariantKindInfo.Unit => {
            syn_variant_path_expr(target_name_span, variant.name_span, attr_span)
        }
        &VariantKindInfo.Tuple(arity) => {
            let callee = syn_variant_path_expr(target_name_span, variant.name_span, attr_span);
            let mut args: Vec<ast.CallArg> = Vec.with_capacity(arity);
            for i in 0usize..arity {
                let l_expr = syn_path_expr(&spans.left_payload_idents[i], attr_span);
                let clone_call = syn_method_call(
                    l_expr,
                    &spans.clone_method,
                    Vec.new(),
                    attr_span,
                );
                args.push(syn_call_arg(clone_call, attr_span));
            }
            syn_call_expr(callee, args, attr_span)
        }
    };

    syn_match_arm(ref_pat, arm_body, attr_span)
}

/// Synthesize `impl Clone for Target { fn clone(self: &Self) -> Self {
/// match self { per-variant arms } } }` for an enum. Each arm
/// reconstructs the matched variant with per-field `.clone()` calls.
/// Supports unit and tuple variants up to MAX_TUPLE_VARIANT_ARITY.
pub fn expand_clone_for_enum(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let variants = match collect_enum_variant_info(ctx, req.target_def) {
        Option.Some(v) => v,
        Option.None => return Option.None,
    };

    let attr_span = req.span;

    // Match scrutinee: `self` (an &Self binding).
    let scrutinee = syn_path_expr(&spans.self_id, attr_span);

    // Build one arm per variant. No catch-all needed — variants are
    // exhaustive, and no arm uses any binding the next arm could catch.
    let mut arms: Vec<ast.MatchArm> = Vec.with_capacity(variants.len());
    for i in 0usize..variants.len() {
        arms.push(build_clone_variant_arm(spans, req.target_name_span, &variants[i], attr_span));
    }

    let match_expr = syn_match_expr(scrutinee, arms, attr_span);

    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(match_expr)),
        span: attr_span,
    };

    // Params: `self: &Self`.
    let self_param_ty = syn_ref_type(syn_path_type(&spans.self_ty, attr_span), false, attr_span);
    let mut params: Vec<ast.Param> = Vec.new();
    params.push(syn_param(&spans.self_id, self_param_ty, attr_span));

    // Return type: `Self`.
    let return_ty = syn_path_type(&spans.self_ty, attr_span);

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.clone_method),
        type_params: Option.None,
        params: params,
        return_type: Option.Some(return_ty),
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.clone_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

// ============================================================
// Default Expansion (struct + enum)
// ============================================================

/// Synthesize `impl Default for Target { fn default() -> Self {
/// Target { f0: <default_0>, f1: <default_1>, ... } } }` for a record
/// struct. Per-field defaults come from `build_field_default_expr`:
/// primitive-typed fields get an inline literal; path-typed user-type
/// fields get a `FieldTypeName.default()` call. Returns `None` if any
/// field's type cannot be defaulted, or if the target is not a record
/// struct.
pub fn expand_default_for_struct(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
    ast_struct: &ast.StructDecl,
) -> Option<ast.ImplBlock> {
    let fields_ast = match &ast_struct.body {
        &ast.StructBody.Record(ref fs) => fs,
        &ast.StructBody.Tuple(_) => return Option.None,
        &ast.StructBody.Unit => return Option.None,
    };

    let attr_span = req.span;

    // Build each field's default; any untypeable field aborts the whole
    // expansion so the caller can emit a single E0901 at the attribute.
    let mut record_fields: Vec<ast.RecordExprField> = Vec.with_capacity(fields_ast.len());
    for i in 0usize..fields_ast.len() {
        let f = &fields_ast[i];
        let val_expr = match build_field_default_expr(ctx, spans, &f.ty, attr_span) {
            Option.Some(e) => e,
            Option.None => return Option.None,
        };
        record_fields.push(ast.RecordExprField {
            name: syn_sym_span(f.name.span),
            val: Option.Some(val_expr),
            span: attr_span,
        });
    }

    let target_type_path = syn_type_path_from_span(req.target_name_span, attr_span);
    let body_expr = syn_record_expr(target_type_path, record_fields, attr_span);

    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(body_expr)),
        span: attr_span,
    };

    // `fn default() -> Self` — no parameters, returns Self by value.
    let params: Vec<ast.Param> = Vec.new();
    let return_ty = syn_path_type(&spans.self_ty, attr_span);

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.default_method),
        type_params: Option.None,
        params: params,
        return_type: Option.Some(return_ty),
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.default_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

/// Synthesize `impl Default for Target { fn default() -> Self {
/// Target.V[(<default_0>, <default_1>, ...)] } }` for an enum, picking the
/// first declared variant. Unit first variant produces `Target.V`; tuple
/// first variant produces `Target.V(...)` with per-field defaults. Record
/// first variants and empty enums return `None`.
pub fn expand_default_for_enum(
    ctx: &hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
    ast_enum: &ast.EnumDecl,
) -> Option<ast.ImplBlock> {
    if ast_enum.variants.len() == 0usize {
        return Option.None;
    }

    let first_variant = &ast_enum.variants[0];
    let attr_span = req.span;

    let body_expr = match &first_variant.body {
        &ast.StructBody.Unit => {
            syn_variant_path_expr(req.target_name_span, first_variant.name.span, attr_span)
        }
        &ast.StructBody.Tuple(ref tys) => {
            let mut args: Vec<ast.CallArg> = Vec.with_capacity(tys.len());
            for i in 0usize..tys.len() {
                let val_expr = match build_field_default_expr(ctx, spans, &tys[i], attr_span) {
                    Option.Some(e) => e,
                    Option.None => return Option.None,
                };
                args.push(syn_call_arg(val_expr, attr_span));
            }
            let callee = syn_variant_path_expr(req.target_name_span, first_variant.name.span, attr_span);
            syn_call_expr(callee, args, attr_span)
        }
        &ast.StructBody.Record(_) => return Option.None,
    };

    let body = ast.Block {
        statements: Vec.new(),
        expr: Option.Some(Box.new(body_expr)),
        span: attr_span,
    };

    let params: Vec<ast.Param> = Vec.new();
    let return_ty = syn_path_type(&spans.self_ty, attr_span);

    let fn_decl = ast.FnDecl {
        attrs: Vec.new(),
        vis: common.Visibility.Public,
        qualifiers: common.FnQualifiers.none(),
        name: syn_sym(&spans.default_method),
        type_params: Option.None,
        params: params,
        return_type: Option.Some(return_ty),
        effects: Option.None,
        spec_clauses: Vec.new(),
        where_clause: Option.None,
        body: Option.Some(body),
        span: attr_span,
    };

    let mut items: Vec<ast.ImplItem> = Vec.new();
    items.push(ast.ImplItem.Function(fn_decl));

    let trait_ty = syn_path_type(&spans.default_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);

    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: items,
        span: attr_span,
    })
}

// ============================================================
// Eq Expansion (marker trait)
// ============================================================

/// Synthesize `impl Eq for Target {}` — an empty impl. Eq is a marker trait
/// in Rust; in Blood we treat it the same way. The impl has no methods, only
/// the trait_ty + self_ty binding which registers the type as implementing Eq.
/// Works identically for structs and enums.
pub fn expand_eq_for_adt(
    spans: &SyntheticSpans,
    req: &DeriveRequest,
) -> Option<ast.ImplBlock> {
    let attr_span = req.span;
    let trait_ty = syn_path_type(&spans.eq_trait, attr_span);
    let self_ty_node = syn_path_type_from_span(req.target_name_span, attr_span);
    Option.Some(ast.ImplBlock {
        attrs: Vec.new(),
        type_params: Option.None,
        trait_ty: Option.Some(trait_ty),
        self_ty: self_ty_node,
        where_clause: Option.None,
        items: Vec.new(),
        span: attr_span,
    })
}

/// Emit an E0901 diagnostic when a known derive kind fails to expand —
/// either because the kind itself is not yet implemented (Debug) or because
/// the target's shape is unsupported (e.g., tuple/unit struct, enum with
/// record variants, tuple variant with arity > 8, or — for Default — a
/// field whose type has no default representation).
fn emit_derive_failure_diag(
    ctx: &mut hir_lower_ctx.LoweringCtx,
    req: &DeriveRequest,
    is_enum: bool,
) {
    let mut msg = String.new();
    match &req.kind {
        &DeriveKind.Debug => {
            msg.push_str("`#[derive(Debug)]` is not yet implemented");
        }
        _ => {
            msg.push_str("`#[derive(");
            msg.push_str(req.kind.trait_name());
            msg.push_str(")]` is not supported for this ");
            if is_enum {
                msg.push_str("enum (record variants and tuple variants with more than 8 fields are unsupported)");
            } else {
                msg.push_str("struct (only record structs are supported; tuple and unit structs are unsupported)");
            }
        }
    }
    ctx.error(hir.DiagnosticCode.E0901, msg, req.span);
}

/// Expand a single derive request to a synthesized impl block. Dispatches
/// based on whether the target is a struct or enum and on the requested
/// kind. `ast_decl` is the original AST declaration for the target and is
/// used by Default expansion to reach field types (other kinds read from
/// HIR via `ctx.get_item`). When the dispatch path returns None
/// (unimplemented kind OR unsupported target shape), emits E0901 at the
/// attribute's span with a kind-specific message before propagating None.
pub fn expand_request(
    ctx: &mut hir_lower_ctx.LoweringCtx,
    spans: &SyntheticSpans,
    req: &DeriveRequest,
    ast_decl: &ast.Declaration,
) -> Option<ast.ImplBlock> {
    let is_enum = target_is_enum(ctx, req.target_def);
    let result = match &req.kind {
        &DeriveKind.Hash => {
            if is_enum {
                expand_hash_for_enum(ctx, spans, req)
            } else {
                expand_hash_for_struct(ctx, spans, req)
            }
        }
        &DeriveKind.PartialEq => {
            if is_enum {
                expand_partial_eq_for_enum(ctx, spans, req)
            } else {
                expand_partial_eq_for_struct(ctx, spans, req)
            }
        }
        &DeriveKind.Eq => expand_eq_for_adt(spans, req),
        &DeriveKind.Clone => {
            if is_enum {
                expand_clone_for_enum(ctx, spans, req)
            } else {
                expand_clone_for_struct(ctx, spans, req)
            }
        }
        &DeriveKind.Default => {
            match ast_decl {
                &ast.Declaration.Struct(ref s) => expand_default_for_struct(ctx, spans, req, s),
                &ast.Declaration.Enum(ref e) => expand_default_for_enum(ctx, spans, req, e),
                _ => Option.None,
            }
        }
        &DeriveKind.Debug => Option.None,
    };
    match &result {
        &Option.Some(_) => {}
        &Option.None => { emit_derive_failure_diag(ctx, req, is_enum); }
    }
    result
}
