// ============================================================
// Builtin DefId Name Mapping
// ============================================================

/// Maps a synthetic builtin DefId to its runtime function name.
/// Used to tell codegen what symbol name to emit for method calls
/// on builtin types (String, Vec, Option, etc.).
pub struct BuiltinDefName {
    /// The DefId index allocated by the type checker.
    pub def_id_index: u32,
    /// The runtime function name (e.g., "string_push_str", "vec_push").
    pub runtime_name: String,
}

impl BuiltinDefName {
    pub fn new(def_id_index: u32, runtime_name: String) -> BuiltinDefName {
        BuiltinDefName {
            def_id_index: def_id_index,
            runtime_name: runtime_name,
        }
    }
}

// ============================================================
// Generic Parameter Helpers
// ============================================================

/// Counts only type parameters in a generics param list, excluding
/// lifetime parameters and const parameters.
fn count_type_params(params: &Vec<hir_ty.GenericParam>) -> u32 {
    let mut count: u32 = 0;
    for i in 0usize..params.len() {
        match &params[i] {
            &hir_ty.GenericParam.TypeParam(_) => {
                count += 1;
            }
            &hir_ty.GenericParam.LifetimeParam(_) => {}
            &hir_ty.GenericParam.ConstParam(_) => {}
        }
    }
    count
}

/// Extracts the actual TyVarId indices from generic parameters.
/// These are the globally unique indices assigned during HIR lowering.
fn extract_type_param_ids(params: &Vec<hir_ty.GenericParam>) -> Vec<u32> {
    let mut ids: Vec<u32> = Vec.new();
    for i in 0usize..params.len() {
        match &params[i] {
            &hir_ty.GenericParam.TypeParam(ref def) => {
                ids.push(def.var_id.index);
            }
            &hir_ty.GenericParam.LifetimeParam(_) => {}
            &hir_ty.GenericParam.ConstParam(_) => {}
        }
    }
    ids
}

// ============================================================
// Exhaustiveness Checking
// ============================================================

/// A witness for non-exhaustiveness (a pattern not covered).
pub struct Witness {
    /// The pattern that isn't covered.
    pub description: String,
}

impl Witness {
    /// Creates a new witness.
    pub fn new(description: String) -> Witness {
        Witness {
            description: description,
        }
    }
}

/// Result of exhaustiveness checking.
pub enum ExhaustivenessResult {
    /// Patterns are exhaustive.
    Exhaustive,
    /// Patterns are not exhaustive, with witnesses.
    NonExhaustive(Vec<Witness>),
}

impl ExhaustivenessResult {
    /// Returns true if the result is exhaustive.
    pub fn is_exhaustive(self: &ExhaustivenessResult) -> bool {
        match self {
            &ExhaustivenessResult.Exhaustive => true,
            &ExhaustivenessResult.NonExhaustive(_) => false,
        }
    }
}

/// A deconstructed pattern for exhaustiveness checking.
pub enum DeconstructedPattern {
    /// A wildcard pattern that matches anything.
    Wildcard,
    /// A literal pattern (integer, bool, char).
    Literal { value: i128 },
    /// A struct variant pattern.
    Variant {
        def_id: hir_def.DefId,
        variant_idx: u32,
        fields: Vec<DeconstructedPattern>,
    },
    /// A struct pattern (non-enum).
    Struct {
        def_id: hir_def.DefId,
        fields: Vec<DeconstructedPattern>,
    },
    /// A tuple pattern.
    Tuple { fields: Vec<DeconstructedPattern> },
    /// An or-pattern (alternative patterns).
    Or { pats: Vec<DeconstructedPattern> },
    /// Missing pattern (for non-exhaustiveness witnesses).
    Missing,
}

impl DeconstructedPattern {
    /// Creates a wildcard pattern.
    pub fn wildcard() -> DeconstructedPattern {
        DeconstructedPattern.Wildcard
    }

    /// Creates a literal pattern.
    pub fn literal(value: i128) -> DeconstructedPattern {
        DeconstructedPattern.Literal { value: value }
    }

    /// Creates a variant pattern.
    pub fn variant(def_id: hir_def.DefId, variant_idx: u32, fields: Vec<DeconstructedPattern>) -> DeconstructedPattern {
        DeconstructedPattern.Variant { def_id: def_id, variant_idx: variant_idx, fields: fields }
    }

    /// Creates a struct pattern.
    pub fn struct_pat(def_id: hir_def.DefId, fields: Vec<DeconstructedPattern>) -> DeconstructedPattern {
        DeconstructedPattern.Struct { def_id: def_id, fields: fields }
    }

    /// Creates a tuple pattern.
    pub fn tuple(fields: Vec<DeconstructedPattern>) -> DeconstructedPattern {
        DeconstructedPattern.Tuple { fields: fields }
    }

    /// Returns true if this pattern is a wildcard.
    pub fn is_wildcard(self: &DeconstructedPattern) -> bool {
        match self {
            &DeconstructedPattern.Wildcard => true,
            _ => false,
        }
    }
}

/// A row in the pattern matrix.
pub struct PatternRow {
    /// The patterns in this row (one per column).
    pub patterns: Vec<DeconstructedPattern>,
}

impl PatternRow {
    /// Creates a new pattern row.
    pub fn new(patterns: Vec<DeconstructedPattern>) -> PatternRow {
        PatternRow { patterns: patterns }
    }
}

/// A pattern matrix for exhaustiveness checking.
pub struct PatternMatrix {
    /// The rows of the matrix.
    pub rows: Vec<PatternRow>,
    /// Number of columns (patterns per row).
    pub width: usize,
}

impl PatternMatrix {
    /// Creates a new empty pattern matrix.
    pub fn new(width: usize) -> PatternMatrix {
        PatternMatrix {
            rows: Vec.new(),
            width: width,
        }
    }

    /// Adds a row to the matrix.
    pub fn push_row(self: &mut PatternMatrix, row: PatternRow) {
        self.rows.push(row);
    }

    /// Returns the number of rows.
    pub fn row_count(self: &PatternMatrix) -> usize {
        self.rows.len()
    }

    /// Returns true if the matrix is empty.
    pub fn is_empty(self: &PatternMatrix) -> bool {
        self.rows.len() == 0
    }
}

// ============================================================
// Type Checker
// ============================================================

/// The main type checker.
///
/// This struct coordinates type checking for an entire HIR crate.
/// It maintains:
/// - Substitution table for type unification
/// - Type variable generator
/// - Current function context
/// - Errors collected during type checking
/// - Registered item signatures for lookup
pub struct TypeChecker {
    /// Substitution table for type unification.
    pub subst_table: unify.SubstTable,
    /// Unifier for generating fresh type variables.
    pub unifier: unify.Unifier,
    /// Current function's return type.
    pub return_ty: Option<type_intern.TyId>,
    /// Whether we're currently in a loop.
    pub in_loop: bool,
    /// Type of the current loop (for break values).
    pub loop_ty: Option<type_intern.TyId>,
    /// Local variable types by LocalId index (offset by local_base).
    pub locals: Vec<typeck_types.LocalInfo>,
    /// Base offset for local variable indices in the current body.
    /// HIR allocates LocalIds globally; we subtract this to index into locals Vec.
    pub local_base: u32,
    /// Type errors collected during checking.
    pub errors: Vec<typeck_types.TypeError>,
    /// Function signature info by DefId.index for O(1) lookup.
    pub fn_sigs: Vec<Option<typeck_info.FnSigInfo>>,
    /// Struct info by DefId.index for O(1) lookup.
    pub structs: Vec<Option<typeck_info.StructInfo>>,
    /// Enum info by DefId.index for O(1) lookup.
    pub enums: Vec<Option<typeck_info.EnumInfo>>,
    /// Const info by DefId.index for O(1) lookup.
    pub consts: Vec<Option<typeck_info.ConstInfo>>,
    /// Static info by DefId.index for O(1) lookup.
    pub statics: Vec<Option<typeck_info.StaticInfo>>,
    /// Impl blocks for method resolution.
    pub impls: Vec<typeck_info.ImplInfo>,
    /// Trait definitions by DefId.index for O(1) lookup.
    pub traits: Vec<Option<typeck_info.TraitInfo>>,
    /// Trait implementations for trait resolution.
    pub trait_impls: Vec<typeck_info.TraitImplInfo>,
    /// DefId counter for allocating synthetic builtin DefIds.
    pub next_def_id: u32,
    /// Builtin type DefIds.
    pub builtin_string_def: Option<hir_def.DefId>,
    pub builtin_vec_def: Option<hir_def.DefId>,
    pub builtin_option_def: Option<hir_def.DefId>,
    pub builtin_box_def: Option<hir_def.DefId>,
    pub builtin_hashmap_def: Option<hir_def.DefId>,
    pub builtin_result_def: Option<hir_def.DefId>,
    /// Effect info by DefId.index for O(1) lookup.
    pub effects: Vec<Option<typeck_info.EffectInfo>>,
    /// Builtin DefId-to-runtime-name mapping.
    /// Populated during register_builtin_signatures.
    pub builtin_def_names: Vec<BuiltinDefName>,
    /// Method resolution side table.
    /// Records resolved method DefIds keyed by expression span start,
    /// so MIR lowering can look up methods that were resolved during type checking.
    pub method_resolutions: Vec<common.MethodResEntry>,
    /// Hash index for O(1) method resolution existence check.
    /// Key = (body_def_id << 32) | (span_start & 0xFFFFFFFF), value = 1.
    pub method_res_hash: hashmap.HashMapU64U64,
    /// Method name → impl/method index for O(1) lookup.
    /// Linked list: method_name_heads maps name.index → head entry index.
    /// Parallel Vecs store impl_idx, method_idx, and next-in-chain.
    pub mn_impl_idx: Vec<usize>,
    pub mn_meth_idx: Vec<usize>,
    pub mn_next: Vec<usize>,
    pub mn_heads: hashmap.HashMapU64U64,
    pub mn_tails: hashmap.HashMapU64U64,
    /// Field resolution side table.
    /// Records resolved field indices keyed by expression span start,
    /// so MIR lowering can look up the correct field index for named fields.
    pub field_resolutions: Vec<common.FieldResEntry>,
    /// Deferred method calls whose receiver was an unresolved Infer variable.
    /// After all bodies are type-checked, these are revisited to resolve methods.
    pub pending_method_calls: Vec<common.PendingMethodCall>,
    /// Current body's DefId for scoping method/field resolutions.
    /// Set before type-checking each function body.
    pub current_body_def_id: u32,
    /// Current function's effect row, for checking undeclared perform operations.
    pub current_effect_row: Vec<u32>,
    /// Type arguments for each effect in current_effect_row (parallel array).
    /// E.g., for `/ {Emit<i32>}`, current_effect_row=[Emit_def_id], current_effect_type_args=[[i32_ty]].
    pub current_effect_type_args: Vec<Vec<type_intern.TyId>>,
    /// Whether we are inside a handler block (try/with or with-handle).
    /// When true, call-site effect checking is suppressed since the handler handles effects.
    pub in_handler: bool,
    /// Effects available from enclosing with...handle blocks (stack, push/pop on enter/exit).
    /// Used by effect-row dispatch to select methods compatible with the handler context.
    pub available_effects: Vec<u32>,
    /// Parallel to available_effects: type args for each handler's effect instantiation.
    /// E.g., for `with CollectInt for Emit<i32>`, stores [i32_TyId].
    /// Used by infer_perform to resolve parametric effect type params (F-02 fix).
    pub available_effect_type_args: Vec<Vec<type_intern.TyId>>,
    /// Hash index for O(1) variant lookup: variant_def_id.index → (enum_idx << 32) | variant_idx
    pub variant_hash: hashmap.HashMapU64U64,
    /// Hash index for O(1) trait impl existence check: trait_def_id.index → 1
    pub trait_impl_hash: hashmap.HashMapU64U32,
    /// Expected type for resume() calls in the current handler op body.
    /// Set before type-checking each handler op body, None when not in a handler op.
    pub resume_ty: Option<type_intern.TyId>,
    /// Whether the current handler is shallow (single resume allowed).
    pub in_shallow_handler: bool,
    /// Count of resume expressions seen in the current handler op body.
    pub resume_count: u32,
    /// Handler state field types for the current handler op body.
    /// Used to check linear/affine types in multi-shot handlers.
    pub handler_state_types: Vec<type_intern.TyId>,
    /// Map from handler DefId index to handler kind (true = deep).
    /// Populated during item registration. Used by with/handle linearity checking.
    pub handler_kind_hash: hashmap.HashMapU64U32,
    /// Maps handler DefId → 1 if handler has a non-identity return clause.
    /// Used by infer_with_handle to return fresh Infer instead of body_ty.
    pub handler_transforming_return_hash: hashmap.HashMapU64U32,
    /// Maps handler DefId → handled effect DefId for effect-row dispatch.
    pub handler_effect_hash: hashmap.HashMapU64U32,
    /// Maps handler DefId → index in handler_effect_type_args_store.
    pub handler_effect_type_args_hash: hashmap.HashMapU64U32,
    /// Stores handler effect type arg lists (indexed by handler_effect_type_args_hash).
    pub handler_effect_type_args_store: Vec<Vec<type_intern.TyId>>,
    /// When inside a deep handler body, the local index boundary.
    /// Locals with index < boundary are outer locals that must not be linear/affine.
    /// None when not inside a deep handler body.
    pub deep_handler_local_boundary: Option<u32>,
    /// Trait default method remapping table.
    /// When a trait default method is used by an impl, calls within the default
    /// method body that target abstract trait methods must be redirected to the
    /// concrete impl methods. This table records those remappings.
    pub default_method_remaps: Vec<common.DefaultMethodRemap>,
    /// Array-to-slice coercion side table.
    /// Records expressions where &[T; N] needs to be coerced to &[T].
    /// MIR lowering uses these to emit Rvalue.ArrayToSlice.
    pub coercion_entries: Vec<common.CoercionEntry>,
    /// DefId index for the persist() builtin, if registered.
    /// Used by infer_call to override return type = argument type.
    pub persist_def_id_index: Option<u32>,
    /// Deferred field accesses whose base type was an unresolved Infer variable.
    /// After all bodies are type-checked, these are revisited to resolve fields.
    pub pending_field_accesses: Vec<common.PendingFieldAccess>,
    /// DefId of the builtin Deref trait, if registered.
    pub deref_trait_def_id: Option<hir_def.DefId>,
    /// DefId of the builtin Freeze marker trait, if registered.
    pub freeze_trait_def_id: Option<hir_def.DefId>,
    /// Deferred trait bound checks (type IDs).
    /// When a where clause bound is checked before type inference has
    /// resolved the type (e.g., unsuffixed integer literals), the check
    /// is deferred and resolved after the function body is fully typed.
    pub pending_bound_check_tys: Vec<type_intern.TyId>,
    /// Deferred trait bound checks (trait DefId indices, parallel with tys).
    pub pending_bound_check_trait_ids: Vec<u32>,
    /// Deferred trait bound checks (spans, parallel with tys).
    pub pending_bound_check_spans: Vec<common.Span>,
    /// Maps ADT DefId.index → Deref Target TyId.index for custom Deref impls.
    /// Populated when processing impl Deref blocks.
    pub deref_target_types: hashmap.HashMapU64U64,
    /// Maps ADT DefId.index → deref method DefId.index for custom Deref impls.
    pub deref_method_ids: hashmap.HashMapU64U64,
    /// Whether we are currently inside an @unsafe block.
    /// Used to gate safety-sensitive casts (Ptr↔usize, Ptr→Ref, fn→integer).
    pub in_unsafe_context: bool,
    /// TyVarId indices for inference variables created from unsuffixed numeric literals.
    /// Unresolved vars are defaulted to i32 (ints) or f64 (floats) after body checking.
    pub numeric_infer_ids: Vec<u32>,
    /// TyVarId indices that are from float literals (subset of numeric_infer_ids).
    /// Used to default unresolved float vars to f64 instead of i32.
    pub float_infer_ids: Vec<u32>,
    /// Index into numeric_infer_ids marking how far defaulting has been applied.
    pub resolved_numeric_cursor: usize,
    /// Temporary: fresh Infer mappings from the most recent instantiate_fn_sig call.
    /// Each entry is (body_ty_var_index, fresh_ty_var_index).
    /// Read by infer_call to extract type param → concrete type bindings.
    pub last_type_param_bindings: Vec<u32>,
    /// Records of calls to type-generic functions with resolved concrete types.
    /// Used by MIR lowering to create monomorphization requests.
    pub type_generic_calls: Vec<common.TypeGenericCallInfo>,
    /// Flat table of impl methods for resolving trait methods during monomorphization.
    /// Each entry maps (self_ty_id, method_name) → method_def_id.
    pub impl_method_table: Vec<common.ImplMethodEntry>,
    /// DefId indices of methods that belong to generic impls (impl<T>).
    /// Used by get_fn_generic_status to treat these as generic even when
    /// the method's own signature has no explicit generics.
    pub generic_impl_method_defs: Vec<u32>,
    /// Human-readable type names indexed by DefId.index.
    /// Populated during struct/enum/effect registration for error messages.
    pub def_names: Vec<Option<String>>,
}

impl TypeChecker {
    /// Creates a new type checker.
    pub fn new() -> TypeChecker {
        TypeChecker {
            subst_table: unify.SubstTable.new(),
            unifier: unify.Unifier.new(),
            return_ty: Option.None,
            in_loop: false,
            loop_ty: Option.None,
            locals: Vec.new(),
            local_base: 0,
            errors: Vec.new(),
            fn_sigs: Vec.new(),
            structs: Vec.new(),
            enums: Vec.new(),
            consts: Vec.new(),
            statics: Vec.new(),
            impls: Vec.new(),
            traits: Vec.new(),
            trait_impls: Vec.new(),
            next_def_id: 0,
            builtin_string_def: Option.None,
            builtin_vec_def: Option.None,
            builtin_option_def: Option.None,
            builtin_box_def: Option.None,
            builtin_hashmap_def: Option.None,
            builtin_result_def: Option.None,
            effects: Vec.new(),
            builtin_def_names: Vec.new(),
            method_resolutions: Vec.new(),
            method_res_hash: hashmap.HashMapU64U64.new(),
            mn_impl_idx: Vec.new(),
            mn_meth_idx: Vec.new(),
            mn_next: Vec.new(),
            mn_heads: hashmap.HashMapU64U64.new(),
            mn_tails: hashmap.HashMapU64U64.new(),
            field_resolutions: Vec.new(),
            pending_method_calls: Vec.new(),
            current_body_def_id: 0,
            current_effect_row: Vec.new(),
            current_effect_type_args: Vec.new(),
            in_handler: false,
            available_effects: Vec.new(),
            available_effect_type_args: Vec.new(),
            variant_hash: hashmap.HashMapU64U64.new(),
            trait_impl_hash: hashmap.HashMapU64U32.new(),
            resume_ty: Option.None,
            in_shallow_handler: false,
            resume_count: 0,
            handler_state_types: Vec.new(),
            handler_kind_hash: hashmap.HashMapU64U32.new(),
            handler_transforming_return_hash: hashmap.HashMapU64U32.new(),
            handler_effect_hash: hashmap.HashMapU64U32.new(),
            handler_effect_type_args_hash: hashmap.HashMapU64U32.new(),
            handler_effect_type_args_store: Vec.new(),
            deep_handler_local_boundary: Option.None,
            default_method_remaps: Vec.new(),
            coercion_entries: Vec.new(),
            persist_def_id_index: Option.None,
            pending_field_accesses: Vec.new(),
            deref_trait_def_id: Option.None,
            freeze_trait_def_id: Option.None,
            pending_bound_check_tys: Vec.new(),
            pending_bound_check_trait_ids: Vec.new(),
            pending_bound_check_spans: Vec.new(),
            deref_target_types: hashmap.HashMapU64U64.new(),
            deref_method_ids: hashmap.HashMapU64U64.new(),
            in_unsafe_context: false,
            numeric_infer_ids: Vec.new(),
            float_infer_ids: Vec.new(),
            resolved_numeric_cursor: 0,
            last_type_param_bindings: Vec.new(),
            type_generic_calls: Vec.new(),
            impl_method_table: Vec.new(),
            generic_impl_method_defs: Vec.new(),
            def_names: Vec.new(),
        }
    }

    /// Creates a new TypeChecker with the type variable counter starting at the given value.
    /// This avoids TyVarId collisions with HIR-allocated inference variables.
    pub fn new_from(start_ty_var: u32) -> TypeChecker {
        TypeChecker {
            subst_table: unify.SubstTable.new(),
            unifier: unify.Unifier.new_from(start_ty_var),
            return_ty: Option.None,
            in_loop: false,
            loop_ty: Option.None,
            locals: Vec.new(),
            local_base: 0,
            errors: Vec.new(),
            fn_sigs: Vec.new(),
            structs: Vec.new(),
            enums: Vec.new(),
            consts: Vec.new(),
            statics: Vec.new(),
            impls: Vec.new(),
            traits: Vec.new(),
            trait_impls: Vec.new(),
            next_def_id: 0,
            builtin_string_def: Option.None,
            builtin_vec_def: Option.None,
            builtin_option_def: Option.None,
            builtin_box_def: Option.None,
            builtin_hashmap_def: Option.None,
            builtin_result_def: Option.None,
            effects: Vec.new(),
            builtin_def_names: Vec.new(),
            method_resolutions: Vec.new(),
            method_res_hash: hashmap.HashMapU64U64.new(),
            mn_impl_idx: Vec.new(),
            mn_meth_idx: Vec.new(),
            mn_next: Vec.new(),
            mn_heads: hashmap.HashMapU64U64.new(),
            mn_tails: hashmap.HashMapU64U64.new(),
            field_resolutions: Vec.new(),
            pending_method_calls: Vec.new(),
            current_body_def_id: 0,
            current_effect_row: Vec.new(),
            current_effect_type_args: Vec.new(),
            in_handler: false,
            available_effects: Vec.new(),
            available_effect_type_args: Vec.new(),
            variant_hash: hashmap.HashMapU64U64.new(),
            trait_impl_hash: hashmap.HashMapU64U32.new(),
            resume_ty: Option.None,
            in_shallow_handler: false,
            resume_count: 0,
            handler_state_types: Vec.new(),
            handler_kind_hash: hashmap.HashMapU64U32.new(),
            handler_transforming_return_hash: hashmap.HashMapU64U32.new(),
            handler_effect_hash: hashmap.HashMapU64U32.new(),
            handler_effect_type_args_hash: hashmap.HashMapU64U32.new(),
            handler_effect_type_args_store: Vec.new(),
            deep_handler_local_boundary: Option.None,
            default_method_remaps: Vec.new(),
            coercion_entries: Vec.new(),
            persist_def_id_index: Option.None,
            pending_field_accesses: Vec.new(),
            deref_trait_def_id: Option.None,
            freeze_trait_def_id: Option.None,
            pending_bound_check_tys: Vec.new(),
            pending_bound_check_trait_ids: Vec.new(),
            pending_bound_check_spans: Vec.new(),
            deref_target_types: hashmap.HashMapU64U64.new(),
            deref_method_ids: hashmap.HashMapU64U64.new(),
            in_unsafe_context: false,
            numeric_infer_ids: Vec.new(),
            float_infer_ids: Vec.new(),
            resolved_numeric_cursor: 0,
            last_type_param_bindings: Vec.new(),
            type_generic_calls: Vec.new(),
            impl_method_table: Vec.new(),
            generic_impl_method_defs: Vec.new(),
            def_names: Vec.new(),
        }
    }

    /// Generates a fresh inference type variable.
    pub fn fresh_infer(self: &mut Self) -> type_intern.TyId {
        self.unifier.fresh_infer_id()
    }

    /// Adds a local variable to the context.
    pub fn add_local(self: &mut Self, ty: type_intern.TyId, mutable: bool, span: common.Span) -> hir_def.LocalId {
        let id = hir_def.LocalId.new(self.locals.len() as u32);
        let info = typeck_types.LocalInfo.new(ty, mutable, span);
        self.locals.push(info);
        id
    }

    /// Gets the type of a local variable.
    pub fn get_local_ty(self: &Self, id: hir_def.LocalId) -> Option<type_intern.TyId> {
        if id.index < self.local_base {
            return Option.None;
        }
        let idx = (id.index - self.local_base) as usize;
        if idx < self.locals.len() {
            let local_ref = &self.locals[idx];
            Some(type_intern.TyId.new(local_ref.ty.index))
        } else {
            Option.None
        }
    }

    /// Checks if a local variable is mutable.
    pub fn is_local_mutable(self: &Self, id: hir_def.LocalId) -> bool {
        if id.index < self.local_base {
            return false;
        }
        let idx = (id.index - self.local_base) as usize;
        if idx < self.locals.len() {
            self.locals[idx].mutable
        } else {
            false
        }
    }

    /// Sets the return type for the current function.
    pub fn set_return_ty(self: &mut Self, ty: type_intern.TyId) {
        self.return_ty = Some(ty);
    }

    /// Clears the return type when exiting a function.
    pub fn clear_return_ty(self: &mut Self) {
        self.return_ty = Option.None;
    }

    /// Enters a loop context.
    pub fn enter_loop(self: &mut Self, ty: type_intern.TyId) {
        self.in_loop = true;
        self.loop_ty = Some(ty);
    }

    /// Exits a loop context.
    pub fn exit_loop(self: &mut Self) {
        self.in_loop = false;
        self.loop_ty = Option.None;
    }

    /// Reports a type error.
    pub fn error(self: &mut Self, kind: typeck_types.TypeErrorKind, span: common.Span) {
        let err = typeck_types.TypeError.new(kind, span);
        self.errors.push(err);
    }

    /// Reports a type error with an additional context note.
    pub fn error_with_note(self: &mut Self, kind: typeck_types.TypeErrorKind, span: common.Span, note: String) {
        let mut err = typeck_types.TypeError.new(kind, span);
        let n = typeck_types.TypeNote.new(note);
        err.notes.push(n);
        self.errors.push(err);
    }

    /// Reports a type error with a note that has a source span.
    pub fn error_with_spanned_note(self: &mut Self, kind: typeck_types.TypeErrorKind, span: common.Span, note: String, note_span: common.Span) {
        let mut err = typeck_types.TypeError.new(kind, span);
        let n = typeck_types.TypeNote.with_span(note, note_span);
        err.notes.push(n);
        self.errors.push(err);
    }

    /// Returns whether any errors have been reported.
    pub fn has_errors(self: &Self) -> bool {
        self.errors.len() > 0
    }

    /// Records a resolved method DefId for a method call expression.
    /// The span_start is the byte offset of the call expression, used as the key.
    /// The def_id_index is the DefId.index of the resolved method.
    pub fn record_method_resolution(self: &mut Self, span_start: usize, def_id_index: u32) {
        self.method_resolutions.push(common.MethodResEntry.new(self.current_body_def_id, span_start, def_id_index));
        let key = ((self.current_body_def_id as u64) << 32) | (span_start as u64);
        self.method_res_hash.insert(key, 1);
    }

    /// Records an array-to-slice coercion for an expression.
    /// The span_start is the byte offset of the expression being coerced.
    pub fn record_coercion(self: &mut Self, span_start: usize, array_len: u64) {
        self.coercion_entries.push(common.CoercionEntry.new(self.current_body_def_id, span_start, array_len));
    }

    /// Records a resolved field index for a named field access expression.
    /// The span_start is the byte offset of the FIELD NAME (not the whole expression).
    /// This is critical: chained accesses like `a.b.c` share the same expr.span.start
    /// but each field name has a unique position.
    pub fn record_field_resolution(self: &mut Self, span_start: usize, field_idx: u32) {
        self.field_resolutions.push(common.FieldResEntry.new(self.current_body_def_id, span_start, field_idx));
    }

    /// Records a call to a type-generic function with resolved concrete type bindings.
    /// Used by MIR lowering to create monomorphization requests.
    pub fn record_type_generic_call(self: &mut Self, info: common.TypeGenericCallInfo) {
        self.type_generic_calls.push(info);
    }

    /// Gets the field index for a struct field by name.
    /// Returns Some(index) where index is the positional index of the field.
    pub fn get_struct_field_idx(self: &Self, def_id: hir_def.DefId, field_name: common.Symbol) -> Option<u32> {
        let struct_info = self.get_struct(def_id);
        match struct_info {
            Some(info) => {
                for i in 0usize..info.fields.len() {
                    if info.fields[i].name.index == field_name.index {
                        return Option.Some(i as u32);
                    }
                }
                Option.None
            }
            None => Option.None,
        }
    }

    /// Records a deferred method call whose receiver is still an Infer variable.
    pub fn record_pending_method_call(self: &mut Self, span_start: usize, receiver_var: u32, method_symbol: common.Symbol, method_name_str: String, return_ty_var: u32) {
        self.pending_method_calls.push(common.PendingMethodCall.new(self.current_body_def_id, span_start, receiver_var, method_symbol, method_name_str, return_ty_var));
    }

    /// Records a deferred field access whose base type is still an Infer variable.
    pub fn record_pending_field_access(self: &mut Self, span_start: usize, base_var: u32, field_symbol: common.Symbol, field_ty_var: u32, field_name_span_start: usize) {
        self.pending_field_accesses.push(common.PendingFieldAccess.new(self.current_body_def_id, span_start, base_var, field_symbol, field_ty_var, field_name_span_start));
    }

    /// Allocates a fresh DefId for synthetic builtin registrations.
    pub fn alloc_def_id(self: &mut Self) -> hir_def.DefId {
        let id = hir_def.DefId.new(self.next_def_id);
        self.next_def_id = self.next_def_id + 1;
        id
    }

    /// Registers a function signature directly with explicit types.
    /// Used for builtin associated functions like String.new(), Vec.new(), etc.
    pub fn register_fn_sig_direct(
        self: &mut Self,
        def_id: hir_def.DefId,
        param_tys: Vec<type_intern.TyId>,
        return_ty: type_intern.TyId,
        num_generics: u32,
    ) {
        let info = typeck_info.FnSigInfo.new(param_tys, return_ty, num_generics);
        let def_idx = def_id.index as usize;
        while self.fn_sigs.len() <= def_idx {
            self.fn_sigs.push(Option.None);
        }
        self.fn_sigs[def_idx] = Some(info);
    }

    /// Unifies two types. Reports errors via self.error on failure.
    pub fn unify(self: &mut Self, a: type_intern.TyId, b: type_intern.TyId, span: common.Span) -> bool {
        let result = unify.unify_id(&mut self.subst_table, &mut self.unifier, a, b, span);

        match result {
            unify.UnifyResult.Ok => true,
            unify.UnifyResult.Err(e) => {
                // Convert unify error to type error
                let kind = match e.kind {
                    unify.UnifyErrorKind.TypeMismatch => typeck_types.TypeErrorKind.TypeMismatch,
                    unify.UnifyErrorKind.OccursCheck => typeck_types.TypeErrorKind.InfiniteType,
                    unify.UnifyErrorKind.ArityMismatch => typeck_types.TypeErrorKind.ArityMismatch,
                    unify.UnifyErrorKind.EffectMismatch => typeck_types.TypeErrorKind.TypeMismatch,
                    unify.UnifyErrorKind.RecordMismatch => typeck_types.TypeErrorKind.TypeMismatch,
                };
                self.error(kind, e.span);
                false
            }
        }
    }

    /// Attempts unification without reporting errors.
    /// Returns true if unification succeeds, false otherwise.
    /// Used by check_expr to try unification before coercion,
    /// deferring error reporting until both have been attempted.
    pub fn try_unify(self: &mut Self, a: type_intern.TyId, b: type_intern.TyId, span: common.Span) -> bool {
        let result = unify.unify_id(&mut self.subst_table, &mut self.unifier, a, b, span);
        match result {
            unify.UnifyResult.Ok => true,
            unify.UnifyResult.Err(_e) => false,
        }
    }

    /// Resolves a type by applying current substitutions.
    pub fn resolve(self: &Self, ty: type_intern.TyId) -> type_intern.TyId {
        let table_ref: &unify.SubstTable = &self.subst_table;
        unify.apply_substs_id(table_ref, ty)
    }

    /// Clears local variables (for entering a new function body).
    pub fn clear_locals(self: &mut Self) {
        self.locals = Vec.new();
        self.local_base = 0;
    }

    // ========================================================
    // Item Registration (for type checking support)
    // ========================================================

    /// Registers a function signature for later lookup.
    pub fn register_fn_sig(self: &mut Self, def_id: hir_def.DefId, sig: &hir_item.FnSig) {
        // Extract parameter types (convert at HIR boundary)
        let mut param_tys: Vec<type_intern.TyId> = Vec.new();
        for i in 0usize..sig.params.len() {
            param_tys.push(sig.params[i].ty);
        }

        // Count type parameters and extract their actual TyVarId indices
        let num_generics = count_type_params(&sig.generics.params);
        let type_param_ids = extract_type_param_ids(&sig.generics.params);

        // Extract effect row DefIds
        let mut effect_def_ids: Vec<u32> = Vec.new();
        for ei in 0usize..sig.effects.effects.len() {
            effect_def_ids.push(sig.effects.effects[ei].def_id.index);
        }

        // Extract where clause predicates and projection metadata
        let where_predicates = hir_ty.copy_where_predicates(&sig.generics.where_predicates);
        let assoc_projections = hir_ty.copy_assoc_projections(&sig.generics.assoc_projections);

        // Create the info with actual param IDs, effect row, and where clauses
        let info = typeck_info.FnSigInfo.with_where_clauses(
            param_tys,
            sig.return_ty,
            num_generics,
            type_param_ids,
            effect_def_ids,
            where_predicates,
            assoc_projections,
        );

        // Store at def_id.index
        let def_idx = def_id.index as usize;
        while self.fn_sigs.len() <= def_idx {
            self.fn_sigs.push(Option.None);
        }
        self.fn_sigs[def_idx] = Some(info);
    }

    /// Registers a function signature with impl-level generics merged in.
    /// For methods in `impl<T> Foo<T>`, the impl's type params are prepended
    /// to the method's own type params so that instantiate_fn_sig creates
    /// fresh inference variables for each call site. Impl-level where
    /// predicates (e.g., `impl<T: Freeze> Frozen<T>`'s `T: Freeze` bound)
    /// are merged ahead of the method's own where predicates so that
    /// check_where_clause_bounds enforces BOTH bound sets at call time
    /// (A1 Phase 3d / GAP-2).
    pub fn register_fn_sig_with_impl_generics(
        self: &mut Self,
        def_id: hir_def.DefId,
        sig: &hir_item.FnSig,
        impl_params: &Vec<hir_ty.GenericParam>,
        impl_where_predicates: &Vec<hir_ty.WherePredicate>,
    ) {
        let mut param_tys: Vec<type_intern.TyId> = Vec.new();
        for i in 0usize..sig.params.len() {
            param_tys.push(sig.params[i].ty);
        }

        // Merge: impl type params first, then method's own type params
        let mut type_param_ids: Vec<u32> = Vec.new();
        let mut num_generics: u32 = 0;
        for i in 0usize..impl_params.len() {
            match &impl_params[i] {
                &hir_ty.GenericParam.TypeParam(ref def) => {
                    type_param_ids.push(def.var_id.index);
                    num_generics += 1;
                }
                &hir_ty.GenericParam.LifetimeParam(_) => {}
                &hir_ty.GenericParam.ConstParam(_) => {}
            }
        }
        num_generics += count_type_params(&sig.generics.params);
        let method_param_ids = extract_type_param_ids(&sig.generics.params);
        for i in 0usize..method_param_ids.len() {
            type_param_ids.push(method_param_ids[i]);
        }

        let mut effect_def_ids: Vec<u32> = Vec.new();
        for ei in 0usize..sig.effects.effects.len() {
            effect_def_ids.push(sig.effects.effects[ei].def_id.index);
        }

        // Merge impl-level where predicates ahead of the method's own so
        // `T: Freeze` on the impl is checked alongside any method-level
        // bounds at each call site.
        let mut where_predicates = hir_ty.copy_where_predicates(impl_where_predicates);
        for wi in 0usize..sig.generics.where_predicates.len() {
            where_predicates.push(hir_ty.copy_where_predicate(&sig.generics.where_predicates[wi]));
        }
        let assoc_projections = hir_ty.copy_assoc_projections(&sig.generics.assoc_projections);

        let info = typeck_info.FnSigInfo.with_where_clauses(
            param_tys,
            sig.return_ty,
            num_generics,
            type_param_ids,
            effect_def_ids,
            where_predicates,
            assoc_projections,
        );

        let def_idx = def_id.index as usize;
        while self.fn_sigs.len() <= def_idx {
            self.fn_sigs.push(Option.None);
        }
        self.fn_sigs[def_idx] = Some(info);
    }

    /// Registers a struct definition for later lookup.
    pub fn register_struct(self: &mut Self, def_id: hir_def.DefId, name: common.Symbol, struct_def: &hir_item.StructDef) {
        // Extract field names and field info based on struct body
        let mut field_names: Vec<common.Symbol> = Vec.new();
        let mut fields: Vec<typeck_info.FieldInfo> = Vec.new();
        match &struct_def.body {
            &hir_item.StructBody.Record(ref struct_fields) => {
                for i in 0usize..struct_fields.len() {
                    let f = &struct_fields[i];
                    field_names.push(f.name.symbol);
                    let info = typeck_info.FieldInfo.new(f.name.symbol, f.ty);
                    fields.push(info);
                }
            }
            &hir_item.StructBody.Tuple(ref types) => {
                // Tuple structs don't have named fields
                let _ = types;
            }
            &hir_item.StructBody.Unit => {
                // Unit structs have no fields
            }
        }

        // Count only type parameters (not lifetime or const params)
        let num_generics = count_type_params(&struct_def.generics.params);
        let type_param_var_ids = extract_type_param_ids(&struct_def.generics.params);

        // Create the info
        let info = typeck_info.StructInfo.new(def_id, name, num_generics, field_names, fields, type_param_var_ids);

        // Store at def_id.index
        let def_idx = def_id.index as usize;
        while self.structs.len() <= def_idx {
            self.structs.push(Option.None);
        }
        self.structs[def_idx] = Some(info);
    }

    /// Registers an enum definition for later lookup.
    pub fn register_enum(self: &mut Self, def_id: hir_def.DefId, name: common.Symbol, enum_def: &hir_item.EnumDef) {
        // Extract variant names and variant info
        let mut variant_names: Vec<common.Symbol> = Vec.new();
        let mut variants: Vec<typeck_info.VariantInfo> = Vec.new();
        for i in 0usize..enum_def.variants.len() {
            let v = &enum_def.variants[i];
            variant_names.push(v.name.symbol);

            // Extract field types and names based on variant kind
            let mut field_tys: Vec<type_intern.TyId> = Vec.new();
            let mut field_names: Vec<common.Symbol> = Vec.new();
            match &v.kind {
                &hir_item.VariantKind.Unit => {
                    // No fields
                }
                &hir_item.VariantKind.Tuple(ref types) => {
                    for j in 0usize..types.len() {
                        field_tys.push(types[j]);
                    }
                }
                &hir_item.VariantKind.Record(ref struct_fields) => {
                    // For record variants, store both field names and types
                    for j in 0usize..struct_fields.len() {
                        field_names.push(struct_fields[j].name.symbol);
                        field_tys.push(struct_fields[j].ty);
                    }
                }
            }

            let info = if field_names.len() > 0 {
                typeck_info.VariantInfo.with_field_names(v.name.symbol, field_tys, field_names, i as u32, v.def_id)
            } else {
                typeck_info.VariantInfo.with_def_id(v.name.symbol, field_tys, i as u32, v.def_id)
            };
            variants.push(info);
        }

        // Count only type parameters (not lifetime or const params)
        let num_generics = count_type_params(&enum_def.generics.params);
        let type_param_var_ids = extract_type_param_ids(&enum_def.generics.params);

        // Create the info
        let info = typeck_info.EnumInfo.new(def_id, name, num_generics, variant_names, variants, type_param_var_ids);

        // Store at def_id.index
        let def_idx = def_id.index as usize;
        while self.enums.len() <= def_idx {
            self.enums.push(Option.None);
        }
        self.enums[def_idx] = Some(info);

        // Populate variant_hash for O(1) variant lookups
        for vi in 0usize..enum_def.variants.len() {
            let var_def_id = enum_def.variants[vi].def_id;
            // Combine enum_idx and variant_idx into a single u64
            let combined = hashmap.combine_u32_usize(def_id.index, vi);
            self.variant_hash.insert(var_def_id.index as u64, combined);
        }
    }

    // ========================================================
    // Item Lookup
    // ========================================================

    /// Gets a function signature by DefId in O(1) time.
    pub fn get_fn_sig(self: &Self, def_id: hir_def.DefId) -> Option<&typeck_info.FnSigInfo> {
        let def_idx = def_id.index as usize;
        if def_idx >= self.fn_sigs.len() {
            return Option.None;
        }
        match &self.fn_sigs[def_idx] {
            &Some(ref info) => Some(info),
            &None => Option.None,
        }
    }

    /// Gets a struct info by DefId in O(1) time.
    pub fn get_struct(self: &Self, def_id: hir_def.DefId) -> Option<&typeck_info.StructInfo> {
        let def_idx = def_id.index as usize;
        if def_idx >= self.structs.len() {
            return Option.None;
        }
        match &self.structs[def_idx] {
            &Some(ref info) => Some(info),
            &None => Option.None,
        }
    }

    /// Gets the number of generic parameters for a struct by DefId.
    /// Returns 0 if the struct is not found (non-generic default).
    /// This returns a value type (u32) to avoid Option<&T> reference issues.
    pub fn get_struct_num_generics(self: &Self, def_id: hir_def.DefId) -> u32 {
        let def_idx = def_id.index as usize;
        if def_idx >= self.structs.len() {
            return 0;
        }
        match &self.structs[def_idx] {
            &Some(ref info) => info.num_generics,
            &None => 0,
        }
    }

    /// Gets the number of fields for a struct by DefId.
    /// Returns 0 if the struct is not found.
    pub fn get_struct_num_fields(self: &Self, def_id: hir_def.DefId) -> u32 {
        let def_idx = def_id.index as usize;
        if def_idx >= self.structs.len() {
            return 0;
        }
        match &self.structs[def_idx] {
            &Some(ref info) => info.field_names.len() as u32,
            &None => 0,
        }
    }

    /// Returns true if a struct with the given DefId is registered.
    pub fn has_struct(self: &Self, def_id: hir_def.DefId) -> bool {
        let def_idx = def_id.index as usize;
        if def_idx >= self.structs.len() {
            return false;
        }
        match &self.structs[def_idx] {
            &Some(_) => true,
            &None => false,
        }
    }

    /// Gets an enum info by DefId in O(1) time.
    pub fn get_enum(self: &Self, def_id: hir_def.DefId) -> Option<&typeck_info.EnumInfo> {
        let def_idx = def_id.index as usize;
        if def_idx >= self.enums.len() {
            return Option.None;
        }
        match &self.enums[def_idx] {
            &Some(ref info) => Some(info),
            &None => Option.None,
        }
    }

    /// Finds a variant's index by its DefId across all registered enums.
    /// Returns (enum_def_id, variant_index) if found.
    pub fn find_variant_index_by_def_id(self: &Self, variant_def_id: hir_def.DefId) -> Option<u32> {
        // O(1) hash lookup. variant_hash is authoritative — both register_enum
        // and the builtin Option/Result registrations populate it. A miss means
        // the def_id is not a variant.
        match self.variant_hash.get(variant_def_id.index as u64) {
            Option.Some(combined) => {
                // Extract variant_idx from combined value (lower 32 bits)
                let variant_idx = (combined & 0xFFFFFFFF) as u32;
                Option.Some(variant_idx)
            }
            Option.None => Option.None,
        }
    }

    /// Finds the parent enum info for a variant DefId.
    /// Returns the enum's DefId, number of generics, and the variant's field types.
    pub fn find_enum_for_variant(self: &Self, variant_def_id: hir_def.DefId) -> Option<EnumVariantLookup> {
        // O(1) hash lookup. variant_hash is authoritative — both register_enum
        // and the builtin Option/Result registrations populate it. A miss means
        // the def_id is not a variant; do not fall back to a linear scan over
        // every enum × every variant (that scan ran on every failed infer_path
        // resolution and was a meaningful fraction of Phase 2b cost).
        match self.variant_hash.get(variant_def_id.index as u64) {
            Option.Some(combined) => {
                // Extract enum_idx and variant_idx from combined value
                let enum_idx = (combined >> 32) as usize;
                let variant_idx = (combined & 0xFFFFFFFF) as usize;
                if enum_idx < self.enums.len() {
                    match &self.enums[enum_idx] {
                        &Some(ref enum_info) => {
                            if variant_idx < enum_info.variants.len() {
                                let mut fn_vec: Vec<common.Symbol> = Vec.new();
                                for k in 0usize..enum_info.variants[variant_idx].field_names.len() {
                                    fn_vec.push(enum_info.variants[variant_idx].field_names[k]);
                                }
                                let mut tpvi: Vec<u32> = Vec.new();
                                for tpi in 0usize..enum_info.type_param_var_ids.len() {
                                    tpvi.push(enum_info.type_param_var_ids[tpi]);
                                }
                                return Option.Some(EnumVariantLookup {
                                    enum_def_id: enum_info.def_id,
                                    num_generics: enum_info.num_generics,
                                    variant_index: enum_info.variants[variant_idx].variant_index,
                                    field_tys: copy_ty_id_vec(&enum_info.variants[variant_idx].field_tys),
                                    field_names: fn_vec,
                                    type_param_var_ids: tpvi,
                                });
                            }
                        }
                        &None => {}
                    }
                }
            }
            Option.None => {}
        }
        Option.None
    }

    /// Gets the field type for a struct field by name.
    pub fn get_struct_field_ty(self: &Self, def_id: hir_def.DefId, field_name: common.Symbol) -> Option<type_intern.TyId> {
        let struct_info = self.get_struct(def_id);
        match struct_info {
            Some(info) => {
                for i in 0usize..info.fields.len() {
                    if info.fields[i].name.index == field_name.index {
                        return Some(type_intern.TyId.new(info.fields[i].ty.index));
                    }
                }
                Option.None
            }
            None => Option.None,
        }
    }

    /// Gets a variant's field type by name using the variant's DefId.
    /// Returns the field type if found, None otherwise.
    pub fn get_variant_field_ty_by_name(self: &Self, variant_def_id: hir_def.DefId, field_name: common.Symbol) -> Option<type_intern.TyId> {
        // O(1) hash lookup. variant_hash is authoritative; a miss means the
        // def_id is not a variant.
        match self.variant_hash.get(variant_def_id.index as u64) {
            Option.Some(combined) => {
                let enum_idx = (combined >> 32) as usize;
                let variant_idx = (combined & 0xFFFFFFFF) as usize;
                if enum_idx < self.enums.len() {
                    match &self.enums[enum_idx] {
                        &Some(ref enum_info) => {
                            if variant_idx < enum_info.variants.len() {
                                // Found the variant - look up field by name
                                for k in 0usize..enum_info.variants[variant_idx].field_names.len() {
                                    if enum_info.variants[variant_idx].field_names[k].index == field_name.index {
                                        if k < enum_info.variants[variant_idx].field_tys.len() {
                                            return Some(type_intern.TyId.new(enum_info.variants[variant_idx].field_tys[k].index));
                                        }
                                    }
                                }
                                return Option.None;
                            }
                        }
                        &None => {}
                    }
                }
            }
            Option.None => {}
        }
        Option.None
    }

    /// Gets a const info by DefId in O(1) time.
    pub fn get_const(self: &Self, def_id: hir_def.DefId) -> Option<&typeck_info.ConstInfo> {
        let def_idx = def_id.index as usize;
        if def_idx >= self.consts.len() {
            return Option.None;
        }
        match &self.consts[def_idx] {
            &Some(ref info) => Some(info),
            &None => Option.None,
        }
    }

    /// Gets a static info by DefId in O(1) time.
    pub fn get_static(self: &Self, def_id: hir_def.DefId) -> Option<&typeck_info.StaticInfo> {
        let def_idx = def_id.index as usize;
        if def_idx >= self.statics.len() {
            return Option.None;
        }
        match &self.statics[def_idx] {
            &Some(ref info) => Some(info),
            &None => Option.None,
        }
    }

    /// Registers a constant definition for later lookup.
    pub fn register_const(self: &mut Self, def_id: hir_def.DefId, name: common.Symbol, ty: type_intern.TyId) {
        let info = typeck_info.ConstInfo.new(def_id, name, ty);
        let def_idx = def_id.index as usize;
        while self.consts.len() <= def_idx {
            self.consts.push(Option.None);
        }
        self.consts[def_idx] = Some(info);
    }

    /// Registers a static definition for later lookup.
    pub fn register_static(self: &mut Self, def_id: hir_def.DefId, name: common.Symbol, ty: type_intern.TyId, mutable: bool) {
        let info = typeck_info.StaticInfo.new(def_id, name, ty, mutable);
        let def_idx = def_id.index as usize;
        while self.statics.len() <= def_idx {
            self.statics.push(Option.None);
        }
        self.statics[def_idx] = Some(info);
    }

    /// Registers an impl block for method resolution.
    pub fn register_impl(self: &mut Self, impl_info: typeck_info.ImplInfo) {
        // If this is a trait impl, mark trait as having an impl for O(1) lookup
        if impl_info.is_trait_impl() {
            self.trait_impl_hash.insert(impl_info.trait_def_id_index as u64, 1);
        }
        let impl_idx = self.impls.len();
        // Index methods by name for O(1) lookup (append to preserve registration order)
        for mi in 0usize..impl_info.methods.len() {
            let name_key = impl_info.methods[mi].name.index as u64;
            let entry_idx = self.mn_impl_idx.len();
            self.mn_impl_idx.push(impl_idx);
            self.mn_meth_idx.push(mi);
            self.mn_next.push(0xFFFFFFFF);
            let tail_opt = self.mn_tails.get(name_key);
            match tail_opt {
                Option.Some(old_tail) => {
                    self.mn_next[old_tail as usize] = entry_idx;
                }
                Option.None => {
                    self.mn_heads.insert(name_key, entry_idx as u64);
                }
            }
            self.mn_tails.insert(name_key, entry_idx as u64);
        }
        self.impls.push(impl_info);
    }

    /// Looks up a method on a type by name.
    /// Returns the method info and the impl it belongs to, or None if not found.
    pub fn lookup_method(self: &Self, ty: type_intern.TyId, method_name: common.Symbol) -> Option<MethodLookupResult> {
        let name_key = method_name.index as u64;
        let head_opt = self.mn_heads.get(name_key);
        let mut cursor = match head_opt {
            Option.Some(h) => h as usize,
            Option.None => { return Option.None; },
        };
        while cursor != 0xFFFFFFFF {
            let impl_idx = self.mn_impl_idx[cursor];
            let method_idx = self.mn_meth_idx[cursor];
            let impl_info = &self.impls[impl_idx];
            if types_match_for_impl_id(impl_info.self_ty, ty) {
                if self.impl_bounds_satisfied(impl_info, ty) {
                    return Some(MethodLookupResult {
                        impl_index: impl_idx,
                        method_index: method_idx,
                    });
                }
            }
            cursor = self.mn_next[cursor];
        }
        Option.None
    }

    /// Counts how many impls provide a method with the given name for the given type.
    /// Early-exits as soon as 2 matches are found — the only caller
    /// (infer_method_call) uses this purely to decide between the single-match
    /// and overloaded-resolution paths, so it doesn't care whether the true count
    /// is 2 or 20. Walking the full chain for every method call wasted cycles
    /// proportional to the average method-name length in the impl table.
    pub fn count_method_matches(self: &Self, ty: type_intern.TyId, method_name: common.Symbol) -> u32 {
        let mut count: u32 = 0;
        let name_key = method_name.index as u64;
        let head_opt = self.mn_heads.get(name_key);
        let mut cursor = match head_opt {
            Option.Some(h) => h as usize,
            Option.None => { return 0; },
        };
        while cursor != 0xFFFFFFFF {
            let impl_idx = self.mn_impl_idx[cursor];
            let impl_info = &self.impls[impl_idx];
            if types_match_for_impl_id(impl_info.self_ty, ty) {
                if self.impl_bounds_satisfied(impl_info, ty) {
                    count += 1;
                    if count >= 2 {
                        return count;
                    }
                }
            }
            cursor = self.mn_next[cursor];
        }
        count
    }

    /// Gets method info from a lookup result.
    pub fn get_method_from_lookup(self: &Self, result: &MethodLookupResult) -> &typeck_info.MethodInfo {
        &self.impls[result.impl_index].methods[result.method_index]
    }

    /// Gets the impl info from a lookup result.
    pub fn get_impl_from_lookup(self: &Self, result: &MethodLookupResult) -> &typeck_info.ImplInfo {
        &self.impls[result.impl_index]
    }

    /// Checks whether the concrete type args of `target_ty` satisfy all trait bounds
    /// on the impl's generic parameters. Returns true if no bounds exist or all are satisfied.
    fn impl_bounds_satisfied(self: &Self, impl_info: &typeck_info.ImplInfo, target_ty: type_intern.TyId) -> bool {
        if impl_info.impl_bounds.len() == 0 {
            return true;
        }
        // Extract concrete type args from the target type
        let target_args = type_intern.get_adt_args(target_ty);
        match &target_args {
            &Option.None => { return true; }
            &Option.Some(args_list) => {
                let interner = type_intern.type_interner();
                let num_args = interner.ty_list_len(args_list);
                for param_idx in 0usize..impl_info.impl_bounds.len() {
                    let bounds = &impl_info.impl_bounds[param_idx];
                    if bounds.len() == 0 {
                        continue;
                    }
                    if param_idx >= num_args {
                        break;
                    }
                    let concrete_ty = interner.get_ty_list_element(args_list, param_idx);
                    // Skip bound checking for unresolved inference variables
                    let concrete_kind = interner.get(concrete_ty);
                    let is_unresolved = match concrete_kind {
                        &type_intern.InternedTypeKind.Infer(_) => true,
                        &type_intern.InternedTypeKind.Param(_) => true,
                        _ => false,
                    };
                    if is_unresolved {
                        continue;
                    }
                    for bi in 0usize..bounds.len() {
                        let trait_ref = hir_ty.TraitRef.new(
                            hir_def.DefId.new(bounds[bi]),
                            Vec.new(),
                            common.Span { start: 0, end: 0, line: 0, column: 0 },
                        );
                        if !self.type_implements_trait(concrete_ty, &trait_ref) {
                            return false;
                        }
                    }
                }
                true
            }
        }
    }

    /// Looks up a method on a type by name with overload resolution using argument types.
    /// When multiple methods share the same name, selects the one whose parameter types
    /// best match the given argument types. Uses specificity scoring:
    /// - Exact concrete match: +2 points per arg
    /// - Flexible match (one side is Infer/Param): +1 point per arg
    /// - Concrete mismatch: method disqualified (score 0, incompatible)
    /// The method with the highest score wins. Ties (ambiguous) return None.
    pub fn lookup_method_overloaded(
        self: &Self,
        ty: type_intern.TyId,
        method_name: common.Symbol,
        arg_tys: &Vec<type_intern.TyId>,
    ) -> Option<MethodLookupResult> {
        // Phase 1: Collect all applicable candidates (name + arity + per-param subtype)
        let mut applicable_impls: Vec<usize> = Vec.new();
        let mut applicable_methods: Vec<usize> = Vec.new();

        let name_key = method_name.index as u64;
        let head_opt = self.mn_heads.get(name_key);
        let mut cursor = match head_opt {
            Option.Some(h) => h as usize,
            Option.None => { return Option.None; },
        };
        while cursor != 0xFFFFFFFF {
            let impl_idx = self.mn_impl_idx[cursor];
            let method_idx = self.mn_meth_idx[cursor];
            let impl_info = &self.impls[impl_idx];
            if types_match_for_impl_id(impl_info.self_ty, ty) {
                if self.impl_bounds_satisfied(impl_info, ty) {
                    let method = &impl_info.methods[method_idx];
                    if method.param_tys.len() == arg_tys.len() {
                        let mut applicable: bool = true;
                        for pi in 0usize..arg_tys.len() {
                            if !typeck_dispatch.is_subtype_id(arg_tys[pi], method.param_tys[pi], 0) {
                                applicable = false;
                                break;
                            }
                        }
                        // Also check method-level type param bounds.
                        // For format<T: A+B>(x: &T), verify the concrete arg type
                        // satisfies ALL bounds on T.
                        if applicable && method.type_param_bounds.len() > 0 {
                            for tpi in 0usize..method.type_param_bounds.len() {
                                if !applicable { break; }
                                let bounds = &method.type_param_bounds[tpi];
                                if bounds.len() == 0 { continue; }
                                // The type param at index tpi corresponds to the argument
                                // at the same index (for methods with one type param per arg).
                                // For now, check against ALL concrete arg types.
                                if tpi < arg_tys.len() {
                                    let arg_ty = strip_refs_for_bounds(arg_tys[tpi]);
                                    for bi in 0usize..bounds.len() {
                                        let trait_ref = hir_ty.TraitRef.new(
                                            hir_def.DefId.new(bounds[bi]),
                                            Vec.new(),
                                            common.Span { start: 0, end: 0, line: 0, column: 0 },
                                        );
                                        if !self.type_implements_trait(arg_ty, &trait_ref) {
                                            applicable = false;
                                        }
                                    }
                                }
                            }
                        }
                        if applicable {
                            applicable_impls.push(impl_idx);
                            applicable_methods.push(method_idx);
                        }
                    }
                }
            }
            cursor = self.mn_next[cursor];
        }

        if applicable_impls.len() == 0 {
            return Option.None;
        }

        // Phase 1.5: Filter by effect compatibility with caller's current_effect_row.
        // A method is compatible if all its declared effects are in the caller's row.
        // Pure methods (empty effect_def_ids) are always compatible.
        if applicable_impls.len() > 1 {
            let mut compat_impls: Vec<usize> = Vec.new();
            let mut compat_methods: Vec<usize> = Vec.new();
            for ci in 0usize..applicable_impls.len() {
                let method = &self.impls[applicable_impls[ci]].methods[applicable_methods[ci]];
                let mut all_in_scope: bool = true;
                for ei in 0usize..method.effect_def_ids.len() {
                    let mut found: bool = false;
                    // Check function's declared effect row
                    for ri in 0usize..self.current_effect_row.len() {
                        if method.effect_def_ids[ei] == self.current_effect_row[ri] {
                            found = true;
                        }
                    }
                    // Check effects available from enclosing with...handle blocks
                    for ai in 0usize..self.available_effects.len() {
                        if method.effect_def_ids[ei] == self.available_effects[ai] {
                            found = true;
                        }
                    }
                    if !found {
                        all_in_scope = false;
                    }
                }
                if all_in_scope {
                    compat_impls.push(applicable_impls[ci]);
                    compat_methods.push(applicable_methods[ci]);
                }
            }
            if compat_impls.len() > 0 {
                // Among compatible methods, prefer the one with the most effects
                // that match the available context (most specialized for this context).
                let mut best_idx: usize = 0;
                let mut best_effect_count: usize = 0;
                for bi in 0usize..compat_impls.len() {
                    let m = &self.impls[compat_impls[bi]].methods[compat_methods[bi]];
                    if m.effect_def_ids.len() > best_effect_count {
                        best_effect_count = m.effect_def_ids.len();
                        best_idx = bi;
                    }
                }
                // If one method has strictly more effects, prefer it directly
                let mut all_same_count: bool = true;
                for bi in 0usize..compat_impls.len() {
                    let m = &self.impls[compat_impls[bi]].methods[compat_methods[bi]];
                    if m.effect_def_ids.len() != best_effect_count {
                        all_same_count = false;
                    }
                }
                if !all_same_count && compat_impls.len() > 1 {
                    // Direct selection: most effects wins
                    return Some(MethodLookupResult {
                        impl_index: compat_impls[best_idx],
                        method_index: compat_methods[best_idx],
                    });
                }
                applicable_impls = compat_impls;
                applicable_methods = compat_methods;
            }
        }

        if applicable_impls.len() == 1 {
            return Some(MethodLookupResult {
                impl_index: applicable_impls[0],
                method_index: applicable_methods[0],
            });
        }

        // Phase 2: Find maximal — candidates where no other is strictly more specific
        let mut maximal_idx: Vec<usize> = Vec.new();
        for i in 0usize..applicable_impls.len() {
            let m_i = &self.impls[applicable_impls[i]].methods[applicable_methods[i]];
            let mut is_maximal: bool = true;
            for j in 0usize..applicable_impls.len() {
                if i == j {
                    continue;
                }
                let m_j = &self.impls[applicable_impls[j]].methods[applicable_methods[j]];
                if typeck_dispatch.is_more_specific(m_j, m_i) {
                    is_maximal = false;
                    break;
                }
            }
            if is_maximal {
                maximal_idx.push(i);
            }
        }

        if maximal_idx.len() == 1 {
            let idx = maximal_idx[0];
            Some(MethodLookupResult {
                impl_index: applicable_impls[idx],
                method_index: applicable_methods[idx],
            })
        } else {
            // 0 = no candidate is maximal (cycle), >1 = ambiguous
            Option.None
        }
    }

    /// Gets a variant's index by name within an enum.
    pub fn get_variant_index(self: &Self, enum_def_id: hir_def.DefId, variant_name: common.Symbol) -> Option<u32> {
        let enum_info = self.get_enum(enum_def_id);
        match enum_info {
            Some(info) => {
                for i in 0usize..info.variants.len() {
                    if info.variants[i].name.index == variant_name.index {
                        return Some(info.variants[i].variant_index);
                    }
                }
                Option.None
            }
            None => Option.None,
        }
    }

    // ========================================================
    // Trait Registration and Resolution
    // ========================================================

    /// Registers a trait definition for later lookup.
    pub fn register_trait(self: &mut Self, def_id: hir_def.DefId, info: typeck_info.TraitInfo) {
        let def_idx = def_id.index as usize;
        while self.traits.len() <= def_idx {
            self.traits.push(Option.None);
        }
        self.traits[def_idx] = Some(info);
    }

    /// Gets a trait definition by DefId.
    pub fn get_trait(self: &Self, def_id: hir_def.DefId) -> Option<&typeck_info.TraitInfo> {
        let def_idx = def_id.index as usize;
        if def_idx < self.traits.len() {
            match &self.traits[def_idx] {
                &Option.Some(ref info) => Some(info),
                &Option.None => Option.None,
            }
        } else {
            Option.None
        }
    }

    /// Checks if a trait is object-safe by looking up its TraitInfo and
    /// running the object safety rules from DISPATCH.md §10.7.
    pub fn is_trait_object_safe(self: &Self, trait_id: hir_def.DefId) -> bool {
        match self.get_trait(trait_id) {
            Option.Some(info) => {
                match typeck_dispatch.check_trait_object_safety(info) {
                    typeck_dispatch.ObjectSafetyResult.Safe => true,
                    typeck_dispatch.ObjectSafetyResult.Unsafe(_) => false,
                }
            }
            Option.None => false,
        }
    }

    /// Registers synthetic impl blocks for `dyn Trait` types.
    /// Called after all traits are registered. Creates an impl entry with
    /// `self_ty = DynTrait { trait_id, [] }` for each trait, allowing
    /// the standard lookup_method path to resolve methods on dyn Trait.
    pub fn register_dyn_trait_impls(self: &mut Self) {
        // Iterate all registered traits
        for trait_idx in 0usize..self.traits.len() {
            match &self.traits[trait_idx] {
                &Option.Some(ref trait_info) => {
                    // Skip object-unsafe traits
                    match typeck_dispatch.check_trait_object_safety(trait_info) {
                        typeck_dispatch.ObjectSafetyResult.Unsafe(_) => { continue; }
                        typeck_dispatch.ObjectSafetyResult.Safe => {}
                    }
                    // Create a DynTrait type for this trait
                    let empty_auto: Vec<hir_def.DefId> = Vec.new();
                    let dyn_ty = type_intern.type_interner().intern(
                        type_intern.InternedTypeKind.DynTrait {
                            trait_id: trait_info.def_id,
                            auto_traits: empty_auto,
                        }
                    );
                    // Convert TraitMethodInfo → MethodInfo (include supertrait methods)
                    let mut methods: Vec<typeck_info.MethodInfo> = Vec.new();
                    // First, add supertrait methods (recursively via chain)
                    self.collect_supertrait_methods_for_dyn(trait_info, &mut methods);
                    // Then add own methods
                    for mi in 0usize..trait_info.methods.len() {
                        let tm = &trait_info.methods[mi];
                        // Copy param_tys
                        let mut ptys: Vec<type_intern.TyId> = Vec.new();
                        for pi in 0usize..tm.param_tys.len() {
                            ptys.push(tm.param_tys[pi]);
                        }
                        methods.push(typeck_info.MethodInfo.new(
                            tm.def_id,
                            tm.name,
                            ptys,
                            tm.return_ty,
                            tm.takes_self_ref,
                            tm.takes_self_mut,
                            Vec.new(),
                            Vec.new(),
                            common.Span { start: 0, end: 0, line: 0, column: 0 },
                        ));
                    }
                    // Register as a synthetic impl
                    let synth_impl = typeck_info.ImplInfo.new(
                        trait_info.def_id,  // use trait's DefId as impl DefId
                        dyn_ty,
                        0,  // no generics on dyn Trait
                        Vec.new(),  // no type_param_ids
                        methods,
                    );
                    let synth_impl_idx = self.impls.len();
                    for smi in 0usize..synth_impl.methods.len() {
                        let sname_key = synth_impl.methods[smi].name.index as u64;
                        let sentry_idx = self.mn_impl_idx.len();
                        self.mn_impl_idx.push(synth_impl_idx);
                        self.mn_meth_idx.push(smi);
                        self.mn_next.push(0xFFFFFFFF);
                        let stail_opt = self.mn_tails.get(sname_key);
                        match stail_opt {
                            Option.Some(old_tail) => {
                                self.mn_next[old_tail as usize] = sentry_idx;
                            }
                            Option.None => {
                                self.mn_heads.insert(sname_key, sentry_idx as u64);
                            }
                        }
                        self.mn_tails.insert(sname_key, sentry_idx as u64);
                    }
                    self.impls.push(synth_impl);
                }
                &Option.None => {}
            }
        }
    }

    /// Collects methods from all supertraits (recursively) for dyn dispatch.
    fn collect_supertrait_methods_for_dyn(
        self: &Self,
        trait_info: &typeck_info.TraitInfo,
        methods: &mut Vec<typeck_info.MethodInfo>,
    ) {
        for si in 0usize..trait_info.supertrait_ids.len() {
            let super_id = trait_info.supertrait_ids[si];
            match self.get_trait(super_id) {
                Option.Some(super_info) => {
                    // Recurse into super-supertraits first
                    self.collect_supertrait_methods_for_dyn(super_info, methods);
                    // Add this supertrait's methods
                    for mi in 0usize..super_info.methods.len() {
                        let tm = &super_info.methods[mi];
                        let mut ptys: Vec<type_intern.TyId> = Vec.new();
                        for pi in 0usize..tm.param_tys.len() {
                            ptys.push(tm.param_tys[pi]);
                        }
                        methods.push(typeck_info.MethodInfo.new(
                            tm.def_id,
                            tm.name,
                            ptys,
                            tm.return_ty,
                            tm.takes_self_ref,
                            tm.takes_self_mut,
                            Vec.new(),
                            Vec.new(),
                            common.Span { start: 0, end: 0, line: 0, column: 0 },
                        ));
                    }
                }
                Option.None => {}
            }
        }
    }

    /// Registers a trait implementation.
    pub fn register_trait_impl(self: &mut Self, impl_info: typeck_info.TraitImplInfo) {
        // Mark this trait as having at least one impl
        self.trait_impl_hash.insert(impl_info.trait_def_id.index as u64, 1);
        self.trait_impls.push(impl_info);
    }

    /// Registers an effect definition.
    pub fn register_effect(self: &mut Self, def_id: hir_def.DefId, info: typeck_info.EffectInfo) {
        let def_idx = def_id.index as usize;
        while self.effects.len() <= def_idx {
            self.effects.push(Option.None);
        }
        self.effects[def_idx] = Some(info);
    }

    /// Checks if an effect is registered.
    pub fn has_effect(self: &Self, def_id: hir_def.DefId) -> bool {
        let def_idx = def_id.index as usize;
        if def_idx >= self.effects.len() {
            return false;
        }
        match &self.effects[def_idx] {
            &Some(_) => true,
            &None => false,
        }
    }

    /// Gets the number of operations for an effect.
    pub fn get_effect_num_ops(self: &Self, def_id: hir_def.DefId) -> u32 {
        let def_idx = def_id.index as usize;
        if def_idx >= self.effects.len() {
            return 0;
        }
        match &self.effects[def_idx] {
            &Some(ref info) => info.operations.len() as u32,
            &None => 0,
        }
    }

    /// Checks if a type implements a trait.
    /// Returns true if an implementation exists.
    ///
    /// Resolution order:
    ///   1. Manual user impls (e.g., `impl Freeze for MyType {}`) — user intent wins.
    ///   2. Auto-derived Freeze for types with no matching manual impl — primitives,
    ///      shared refs, closures, and structurally-Freeze ADTs.
    /// This ordering means users can opt a non-structurally-Freeze type INTO Freeze
    /// via explicit impl, but cannot opt out of structural Freeze (consistent with
    /// the marker-trait semantics: auto-derive is a safety floor, not a ceiling).
    pub fn type_implements_trait(self: &Self, ty: type_intern.TyId, trait_ref: &hir_ty.TraitRef) -> bool {
        // Manual impls first (user's `impl Freeze for T {}` wins).
        let target_trait_idx = trait_ref.def_id.index;
        match self.trait_impl_hash.get(target_trait_idx as u64) {
            Option.Some(_) => {
                for i in 0usize..self.impls.len() {
                    let impl_info = &self.impls[i];
                    if impl_info.trait_def_id_index == target_trait_idx {
                        if types_match_for_impl_id(impl_info.self_ty, ty) {
                            if self.impl_bounds_satisfied(impl_info, ty) {
                                return true;
                            }
                        }
                    }
                }
            }
            Option.None => {}
        }

        // Auto-derive Freeze as a fallback when no manual impl matches.
        match &self.freeze_trait_def_id {
            &Option.Some(ref freeze_id) => {
                if target_trait_idx == freeze_id.index {
                    let resolved = self.resolve(ty);
                    return type_is_freeze(resolved, &self.structs);
                }
            }
            &Option.None => {}
        }

        false
    }

    /// Resolves an obligation (checks if a predicate is satisfied).
    /// Returns true if the obligation is satisfied.
    pub fn resolve_obligation(self: &Self, obligation: &typeck_types.Obligation) -> bool {
        match &obligation.predicate {
            &typeck_types.Predicate.Trait(ref trait_ref) => {
                // For trait bounds, we need to find an impl
                // The trait ref contains the type parameter that must implement the trait
                // For now, we check if any impl exists for the trait
                self.has_impl_for_trait(trait_ref.def_id)
            }
            &typeck_types.Predicate.TypeEqual { left, right } => {
                // For type equality, types must unify
                // We can't mutate here, so do a simple structural check
                types_structurally_equal_id(left, right)
            }
            &typeck_types.Predicate.WellFormed(_) => {
                // WF predicates are assumed satisfied for now
                true
            }
        }
    }

    /// Checks if any implementation exists for a trait.
    fn has_impl_for_trait(self: &Self, trait_def_id: hir_def.DefId) -> bool {
        // O(1) hash lookup
        match self.trait_impl_hash.get(trait_def_id.index as u64) {
            Option.Some(_) => true,
            Option.None => false,
        }
    }

    /// Checks trait bounds from where clauses for a generic function call.
    /// `arg_types` are the resolved types of the actual arguments.
    pub fn check_where_clause_bounds(
        self: &mut Self,
        fn_sig: &typeck_info.FnSigInfo,
        arg_types: &Vec<type_intern.TyId>,
        span: common.Span,
    ) {
        if fn_sig.where_predicates.len() == 0 {
            return;
        }

        for pi in 0usize..fn_sig.where_predicates.len() {
            match &fn_sig.where_predicates[pi] {
                &hir_ty.WherePredicate.TypeBound { ref ty, ref bounds, span: pred_span } => {
                    // Find what concrete type was substituted for this type param.
                    // The constrained type is Infer(param_id) — find which parameter
                    // position uses that Infer ID, then get the resolved arg type.
                    let concrete_ty = self.resolve_where_param_type(ty, fn_sig, arg_types);
                    match &concrete_ty {
                        &Option.Some(resolved_ty) => {
                            // Resolve through subst table to get concrete types
                            let final_ty = self.resolve(resolved_ty);
                            // Check if the type is still an unresolved Infer variable.
                            // If so, defer the check until after the full expression
                            // has been type-checked (e.g., unsuffixed integer literals
                            // get their concrete type from context like `let a: i32`).
                            let interner = type_intern.type_interner();
                            let final_kind = interner.get(final_ty);
                            let is_infer = match final_kind {
                                &type_intern.InternedTypeKind.Infer(_) => true,
                                _ => false,
                            };
                            if is_infer {
                                // Defer: store the Infer TyId, trait DefId, and span
                                for bi in 0usize..bounds.len() {
                                    self.pending_bound_check_tys.push(final_ty);
                                    self.pending_bound_check_trait_ids.push(bounds[bi].def_id.index);
                                    self.pending_bound_check_spans.push(span);
                                }
                            } else {
                                // Check each trait bound immediately
                                for bi in 0usize..bounds.len() {
                                    if !self.type_implements_trait(final_ty, &bounds[bi]) {
                                        self.error(typeck_types.TypeErrorKind.TraitNotImplemented, span);
                                    }
                                }
                            }
                        }
                        &Option.None => {
                            // Could not resolve via direct param matching.
                            // Check if this is a projection bound (T.Item: Trait).
                            let proj_resolved = self.resolve_projection_bound(ty, fn_sig, arg_types);
                            match &proj_resolved {
                                &Option.Some(assoc_ty) => {
                                    let final_ty = self.resolve(assoc_ty);
                                    let interner = type_intern.type_interner();
                                    let final_kind = interner.get(final_ty);
                                    let is_infer = match final_kind {
                                        &type_intern.InternedTypeKind.Infer(_) => true,
                                        _ => false,
                                    };
                                    if is_infer {
                                        for bi in 0usize..bounds.len() {
                                            self.pending_bound_check_tys.push(final_ty);
                                            self.pending_bound_check_trait_ids.push(bounds[bi].def_id.index);
                                            self.pending_bound_check_spans.push(span);
                                        }
                                    } else {
                                        for bi in 0usize..bounds.len() {
                                            if !self.type_implements_trait(final_ty, &bounds[bi]) {
                                                self.error(typeck_types.TypeErrorKind.TraitNotImplemented, span);
                                            }
                                        }
                                    }
                                }
                                &Option.None => {}
                            }
                        }
                    }
                }
                &hir_ty.WherePredicate.LifetimeBound { lifetime: _, bound: _, span: _ } => {}
                &hir_ty.WherePredicate.EffectBound { effect_var: _, ref bounds, span: _ } => {}
            }
        }
    }

    /// Resolves the concrete type for a where clause type parameter.
    /// Given a type (usually Infer(param_id) from the where clause), finds
    /// which parameter position uses that ID and returns the corresponding arg type.
    fn resolve_where_param_type(
        self: &Self,
        where_ty: &hir_ty.Type,
        fn_sig: &typeck_info.FnSigInfo,
        arg_types: &Vec<type_intern.TyId>,
    ) -> Option<type_intern.TyId> {
        // Get the param ID from the where clause type
        let param_id: Option<u32> = match &where_ty.kind {
            &hir_ty.TypeKind.Infer(ref var_id) => Option.Some(var_id.index),
            &hir_ty.TypeKind.Param(ref var_id) => Option.Some(var_id.index),
            _ => Option.None,
        };

        match &param_id {
            &Option.Some(pid) => {
                // Find which parameter position has this Infer(pid) in the original sig
                let mut i: usize = 0;
                while i < fn_sig.param_tys.len() && i < arg_types.len() {
                    if self.param_type_uses_infer_id(fn_sig.param_tys[i], pid) {
                        // Peel reference layers from arg_type matching the param structure.
                        // E.g., param &Infer(T), arg &Pair → return Pair (not &Pair).
                        let resolved = peel_refs_matching(fn_sig.param_tys[i], arg_types[i]);
                        return Option.Some(resolved);
                    }
                    i += 1;
                }
                Option.None
            }
            &Option.None => Option.None,
        }
    }

    /// Resolves a projection bound (where T.Item: Trait) to its concrete type.
    /// Uses assoc_projections metadata to trace the projection TyVarId back to its
    /// base type parameter, then looks up the impl's associated type binding.
    fn resolve_projection_bound(
        self: &Self,
        where_ty: &hir_ty.Type,
        fn_sig: &typeck_info.FnSigInfo,
        arg_types: &Vec<type_intern.TyId>,
    ) -> Option<type_intern.TyId> {
        // Extract the TyVarId from the where_ty
        let var_index: Option<u32> = match &where_ty.kind {
            &hir_ty.TypeKind.Infer(ref var_id) => Option.Some(var_id.index),
            &hir_ty.TypeKind.Param(ref var_id) => Option.Some(var_id.index),
            _ => Option.None,
        };
        if var_index.is_none() {
            return Option.None;
        }
        let target_var = var_index.unwrap();

        // Check if this TyVarId is a known projection
        let mut proj_idx: usize = 0;
        while proj_idx < fn_sig.assoc_projections.len() {
            if fn_sig.assoc_projections[proj_idx].projection_var_index == target_var {
                // Found a projection. Now resolve the base param to a concrete type.
                let base_var = fn_sig.assoc_projections[proj_idx].base_param_var_index;
                let trait_def = fn_sig.assoc_projections[proj_idx].trait_def_index;
                let assoc_name = fn_sig.assoc_projections[proj_idx].assoc_name;

                // Resolve the base type parameter to a concrete type.
                // Find which fn parameter uses base_var, get the arg type.
                let mut pi: usize = 0;
                let mut base_concrete: Option<type_intern.TyId> = Option.None;
                while pi < fn_sig.param_tys.len() && pi < arg_types.len() {
                    if self.param_type_uses_infer_id(fn_sig.param_tys[pi], base_var) {
                        let resolved = peel_refs_matching(fn_sig.param_tys[pi], arg_types[pi]);
                        base_concrete = Option.Some(self.resolve(resolved));
                        pi = fn_sig.param_tys.len();
                    }
                    pi += 1;
                }

                // If base param resolved, look up the impl's associated type
                match &base_concrete {
                    &Option.Some(concrete_self_ty) => {
                        // Search impls for (concrete_self_ty, trait_def) and extract assoc type
                        let mut ii: usize = 0;
                        while ii < self.impls.len() {
                            let impl_info = &self.impls[ii];
                            if impl_info.trait_def_id_index == trait_def {
                                if types_match_for_impl_id(impl_info.self_ty, concrete_self_ty) {
                                    // Found the impl. Look for the assoc type binding.
                                    let mut bi: usize = 0;
                                    while bi < impl_info.assoc_type_bindings.len() {
                                        if impl_info.assoc_type_bindings[bi].name.index == assoc_name.index {
                                            return Option.Some(impl_info.assoc_type_bindings[bi].ty);
                                        }
                                        bi += 1;
                                    }
                                }
                            }
                            ii += 1;
                        }
                    }
                    &Option.None => {}
                }
                return Option.None;
            }
            proj_idx += 1;
        }
        Option.None
    }

    /// Checks if a parameter type uses a specific Infer ID, possibly under references.
    fn param_type_uses_infer_id(self: &Self, ty: type_intern.TyId, target_id: u32) -> bool {
        let interner = type_intern.type_interner();
        let kind = interner.get(ty);
        match kind {
            &type_intern.InternedTypeKind.Infer(ref var_id) => var_id.index == target_id,
            &type_intern.InternedTypeKind.Param(ref var_id) => var_id.index == target_id,
            &type_intern.InternedTypeKind.Ref { inner, mutable: _ } => {
                self.param_type_uses_infer_id(type_intern.TyId.new(inner.index), target_id)
            }
            _ => false,
        }
    }

    /// Checks all collected obligations and reports errors for unsatisfied ones.
    pub fn check_obligations(self: &mut Self, obligations: &Vec<typeck_types.Obligation>) {
        for i in 0usize..obligations.len() {
            if !self.resolve_obligation(&obligations[i]) {
                // Report error for unsatisfied obligation
                self.error(typeck_types.TypeErrorKind.TraitNotImplemented, obligations[i].span);
            }
        }
    }

    /// Resolves deferred trait bound checks.
    /// Called after the function body is fully type-checked so that
    /// inference variables have been resolved to concrete types.
    pub fn flush_pending_bound_checks(self: &mut Self) {
        for i in 0usize..self.pending_bound_check_tys.len() {
            let ty = self.pending_bound_check_tys[i];
            let trait_id = self.pending_bound_check_trait_ids[i];
            let span = self.pending_bound_check_spans[i];
            let resolved = self.resolve(ty);
            let trait_ref = hir_ty.TraitRef.new(
                hir_def.DefId.new(trait_id),
                Vec.new(),
                span,
            );
            if !self.type_implements_trait(resolved, &trait_ref) {
                self.error(typeck_types.TypeErrorKind.TraitNotImplemented, span);
            }
        }
        self.pending_bound_check_tys = Vec.new();
        self.pending_bound_check_trait_ids = Vec.new();
        self.pending_bound_check_spans = Vec.new();
    }
}

/// Peels reference layers from arg_ty matching the structure of param_ty.
/// E.g., param_ty = &Infer(T), arg_ty = &Pair → returns Pair.
/// If param_ty = &&Infer(T), arg_ty = &&Pair → returns Pair.
/// If no Ref wrapping, returns arg_ty unchanged.
fn peel_refs_matching(param_ty: type_intern.TyId, arg_ty: type_intern.TyId) -> type_intern.TyId {
    let interner = type_intern.type_interner();
    let pk = interner.get(param_ty);
    match pk {
        &type_intern.InternedTypeKind.Ref { inner: param_inner, mutable: _ } => {
            let ak = interner.get(arg_ty);
            match ak {
                &type_intern.InternedTypeKind.Ref { inner: arg_inner, mutable: _ } => {
                    peel_refs_matching(param_inner, arg_inner)
                }
                _ => arg_ty,
            }
        }
        _ => arg_ty,
    }
}

/// Result of a method lookup.
pub struct MethodLookupResult {
    /// Index into the impls vector.
    pub impl_index: usize,
    /// Index into the impl's methods vector.
    pub method_index: usize,
}

/// Result of looking up a variant's parent enum.
pub struct EnumVariantLookup {
    /// The parent enum's DefId.
    pub enum_def_id: hir_def.DefId,
    /// Number of generic parameters on the enum.
    pub num_generics: u32,
    /// This variant's index within the enum.
    pub variant_index: u32,
    /// The variant's field types.
    pub field_tys: Vec<type_intern.TyId>,
    /// Field names for record variants (empty for tuple/unit variants).
    pub field_names: Vec<common.Symbol>,
    /// Actual TyVarId indices for each type parameter.
    pub type_param_var_ids: Vec<u32>,
}

/// Copies a Vec of TyId values.
fn copy_ty_id_vec(tys: &Vec<type_intern.TyId>) -> Vec<type_intern.TyId> {
    let mut result: Vec<type_intern.TyId> = Vec.new();
    for i in 0usize..tys.len() {
        result.push(type_intern.TyId.new(tys[i].index));
    }
    result
}

/// Checks if a type matches an impl's self type for method lookup.
/// This handles basic cases; generic matching requires instantiation.
fn types_match_for_impl(impl_ty: &hir_ty.Type, target_ty: &hir_ty.Type) -> bool {
    match (&impl_ty.kind, &target_ty.kind) {
        // ADT types match if same def_id (generic args checked during instantiation)
        (&hir_ty.TypeKind.Adt { def_id: impl_def, args: _ }, &hir_ty.TypeKind.Adt { def_id: target_def, args: _ }) => {
            impl_def.index == target_def.index
        }
        // Primitive types must match exactly
        (&hir_ty.TypeKind.Primitive(impl_prim), &hir_ty.TypeKind.Primitive(target_prim)) => {
            unify.primitives_equal(impl_prim, target_prim)
        }
        // Reference types - check inner type
        (&hir_ty.TypeKind.Ref { ref inner, mutable: impl_mut }, &hir_ty.TypeKind.Ref { inner: ref target_inner, mutable: target_mut }) => {
            impl_mut == target_mut && types_match_for_impl(inner.as_ref(), target_inner.as_ref())
        }
        // Slice types
        (&hir_ty.TypeKind.Slice { ref element }, &hir_ty.TypeKind.Slice { element: ref target_elem }) => {
            types_match_for_impl(element.as_ref(), target_elem.as_ref())
        }
        // Array types
        (&hir_ty.TypeKind.Array { ref element, size }, &hir_ty.TypeKind.Array { element: ref target_elem, size: target_size }) => {
            size == target_size && types_match_for_impl(element.as_ref(), target_elem.as_ref())
        }
        // Inference variables match anything (will be constrained during checking)
        (&hir_ty.TypeKind.Infer(_), _) => true,
        (_, &hir_ty.TypeKind.Infer(_)) => true,
        // Type parameters in impl self_ty match anything (generic impls)
        (&hir_ty.TypeKind.Param(_), _) => true,
        (_, &hir_ty.TypeKind.Param(_)) => true,
        // Ownership types - compare inner types
        (&hir_ty.TypeKind.Ownership { qualifier: impl_q, ref inner },
         &hir_ty.TypeKind.Ownership { qualifier: target_q, inner: ref target_inner }) => {
            impl_q == target_q && types_match_for_impl(inner.as_ref(), target_inner.as_ref())
        }
        // Other combinations don't match
        _ => false,
    }
}

/// Checks if a type implements the Freeze marker trait (no interior mutability).
/// Primitives, shared refs (if inner is Freeze), ptrs, fn types, arrays/tuples
/// of Freeze types are all Freeze. Mutable refs and closures are NOT Freeze.
/// ADTs are Freeze if all type args AND all concrete field types are Freeze.
fn type_is_freeze(ty: type_intern.TyId, structs: &Vec<Option<typeck_info.StructInfo>>) -> bool {
    let interner = type_intern.type_interner();
    let kind = interner.get(ty);
    match kind {
        &type_intern.InternedTypeKind.Primitive(_) => true,
        &type_intern.InternedTypeKind.Ref { inner, mutable } => {
            if mutable { false }
            else { type_is_freeze(type_intern.TyId.new(inner.index), structs) }
        }
        &type_intern.InternedTypeKind.Ptr { inner: _, mutable: _ } => true,
        &type_intern.InternedTypeKind.Fn { params: _, ret: _, effects: _ } => true,
        &type_intern.InternedTypeKind.Never => true,
        &type_intern.InternedTypeKind.Array { element, size: _ } => {
            type_is_freeze(type_intern.TyId.new(element.index), structs)
        }
        &type_intern.InternedTypeKind.Tuple(list_id) => {
            let len: usize = interner.ty_list_len(list_id);
            let mut i: usize = 0;
            while i < len {
                if !type_is_freeze(interner.get_ty_list_element(list_id, i), structs) {
                    return false;
                }
                i += 1;
            }
            true
        }
        &type_intern.InternedTypeKind.Slice { element } => {
            type_is_freeze(type_intern.TyId.new(element.index), structs)
        }
        &type_intern.InternedTypeKind.Closure { def_id: _, params: _, ret: _ } => false,
        &type_intern.InternedTypeKind.Adt { def_id, args } => {
            // Check all type args are Freeze (covers generic type parameters)
            let num_args: usize = interner.ty_list_len(args);
            let mut ai: usize = 0;
            while ai < num_args {
                if !type_is_freeze(interner.get_ty_list_element(args, ai), structs) {
                    return false;
                }
                ai += 1;
            }
            // Check all concrete (non-generic) field types are Freeze
            let def_idx = def_id.index as usize;
            if def_idx < structs.len() {
                match &structs[def_idx] {
                    &Option.Some(ref info) => {
                        let mut fi: usize = 0;
                        while fi < info.fields.len() {
                            let field_ty = info.fields[fi].ty;
                            let field_kind = interner.get(field_ty);
                            // Skip Infer/Param — these are unsubstituted generic params,
                            // already covered by the type args check above.
                            match field_kind {
                                &type_intern.InternedTypeKind.Infer(_) => {}
                                &type_intern.InternedTypeKind.Param(_) => {}
                                _ => {
                                    if !type_is_freeze(field_ty, structs) {
                                        return false;
                                    }
                                }
                            }
                            fi += 1;
                        }
                    }
                    &Option.None => {
                        // Unknown struct — conservatively not Freeze
                        return false;
                    }
                }
            } else {
                // def_id out of range — conservatively not Freeze
                return false;
            }
            true
        }
        &type_intern.InternedTypeKind.DynTrait { trait_id: _, auto_traits: _ } => false,
        &type_intern.InternedTypeKind.Record { fields: _, row_var: _ } => false,
        &type_intern.InternedTypeKind.Infer(_) => false,
        &type_intern.InternedTypeKind.Param(_) => false,
        &type_intern.InternedTypeKind.Error => true,
        &type_intern.InternedTypeKind.Range { element, inclusive: _ } => {
            type_is_freeze(type_intern.TyId.new(element.index), structs)
        }
        &type_intern.InternedTypeKind.Forall { params: _, body: _ } => false,
        &type_intern.InternedTypeKind.Ownership { qualifier: _, inner: _ } => false,
    }
}

/// Strips reference wrappers from a TyId for bounds checking.
fn strip_refs_for_bounds(ty: type_intern.TyId) -> type_intern.TyId {
    let interner = type_intern.type_interner();
    match interner.get(ty) {
        &type_intern.InternedTypeKind.Ref { inner, mutable: _ } => strip_refs_for_bounds(inner),
        _ => ty,
    }
}

/// Checks if a type matches an impl's self type for method lookup, using TyId.
fn types_match_for_impl_id(impl_ty: type_intern.TyId, target_ty: type_intern.TyId) -> bool {
    let interner = type_intern.type_interner();
    let impl_kind = interner.get(impl_ty);
    // Check if impl type is Infer or Param (matches anything)
    match impl_kind {
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        _ => {}
    }
    // Check if target type is Infer or Param (matches anything)
    let target_kind = interner.get(target_ty);
    match target_kind {
        &type_intern.InternedTypeKind.Infer(_) => { return true; }
        &type_intern.InternedTypeKind.Param(_) => { return true; }
        _ => {}
    }
    // Match both types for structural compatibility
    match impl_kind {
        &type_intern.InternedTypeKind.Adt { def_id: impl_def, args: _ } => {
            match target_kind {
                &type_intern.InternedTypeKind.Adt { def_id: target_def, args: _ } => {
                    impl_def.index == target_def.index
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Primitive(impl_prim) => {
            match target_kind {
                &type_intern.InternedTypeKind.Primitive(target_prim) => {
                    unify.primitives_equal(impl_prim, target_prim)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ref { inner: impl_inner, mutable: impl_mut } => {
            match target_kind {
                &type_intern.InternedTypeKind.Ref { inner: target_inner, mutable: target_mut } => {
                    impl_mut == target_mut && types_match_for_impl_id(
                        type_intern.TyId.new(impl_inner.index),
                        type_intern.TyId.new(target_inner.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Slice { element: impl_elem } => {
            match target_kind {
                &type_intern.InternedTypeKind.Slice { element: target_elem } => {
                    types_match_for_impl_id(
                        type_intern.TyId.new(impl_elem.index),
                        type_intern.TyId.new(target_elem.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Array { element: impl_elem, size: impl_size } => {
            match target_kind {
                &type_intern.InternedTypeKind.Array { element: target_elem, size: target_size } => {
                    impl_size == target_size && types_match_for_impl_id(
                        type_intern.TyId.new(impl_elem.index),
                        type_intern.TyId.new(target_elem.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ownership { qualifier: impl_q, inner: impl_inner } => {
            match target_kind {
                &type_intern.InternedTypeKind.Ownership { qualifier: target_q, inner: target_inner } => {
                    impl_q == target_q && types_match_for_impl_id(
                        type_intern.TyId.new(impl_inner.index),
                        type_intern.TyId.new(target_inner.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.DynTrait { trait_id: impl_trait, auto_traits: _ } => {
            match target_kind {
                &type_intern.InternedTypeKind.DynTrait { trait_id: target_trait, auto_traits: _ } => {
                    impl_trait.index == target_trait.index
                }
                _ => false,
            }
        }
        _ => false,
    }
}

/// Computes the specificity of a type match between a method param type and an arg type.
/// Returns:
/// - 0: incompatible types (no match)
/// - 1: flexible match (one or both are Infer/Param — matches anything)
/// - 2: exact match (both are concrete and structurally equal)
fn type_match_specificity(param_ty: type_intern.TyId, arg_ty: type_intern.TyId) -> u32 {
    let interner = type_intern.type_interner();
    let param_kind = interner.get(param_ty);
    let arg_kind = interner.get(arg_ty);
    // If either side is Infer or Param, it's a flexible match (score 1)
    match param_kind {
        &type_intern.InternedTypeKind.Infer(_) => { return 1; }
        &type_intern.InternedTypeKind.Param(_) => { return 1; }
        _ => {}
    }
    match arg_kind {
        &type_intern.InternedTypeKind.Infer(_) => { return 1; }
        &type_intern.InternedTypeKind.Param(_) => { return 1; }
        _ => {}
    }
    // Both are concrete — check for exact structural match
    if types_match_for_impl_id(param_ty, arg_ty) {
        2
    } else {
        0
    }
}

/// Checks if two types are structurally equal (for obligation resolution).
/// This is a simplified check that doesn't handle inference variables.
fn types_structurally_equal(a: &hir_ty.Type, b: &hir_ty.Type) -> bool {
    match (&a.kind, &b.kind) {
        (&hir_ty.TypeKind.Never, &hir_ty.TypeKind.Never) => true,
        (&hir_ty.TypeKind.Error, &hir_ty.TypeKind.Error) => true,
        (&hir_ty.TypeKind.Primitive(ref pa), &hir_ty.TypeKind.Primitive(ref pb)) => {
            unify.primitives_equal(*pa, *pb)
        }
        (&hir_ty.TypeKind.Tuple(ref elems_a), &hir_ty.TypeKind.Tuple(ref elems_b)) => {
            if elems_a.len() != elems_b.len() {
                return false;
            }
            for i in 0usize..elems_a.len() {
                if !types_structurally_equal(&elems_a[i], &elems_b[i]) {
                    return false;
                }
            }
            true
        }
        (&hir_ty.TypeKind.Ref { ref inner, mutable: ma },
         &hir_ty.TypeKind.Ref { inner: ref inner_b, mutable: mb }) => {
            ma == mb && types_structurally_equal(inner.as_ref(), inner_b.as_ref())
        }
        (&hir_ty.TypeKind.Ptr { ref inner, mutable: ma },
         &hir_ty.TypeKind.Ptr { inner: ref inner_b, mutable: mb }) => {
            ma == mb && types_structurally_equal(inner.as_ref(), inner_b.as_ref())
        }
        (&hir_ty.TypeKind.Array { ref element, size: sa },
         &hir_ty.TypeKind.Array { element: ref elem_b, size: sb }) => {
            sa == sb && types_structurally_equal(element.as_ref(), elem_b.as_ref())
        }
        (&hir_ty.TypeKind.Slice { ref element },
         &hir_ty.TypeKind.Slice { element: ref elem_b }) => {
            types_structurally_equal(element.as_ref(), elem_b.as_ref())
        }
        (&hir_ty.TypeKind.Adt { def_id: da, ref args },
         &hir_ty.TypeKind.Adt { def_id: db, args: ref args_b }) => {
            if da.index != db.index {
                return false;
            }
            if args.len() != args_b.len() {
                return false;
            }
            for i in 0usize..args.len() {
                if !types_structurally_equal(&args[i], &args_b[i]) {
                    return false;
                }
            }
            true
        }
        // Ownership types - compare qualifier and inner type
        (&hir_ty.TypeKind.Ownership { qualifier: qa, ref inner },
         &hir_ty.TypeKind.Ownership { qualifier: qb, inner: ref inner_b }) => {
            qa == qb && types_structurally_equal(inner.as_ref(), inner_b.as_ref())
        }
        _ => false,
    }
}

/// Checks if two interned types are structurally equal (for obligation resolution).
/// TyId version of types_structurally_equal.
fn types_structurally_equal_id(a: type_intern.TyId, b: type_intern.TyId) -> bool {
    // Quick check: same TyId index means same interned type
    if a.index == b.index {
        return true;
    }
    let interner = type_intern.type_interner();
    let a_kind = interner.get(a);
    let b_kind = interner.get(b);
    match a_kind {
        &type_intern.InternedTypeKind.Never => {
            match b_kind {
                &type_intern.InternedTypeKind.Never => true,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Error => {
            match b_kind {
                &type_intern.InternedTypeKind.Error => true,
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Primitive(pa) => {
            match b_kind {
                &type_intern.InternedTypeKind.Primitive(pb) => {
                    unify.primitives_equal(pa, pb)
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Tuple(list_a) => {
            match b_kind {
                &type_intern.InternedTypeKind.Tuple(list_b) => {
                    let len_a = interner.ty_list_len(list_a);
                    let len_b = interner.ty_list_len(list_b);
                    if len_a != len_b {
                        return false;
                    }
                    for i in 0usize..len_a {
                        let ea = interner.get_ty_list_element(list_a, i);
                        let eb = interner.get_ty_list_element(list_b, i);
                        if !types_structurally_equal_id(ea, eb) {
                            return false;
                        }
                    }
                    true
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ref { inner: inner_a, mutable: ma } => {
            match b_kind {
                &type_intern.InternedTypeKind.Ref { inner: inner_b, mutable: mb } => {
                    ma == mb && types_structurally_equal_id(
                        type_intern.TyId.new(inner_a.index),
                        type_intern.TyId.new(inner_b.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ptr { inner: inner_a, mutable: ma } => {
            match b_kind {
                &type_intern.InternedTypeKind.Ptr { inner: inner_b, mutable: mb } => {
                    ma == mb && types_structurally_equal_id(
                        type_intern.TyId.new(inner_a.index),
                        type_intern.TyId.new(inner_b.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Array { element: elem_a, size: sa } => {
            match b_kind {
                &type_intern.InternedTypeKind.Array { element: elem_b, size: sb } => {
                    sa == sb && types_structurally_equal_id(
                        type_intern.TyId.new(elem_a.index),
                        type_intern.TyId.new(elem_b.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Slice { element: elem_a } => {
            match b_kind {
                &type_intern.InternedTypeKind.Slice { element: elem_b } => {
                    types_structurally_equal_id(
                        type_intern.TyId.new(elem_a.index),
                        type_intern.TyId.new(elem_b.index),
                    )
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Adt { def_id: da, args: args_a } => {
            match b_kind {
                &type_intern.InternedTypeKind.Adt { def_id: db, args: args_b } => {
                    if da.index != db.index {
                        return false;
                    }
                    let len_a = interner.ty_list_len(args_a);
                    let len_b = interner.ty_list_len(args_b);
                    if len_a != len_b {
                        return false;
                    }
                    for i in 0usize..len_a {
                        let ea = interner.get_ty_list_element(args_a, i);
                        let eb = interner.get_ty_list_element(args_b, i);
                        if !types_structurally_equal_id(ea, eb) {
                            return false;
                        }
                    }
                    true
                }
                _ => false,
            }
        }
        &type_intern.InternedTypeKind.Ownership { qualifier: qa, inner: inner_a } => {
            match b_kind {
                &type_intern.InternedTypeKind.Ownership { qualifier: qb, inner: inner_b } => {
                    qa == qb && types_structurally_equal_id(
                        type_intern.TyId.new(inner_a.index),
                        type_intern.TyId.new(inner_b.index),
                    )
                }
                _ => false,
            }
        }
        _ => false,
    }
}

// ============================================================
// Pattern Exhaustiveness Checking Implementation
// ============================================================

/// Checks if a set of match arms is exhaustive for a given type.
/// Returns ExhaustivenessResult indicating whether patterns cover all cases.
pub fn check_exhaustiveness_arms(
    checker: &mut TypeChecker,
    scrutinee_ty: &hir_ty.Type,
    arms: &Vec<hir_expr.MatchArm>,
    _span: common.Span,
) -> ExhaustivenessResult {
    // Convert HIR patterns to deconstructed patterns
    let mut matrix = PatternMatrix.new(1);

    for i in 0usize..arms.len() {
        let decon = deconstruct_pattern(checker, &arms[i].pattern);
        let row = PatternRow.new(vec_of_one(decon));
        matrix.push_row(row);
    }

    // Check if the matrix is exhaustive
    let witnesses = compute_witnesses(checker, scrutinee_ty, &matrix);

    if witnesses.len() == 0 {
        ExhaustivenessResult.Exhaustive
    } else {
        ExhaustivenessResult.NonExhaustive(witnesses)
    }
}

/// Converts an HIR pattern to a deconstructed pattern.
fn deconstruct_pattern(checker: &mut TypeChecker, pattern: &hir_expr.Pattern) -> DeconstructedPattern {
    match &pattern.kind {
        &hir_expr.PatternKind.Wildcard => DeconstructedPattern.Wildcard,
        &hir_expr.PatternKind.Binding { local_id: _, ref name, mode: _, ref subpattern } => {
            // Binding acts as wildcard unless it has a sub-pattern
            let _ = name;
            match subpattern {
                &Option.Some(ref sub) => deconstruct_pattern(checker, sub.as_ref()),
                &Option.None => DeconstructedPattern.Wildcard,
            }
        }
        &hir_expr.PatternKind.Literal(ref lit) => {
            deconstruct_literal(lit)
        }
        &hir_expr.PatternKind.Tuple(ref pats) => {
            let mut fields: Vec<DeconstructedPattern> = Vec.new();
            for i in 0usize..pats.len() {
                fields.push(deconstruct_pattern(checker, &pats[i]));
            }
            DeconstructedPattern.Tuple { fields: fields }
        }
        &hir_expr.PatternKind.Struct { ref path, ref fields, has_rest } => {
            let def_id = path.def_id;
            let mut field_pats: Vec<DeconstructedPattern> = Vec.new();
            for i in 0usize..fields.len() {
                field_pats.push(deconstruct_pattern(checker, &fields[i].pattern));
            }
            let _ = has_rest;
            // Check if this is a record enum variant (has variant_index) or a plain struct
            let variant_idx_opt = match path.variant_index {
                Option.Some(idx) => Option.Some(idx),
                Option.None => {
                    checker.find_variant_index_by_def_id(def_id)
                }
            };
            match variant_idx_opt {
                Option.Some(variant_idx) => {
                    // Record enum variant — use Variant for exhaustiveness
                    DeconstructedPattern.Variant { def_id: def_id, variant_idx: variant_idx, fields: field_pats }
                }
                Option.None => {
                    // Plain struct or unresolved — use Struct
                    DeconstructedPattern.Struct { def_id: def_id, fields: field_pats }
                }
            }
        }
        &hir_expr.PatternKind.TupleStruct { ref path, ref fields } => {
            // Tuple struct pattern - could be enum variant with fields
            let def_id = path.def_id;
            let variant_idx_opt = match path.variant_index {
                Option.Some(idx) => Option.Some(idx),
                Option.None => {
                    checker.find_variant_index_by_def_id(def_id)
                }
            };
            match variant_idx_opt {
                Option.Some(variant_idx) => {
                    let mut field_pats: Vec<DeconstructedPattern> = Vec.new();
                    for i in 0usize..fields.len() {
                        field_pats.push(deconstruct_pattern(checker, &fields[i]));
                    }
                    DeconstructedPattern.Variant { def_id: def_id, variant_idx: variant_idx, fields: field_pats }
                }
                Option.None => {
                    // Variant index unknown (cross-module enum not registered).
                    // Treat as Wildcard to avoid false non-exhaustive errors.
                    DeconstructedPattern.Wildcard
                }
            }
        }
        &hir_expr.PatternKind.Or(ref pats) => {
            let mut alts: Vec<DeconstructedPattern> = Vec.new();
            for i in 0usize..pats.len() {
                alts.push(deconstruct_pattern(checker, &pats[i]));
            }
            DeconstructedPattern.Or { pats: alts }
        }
        &hir_expr.PatternKind.Ref { ref inner, mutable: _ } => {
            // Reference pattern - unwrap and deconstruct the inner pattern
            deconstruct_pattern(checker, inner.as_ref())
        }
        &hir_expr.PatternKind.Range { ref start, ref end_val, inclusive: _ } => {
            // Range patterns are complex - treat as partial coverage for now
            let _ = start;
            let _ = end_val;
            DeconstructedPattern.Missing
        }
        &hir_expr.PatternKind.Slice { ref prefix, ref rest, ref suffix } => {
            // Slice patterns - simplified handling
            let _ = prefix;
            let _ = rest;
            let _ = suffix;
            DeconstructedPattern.Wildcard
        }
        &hir_expr.PatternKind.Path(ref path) => {
            // Path patterns (could be enum variant or const)
            let def_id = path.def_id;
            let variant_idx_opt = match path.variant_index {
                Option.Some(idx) => Option.Some(idx),
                Option.None => {
                    // variant_index not set by HIR lowering — look up by def_id
                    checker.find_variant_index_by_def_id(def_id)
                }
            };
            match variant_idx_opt {
                Option.Some(variant_idx) => {
                    DeconstructedPattern.Variant { def_id: def_id, variant_idx: variant_idx, fields: Vec.new() }
                }
                Option.None => {
                    // Variant index unknown (cross-module enum not registered).
                    // Treat as Wildcard to avoid false non-exhaustive errors.
                    DeconstructedPattern.Wildcard
                }
            }
        }
        &hir_expr.PatternKind.Rest => {
            // Rest pattern (..) - matches any number of elements
            DeconstructedPattern.Wildcard
        }
        &hir_expr.PatternKind.Error => {
            // Error pattern - treat as wildcard for recovery
            DeconstructedPattern.Wildcard
        }
    }
}

/// Converts a literal to a deconstructed pattern.
fn deconstruct_literal(lit: &hir_expr.Literal) -> DeconstructedPattern {
    match &lit.kind {
        &hir_expr.LiteralKind.Int { val, ty: _ } => {
            DeconstructedPattern.Literal { value: val as i128 }
        }
        &hir_expr.LiteralKind.Bool(b) => {
            let value = if b { 1i128 } else { 0i128 };
            DeconstructedPattern.Literal { value: value }
        }
        &hir_expr.LiteralKind.Char(c) => {
            DeconstructedPattern.Literal { value: c as i128 }
        }
        &hir_expr.LiteralKind.Float { bits: _, ty: _ } => {
            // Float patterns - treat as partial
            DeconstructedPattern.Missing
        }
        &hir_expr.LiteralKind.Str(_) => {
            // String patterns - treat as partial
            DeconstructedPattern.Missing
        }
        &hir_expr.LiteralKind.ByteStr(_) => {
            DeconstructedPattern.Missing
        }
    }
}

/// Computes witnesses for non-exhaustiveness.
/// Returns empty vector if patterns are exhaustive.
fn compute_witnesses(
    checker: &mut TypeChecker,
    scrutinee_ty: &hir_ty.Type,
    matrix: &PatternMatrix,
) -> Vec<Witness> {
    // For exhaustiveness, we need to check if every possible constructor of
    // the scrutinee type is covered by the pattern matrix.

    // If the scrutinee type is still an unresolved inference variable,
    // we cannot determine the constructors. Treat as exhaustive to
    // avoid false non-exhaustive errors for cross-module enums and
    // other cases where type inference hasn't fully resolved.
    match &scrutinee_ty.kind {
        &hir_ty.TypeKind.Infer(_) => {
            return Vec.new();
        }
        &hir_ty.TypeKind.Error => {
            return Vec.new();
        }
        _ => {}
    }

    // Get all constructors for the type
    let constructors = get_type_constructors(checker, scrutinee_ty);

    // If no constructors, the type is uninhabited (like Never)
    if constructors.len() == 0 {
        return Vec.new(); // Exhaustive by vacuity
    }

    let mut witnesses: Vec<Witness> = Vec.new();

    // For each constructor, check if it's covered
    for i in 0usize..constructors.len() {
        let ctor = &constructors[i];

        // Check if this constructor is matched by any row in the matrix
        if !constructor_is_covered(matrix, ctor) {
            // This constructor is not covered - it's a witness
            witnesses.push(Witness.new(ctor.description.clone()));
        }
    }

    witnesses
}

/// A constructor for a type (represents one way to create a value).
struct Constructor {
    /// Description of this constructor for error messages.
    description: String,
    /// For enum variants, the variant index.
    variant_idx: Option<u32>,
    /// For literals, the specific value (if finite).
    literal_value: Option<i128>,
}

impl Constructor {
    fn new(description: String) -> Constructor {
        Constructor {
            description: description,
            variant_idx: Option.None,
            literal_value: Option.None,
        }
    }

    fn variant(name: String, idx: u32) -> Constructor {
        Constructor {
            description: name,
            variant_idx: Option.Some(idx),
            literal_value: Option.None,
        }
    }
}

/// Gets all constructors for a type.
fn get_type_constructors(checker: &mut TypeChecker, ty: &hir_ty.Type) -> Vec<Constructor> {
    let mut ctors: Vec<Constructor> = Vec.new();

    match &ty.kind {
        &hir_ty.TypeKind.Primitive(ref prim) => {
            match prim {
                &hir_ty.PrimitiveTy.Bool => {
                    // Bool has two constructors: true and false
                    ctors.push(Constructor.new(common.make_string("true")));
                    ctors.push(Constructor.new(common.make_string("false")));
                }
                _ => {
                    // Other primitives (integers, etc.) have infinite constructors
                    // Treat as single wildcard constructor for simplicity
                    ctors.push(Constructor.new(common.make_string("_")));
                }
            }
        }
        &hir_ty.TypeKind.Adt { def_id, args: _ } => {
            // Check if it's an enum
            match checker.get_enum(def_id) {
                Option.Some(enum_info) => {
                    // Add one constructor per variant
                    for i in 0usize..enum_info.variants.len() {
                        let variant = &enum_info.variants[i];
                        let name = match interner.resolve(variant.name) {
                            Option.Some(resolved) => {
                                // Clone the resolved string
                                let mut s = common.make_string("");
                                s.push_str(resolved.as_str());
                                s
                            }
                            Option.None => {
                                // Fallback if interner resolution fails
                                let mut s = common.make_string("Variant");
                                let idx_str = usize_to_string(i);
                                s.push_str(idx_str.as_str());
                                s
                            }
                        };
                        ctors.push(Constructor.variant(name, variant.variant_index));
                    }
                }
                Option.None => {
                    // It's a struct - single constructor
                    ctors.push(Constructor.new(common.make_string("_")));
                }
            }
        }
        &hir_ty.TypeKind.Tuple(_) => {
            // Tuple has single constructor
            ctors.push(Constructor.new(common.make_string("(..)")));
        }
        &hir_ty.TypeKind.Never => {
            // Never type has no constructors (uninhabited)
        }
        &hir_ty.TypeKind.Ownership { qualifier: _, ref inner } => {
            // Ownership type uses inner type's constructors
            return get_type_constructors(checker, inner.as_ref());
        }
        &hir_ty.TypeKind.Ref { ref inner, mutable: _ } => {
            // Reference type uses inner type's constructors (auto-deref)
            return get_type_constructors(checker, inner.as_ref());
        }
        _ => {
            // Other types - treat as single wildcard
            ctors.push(Constructor.new(common.make_string("_")));
        }
    }

    ctors
}

/// Checks if a constructor is covered by the pattern matrix.
fn constructor_is_covered(matrix: &PatternMatrix, ctor: &Constructor) -> bool {
    // A constructor is covered if some row in the matrix matches it
    for i in 0usize..matrix.rows.len() {
        if matrix.width > 0 {
            let first_pat = &matrix.rows[i].patterns[0];
            if pattern_matches_constructor(first_pat, ctor) {
                return true;
            }
        }
    }
    false
}

/// Checks if a pattern matches a constructor.
fn pattern_matches_constructor(pat: &DeconstructedPattern, ctor: &Constructor) -> bool {
    match pat {
        &DeconstructedPattern.Wildcard => true,
        &DeconstructedPattern.Variant { def_id: _, variant_idx, fields: _ } => {
            match ctor.variant_idx {
                Option.Some(ctor_idx) => variant_idx == ctor_idx,
                Option.None => false,
            }
        }
        &DeconstructedPattern.Literal { value } => {
            match ctor.literal_value {
                Option.Some(ctor_val) => value == ctor_val,
                Option.None => true, // Literal matches wildcard constructor
            }
        }
        &DeconstructedPattern.Struct { def_id: _, fields: _ } => {
            // Struct pattern matches single struct constructor
            ctor.variant_idx.is_none()
        }
        &DeconstructedPattern.Tuple { fields: _ } => {
            // Tuple pattern matches tuple constructor
            true
        }
        &DeconstructedPattern.Or { ref pats } => {
            // Or pattern matches if any alternative matches
            for i in 0usize..pats.len() {
                if pattern_matches_constructor(&pats[i], ctor) {
                    return true;
                }
            }
            false
        }
        &DeconstructedPattern.Missing => false,
    }
}

/// Creates a Vec with a single element.
fn vec_of_one(p: DeconstructedPattern) -> Vec<DeconstructedPattern> {
    let mut v: Vec<DeconstructedPattern> = Vec.new();
    v.push(p);
    v
}


/// Converts a usize to a String.
fn usize_to_string(n: usize) -> String {
    if n == 0 {
        return common.make_string("0");
    }

    let mut result = String.new();
    let mut num = n;
    let mut digits: Vec<char> = Vec.new();

    while num > 0 {
        let digit = (num % 10) as u8;
        digits.push((digit + 48) as char); // 48 is ASCII '0'
        num /= 10;
    }

    // Reverse the digits
    let mut i = digits.len();
    while i > 0 {
        i -= 1;
        result.push(digits[i]);
    }

    result
}

// ============================================================
// Trait Obligation Resolution
// ============================================================

/// Resolves all pending trait obligations.
///
/// For each obligation, checks if a matching impl exists in the trait_impls list.
/// Returns a list of unresolved obligations (which become type errors).
pub fn resolve_obligations(
    checker: &mut TypeChecker,
    obligations: &Vec<typeck_types.Obligation>,
) -> Vec<typeck_types.Obligation> {
    let mut unresolved: Vec<typeck_types.Obligation> = Vec.new();

    for i in 0usize..obligations.len() {
        let obligation = &obligations[i];
        let resolved = resolve_single_obligation(checker, obligation);
        if !resolved {
            // Re-create obligation for error reporting
            let unresolve = typeck_types.Obligation.new(
                copy_predicate(&obligation.predicate),
                obligation.span,
                copy_obligation_cause(&obligation.cause),
            );
            unresolved.push(unresolve);
        }
    }

    unresolved
}

/// Resolves a single obligation.
/// Returns true if resolved, false if not.
fn resolve_single_obligation(
    checker: &mut TypeChecker,
    obligation: &typeck_types.Obligation,
) -> bool {
    match &obligation.predicate {
        &typeck_types.Predicate.Trait(ref trait_ref) => {
            // O(1) hash lookup to check if any impl exists for this trait
            let trait_def_id = trait_ref.def_id;
            match checker.trait_impl_hash.get(trait_def_id.index as u64) {
                Option.Some(_) => true,
                Option.None => false,
            }
        }
        &typeck_types.Predicate.TypeEqual { left, right } => {
            let result = unify.unify_id(
                &mut checker.subst_table,
                &mut checker.unifier,
                left,
                right,
                obligation.span,
            );
            match result {
                unify.UnifyResult.Ok => true,
                unify.UnifyResult.Err(_) => false,
            }
        }
        &typeck_types.Predicate.WellFormed(_) => {
            // Well-formedness is always satisfied for now
            true
        }
    }
}

/// Copies a predicate (since Blood lacks Clone).
fn copy_predicate(pred: &typeck_types.Predicate) -> typeck_types.Predicate {
    match pred {
        &typeck_types.Predicate.Trait(ref tr) => {
            typeck_types.Predicate.Trait(hir_ty.TraitRef {
                def_id: hir_def.DefId.new(tr.def_id.index),
                args: Vec.new(),
                span: tr.span,
            })
        }
        &typeck_types.Predicate.TypeEqual { left, right } => {
            typeck_types.Predicate.TypeEqual {
                left: type_intern.TyId.new(left.index),
                right: type_intern.TyId.new(right.index),
            }
        }
        &typeck_types.Predicate.WellFormed(ty) => {
            typeck_types.Predicate.WellFormed(type_intern.TyId.new(ty.index))
        }
    }
}

/// Copies an obligation cause.
fn copy_obligation_cause(cause: &typeck_types.ObligationCause) -> typeck_types.ObligationCause {
    match cause {
        &typeck_types.ObligationCause.WhereClause => typeck_types.ObligationCause.WhereClause,
        &typeck_types.ObligationCause.FnArgument => typeck_types.ObligationCause.FnArgument,
        &typeck_types.ObligationCause.FnReturn => typeck_types.ObligationCause.FnReturn,
        &typeck_types.ObligationCause.FieldType => typeck_types.ObligationCause.FieldType,
        &typeck_types.ObligationCause.MethodCall => typeck_types.ObligationCause.MethodCall,
        &typeck_types.ObligationCause.Operator => typeck_types.ObligationCause.Operator,
        &typeck_types.ObligationCause.Cast => typeck_types.ObligationCause.Cast,
        &typeck_types.ObligationCause.Coercion => typeck_types.ObligationCause.Coercion,
        &typeck_types.ObligationCause.Pattern => typeck_types.ObligationCause.Pattern,
    }
}

// ============================================================
// Unreachable Arm Detection
// ============================================================

/// Result of checking for unreachable arms in a match expression.
pub struct UnreachableArmsResult {
    /// Indices of unreachable arms (0-based).
    pub unreachable_indices: Vec<u32>,
}

/// Checks for unreachable arms in a match expression.
///
/// An arm is unreachable if a previous arm's pattern is a superset of it.
/// The simplest check: if a wildcard or binding-without-guard appears before
/// the last arm, all subsequent arms are unreachable.
pub fn check_unreachable_arms(
    checker: &mut TypeChecker,
    arms: &Vec<hir_expr.MatchArm>,
) -> UnreachableArmsResult {
    let mut result = UnreachableArmsResult {
        unreachable_indices: Vec.new(),
    };

    let mut wildcard_seen = false;
    let mut wildcard_index: u32 = 0;

    for i in 0usize..arms.len() {
        if wildcard_seen {
            // Every arm after a wildcard (without guard) is unreachable
            result.unreachable_indices.push(i as u32);
        } else {
            // Check if this arm is a wildcard/catch-all without a guard
            let is_catchall = is_catchall_pattern(&arms[i].pattern);
            let has_guard = match &arms[i].guard {
                &Option.Some(_) => true,
                &Option.None => false,
            };
            if is_catchall && !has_guard {
                wildcard_seen = true;
                wildcard_index = i as u32;
            }
        }
    }

    result
}

/// Checks if a pattern is a catch-all (wildcard or simple binding).
fn is_catchall_pattern(pattern: &hir_expr.Pattern) -> bool {
    match &pattern.kind {
        &hir_expr.PatternKind.Wildcard => true,
        &hir_expr.PatternKind.Binding { local_id: _, name: _, mode: _, ref subpattern } => {
            match subpattern {
                &Option.Some(ref sub) => is_catchall_pattern(sub.as_ref()),
                &Option.None => true,
            }
        }
        _ => false,
    }
}
