    pub fn new() -> Args {
        Args {
            command: Command.Help,
            source_file: Option.None,
            output_file: Option.None,
            verbose: false,
            colors: true,
            timings: false,
            no_cache: false,
            release: false,
            dump_mir: false,
            dump_mir_filter: Option.None,
            trace_codegen: false,
            dump_types: false,
            dump_layouts: false,
            validate_mir: false,
            mem_profile: false,
            alloc_profile: false,
            hash_stats: false,
            emit_mode: EmitMode.Full, emit_hashes: false, store_codebase: false,
            opt_level: 0,
            strip: false,
            sanitize_address: false,
            test_filter: Option.None,
            test_list: false,
            test_include_ignored: false,
            test_only_ignored: false,
            test_fail_fast: false,
            build_dir: Option.None,
            stdlib_path: Option.None,
            split_modules: false,
            no_parallel: false,
        }
    }

    /// Creates arguments for checking a file.
    pub fn check(file: String) -> Args {
        Args {
            command: Command.Check,
            source_file: Option.Some(file),
            output_file: Option.None,
            verbose: false,
            colors: true,
            timings: false,
            no_cache: false,
            release: false,
            dump_mir: false,
            dump_mir_filter: Option.None,
            trace_codegen: false,
            dump_types: false,
            dump_layouts: false,
            validate_mir: false,
            mem_profile: false,
            alloc_profile: false,
            hash_stats: false,
            emit_mode: EmitMode.Full, emit_hashes: false, store_codebase: false,
            opt_level: 0,
            strip: false,
            sanitize_address: false,
            test_filter: Option.None,
            test_list: false,
            test_include_ignored: false,
            test_only_ignored: false,
            test_fail_fast: false,
            build_dir: Option.None,
            stdlib_path: Option.None,
            split_modules: false,
            no_parallel: false,
        }
    }

    /// Creates arguments for building a file.
    pub fn build(file: String) -> Args {
        Args {
            command: Command.Build,
            source_file: Option.Some(file),
            output_file: Option.None,
            verbose: false,
            colors: true,
            timings: false,
            no_cache: false,
            release: false,
            dump_mir: false,
            dump_mir_filter: Option.None,
            trace_codegen: false,
            dump_types: false,
            dump_layouts: false,
            validate_mir: false,
            mem_profile: false,
            alloc_profile: false,
            hash_stats: false,
            emit_mode: EmitMode.Full, emit_hashes: false, store_codebase: false,
            opt_level: 0,
            strip: false,
            sanitize_address: false,
            test_filter: Option.None,
            test_list: false,
            test_include_ignored: false,
            test_only_ignored: false,
            test_fail_fast: false,
            build_dir: Option.None,
            stdlib_path: Option.None,
            split_modules: false,
            no_parallel: false,
        }
    }
}

// ============================================================
// Main Entry Point
// ============================================================

/// Main function - entry point for the compiler.
pub fn main() -> i32 {
    // Initialize the global string interner before any parsing
    // This ensures consistent symbol indices across all compilation phases
    interner.init_global_interner();
    type_intern.init_type_interner();

    // Parse command line arguments
    // Note: Without FFI for argument access, we use a stub
    let args = parse_args_stub();

    // Execute the command
    match &args.command {
        &Command.Check => run_check(&args),
        &Command.Build => run_build(&args),
        &Command.Run => run_run(&args),
        &Command.Test => run_test(&args),
        &Command.Clean => run_clean(&args),
        &Command.Help => run_help(&args),
        &Command.Version => run_version(&args),
    }
}

/// Parses command line arguments using blood-rust builtins.
///
/// Uses args_count() and args_get() builtins to access actual CLI args.
fn parse_args_stub() -> Args {
    let argc = args_count();

    // Build argv vector from CLI args
    let mut argv: Vec<String> = Vec.new();
    for i in 0..argc {
        let arg_ref: &str = args_get(i);
        argv.push(common.make_string(arg_ref));
    }

    // Use existing parse_args function
    parse_args(argc, &argv)
}

// ============================================================
// Command Handlers
// ============================================================

/// Runs the check command.
///
/// Wraps the entire check in a region so all front-end allocations (parse, HIR,
/// typeck for all transitive imports) are bulk-freed when check completes.
fn run_check(args: &Args) -> i32 {
    match &args.source_file {
        &Option.Some(ref path) => {
            let check_start = blood_clock_millis();

            // Create region for all check allocations.
            // 16 MB initial, 50 GB max — virtual address reservation via mmap,
            // physical pages committed on demand.
            let check_region = region_create(16777216, 53687091200);
            region_activate(check_region);

            eprint_str("  Checking...");
            let stdlib_path = resolve_stdlib_path(args);
            let result = driver.check_file(path.as_str(), stdlib_path);
            let check_elapsed = blood_clock_millis() - check_start;
            eprint_str(" done\n");

            let exit_code = if result.success {
                main_helpers.print_success("Check passed");
                if args.timings {
                    print_str("\nTimings:\n");
                    print_str("  Check total          ");
                    print_timing_ms(check_elapsed);
                }
                0
            } else {
                // Read the source content for error reporting
                let read_result = source.read_file(path.as_str());
                let content = match &read_result.content {
                    &Option.Some(ref c) => c.as_str(),
                    &Option.None => "",
                };
                // Format and print errors to stderr
                let error_reporter = reporter.ErrorReporter.new(content, path.as_str());
                let formatted = error_reporter.format_errors(&result.errors);
                eprint_str(formatted.as_str());
                1
            };

            // Bulk-free all front-end data
            region_deactivate();
            region_destroy(check_region);

            exit_code
        }
        &Option.None => {
            main_helpers.print_error("No source file specified");
            1
        }
    }
}

// ============================================================
// Runtime Discovery
// ============================================================

/// Paths to the Blood runtime libraries needed for linking.
pub struct RuntimePaths {
    /// Path to the runtime static library (libblood_runtime.a).
    pub rust_runtime: String,
}

/// Finds the runtime static library (libblood_runtime.a).
///
/// Search order:
/// 1. BLOOD_RUST_RUNTIME environment variable
/// 2. Relative to executable directory: <exe_dir>/libblood_runtime.a
/// 3. Installed toolchain: ~/.blood/lib/libblood_runtime.a
fn find_rust_runtime() -> Option<String> {
    // 1. Check BLOOD_RUST_RUNTIME environment variable
    let env_val: &str = env_get("BLOOD_RUST_RUNTIME");
    if env_val.len() > 0 {
        if file_exists(env_val) {
            return Option.Some(common.make_string(env_val));
        }
    }

    // 2. Search relative to executable
    let exe_path: &str = args_get(0);
    let exe_dir = source.parent_dir(exe_path);

    // <exe_dir>/libblood_runtime.a
    let sibling = source.join_path(exe_dir.as_str(), "libblood_runtime.a");
    if file_exists(sibling.as_str()) {
        return Option.Some(sibling);
    }

    // 3. Installed toolchain: ~/.blood/lib/libblood_runtime.a
    let home: &str = env_get("HOME");
    if home.len() > 0 {
        let installed = source.join_path(home, ".blood/lib/libblood_runtime.a");
        if file_exists(installed.as_str()) {
            return Option.Some(installed);
        }
    }

    Option.None
}

/// Finds the runtime library, printing a helpful error if missing.
fn find_runtime_paths() -> Option<RuntimePaths> {
    let rust_rt = find_rust_runtime();

    match rust_rt {
        Option.Some(r_path) => {
            return Option.Some(RuntimePaths {
                rust_runtime: r_path,
            });
        }
        Option.None => {}
    }

    // Print helpful error
    main_helpers.print_error("Could not find Blood runtime library for linking.");
    print_str("  missing: libblood_runtime.a (runtime library)\n");
    print_str("  Searched:\n");
    print_str("    1. BLOOD_RUST_RUNTIME environment variable\n");
    let exe_path: &str = args_get(0);
    let exe_dir = source.parent_dir(exe_path);
    print_str("    2. Next to executable: ");
    print_str(exe_dir.as_str());
    print_str("/\n");
    print_str("    3. Installed toolchain: ~/.blood/lib/\n");
    print_str("  Fix: run './build_selfhost.sh install' from the compiler repo,\n");
    print_str("       or set BLOOD_RUST_RUNTIME env var.\n");

    Option.None
}

// ============================================================
// Build & Run Commands
// ============================================================

/// Runs the build command.
/// Uses streaming codegen to write IR directly to file, avoiding OOM.
/// Then invokes llc-18 to produce an object file and clang-18 to link an executable.
fn run_build(args: &Args) -> i32 {
    match &args.source_file {
        &Option.Some(ref path) => {
            // Discover runtime libraries early (fail before expensive IR generation)
            let runtime = match find_runtime_paths() {
                Option.Some(rt) => rt,
                Option.None => { return 1; }
            };

            // Resolve build directory and create profile subdirectory
            let build_dir = resolve_build_dir(args);
            let profile_dir = source.join_path(build_dir.as_str(), profile_subdir(args));
            main_helpers.ensure_dir(profile_dir.as_str());

            let stem = main_helpers.file_stem(path);

            // Determine output path for LLVM IR
            let ll_path = match &args.output_file {
                &Option.Some(ref out) => main_helpers.clone_string(out),
                &Option.None => {
                    let mut p = main_helpers.clone_string(&profile_dir);
                    p.push('/');
                    p.push_str(stem.as_str());
                    p.push_str(".ll");
                    p
                }
            };

            // Phase 1: Generate LLVM IR via streaming codegen
            let result = compile_file_streaming(path.as_str(), ll_path.as_str(), args);
            if !result {
                return 1;
            }
            main_helpers.print_success("Wrote LLVM IR to: ");
            print_str(ll_path.as_str());
            print_newline();

            // Early return for --emit llvm-ir
            match &args.emit_mode {
                &EmitMode.LlvmIr => { return 0; }
                &EmitMode.Full => {}
                &EmitMode.Obj => {}
            }

            // Phase 2+3: Compile IR → .o → binary
            if args.split_modules {
                // Per-module: compile each changed .ll, link all .o files
                let obj_dir_path = source.join_path(build_dir.as_str(), "obj");
                let base_path = main_helpers.strip_ll_ext(&ll_path);
                let bin_path = base_path;
                let llc_start = blood_clock_millis();

                // Run llc-18 on each .ll in obj/ that is newer than its .o (parallel)
                let mut llc_cmd = String.new();
                llc_cmd.push_str("pids=\"\"; for f in ");
                llc_cmd.push_str(obj_dir_path.as_str());
                llc_cmd.push_str("/*.ll; do o=\"${f%.ll}.o\"; if [ \"$f\" -nt \"$o\" ] 2>/dev/null || [ ! -f \"$o\" ]; then (llc-18 \"$f\" -O");
                if args.opt_level == 0 {
                    llc_cmd.push('0');
                } else if args.opt_level == 1 {
                    llc_cmd.push('1');
                } else if args.opt_level == 2 {
                    llc_cmd.push('2');
                } else {
                    llc_cmd.push('3');
                }
                llc_cmd.push_str(" -filetype=obj -relocation-model=pic -o \"$o\" || exit 1) & pids=\"$pids $!\"; fi; done; rc=0; for p in $pids; do wait $p || rc=1; done; exit $rc");
                let llc_result = system(llc_cmd.as_str());
                let llc_elapsed = blood_clock_millis() - llc_start;
                if llc_result != 0 {
                    main_helpers.print_error("llc-18 failed on per-module .ll files");
                    return 1;
                }

                // Early return for --emit obj
                match &args.emit_mode {
                    &EmitMode.Obj => { return 0; }
                    &EmitMode.Full => {}
                    &EmitMode.LlvmIr => {}
                }

                // Link all .o files
                let mut clang_cmd = String.new();
                clang_cmd.push_str("clang-18 ");
                clang_cmd.push_str(obj_dir_path.as_str());
                clang_cmd.push_str("/*.o ");
                clang_cmd.push_str(runtime.rust_runtime.as_str());
                clang_cmd.push_str(" -Wl,-z,muldefs");
                if args.strip {
                    clang_cmd.push_str(" -s");
                }
                clang_cmd.push_str(" -lm -ldl -lpthread");
                if args.sanitize_address {
                    clang_cmd.push_str(" -fsanitize=address");
                }
                clang_cmd.push_str(" -pie -o ");
                clang_cmd.push_str(bin_path.as_str());
                let clang_start = blood_clock_millis();
                let clang_result = system(clang_cmd.as_str());
                let clang_elapsed = blood_clock_millis() - clang_start;
                if clang_result != 0 {
                    main_helpers.print_error("clang-18 linking failed");
                    return 1;
                }
                main_helpers.print_success("Wrote executable to: ");
                print_str(bin_path.as_str());
                print_newline();

                if args.timings {
                    print_str("  llc-18 (per-module)   ");
                    print_timing_ms(llc_elapsed);
                    print_str("  clang-18 (link)      ");
                    print_timing_ms(clang_elapsed);
                }

                0
            } else {
            // Monolithic: single .ll → .o → binary
            let base_path = main_helpers.strip_ll_ext(&ll_path);
            let mut obj_path = common.make_string(base_path.as_str());
            obj_path.push_str(".o");
            let mut llc_cmd = String.new();
            llc_cmd.push_str("llc-18 ");
            llc_cmd.push_str(ll_path.as_str());
            if args.opt_level == 0 {
                llc_cmd.push_str(" -O0");
            } else if args.opt_level == 1 {
                llc_cmd.push_str(" -O1");
            } else if args.opt_level == 2 {
                llc_cmd.push_str(" -O2");
            } else {
                llc_cmd.push_str(" -O3");
            }
            llc_cmd.push_str(" -filetype=obj -relocation-model=pic -o ");
            llc_cmd.push_str(obj_path.as_str());
            let llc_start = blood_clock_millis();
            let llc_result = system(llc_cmd.as_str());
            let llc_elapsed = blood_clock_millis() - llc_start;
            if llc_result != 0 {
                main_helpers.print_error("llc-18 failed to compile IR to object file");
                return 1;
            }
            main_helpers.print_success("Wrote object file to: ");
            print_str(obj_path.as_str());
            print_newline();

            // Early return for --emit obj
            match &args.emit_mode {
                &EmitMode.Obj => { return 0; }
                &EmitMode.Full => {}
                &EmitMode.LlvmIr => {}
            }

            // Phase 3: Link with clang-18, blood runtime, and C runtime stub
            let bin_path = base_path;
            let mut clang_cmd = String.new();
            clang_cmd.push_str("clang-18 ");
            clang_cmd.push_str(obj_path.as_str());
            clang_cmd.push_str(" ");
            clang_cmd.push_str(runtime.rust_runtime.as_str());
            clang_cmd.push_str(" -Wl,-z,muldefs");
            if args.strip {
                clang_cmd.push_str(" -s");
            }
            clang_cmd.push_str(" -lm -ldl -lpthread");
            if args.sanitize_address {
                clang_cmd.push_str(" -fsanitize=address");
            }
            clang_cmd.push_str(" -pie -o ");
            clang_cmd.push_str(bin_path.as_str());
            let clang_start = blood_clock_millis();
            let clang_result = system(clang_cmd.as_str());
            let clang_elapsed = blood_clock_millis() - clang_start;
            if clang_result != 0 {
                main_helpers.print_error("clang-18 linking failed");
                return 1;
            }
            main_helpers.print_success("Wrote executable to: ");
            print_str(bin_path.as_str());
            print_newline();

            if args.timings {
                print_str("  llc-18               ");
                print_timing_ms(llc_elapsed);
                print_str("  clang-18             ");
                print_timing_ms(clang_elapsed);
            }

            0
            } // end else (monolithic path)
        }
        &Option.None => {
            main_helpers.print_error("No source file specified");
            1
        }
    }
}

/// Runs the run command.
/// Compiles source to LLVM IR, invokes llc-18 and clang-18, then executes the result.
fn run_run(args: &Args) -> i32 {
    match &args.source_file {
        &Option.Some(ref path) => {
            // Discover runtime libraries early (fail before expensive IR generation)
            let runtime = match find_runtime_paths() {
                Option.Some(rt) => rt,
                Option.None => { return 1; }
            };

            // Resolve build directory and create profile subdirectory
            let build_dir = resolve_build_dir(args);
            let profile_dir = source.join_path(build_dir.as_str(), profile_subdir(args));
            main_helpers.ensure_dir(profile_dir.as_str());

            let stem = main_helpers.file_stem(path);

            // Phase 1: Generate LLVM IR
            let ll_path = {
                let mut p = main_helpers.clone_string(&profile_dir);
                p.push('/');
                p.push_str(stem.as_str());
                p.push_str(".ll");
                p
            };
            let result = compile_file_streaming(path.as_str(), ll_path.as_str(), args);
            if !result {
                return 1;
            }

            // Early return for --emit llvm-ir
            match &args.emit_mode {
                &EmitMode.LlvmIr => {
                    main_helpers.print_success("Wrote LLVM IR to: ");
                    print_str(ll_path.as_str());
                    print_newline();
                    return 0;
                }
                &EmitMode.Full => {}
                &EmitMode.Obj => {}
            }

            // Phase 2: Compile IR to object file with llc-18
            let base_path = main_helpers.strip_ll_ext(&ll_path);
            let mut obj_path = common.make_string(base_path.as_str());
            obj_path.push_str(".o");
            let mut llc_cmd = String.new();
            llc_cmd.push_str("llc-18 ");
            llc_cmd.push_str(ll_path.as_str());
            if args.opt_level == 0 {
                llc_cmd.push_str(" -O0");
            } else if args.opt_level == 1 {
                llc_cmd.push_str(" -O1");
            } else if args.opt_level == 2 {
                llc_cmd.push_str(" -O2");
            } else {
                llc_cmd.push_str(" -O3");
            }
            llc_cmd.push_str(" -filetype=obj -relocation-model=pic -o ");
            llc_cmd.push_str(obj_path.as_str());
            let llc_result = system(llc_cmd.as_str());
            if llc_result != 0 {
                main_helpers.print_error("llc-18 failed to compile IR to object file");
                return 1;
            }

            // Early return for --emit obj
            match &args.emit_mode {
                &EmitMode.Obj => {
                    main_helpers.print_success("Wrote object file to: ");
                    print_str(obj_path.as_str());
                    print_newline();
                    return 0;
                }
                &EmitMode.Full => {}
                &EmitMode.LlvmIr => {}
            }

            // Phase 3: Link with clang-18, blood runtime, and C runtime stub
            let bin_path = base_path;
            let mut clang_cmd = String.new();
            clang_cmd.push_str("clang-18 ");
            clang_cmd.push_str(obj_path.as_str());
            clang_cmd.push_str(" ");
            clang_cmd.push_str(runtime.rust_runtime.as_str());
            clang_cmd.push_str(" -Wl,-z,muldefs");
            if args.strip {
                clang_cmd.push_str(" -s");
            }
            clang_cmd.push_str(" -lm -ldl -lpthread");
            if args.sanitize_address {
                clang_cmd.push_str(" -fsanitize=address");
            }
            clang_cmd.push_str(" -pie -o ");
            clang_cmd.push_str(bin_path.as_str());
            let clang_result = system(clang_cmd.as_str());
            if clang_result != 0 {
                main_helpers.print_error("clang-18 linking failed");
                return 1;
            }

            // Phase 4: Execute the binary
            let exit_code = system(bin_path.as_str());
            exit_code
        }
        &Option.None => {
            main_helpers.print_error("No source file specified");
            1
        }
    }
}

