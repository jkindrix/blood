    help.push_str("    --no-color         Disable colored output\n");
    help.push_str("    --timings          Print per-phase timing\n");
    help.push_str("    --mem-profile      Print per-phase memory diagnostics\n");
    help.push_str("    --alloc-profile    Print per-module allocation breakdown\n");
    help.push_str("    --hash-stats       Print hash table load factor diagnostics\n");
    help.push_str("    --no-cache         Skip the build cache\n");
    help.push_str("    --release          Build with -O2 and strip symbols\n");
    help.push_str("    -O0/-O1/-O2/-O3   Set optimization level (default: -O0)\n");
    help.push_str("    --build-dir <path> Build output directory (default: build/)\n");
    help.push_str("    --emit <mode>      Stop early: 'llvm-ir' or 'obj'\n");
    help.push_str("    --sanitize=address Enable AddressSanitizer\n");
    help.push_str("\n");
    help.push_str("DEBUG OPTIONS:\n");
    help.push_str("    --dump-mir          Dump MIR for all functions to stderr\n");
    help.push_str("    --dump-mir=<filter> Dump MIR for functions matching filter\n");
    help.push_str("    --trace-codegen     Emit MIR as comments in LLVM IR output\n");
    help.push_str("    --dump-types        Dump type/field resolutions to stderr\n");
    help.push_str("    --dump-layouts      Dump ADT sizes, fields, variant layouts\n");
    help.push_str("    --validate-mir      Validate MIR before codegen\n");
    help.push_str("\n");
    help.push_str("TEST OPTIONS (for 'test' command):\n");
    help.push_str("    --filter <name>     Only run tests containing <name>\n");
    help.push_str("    -F <name>           Short form of --filter\n");
    help.push_str("    --list              List test names without running\n");
    help.push_str("    --ignored           Run only ignored tests\n");
    help.push_str("    --include-ignored   Include ignored tests in run\n");
    help.push_str("    --fail-fast         Stop on first test failure\n");
    main_helpers.print_string(&help);
    0
}

/// Prints version information.
fn run_version(_args: &Args) -> i32 {
    let mut version = String.new();
    version.push_str("Blood Compiler 0.1.0\n");
    version.push_str("Host: x86_64-unknown-linux-gnu\n");
    version.push_str("LLVM: 18\n");
    main_helpers.print_string(&version);
    0
}

/// Runs the clean command.
/// Removes build cache directory and (if source file given) derived build artifacts.
fn run_clean(args: &Args) -> i32 {
    // Remove build directory
    let build_dir = resolve_build_dir(args);
    if file_exists(build_dir.as_str()) {
        let mut rm_build = String.new();
        rm_build.push_str("rm -rf ");
        main_helpers.shell_quote_into(&mut rm_build, build_dir.as_str());
        system(rm_build.as_str());
        print_str("info: Removed build directory: ");
        print_str(build_dir.as_str());
        print_newline();
    }

    // Determine cache directory: BLOOD_CACHE env var or <base_dir>/.blood-cache/
    let base_dir = match &args.source_file {
        &Option.Some(ref path) => source.parent_dir(path.as_str()),
        &Option.None => common.make_string("."),
    };
    let cache_env: &str = env_get("BLOOD_CACHE");
    let cache_dir = if cache_env.len() > 0 {
        common.make_string(cache_env)
    } else {
        source.join_path(base_dir.as_str(), ".blood-cache")
    };

    // Remove cache directory
    if file_exists(cache_dir.as_str()) {
        let mut rm_cache = String.new();
        rm_cache.push_str("rm -rf ");
        main_helpers.shell_quote_into(&mut rm_cache, cache_dir.as_str());
        system(rm_cache.as_str());
        print_str("info: Removed cache: ");
        print_str(cache_dir.as_str());
        print_newline();
    }

    // Legacy cleanup: remove artifacts next to source files from before build-dir support
    match &args.source_file {
        &Option.Some(ref path) => {
            let ll = main_helpers.default_ll_path(path);
            let obj = main_helpers.replace_ext(path, ".o");
            let bin = main_helpers.strip_blood_ext(path);

            if file_exists(ll.as_str()) {
                let mut rm_ll = String.new();
                rm_ll.push_str("rm -f ");
                main_helpers.shell_quote_into(&mut rm_ll, ll.as_str());
                system(rm_ll.as_str());
                print_str("info: Removed legacy ");
                print_str(ll.as_str());
                print_newline();
            }
            if file_exists(obj.as_str()) {
                let mut rm_obj = String.new();
                rm_obj.push_str("rm -f ");
                main_helpers.shell_quote_into(&mut rm_obj, obj.as_str());
                system(rm_obj.as_str());
                print_str("info: Removed legacy ");
                print_str(obj.as_str());
                print_newline();
            }
            if file_exists(bin.as_str()) {
                let mut rm_bin = String.new();
                rm_bin.push_str("rm -f ");
                main_helpers.shell_quote_into(&mut rm_bin, bin.as_str());
                system(rm_bin.as_str());
                print_str("info: Removed legacy ");
                print_str(bin.as_str());
                print_newline();
            }
        }
        &Option.None => {}
    }

    0
}

// ============================================================
// Test Framework
// ============================================================

/// Configuration for a test function derived from its attributes.
struct TestConfig {
    /// Whether the function has #[test].
    is_test: bool,
    /// Whether the function has #[ignore].
    ignore: bool,
    /// Whether the function has #[should_panic].
    should_panic: bool,
}

/// Information about a discovered test function.
struct TestInfo {
    /// The test function name.
    name: String,
    /// Test configuration from attributes.
    config: TestConfig,
}

/// Outcome of running a single test.
enum TestOutcome {
    /// Test passed.
    Passed,
    /// Test failed with a message.
    Failed(String),
    /// Test was ignored.
    Ignored,
}

/// Record of a single test failure.
struct TestFailure {
    /// Name of the failed test.
    name: String,
    /// Failure message.
    message: String,
}

/// Aggregated test results.
struct TestResults {
    /// Number of tests that passed.
    passed: u32,
    /// Number of tests that failed.
    failed: u32,
    /// Number of tests that were ignored.
    ignored: u32,
    /// Details of each failure.
    failures: Vec<TestFailure>,
}

/// Extracts a substring from source bytes given a span.
fn span_to_str(source: &str, span: &common.Span) -> String {
    let bytes = source.as_bytes();
    let start = span.start as usize;
    let end = span.end as usize;
    let mut result = String.new();
    let mut i: usize = start;
    while i < end && i < bytes.len() {
        result.push(bytes[i] as char);
        i += 1;
    }
    result
}

/// Extracts test configuration from a function's attribute list.
///
/// Scans for #[test], #[ignore], and #[should_panic] attributes
/// by extracting attribute path names directly from the source text.
fn extract_test_config(attrs: &Vec<ast.Attribute>, source: &str) -> TestConfig {
    let mut is_test = false;
    let mut ignore = false;
    let mut should_panic = false;

    for i in 0usize..attrs.len() {
        let attr = &attrs[i];
        // Each attribute path is a Vec<SpannedSymbol>; simple attrs have one element
        if attr.path.len() > 0 {
            let name = span_to_str(source, &attr.path[0].span);
            if main_helpers.str_equals(&name, "test") {
                is_test = true;
            } else if main_helpers.str_equals(&name, "ignore") {
                ignore = true;
            } else if main_helpers.str_equals(&name, "should_panic") {
                should_panic = true;
            }
        }
    }

    TestConfig {
        is_test: is_test,
        ignore: ignore,
        should_panic: should_panic,
    }
}

/// Discovers all #[test] functions in a parsed program.
///
/// Exhaustively matches all 14 Declaration variants. Only Function
/// declarations can carry #[test] attributes. Uses source text for
/// span-based name extraction (parser symbols are not in the global interner).
fn discover_tests(program: &ast.Program, source: &str) -> Vec<TestInfo> {
    let mut tests: Vec<TestInfo> = Vec.new();

    for i in 0usize..program.declarations.len() {
        match &program.declarations[i] {
            &ast.Declaration.Function(ref fn_decl) => {
                let config = extract_test_config(&fn_decl.attrs, source);
                if config.is_test {
                    // Extract function name from source text using span
                    let name = span_to_str(source, &fn_decl.name.span);
                    tests.push(TestInfo {
                        name: name,
                        config: config,
                    });
                }
            }
            &ast.Declaration.TypeAlias(ref _ta) => {}
            &ast.Declaration.Struct(ref _s) => {}
            &ast.Declaration.Enum(ref _e) => {}
            &ast.Declaration.Effect(ref _ef) => {}
            &ast.Declaration.Handler(ref _h) => {}
            &ast.Declaration.Const(ref _c) => {}
            &ast.Declaration.Static(ref _s) => {}
            &ast.Declaration.Impl(ref _im) => {}
            &ast.Declaration.Trait(ref _t) => {}
            &ast.Declaration.Bridge(ref _b) => {}
            &ast.Declaration.Module(ref _m) => {}
            &ast.Declaration.Macro(ref _ma) => {}
            &ast.Declaration.Use(ref _u) => {}
        }
    }

    tests
}

/// Generates a test harness by appending a main() that calls the test function.
/// Uses `-> i32` return type and explicit `0` return to ensure clean exit code.
fn generate_test_harness(original_source: &str, test_name: &String) -> String {
    let mut harness = common.make_string(original_source);
    harness.push_str("\nfn main() -> i32 {\n    ");
    harness.push_str(test_name.as_str());
    harness.push_str("();\n    0\n}\n");
    harness
}

/// Runs a single test: generates harness, compiles, links, executes.
///
/// Returns the test outcome (Passed, Failed, or Ignored).
fn run_single_test(
    test: &TestInfo,
    source_path: &String,
    original_source: &str,
    args: &Args,
) -> TestOutcome {
    // Generate harness source
    let harness_source = generate_test_harness(original_source, &test.name);

    // Write harness to temp file
    let mut harness_path = String.new();
    harness_path.push_str("/tmp/blood_test_");
    harness_path.push_str(test.name.as_str());
    harness_path.push_str(".blood");
    file_write_string(harness_path.as_str(), harness_source.as_str());

    // Determine output paths
    let mut ll_path = String.new();
    ll_path.push_str("/tmp/blood_test_");
    ll_path.push_str(test.name.as_str());
    ll_path.push_str(".ll");

    let mut obj_path = String.new();
    obj_path.push_str("/tmp/blood_test_");
    obj_path.push_str(test.name.as_str());
    obj_path.push_str(".o");

    let mut bin_path = String.new();
    bin_path.push_str("/tmp/blood_test_");
    bin_path.push_str(test.name.as_str());

    // Build Args for compilation (no cache, quiet)
    let mut build_args = Args.build(main_helpers.clone_string(&harness_path));
    build_args.no_cache = true;

    // Phase 1: Compile to LLVM IR via streaming codegen
    let compile_ok = compile_file_streaming(harness_path.as_str(), ll_path.as_str(), &build_args);

    // Clean up harness source file
    let mut rm_harness = String.new();
    rm_harness.push_str("rm -f ");
    rm_harness.push_str(harness_path.as_str());
    system(rm_harness.as_str());

    if !compile_ok {
        // Clean up any partial artifacts
        let mut rm_ll = String.new();
        rm_ll.push_str("rm -f ");
        rm_ll.push_str(ll_path.as_str());
        system(rm_ll.as_str());

        if test.config.should_panic {
            return TestOutcome.Passed;
        }
        return TestOutcome.Failed(common.make_string("compilation failed"));
    }

    // Phase 2: Find runtime and compile IR to object
    let runtime = match find_runtime_paths() {
        Option.Some(rt) => rt,
        Option.None => {
            let mut rm_ll = String.new();
            rm_ll.push_str("rm -f ");
            rm_ll.push_str(ll_path.as_str());
            system(rm_ll.as_str());
            return TestOutcome.Failed(common.make_string("runtime not found"));
        }
    };

    // llc-18: IR -> object
    let mut llc_cmd = String.new();
    llc_cmd.push_str("llc-18 ");
    llc_cmd.push_str(ll_path.as_str());
    llc_cmd.push_str(" -O0 -filetype=obj -relocation-model=pic -o ");
    llc_cmd.push_str(obj_path.as_str());
    llc_cmd.push_str(" 2>/dev/null");
    let llc_result = system(llc_cmd.as_str());

    // Clean up .ll
    let mut rm_ll = String.new();
    rm_ll.push_str("rm -f ");
    rm_ll.push_str(ll_path.as_str());
    system(rm_ll.as_str());

    if llc_result != 0 {
        let mut rm_obj = String.new();
        rm_obj.push_str("rm -f ");
        rm_obj.push_str(obj_path.as_str());
        system(rm_obj.as_str());

        if test.config.should_panic {
            return TestOutcome.Passed;
        }
        return TestOutcome.Failed(common.make_string("llc-18 failed"));
    }

    // Phase 3: clang-18 link
    let mut clang_cmd = String.new();
    clang_cmd.push_str("clang-18 ");
    clang_cmd.push_str(obj_path.as_str());
    clang_cmd.push_str(" ");
    clang_cmd.push_str(runtime.rust_runtime.as_str());
    clang_cmd.push_str(" -Wl,-z,muldefs -lm -ldl -lpthread -pie -o ");
    clang_cmd.push_str(bin_path.as_str());
    clang_cmd.push_str(" 2>/dev/null");
    let clang_result = system(clang_cmd.as_str());

    // Clean up .o
    let mut rm_obj = String.new();
    rm_obj.push_str("rm -f ");
    rm_obj.push_str(obj_path.as_str());
    system(rm_obj.as_str());

    if clang_result != 0 {
        let mut rm_bin = String.new();
        rm_bin.push_str("rm -f ");
        rm_bin.push_str(bin_path.as_str());
        system(rm_bin.as_str());

        if test.config.should_panic {
            return TestOutcome.Passed;
        }
        return TestOutcome.Failed(common.make_string("linking failed"));
    }

    // Phase 4: Execute the test binary
    let mut run_cmd = String.new();
    run_cmd.push_str(bin_path.as_str());
    run_cmd.push_str(" 2>/dev/null");
    let exit_code = system(run_cmd.as_str());

    // Clean up binary
    let mut rm_bin = String.new();
    rm_bin.push_str("rm -f ");
    rm_bin.push_str(bin_path.as_str());
    system(rm_bin.as_str());

    // Interpret result
    if test.config.should_panic {
        if exit_code != 0 {
            TestOutcome.Passed
        } else {
            TestOutcome.Failed(common.make_string("expected panic but test passed"))
        }
    } else {
        if exit_code == 0 {
            TestOutcome.Passed
        } else {
            let mut msg = String.new();
            msg.push_str("exit code ");
            push_usize(&mut msg, exit_code as usize);
            TestOutcome.Failed(msg)
        }
    }
}

/// Prints the test summary (failures + totals).
fn print_test_summary(results: &TestResults) {
    // Print failure details
    if results.failed > 0 {
        print_str("\nfailures:\n\n");
        for i in 0usize..results.failures.len() {
            let failure = &results.failures[i];
            print_str("---- ");
            print_str(failure.name.as_str());
            print_str(" ----\n");
            print_str("    ");
            print_str(failure.message.as_str());
            print_str("\n");
        }

        print_str("\nfailures:\n");
        for j in 0usize..results.failures.len() {
            print_str("    ");
            print_str(results.failures[j].name.as_str());
            print_str("\n");
        }
    }

    // Print summary line
    print_str("\ntest result: ");
    if results.failed == 0 {
        print_str("ok");
    } else {
        print_str("FAILED");
    }
    print_str(". ");

    let mut passed_str = String.new();
    push_usize(&mut passed_str, results.passed as usize);
    print_str(passed_str.as_str());
    print_str(" passed; ");

    let mut failed_str = String.new();
    push_usize(&mut failed_str, results.failed as usize);
    print_str(failed_str.as_str());
    print_str(" failed; ");

    let mut ignored_str = String.new();
    push_usize(&mut ignored_str, results.ignored as usize);
    print_str(ignored_str.as_str());
    print_str(" ignored\n");
}

/// Runs the test command.
///
/// Discovers #[test] functions via AST-only parsing, generates per-test
/// harnesses, compiles and runs each test independently.
fn run_test(args: &Args) -> i32 {
    match &args.source_file {
        &Option.Some(ref path) => {
            // Phase 1: Read source file
            let read_result = source.read_file(path.as_str());
            if !read_result.success {
                main_helpers.print_error("Failed to read source file");
                return 1;
            }

            let content = match &read_result.content {
                &Option.Some(ref c) => c,
                &Option.None => {
                    main_helpers.print_error("No content in file");
                    return 1;
                }
            };

            // Phase 2: Parse (AST only — no type checking needed for test discovery)
            let parse_region = region_create(2097152, 10737418240);
            region_activate(parse_region);

            let parse_result = parser.parse_file(content.as_str());
            let program = match &parse_result.program {
                &Option.Some(ref p) => p,
                &Option.None => {
                    main_helpers.print_error("Failed to parse source file");
                    region_deactivate();
                    region_destroy(parse_region);
                    return 1;
                }
            };

            // Phase 3: Discover tests
            // Deactivate region first so String allocations go to system heap.
            // AST data in the region remains valid until region_destroy.
            region_deactivate();
            let all_tests = discover_tests(program, content.as_str());

            // Destroy parse region — AST data freed, but extracted strings survive
            region_destroy(parse_region);

            if all_tests.len() == 0 {
                print_str("no tests found\n");
                return 0;
            }

            // Phase 4: Apply filters
            let mut tests: Vec<TestInfo> = Vec.new();
            for ti in 0usize..all_tests.len() {
                let t = &all_tests[ti];
                let mut include = true;

                // Filter by name substring
                match &args.test_filter {
                    &Option.Some(ref filter) => {
                        if !main_helpers.str_contains_ref(t.name.as_str(), filter.as_str()) {
                            include = false;
                        }
                    }
                    &Option.None => {}
                }

                // Filter by ignore status
                if args.test_only_ignored && !t.config.ignore {
                    include = false;
                }

                if include {
                    tests.push(TestInfo {
                        name: main_helpers.clone_string(&t.name),
                        config: TestConfig {
                            is_test: t.config.is_test,
                            ignore: t.config.ignore,
                            should_panic: t.config.should_panic,
                        },
                    });
                }

            }

            // --list mode: print test names and return
            if args.test_list {
                for li in 0usize..tests.len() {
                    print_str(tests[li].name.as_str());
                    print_str(": test\n");
                }
                let mut count_str = String.new();
                push_usize(&mut count_str, tests.len());
                print_str("\n");
                print_str(count_str.as_str());
                print_str(" tests\n");
                return 0;
            }

            // Phase 5: Run tests
            let mut count_str = String.new();
            push_usize(&mut count_str, tests.len());
            print_str("\nrunning ");
            print_str(count_str.as_str());
            print_str(" tests\n");

            let mut results = TestResults {
                passed: 0,
                failed: 0,
                ignored: 0,
                failures: Vec.new(),
            };

            let mut ri: usize = 0;
            while ri < tests.len() {
                let t = &tests[ri];

                print_str("test ");
                print_str(t.name.as_str());
                print_str(" ... ");

                // Check if ignored (skip unless --include-ignored or --ignored)
                if t.config.ignore && !args.test_include_ignored && !args.test_only_ignored {
                    print_str("ignored\n");
                    results.ignored = results.ignored + 1;
                    ri += 1;
                    continue;
                }

                let outcome = run_single_test(t, path, content.as_str(), args);
                match &outcome {
                    &TestOutcome.Passed => {
                        print_str("ok\n");
                        results.passed = results.passed + 1;
                    }
                    &TestOutcome.Failed(ref msg) => {
                        print_str("FAILED\n");
                        results.failed = results.failed + 1;
                        results.failures.push(TestFailure {
                            name: main_helpers.clone_string(&t.name),
                            message: main_helpers.clone_string(msg),
                        });
                        if args.test_fail_fast {
                            ri = tests.len(); // break
                        }
                    }
                    &TestOutcome.Ignored => {
                        print_str("ignored\n");
                        results.ignored = results.ignored + 1;
                    }
                }

                ri += 1;
            }

            // Phase 6: Print summary
            print_test_summary(&results);

            if results.failed > 0 { 1 } else { 0 }
        }
        &Option.None => {
            main_helpers.print_error("No source file specified");
            1
        }
    }
}

// ============================================================
// Compile From String (Test API)
// ============================================================

/// Compiles source code from a string (for testing without file I/O).
pub fn compile_source(source: &str, filename: &str) -> CompileOutput {
    let result = driver.compile(source);

    if result.success {
        CompileOutput {
            success: true,
            llvm_ir: result.llvm_ir,
            error_output: Option.None,
        }
    } else {
        let error_reporter = reporter.ErrorReporter.new(source, filename);
        let formatted = error_reporter.format_errors(&result.errors);
        CompileOutput {
            success: false,
            llvm_ir: Option.None,
            error_output: Option.Some(formatted),
        }
    }
}

/// Output from compiling source code.
pub struct CompileOutput {
    /// Whether compilation succeeded.
    pub success: bool,
    /// Generated LLVM IR (if successful).
    pub llvm_ir: Option<String>,
    /// Formatted error output (if failed).
    pub error_output: Option<String>,
}

// ============================================================
// Argument Parsing (Structure for when FFI is available)
// ============================================================

/// Parses command line arguments into Args structure.
/// This function structure is ready for when argument access is available.
pub fn parse_args(argc: i32, argv: &Vec<String>) -> Args {
    let mut args = Args.new();

    if argc < 2 {
        return args;
    }

    // Parse command
    let cmd = &argv[1];
    args.command = parse_command(cmd);

    // Parse remaining arguments
    let mut i: usize = 2;
    while i < argv.len() {
        let arg = &argv[i];
        let bytes = arg.as_bytes();

        if bytes.len() > 0 && bytes[0] == 45 { // '-'
            // Option flag
            if main_helpers.str_equals(arg, "-o") {
                if i + 1 < argv.len() {
                    i += 1;
                    args.output_file = Option.Some(main_helpers.clone_string(&argv[i]));
                } else {
                    main_helpers.print_error("missing value for -o");
                }
            } else if main_helpers.str_equals(arg, "-v") {
                args.verbose = true;
            } else if main_helpers.str_equals(arg, "--no-color") {
                args.colors = false;
            } else if main_helpers.str_equals(arg, "--timings") {
                args.timings = true;
            } else if main_helpers.str_equals(arg, "--no-cache") {
                args.no_cache = true;
            } else if main_helpers.str_equals(arg, "--build-dir") {
                if i + 1 < argv.len() {
                    i += 1;
                    args.build_dir = Option.Some(main_helpers.clone_string(&argv[i]));
                } else {
                    main_helpers.print_error("missing value for --build-dir");
                }
            } else if main_helpers.str_equals(arg, "--stdlib-path") {
                if i + 1 < argv.len() {
                    i += 1;
                    args.stdlib_path = Option.Some(main_helpers.clone_string(&argv[i]));
                } else {
                    main_helpers.print_error("missing value for --stdlib-path");
                }
            } else if main_helpers.str_equals(arg, "--release") {
                args.release = true;
                args.opt_level = 2;
                args.strip = true;
            } else if main_helpers.str_equals(arg, "--emit=llvm-ir") {
                args.emit_mode = EmitMode.LlvmIr;
            } else if main_helpers.str_equals(arg, "--emit=obj") {
                args.emit_mode = EmitMode.Obj;
            } else if main_helpers.str_equals(arg, "--emit=hashes") {
                args.emit_hashes = true;
            } else if main_helpers.str_equals(arg, "--store-codebase") {
                args.store_codebase = true;
                args.emit_hashes = true;
            } else if main_helpers.str_equals(arg, "--emit") {
                // Space-separated: --emit llvm-ir / --emit obj
                if i + 1 < argv.len() {
                    i += 1;
                    let emit_val = &argv[i];
                    if main_helpers.str_equals(emit_val, "llvm-ir") {
                        args.emit_mode = EmitMode.LlvmIr;
                    } else if main_helpers.str_equals(emit_val, "obj") {
                        args.emit_mode = EmitMode.Obj;
                    } else {
                        main_helpers.print_error("unknown --emit mode (expected 'llvm-ir' or 'obj')");
                    }
                } else {
                    main_helpers.print_error("missing value for --emit (expected 'llvm-ir' or 'obj')");
                }
            } else if main_helpers.str_equals(arg, "-O0") {
                args.opt_level = 0;
            } else if main_helpers.str_equals(arg, "-O1") {
                args.opt_level = 1;
            } else if main_helpers.str_equals(arg, "-O2") {
                args.opt_level = 2;
            } else if main_helpers.str_equals(arg, "-O3") {
                args.opt_level = 3;
            } else if main_helpers.str_equals(arg, "--sanitize=address") {
                args.sanitize_address = true;
            } else if main_helpers.str_equals(arg, "--dump-mir") {
                args.dump_mir = true;
            } else if main_helpers.str_starts_with(arg, "--dump-mir=") {
                args.dump_mir = true;
                args.dump_mir_filter = Option.Some(main_helpers.substr_after(arg, 11));
            } else if main_helpers.str_equals(arg, "--trace-codegen") {
                args.trace_codegen = true;
            } else if main_helpers.str_equals(arg, "--dump-types") {
                args.dump_types = true;
            } else if main_helpers.str_equals(arg, "--dump-layouts") {
                args.dump_layouts = true;
            } else if main_helpers.str_equals(arg, "--validate-mir") {
                args.validate_mir = true;
            } else if main_helpers.str_equals(arg, "--no-validate-mir") {
                args.validate_mir = false;
            } else if main_helpers.str_equals(arg, "--mem-profile") {
                args.mem_profile = true;
            } else if main_helpers.str_equals(arg, "--alloc-profile") {
                args.alloc_profile = true;
            } else if main_helpers.str_equals(arg, "--hash-stats") {
                args.hash_stats = true;
            } else if main_helpers.str_equals(arg, "--split-modules") {
                args.split_modules = true;
            } else if main_helpers.str_equals(arg, "--no-parallel") {
                args.no_parallel = true;
            } else if main_helpers.str_equals(arg, "--list") {
                args.test_list = true;
            } else if main_helpers.str_equals(arg, "--fail-fast") {
                args.test_fail_fast = true;
            } else if main_helpers.str_equals(arg, "--ignored") {
                args.test_only_ignored = true;
            } else if main_helpers.str_equals(arg, "--include-ignored") {
                args.test_include_ignored = true;
            } else if main_helpers.str_equals(arg, "--filter") {
                if i + 1 < argv.len() {
                    i += 1;
                    args.test_filter = Option.Some(main_helpers.clone_string(&argv[i]));
                } else {
                    main_helpers.print_error("missing value for --filter");
                }
            } else if main_helpers.str_equals(arg, "-F") {
                if i + 1 < argv.len() {
                    i += 1;
                    args.test_filter = Option.Some(main_helpers.clone_string(&argv[i]));
                } else {
                    main_helpers.print_error("missing value for -F");
                }
            } else if main_helpers.str_starts_with(arg, "--filter=") {
                args.test_filter = Option.Some(main_helpers.substr_after(arg, 9));
            }
        } else {
            // Positional argument (source file)
            if args.source_file.is_none() {
                args.source_file = Option.Some(main_helpers.clone_string(arg));
            }
        }
        i += 1;
    }

    args
}

/// Parses a command string into Command enum.
fn parse_command(cmd: &String) -> Command {
    if main_helpers.str_equals(cmd, "check") {
        Command.Check
    } else if main_helpers.str_equals(cmd, "build") {
        Command.Build
    } else if main_helpers.str_equals(cmd, "run") {
        Command.Run
    } else if main_helpers.str_equals(cmd, "test") {
        Command.Test
    } else if main_helpers.str_equals(cmd, "help") {
        Command.Help
    } else if main_helpers.str_equals(cmd, "version") {
        Command.Version
    } else if main_helpers.str_equals(cmd, "clean") {
        Command.Clean
    } else {
        Command.Help
    }
}

// ============================================================
fn resolve_build_dir(args: &Args) -> String {
    // 1. CLI flag
    match &args.build_dir {
        &Option.Some(ref dir) => { return main_helpers.clone_string(dir); }
        &Option.None => {}
    }
    // 2. BLOOD_BUILD_DIR env var
    let env_val: &str = env_get("BLOOD_BUILD_DIR");
    if env_val.len() > 0 {
        return common.make_string(env_val);
    }
    // 3. Default: build/ relative to source file parent
    let base_dir = match &args.source_file {
        &Option.Some(ref path) => source.parent_dir(path.as_str()),
        &Option.None => common.make_string("."),
    };
    source.join_path(base_dir.as_str(), "build")
}

/// Resolve the stdlib path using the override hierarchy:
/// 1. CLI flag (--stdlib-path)
/// 2. BLOOD_STDLIB_PATH environment variable
/// 3. Installed toolchain: ~/.blood/lib/stdlib/
fn default_codebase_path() -> String {
    let home: &str = env_get("HOME");
    let mut path = common.make_string(home);
    path.push_str("/.blood/codebases/default");
    path
}

fn resolve_stdlib_path(args: &Args) -> Option<String> {
    // 1. CLI flag
    match &args.stdlib_path {
        &Option.Some(ref dir) => { return Option.Some(main_helpers.clone_string(dir)); }
        &Option.None => {}
    }
    // 2. BLOOD_STDLIB_PATH env var
    let env_val: &str = env_get("BLOOD_STDLIB_PATH");
    if env_val.len() > 0 {
        return Option.Some(common.make_string(env_val));
    }
    // 3. Installed toolchain: ~/.blood/lib/stdlib/
    let home: &str = env_get("HOME");
    if home.len() > 0 {
        let installed = source.join_path(home, ".blood/lib/stdlib");
        if file_exists(installed.as_str()) {
            return Option.Some(installed);
        }
    }
    Option.None
}

/// Return the profile subdirectory name based on release mode.
fn profile_subdir(args: &Args) -> &str {
    if args.release { "release" } else { "debug" }
}

/// Create a directory (and parents) if it doesn't exist. Uses mkdir -p.
// Effect Handler Info Collection
// ============================================================

/// Information about a handler operation needed for wrapper generation.
struct HandlerOpInfo {
    /// The handler's user-visible name (e.g., "SilentLog").
    handler_name: String,
    /// The operation's user-visible name (e.g., "log").
    op_name: String,
    /// The operation's index within the effect.
    op_index: u32,
    /// The handler's DefId.
    handler_def_id: u32,
    /// The effect's DefId.
    effect_def_id: u32,
    /// The body DefId of the handler op implementation.
    body_def_id: u32,
    /// The number of parameters the operation takes (excluding self/state).
    param_count: u32,
    /// The number of state fields in the enclosing handler.
    state_field_count: u32,
}

/// Information about a handler's return clause.
struct HandlerReturnInfo {
    /// The handler's user-visible name (e.g., "SilentLog").
    handler_name: String,
    /// The handler's DefId.
    handler_def_id: u32,
    /// The effect's DefId.
    effect_def_id: u32,
    /// The body DefId of the return clause (BodyId.index used as DefId).
    body_def_id: u32,
    /// Whether this handler has an explicit return clause body.
    has_body: bool,
    /// Return clause kind (see ReturnClauseKind for values 0-9).
    return_kind: u32,
    /// For return_kind=1,3,5,7,8: index of the state field in the handler state struct.
    state_field_index: u32,
    /// For return_kind=4,6,9: the literal integer value.
    literal_value: i64,
    /// Number of state fields in the handler.
    state_field_count: u32,
    /// TyId indices of handler state fields (for kind=2 general wrapper call generation).
    state_field_ty_ids: Vec<u32>,
}

/// Information about a handler's finally clause.
struct HandlerFinallyInfo {
    /// The handler's user-visible name (e.g., "handler19").
    handler_name: String,
    /// The handler's DefId.
    handler_def_id: u32,
    /// Whether this handler has an explicit finally clause body.
    has_body: bool,
    /// The body DefId of the finally clause.
    body_def_id: u32,
    /// Number of state fields in the handler.
    state_field_count: u32,
    /// TyId indices of handler state fields.
    state_field_ty_ids: Vec<u32>,
}

/// Collected information about all handlers in the program.
struct HandlerInfo {
    /// Handler operation infos for wrapper generation.
    ops: Vec<HandlerOpInfo>,
    /// Handler return clause infos.
    returns: Vec<HandlerReturnInfo>,
    /// Handler finally clause infos.
    finallys: Vec<HandlerFinallyInfo>,
}

/// Return clause classification result.
/// kind values:
///   0 = identity: return(x) { x }
///   1 = state field: return(x) { state_field }
///   2 = general (calls compiled body, returns result unchanged)
///   3 = add result + state field: return(x) { x + state_field }
///   4 = add result + literal: return(x) { x + N }
///   5 = sub result - state field: return(x) { x - state_field }
///   6 = mul result * literal: return(x) { x * N }
///   7 = mul result * state field: return(x) { x * state_field }
///   8 = div result / state field: return(x) { x / state_field }
///   9 = div result / literal: return(x) { x / N }
struct ReturnClauseKind {
    kind: u32,
    /// For kind=1,3,5: index of the referenced state field
    field_index: u32,
    /// For kind=4: the literal integer value
    literal_value: i64,
}

/// Classifies a return clause body expression.
/// Looks up the body by body_id and inspects the expression:
/// - If the body expression is a VarRef to the last param (result), return kind=0 (identity).
/// - If the body expression is a VarRef to a state field (local index < state_count), return kind=1.
/// - Otherwise return kind=2 (general).
fn classify_return_clause(
    bodies: &Vec<hir_lower_ctx.BodyEntry>,
    body_id_index: u32,
    state_count: u32,
) -> ReturnClauseKind {
    // Find the body by body_id
    for bi in 0usize..bodies.len() {
        if bodies[bi].body_id.index == body_id_index {
            let body = &bodies[bi].body;
            // Classify the body expression.
            // The body expression is typically a Block with a tail expression.
            // We need to dig through Block wrappers to find the actual leaf expression.
            return classify_leaf_expr(&body.expr, state_count);
        }
    }
    // Body not found — treat as identity
    ReturnClauseKind { kind: 0, field_index: 0, literal_value: 0 }
}

/// Classifies a local reference expression for return clause analysis.
/// Returns: 0=identity (references result param), 1=state field, 2=unknown
fn classify_local_ref(local_index: u32, state_count: u32) -> ReturnClauseKind {
    if local_index == state_count {
        return ReturnClauseKind { kind: 0, field_index: 0, literal_value: 0 };
    }
    if local_index < state_count {
        return ReturnClauseKind { kind: 1, field_index: local_index, literal_value: 0 };
    }
    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
}

/// Extracts the local variable index from a block tail expression.
/// Returns -1 if the block doesn't have a simple Local tail expression.
fn extract_block_tail_local(block: &hir_expr.Block) -> i32 {
    if block.stmts.len() != 0 {
        return -1;
    }
    match &block.expr {
        &Some(ref e) => extract_expr_local_index(e.as_ref()),
        &None => -1,
    }
}

/// Extracts the local variable index from a simple Local expression.
/// Returns -1 if the expression is not a simple Local reference.
fn extract_expr_local_index(expr: &hir_expr.Expr) -> i32 {
    match &expr.kind {
        &hir_expr.ExprKind.Local(local_id) => local_id.index as i32,
        _ => -1,
    }
}

/// Extracts an integer literal value from an expression.
/// Returns (true, value) if it's an integer literal, (false, 0) otherwise.
fn extract_int_literal(expr: &hir_expr.Expr) -> (bool, i64) {
    match &expr.kind {
        &hir_expr.ExprKind.Literal(ref lit) => {
            match &lit.kind {
                &hir_expr.LiteralKind.Int { val, ty: _ } => (true, val as i64),
                _ => (false, 0i64),
            }
        }
        _ => (false, 0i64),
    }
}

/// Classifies the leaf expression of a return clause.
fn classify_leaf_expr(expr: &hir_expr.Expr, state_count: u32) -> ReturnClauseKind {
    // Check if this is a Local reference directly
    let direct_idx = extract_expr_local_index(expr);
    if direct_idx >= 0 {
        return classify_local_ref(direct_idx as u32, state_count);
    }
    // Check if this is a Block wrapper
    match &expr.kind {
        &hir_expr.ExprKind.Block(ref block) => {
            // Simple tail local?
            let block_idx = extract_block_tail_local(block);
            if block_idx >= 0 {
                return classify_local_ref(block_idx as u32, state_count);
            }
            // Block with no stmts and a binary tail expression?
            if block.stmts.len() == 0 {
                match &block.expr {
                    &Some(ref e) => return classify_leaf_expr(e.as_ref(), state_count),
                    &None => {}
                }
            }
            ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
        }
        &hir_expr.ExprKind.Binary { operator: bin_op, ref left, ref right } => {
            // Classify left and right operands as local references
            let left_idx = extract_expr_local_index(left.as_ref());
            let right_idx = extract_expr_local_index(right.as_ref());

            match bin_op {
                common.BinOp.Add => {
                    // return(x) { x + state_field } or { state_field + x }
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        // result + state_field
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 3, field_index: right_kind.field_index, literal_value: 0 };
                        }
                        // state_field + result
                        if left_kind.kind == 1 && right_kind.kind == 0 {
                            return ReturnClauseKind { kind: 3, field_index: left_kind.field_index, literal_value: 0 };
                        }
                    }
                    // return(x) { x + literal }
                    if left_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let (is_lit, lit_val) = extract_int_literal(right.as_ref());
                        if left_kind.kind == 0 && is_lit {
                            return ReturnClauseKind { kind: 4, field_index: 0, literal_value: lit_val };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.Sub => {
                    // return(x) { x - state_field }
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 5, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.Mul => {
                    // return(x) { x * state_field } or { state_field * x }
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 7, field_index: right_kind.field_index, literal_value: 0 };
                        }
                        if left_kind.kind == 1 && right_kind.kind == 0 {
                            return ReturnClauseKind { kind: 7, field_index: left_kind.field_index, literal_value: 0 };
                        }
                    }
                    // return(x) { x * literal } or { literal * x }
                    if left_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let (is_lit, lit_val) = extract_int_literal(right.as_ref());
                        if left_kind.kind == 0 && is_lit {
                            return ReturnClauseKind { kind: 6, field_index: 0, literal_value: lit_val };
                        }
                    }
                    if right_idx >= 0 {
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        let (is_lit, lit_val) = extract_int_literal(left.as_ref());
                        if right_kind.kind == 0 && is_lit {
                            return ReturnClauseKind { kind: 6, field_index: 0, literal_value: lit_val };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.Div => {
                    // return(x) { x / state_field }
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 8, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    // return(x) { x / literal }
                    if left_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let (is_lit, lit_val) = extract_int_literal(right.as_ref());
                        if left_kind.kind == 0 && is_lit {
                            return ReturnClauseKind { kind: 9, field_index: 0, literal_value: lit_val };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.Rem => {
                    // return(x) { x % state_field }
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 10, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.BitAnd => {
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 11, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.BitOr => {
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 12, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.Shl => {
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 13, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.Shr => {
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 14, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                common.BinOp.BitXor => {
                    if left_idx >= 0 && right_idx >= 0 {
                        let left_kind = classify_local_ref(left_idx as u32, state_count);
                        let right_kind = classify_local_ref(right_idx as u32, state_count);
                        if left_kind.kind == 0 && right_kind.kind == 1 {
                            return ReturnClauseKind { kind: 15, field_index: right_kind.field_index, literal_value: 0 };
                        }
                    }
                    ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 }
                }
                _ => ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 },
            }
        }
        _ => ReturnClauseKind { kind: 2, field_index: 0, literal_value: 0 },
    }
}

/// Checks if an HIR expression is a tail-position resume call.
/// TR = the body expression IS resume(...) directly. NTR = resume used
/// in non-tail position or not present. Only walks through Block wrappers.
fn expr_is_tail_resume(expr: &hir_expr.Expr) -> bool {
    match &expr.kind {
        &hir_expr.ExprKind.Resume(_) => true,
        &hir_expr.ExprKind.Block(ref block) => {
            // TR only if the block has no stmts and the tail expr is resume
            if block.stmts.len() != 0 { return false; }
            match &block.expr {
                &Option.Some(ref e) => expr_is_tail_resume(e.as_ref()),
                &Option.None => false,
            }
        }
        _ => false,
    }
}

/// Finds a body by body_id and checks if its tail expression is resume().
fn handler_op_is_tail_resumptive(
    bodies: &Vec<hir_lower_ctx.BodyEntry>,
    body_id_index: u32,
) -> bool {
    for bi in 0usize..bodies.len() {
        if bodies[bi].body_id.index == body_id_index {
            return expr_is_tail_resume(&bodies[bi].body.expr);
        }
    }
    false
}

/// Collects handler information from HIR items.
/// Populates handler→effect mappings in the codegen context and returns
/// HandlerInfo for wrapper/registration generation.
fn collect_handler_info(
    ctx: &mut codegen_ctx.CodegenCtx,
    intern: &interner.StringInterner,
    items: &Vec<hir_lower_ctx.ItemEntry>,
    bodies: &Vec<hir_lower_ctx.BodyEntry>,
) -> HandlerInfo {
    let mut ops: Vec<HandlerOpInfo> = Vec.new();
    let mut returns: Vec<HandlerReturnInfo> = Vec.new();
    let mut finallys: Vec<HandlerFinallyInfo> = Vec.new();

    for i in 0usize..items.len() {
        let entry = &items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                let handler_def_id = entry.def_id.index;
                let effect_def_id = handler_def.handled_effect.def_id.index;

                // Use DefId-based handler name to avoid interner mismatch.
                // The wrapper functions use handler{N} prefix (e.g., handler19_log).
                let mut handler_name = common.make_string("handler");
                push_usize(&mut handler_name, handler_def_id as usize);

                // Register handler→effect mapping, kind, and state count
                ctx.register_handler_effect(handler_def_id, effect_def_id);
                let kind_val: u32 = match &handler_def.kind {
                    &common.HandlerKind.Deep => 0,
                    &common.HandlerKind.Shallow => 1,
                };
                ctx.register_handler_kind(handler_def_id, kind_val);
                let state_count = handler_def.state.len() as u32;
                ctx.register_handler_state_count(handler_def_id, state_count);

                // Collect state field TyId indices for kind=2 wrapper call generation.
                let mut field_ty_ids: Vec<u32> = Vec.new();
                for si in 0usize..handler_def.state.len() {
                    field_ty_ids.push(handler_def.state[si].ty.index);
                }

                // Collect return clause info
                // Handlers without an explicit return clause get body_def_id=0
                // which signals "identity return" (return body result unchanged)

                match &handler_def.return_clause {
                    &Option.Some(ref ret_clause) => {
                        // Classify the return clause by inspecting the HIR body expression.
                        let ret_kind = classify_return_clause(bodies, ret_clause.body_id.index, state_count);

                        returns.push(HandlerReturnInfo {
                            handler_name: main_helpers.clone_string(&handler_name),
                            handler_def_id,
                            effect_def_id,
                            body_def_id: ret_clause.body_id.index,
                            has_body: true,
                            return_kind: ret_kind.kind,
                            state_field_index: ret_kind.field_index,
                            literal_value: ret_kind.literal_value,
                            state_field_count: state_count,
                            state_field_ty_ids: field_ty_ids,
                        });
                    }
                    &Option.None => {
                        // Generate identity return wrapper (ret i64 %result)
                        let mut id_name = common.make_string("handler");
                        push_usize(&mut id_name, handler_def_id as usize);
                        returns.push(HandlerReturnInfo {
                            handler_name: id_name,
                            handler_def_id,
                            effect_def_id,
                            body_def_id: 0,
                            has_body: false,
                            return_kind: 0,
                            state_field_index: 0,
                            literal_value: 0,
                            state_field_count: state_count,
                            state_field_ty_ids: field_ty_ids,
                        });
                    }
                }

                // Collect finally clause info
                let mut finally_field_ty_ids: Vec<u32> = Vec.new();
                for si in 0usize..handler_def.state.len() {
                    finally_field_ty_ids.push(handler_def.state[si].ty.index);
                }
                match &handler_def.finally_clause {
                    &Option.Some(ref fin_clause) => {
                        finallys.push(HandlerFinallyInfo {
                            handler_name: main_helpers.clone_string(&handler_name),
                            handler_def_id,
                            has_body: true,
                            body_def_id: fin_clause.def_id.index,
                            state_field_count: state_count,
                            state_field_ty_ids: finally_field_ty_ids,
                        });
                    }
                    &Option.None => {
                        finallys.push(HandlerFinallyInfo {
                            handler_name: main_helpers.clone_string(&handler_name),
                            handler_def_id,
                            has_body: false,
                            body_def_id: 0,
                            state_field_count: state_count,
                            state_field_ty_ids: finally_field_ty_ids,
                        });
                    }
                }

                // Collect operation infos + per-op tail-resumptive classification
                let mut has_ntr_op = false;
                for oi in 0usize..handler_def.op_impls.len() {
                    let op_impl = &handler_def.op_impls[oi];

                    // Use DefId-based op name for reliability
                    let mut op_name = common.make_string("op");
                    push_usize(&mut op_name, op_impl.op_def_id.index as usize);

                    // Find op_index by searching the effect's operations
                    let op_index = find_op_index(items, effect_def_id, op_impl.op_def_id.index);

                    // Per-op TR classification: scan body for resume() calls
                    let op_is_tr = handler_op_is_tail_resumptive(bodies, op_impl.body_id.index);
                    if op_is_tr {
                        // register_tail_resumptive_op only sets TR if not already classified
                        ctx.register_tail_resumptive_op(effect_def_id, op_impl.name.symbol.index);
                    } else {
                        has_ntr_op = true;
                        // NTR always wins — overrides any previous TR from another handler
                        ctx.register_non_tail_resumptive_op(effect_def_id, op_impl.name.symbol.index);
                    }

                    ops.push(HandlerOpInfo {
                        handler_name: main_helpers.clone_string(&handler_name),
                        op_name,
                        op_index,
                        handler_def_id,
                        effect_def_id,
                        // Use body_id offset by 0x80000000 to create unique DefId per
                        // handler op body. This matches find_fn_for_body in driver.blood
                        // which uses the same offset for handler op bodies.
                        body_def_id: 0x80000000 + op_impl.body_id.index,
                        param_count: op_impl.param_names.len() as u32,
                        state_field_count: state_count,
                    });
                }
            }
            &hir_item.ItemKind.Fn(_) => {}
            &hir_item.ItemKind.Struct(_) => {}
            &hir_item.ItemKind.Enum(_) => {}
            &hir_item.ItemKind.TypeAlias(_) => {}
            &hir_item.ItemKind.Const(_) => {}
            &hir_item.ItemKind.Static(_) => {}
            &hir_item.ItemKind.Trait(_) => {}
            &hir_item.ItemKind.Effect(ref effect_def) => {
                // Register (effect_def_id, op_name_symbol) → positional index for Perform resolution.
                let effect_item_def_id = entry.item.def_id.index;
                for opi in 0usize..effect_def.operations.len() {
                    ctx.register_op_def_index(
                        effect_item_def_id,
                        effect_def.operations[opi].name.symbol.index,
                        opi as u32,
                    );
                }

                // Register all effects as non-tail-resumptive by default (safe).
                // Only known tail-resumptive builtins (State, IO, Console) are
                // excluded — their handlers always resume in tail position.
                // Use span-based extraction because item name symbols use the AST
                // parser's interner, not the HIR interner.
                let effect_name = main_helpers.resolve_symbol(intern, entry.item.name.symbol);
                let is_known_tail_resumptive =
                    main_helpers.str_equals(&effect_name, "State")
                    || main_helpers.str_equals(&effect_name, "IO")
                    || main_helpers.str_equals(&effect_name, "Console");
                if !is_known_tail_resumptive {
                    ctx.register_non_tail_resumptive_effect(effect_item_def_id);
                }
            }
            &hir_item.ItemKind.Module(_) => {}
            &hir_item.ItemKind.Macro(_) => {}
            &hir_item.ItemKind.Impl(_) => {}
            &hir_item.ItemKind.Foreign(_) => {}
        }
    }

    HandlerInfo { ops, returns, finallys }
}

/// Finds the operation index within an effect definition by op DefId.
fn find_op_index(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    effect_def_id: u32,
    op_def_id: u32,
) -> u32 {
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Effect(ref effect_def) => {
                if items[i].def_id.index == effect_def_id {
                    for j in 0usize..effect_def.operations.len() {
                        if effect_def.operations[j].def_id.index == op_def_id {
                            return j as u32;
                        }
                    }
                }
            }
            _ => {}
        }
    }
    0 // fallback
}

/// Generates __blood_vft_init constructor that registers trait impl methods in the VFT.
/// For each trait impl method with a body, computes its content hash and emits a
/// blood_vft_register(hash_lo, hash_hi, fn_ptr, arity) call.
fn generate_vft_init_ir(
    lower_result: &hir_lower_ctx.LowerResult,
) -> String {
    let mut ir = common.make_string("define linkonce_odr void @__blood_vft_init() {\nentry:\n");
    let mut count: usize = 0;

    for i in 0usize..lower_result.items.len() {
        let entry = &lower_result.items[i];
        match &entry.item.kind {
            &hir_item.ItemKind.Impl(ref impl_def) => {
                // Only trait impls (not inherent impls)
                if impl_def.trait_ref.is_some() {
                    for j in 0usize..impl_def.items.len() {
                        match &impl_def.items[j] {
                            &hir_item.AssocItem.Fn(ref assoc_fn) => {
                                match &assoc_fn.body_id {
                                    &Option.Some(ref bid) => {
                                        // Find the body
                                        for bi in 0usize..lower_result.bodies.len() {
                                            if lower_result.bodies[bi].body_id.index == bid.index {
                                                let hash = content_hash.hash_fn_body(&lower_result.bodies[bi].body, &assoc_fn.sig);
                                                // Convert first 16 bytes to hash_lo/hash_hi (LE)
                                                let mut hash_lo: u64 = 0;
                                                let mut hash_hi: u64 = 0;
                                                let mut b: usize = 0;
                                                while b < 8 {
                                                    let shift: u64 = (b as u64) * 8;
                                                    hash_lo = hash_lo | ((hash[b] as u64) << shift);
                                                    hash_hi = hash_hi | ((hash[b + 8] as u64) << shift);
                                                    b += 1;
                                                }
                                                // Get mangled fn name
                                                let fn_info = driver.FnInfo {
                                                    def_id: assoc_fn.def_id,
                                                    name: assoc_fn.name.symbol,
                                                    name_span: assoc_fn.name.span,
                                                    return_ty: assoc_fn.sig.return_ty,
                                                    span: assoc_fn.name.span,
                                                };
                                                let fn_name = main_helpers.make_mangled_fn_name(
                                                    &lower_result.interner, &fn_info,
                                                    &lower_result.no_mangle_def_ids,
                                                    &lower_result.export_name_entries,
                                                );
                                                let arity = assoc_fn.sig.params.len();
                                                // Emit: call void @blood_vft_register(i64 lo, i64 hi, i64 ptrtoint(ptr @fn to i64), i32 arity)
                                                let lo_str = codegen_types.format_u64(hash_lo);
                                                let hi_str = codegen_types.format_u64(hash_hi);
                                                ir.push_str("  call void @blood_vft_register(i64 ");
                                                ir.push_str(lo_str.as_str());
                                                ir.push_str(", i64 ");
                                                ir.push_str(hi_str.as_str());
                                                ir.push_str(", i64 ptrtoint(ptr @");
                                                ir.push_str(fn_name.as_str());
                                                ir.push_str(" to i64), i32 ");
                                                push_usize(&mut ir, arity);
                                                ir.push_str(")\n");
                                                count += 1;
                                            }
                                        }
                                    }
                                    &Option.None => {}
                                }
                            }
                            _ => {}
                        }
                    }
                }
            }
            _ => {}
        }
    }

    ir.push_str("  ret void\n}\n\n");
    ir
}

/// Generates handler op wrapper functions and the __blood_register_handlers function.
/// Returns the LLVM IR string to append to the module.
fn generate_handler_wrappers(
    handler_info: &HandlerInfo,
    ctx: &mut codegen_ctx.CodegenCtx,
    body_id_names: &Vec<BodyIdNameEntry>,
) -> String {
    let mut ir = String.new();

    if handler_info.ops.len() == 0 && handler_info.returns.len() == 0 && handler_info.finallys.len() == 0 {
        // Still need global_ctors for VFT init even without handlers
        ir.push_str("define linkonce_odr void @__blood_register_handlers() {\nentry:\n  ret void\n}\n\n");
        ir.push_str("@llvm.global_ctors = appending global [2 x { i32, ptr, ptr }] [{ i32, ptr, ptr } { i32 65535, ptr @__blood_register_handlers, ptr null }, { i32, ptr, ptr } { i32 65535, ptr @__blood_vft_init, ptr null }]\n");
        return ir;
    }

    ir.push_str("\n; Effect handler wrapper functions\n");

    // Generate wrapper for each handler operation.
    // Wrapper signature: i64 (ptr %state, ptr %args, i64 %arg_count, i64 %cont)
    // The wrapper unpacks args, calls the inner body, and handles continuation resume.
    for oi in 0usize..handler_info.ops.len() {
        let opinfo = &handler_info.ops[oi];

        // Wrapper function name: {HandlerName}_{OpName}
        let mut wrapper_name = main_helpers.clone_string(&opinfo.handler_name);
        wrapper_name.push(95 as char); // '_'
        wrapper_name.push_str(opinfo.op_name.as_str());

        // Find the inner body function name
        let inner_name = match ctx.lookup_def_name(opinfo.body_def_id) {
            Option.Some(name) => name,
            Option.None => {
                let mut fallback = common.make_string("fn_");
                push_usize(&mut fallback, opinfo.body_def_id as usize);
                fallback
            }
        };

        // Determine inner function return type (from fn_signatures)
        let inner_ret_ty = match ctx.lookup_fn_ret_type(opinfo.body_def_id) {
            Option.Some(ty) => ty,
            Option.None => common.make_string("void"),
        };

        // Generate wrapper
        ir.push_str("define weak_odr i64 @");
        ir.push_str(wrapper_name.as_str());
        ir.push_str("(ptr %state, ptr %args, i64 %arg_count, i64 %cont) {\n");
        ir.push_str("entry:\n");

        // Unpack args and call inner body
        // Inner body params: the natural parameters of the handler op
        let param_count = opinfo.param_count as usize;
        let has_state = opinfo.state_field_count > 0;

        // sig_offset: skip past the state pointer param in the inner function signature
        // when looking up op param types. For stateless handlers, op params
        // start at MIR local 1 (sig index 0), not local 2.
        // State field locals are no longer function params (they're accessed via GEP),
        // so we only skip the one state pointer param.
        let mut sig_offset: usize = 0;
        if has_state {
            sig_offset = 1;
        }

        // Build call to inner function
        // Pass ptr %state only if the handler has state fields.
        // All inner body functions now receive i64 %cont as their last parameter
        // for non-tail-resumptive continuation access.
        if param_count == 0 {
            if has_state {
                // State-only — call inner with state pointer + cont
                if str_eq(inner_ret_ty.as_str(), "void") {
                    ir.push_str("  call void @");
                    ir.push_str(inner_name.as_str());
                    ir.push_str("(ptr %state, i64 %cont)\n");
                    ir.push_str("  ret i64 0\n");
                } else {
                    ir.push_str("  %inner_result = call ");
                    ir.push_str(inner_ret_ty.as_str());
                    ir.push_str(" @");
                    ir.push_str(inner_name.as_str());
                    ir.push_str("(ptr %state, i64 %cont)\n");
                    let widened = widen_to_i64(&mut ir, "inner_result", inner_ret_ty.as_str());
                    ir.push_str("  ret i64 ");
                    ir.push_str(widened.as_str());
                    ir.push_str("\n");
                }
            } else {
                // No state, no params — call inner with just cont
                if str_eq(inner_ret_ty.as_str(), "void") {
                    ir.push_str("  call void @");
                    ir.push_str(inner_name.as_str());
                    ir.push_str("(i64 %cont)\n");
                    ir.push_str("  ret i64 0\n");
                } else {
                    ir.push_str("  %inner_result = call ");
                    ir.push_str(inner_ret_ty.as_str());
                    ir.push_str(" @");
                    ir.push_str(inner_name.as_str());
                    ir.push_str("(i64 %cont)\n");
                    let widened = widen_to_i64(&mut ir, "inner_result", inner_ret_ty.as_str());
                    ir.push_str("  ret i64 ");
                    ir.push_str(widened.as_str());
                    ir.push_str("\n");
                }
            }
        } else {
            // Load args from args array
            for pi in 0usize..param_count {
                // Get the expected param type from inner function signature.
                // sig_offset skips past state params for stateful handlers.
                let param_ty = match ctx.lookup_fn_param_type(opinfo.body_def_id, pi + sig_offset) {
                    Option.Some(ty) => ty,
                    Option.None => common.make_string("i64"),
                };

                if pi == 0 {
                    // First arg: load directly from args ptr
                    ir.push_str("  %arg_i64_0 = load i64, ptr %args, align 8\n");
                } else {
                    // Subsequent args: GEP into args array
                    ir.push_str("  %arg_ptr_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = getelementptr i64, ptr %args, i64 ");
                    push_usize(&mut ir, pi);
                    ir.push_str("\n");
                    ir.push_str("  %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = load i64, ptr %arg_ptr_");
                    push_usize(&mut ir, pi);
                    ir.push_str(", align 8\n");
                }

                // Narrow i64 to param type if needed
                if str_eq(param_ty.as_str(), "i64") {
                    // Already correct
                } else if str_eq(param_ty.as_str(), "i32") {
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = trunc i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to i32\n");
                } else if str_eq(param_ty.as_str(), "i16") {
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = trunc i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to i16\n");
                } else if str_eq(param_ty.as_str(), "i8") {
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = trunc i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to i8\n");
                } else if str_eq(param_ty.as_str(), "i1") {
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = trunc i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to i1\n");
                } else if str_eq(param_ty.as_str(), "ptr") {
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = inttoptr i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to ptr\n");
                } else if str_eq(param_ty.as_str(), "double") {
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = bitcast i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to double\n");
                } else if str_eq(param_ty.as_str(), "float") {
                    ir.push_str("  %arg_f64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = bitcast i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to double\n");
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = fptrunc double %arg_f64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to float\n");
                } else {
                    // For struct/aggregate types, use inttoptr then load
                    ir.push_str("  %arg_ptr_cast_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = inttoptr i64 %arg_i64_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" to ptr\n");
                    ir.push_str("  %arg_");
                    push_usize(&mut ir, pi);
                    ir.push_str(" = load ");
                    ir.push_str(param_ty.as_str());
                    ir.push_str(", ptr %arg_ptr_cast_");
                    push_usize(&mut ir, pi);
                    ir.push_str("\n");
                }

            }

            // Build call to inner function.
            // For stateful handlers: call @inner(ptr %state, args..., i64 %cont)
            // For stateless handlers: call @inner(args..., i64 %cont)
            if str_eq(inner_ret_ty.as_str(), "void") {
                ir.push_str("  call void @");
                ir.push_str(inner_name.as_str());
                ir.push_str("(");
                if has_state {
                    ir.push_str("ptr %state");
                    if param_count > 0 {
                        ir.push_str(", ");
                    }
                }
                emit_call_args(&mut ir, ctx, opinfo.body_def_id, param_count, sig_offset);
                if has_state || param_count > 0 {
                    ir.push_str(", ");
                }
                ir.push_str("i64 %cont)\n");
                ir.push_str("  ret i64 0\n");
            } else {
                ir.push_str("  %inner_result = call ");
                ir.push_str(inner_ret_ty.as_str());
                ir.push_str(" @");
                ir.push_str(inner_name.as_str());
                ir.push_str("(");
                if has_state {
                    ir.push_str("ptr %state");
                    if param_count > 0 {
                        ir.push_str(", ");
                    }
                }
                emit_call_args(&mut ir, ctx, opinfo.body_def_id, param_count, sig_offset);
                if has_state || param_count > 0 {
                    ir.push_str(", ");
                }
                ir.push_str("i64 %cont)\n");
                let widened = widen_to_i64(&mut ir, "inner_result", inner_ret_ty.as_str());
                ir.push_str("  ret i64 ");
                ir.push_str(widened.as_str());
                ir.push_str("\n");
            }
        }

        ir.push_str("}\n\n");

    }

    // Generate return clause wrappers
    // Signature: i64 (i64 %result, ptr %state)
    for ri in 0usize..handler_info.returns.len() {
        let ret_info = &handler_info.returns[ri];

        let mut wrapper_name = main_helpers.clone_string(&ret_info.handler_name);
        wrapper_name.push_str("_return");

        ir.push_str("define weak_odr i64 @");
        ir.push_str(wrapper_name.as_str());
        ir.push_str("(i64 %result, ptr %state) {\n");
        ir.push_str("entry:\n");

        if ret_info.return_kind == 0 {
            // Identity: return(x) { x } — just return the result unchanged
            ir.push_str("  ret i64 %result\n");
        } else if ret_info.return_kind == 1 {
            // State field: return(x) { total } — load state field from %state pointer
            // State shadow is a struct { i64, i64, ... } (one i64 per state field).
            // For single-field state, load directly from %state.
            // For multi-field state, GEP to the correct field offset.
            if ret_info.state_field_count == 1 {
                // Single field: load i32 directly from state pointer
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
                ir.push_str("  %ret_ext = sext i32 %state_val to i64\n");
                ir.push_str("  ret i64 %ret_ext\n");
            } else {
                // Multi-field: GEP to field offset, then load
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
                ir.push_str("  %ret_ext = sext i32 %state_val to i64\n");
                ir.push_str("  ret i64 %ret_ext\n");
            }
        } else if ret_info.return_kind == 3 {
            // Add result + state field: return(x) { x + state_field }
            // Truncate result to i32, load state field as i32, add, extend back.
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %sum = add i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %sum to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 4 {
            // Add result + literal: return(x) { x + N }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            ir.push_str("  %sum = add i32 %res_i32, ");
            push_usize(&mut ir, ret_info.literal_value as usize);
            ir.push_str("\n");
            ir.push_str("  %ret_ext = sext i32 %sum to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 5 {
            // Sub result - state field: return(x) { x - state_field }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %diff = sub i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %diff to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 6 {
            // Mul result * literal: return(x) { x * N }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            ir.push_str("  %prod = mul i32 %res_i32, ");
            push_usize(&mut ir, ret_info.literal_value as usize);
            ir.push_str("\n");
            ir.push_str("  %ret_ext = sext i32 %prod to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 7 {
            // Mul result * state field: return(x) { x * state_field }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %prod = mul i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %prod to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 8 {
            // Div result / state field: return(x) { x / state_field }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %quot = sdiv i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %quot to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 9 {
            // Div result / literal: return(x) { x / N }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            ir.push_str("  %quot = sdiv i32 %res_i32, ");
            push_usize(&mut ir, ret_info.literal_value as usize);
            ir.push_str("\n");
            ir.push_str("  %ret_ext = sext i32 %quot to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 10 {
            // Rem result % state field: return(x) { x % state_field }
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %divchk = icmp eq i32 %state_val, 0\n");
            ir.push_str("  br i1 %divchk, label %rem_zero, label %rem_ok\n");
            ir.push_str("rem_zero:\n");
            ir.push_str("  call void @blood_panic_div_zero()\n");
            ir.push_str("  unreachable\n");
            ir.push_str("rem_ok:\n");
            ir.push_str("  %rem_val = srem i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %rem_val to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 11 {
            // BitAnd result & state field
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %and_val = and i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %and_val to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 12 {
            // BitOr result | state field
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %or_val = or i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %or_val to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 13 {
            // Shl result << state field
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %shl_val = shl i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %shl_val to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 14 {
            // Shr result >> state field (arithmetic)
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %shr_val = ashr i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %shr_val to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else if ret_info.return_kind == 15 {
            // BitXor result ^ state field
            ir.push_str("  %res_i32 = trunc i64 %result to i32\n");
            if ret_info.state_field_count == 1 {
                ir.push_str("  %state_val = load i32, ptr %state, align 4\n");
            } else {
                ir.push_str("  %field_ptr = getelementptr i64, ptr %state, i64 ");
                push_usize(&mut ir, ret_info.state_field_index as usize);
                ir.push_str("\n");
                ir.push_str("  %state_val = load i32, ptr %field_ptr, align 4\n");
            }
            ir.push_str("  %xor_val = xor i32 %res_i32, %state_val\n");
            ir.push_str("  %ret_ext = sext i32 %xor_val to i64\n");
            ir.push_str("  ret i64 %ret_ext\n");
        } else {
            // General case (return_kind == 2): call the compiled return clause body function.
            // The body function takes state fields by value + result as i64.
            // We load state fields from %state, call the body for side effects,
            // and return %result.
            // Look up body function name from the worklist's body_id→name mapping.
            // This avoids the def_name collision where register_all_item_names
            // overwrites the handler body's name with a real item name.
            let mut body_name: Option<String> = Option.None;
            for bni in 0usize..body_id_names.len() {
                if body_id_names[bni].body_id == ret_info.body_def_id {
                    body_name = Option.Some(main_helpers.clone_string(&body_id_names[bni].fn_name));
                }
            }
            match &body_name {
                &Option.Some(ref fn_name) => {
                    // Load state fields from the state shadow pointer.
                    // State shadow layout: [N x i64] where state fields are packed.
                    let field_count = ret_info.state_field_ty_ids.len();
                    let mut offset: u64 = 0;
                    for fi in 0usize..field_count {
                        let ty_id = type_intern.TyId.new(ret_info.state_field_ty_ids[fi]);
                        let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, ty_id);
                        let ty_size = codegen_size.llvm_type_size(llvm_ty.as_str());
                        // GEP to byte offset, then load
                        if offset == 0 {
                            ir.push_str("  %fld");
                            push_usize(&mut ir, fi);
                            ir.push_str(" = load ");
                            ir.push_str(llvm_ty.as_str());
                            ir.push_str(", ptr %state\n");
                        } else {
                            ir.push_str("  %fld_ptr");
                            push_usize(&mut ir, fi);
                            ir.push_str(" = getelementptr i8, ptr %state, i64 ");
                            push_usize(&mut ir, offset as usize);
                            ir.push_str("\n");
                            ir.push_str("  %fld");
                            push_usize(&mut ir, fi);
                            ir.push_str(" = load ");
                            ir.push_str(llvm_ty.as_str());
                            ir.push_str(", ptr %fld_ptr");
                            push_usize(&mut ir, fi);
                            ir.push_str("\n");
                        }
                        // Advance offset, aligned to 8 bytes
                        offset = offset + ((ty_size + 7) / 8) * 8;
                    }
                    // Build the call: i64 @body_fn(field0, field1, ..., i64 %result)
                    ir.push_str("  %ret_val = call i64 @");
                    ir.push_str(fn_name.as_str());
                    ir.push_str("(");
                    for ai in 0usize..field_count {
                        if ai > 0 {
                            ir.push_str(", ");
                        }
                        let ty_id = type_intern.TyId.new(ret_info.state_field_ty_ids[ai]);
                        let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, ty_id);
                        ir.push_str(llvm_ty.as_str());
                        ir.push_str(" %fld");
                        push_usize(&mut ir, ai);
                    }
                    if field_count > 0 {
                        ir.push_str(", ");
                    }
                    ir.push_str("i64 %result)\n");
                    ir.push_str("  ret i64 %ret_val\n");
                }
                &Option.None => {
                    // Body function not found — fall back to identity
                    ir.push_str("  ret i64 %result\n");
                }
            }
        }

        ir.push_str("}\n\n");

    }

    // Generate finally clause wrappers
    // Signature: void (ptr %state)
    for fi in 0usize..handler_info.finallys.len() {
        let fin_info = &handler_info.finallys[fi];

        let mut wrapper_name = main_helpers.clone_string(&fin_info.handler_name);
        wrapper_name.push_str("_finally");

        ir.push_str("define weak_odr void @");
        ir.push_str(wrapper_name.as_str());
        ir.push_str("(ptr %state) {\n");
        ir.push_str("entry:\n");

        if !fin_info.has_body {
            // No finally clause — just return void
            ir.push_str("  ret void\n");
        } else {
            // Call the compiled finally clause body function.
            // Body takes state fields by value (same as return clause kind=2).
            let body_name = ctx.lookup_def_name(fin_info.body_def_id);
            match &body_name {
                &Option.Some(ref fn_name) => {
                    let field_count = fin_info.state_field_ty_ids.len();
                    let mut offset: u64 = 0;
                    for fld_i in 0usize..field_count {
                        let ty_id = type_intern.TyId.new(fin_info.state_field_ty_ids[fld_i]);
                        let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, ty_id);
                        let ty_size = codegen_size.llvm_type_size(llvm_ty.as_str());
                        if offset == 0 {
                            ir.push_str("  %fld");
                            push_usize(&mut ir, fld_i);
                            ir.push_str(" = load ");
                            ir.push_str(llvm_ty.as_str());
                            ir.push_str(", ptr %state\n");
                        } else {
                            ir.push_str("  %fld_ptr");
                            push_usize(&mut ir, fld_i);
                            ir.push_str(" = getelementptr i8, ptr %state, i64 ");
                            push_usize(&mut ir, offset as usize);
                            ir.push_str("\n");
                            ir.push_str("  %fld");
                            push_usize(&mut ir, fld_i);
                            ir.push_str(" = load ");
                            ir.push_str(llvm_ty.as_str());
                            ir.push_str(", ptr %fld_ptr");
                            push_usize(&mut ir, fld_i);
                            ir.push_str("\n");
                        }
                        offset = offset + ((ty_size + 7) / 8) * 8;
                    }
                    // Build the call: void @body_fn(field0, field1, ...)
                    ir.push_str("  call void @");
                    ir.push_str(fn_name.as_str());
                    ir.push_str("(");
                    for ai in 0usize..field_count {
                        if ai > 0 {
                            ir.push_str(", ");
                        }
                        let ty_id = type_intern.TyId.new(fin_info.state_field_ty_ids[ai]);
                        let llvm_ty = codegen_size.type_to_llvm_with_ctx_id(ctx, ty_id);
                        ir.push_str(llvm_ty.as_str());
                        ir.push_str(" %fld");
                        push_usize(&mut ir, ai);
                    }
                    ir.push_str(")\n");
                    ir.push_str("  ret void\n");
                }
                &Option.None => {
                    ir.push_str("  ret void\n");
                }
            }
        }

        ir.push_str("}\n\n");
    }

    // Generate __blood_register_handlers
    ir.push_str("; Handler registration\n");
    // Emit globals for per-HANDLER registry index (used by PushHandler push_by_index).
    // Each handler gets its own registry entry so that different handlers for the
    // same effect can be swapped at runtime.
    {
        let mut globals_emitted: Vec<u32> = Vec.new();
        for gi in 0usize..handler_info.ops.len() {
            let ghid = handler_info.ops[gi].handler_def_id;
            let mut galready = false;
            for gj in 0usize..globals_emitted.len() {
                if globals_emitted[gj] == ghid { galready = true; }
            }
            if !galready {
                ir.push_str("@__handler_reg_idx_");
                push_usize(&mut ir, ghid as usize);
                ir.push_str(" = common global i64 0\n");
                globals_emitted.push(ghid);
            }
        }
    }
    ir.push_str("define linkonce_odr void @__blood_register_handlers() {\n");
    ir.push_str("entry:\n");

    // Register each handler independently (per-handler, NOT per-effect).
    // This allows multiple handlers for the same effect to coexist —
    // PushHandler loads the specific handler's registry index.
    let mut registered_handlers: Vec<u32> = Vec.new();
    for ei in 0usize..handler_info.ops.len() {
        let opentry = &handler_info.ops[ei];
        let hid = opentry.handler_def_id;

        // Check if we already registered this handler
        let mut already = false;
        let mut ri2: usize = 0;
        while ri2 < registered_handlers.len() {
            if registered_handlers[ri2] == hid {
                already = true;
                ri2 = registered_handlers.len(); // break
            }
            ri2 += 1;
        }

        if !already {
            registered_handlers.push(hid);

            let eid = opentry.effect_def_id;
            let eid_str = codegen_types.format_u64(eid as u64);
            let hid_str = codegen_types.format_u64(hid as u64);

            // Count ops for this handler (not all ops for the effect)
            let mut op_count: usize = 0;
            for ci in 0usize..handler_info.ops.len() {
                if handler_info.ops[ci].handler_def_id == hid {
                    op_count += 1;
                }
            }

            // Alloca for this handler's ops array
            ir.push_str("  %handler_ops_");
            ir.push_str(hid_str.as_str());
            ir.push_str(" = alloca [");
            push_usize(&mut ir, op_count);
            ir.push_str(" x ptr]\n");

            // Store each op's wrapper function pointer at its op_index position
            for si in 0usize..handler_info.ops.len() {
                if handler_info.ops[si].handler_def_id == hid {
                    let sop = &handler_info.ops[si];
                    let mut wrapper_name = main_helpers.clone_string(&sop.handler_name);
                    wrapper_name.push(95 as char); // '_'
                    wrapper_name.push_str(sop.op_name.as_str());
                    let store_idx = sop.op_index as usize;

                    if store_idx == 0 {
                        ir.push_str("  store ptr @");
                        ir.push_str(wrapper_name.as_str());
                        ir.push_str(", ptr %handler_ops_");
                        ir.push_str(hid_str.as_str());
                        ir.push_str("\n");
                    } else {
                        ir.push_str("  %op_ptr_");
                        ir.push_str(hid_str.as_str());
                        ir.push_str("_");
                        push_usize(&mut ir, store_idx);
                        ir.push_str(" = getelementptr [");
                        push_usize(&mut ir, op_count);
                        ir.push_str(" x ptr], ptr %handler_ops_");
                        ir.push_str(hid_str.as_str());
                        ir.push_str(", i64 0, i64 ");
                        push_usize(&mut ir, store_idx);
                        ir.push_str("\n");
                        ir.push_str("  store ptr @");
                        ir.push_str(wrapper_name.as_str());
                        ir.push_str(", ptr %op_ptr_");
                        ir.push_str(hid_str.as_str());
                        ir.push_str("_");
                        push_usize(&mut ir, store_idx);
                        ir.push_str("\n");
                    }
                }
            }

            // Call blood_evidence_register — effect_id identifies the effect,
            // but the registry entry is unique to this handler
            let is_deep_val = if ctx.handler_is_deep(opentry.handler_def_id) { 1usize } else { 0usize };
            ir.push_str("  %reg_idx_");
            ir.push_str(hid_str.as_str());
            ir.push_str(" = call i64 @blood_evidence_register(ptr null, i64 ");
            ir.push_str(eid_str.as_str());
            ir.push_str(", ptr %handler_ops_");
            ir.push_str(hid_str.as_str());
            ir.push_str(", i64 ");
            push_usize(&mut ir, op_count);
            ir.push_str(", i64 ");
            push_usize(&mut ir, is_deep_val);
            ir.push_str(")\n");
            // Store registry index in per-handler global for PushHandler
            ir.push_str("  store i64 %reg_idx_");
            ir.push_str(hid_str.as_str());
            ir.push_str(", ptr @__handler_reg_idx_");
            ir.push_str(hid_str.as_str());
            ir.push_str("\n");
        }

    }

    ir.push_str("  ret void\n");
    ir.push_str("}\n\n");
    ir.push_str("@llvm.global_ctors = appending global [2 x { i32, ptr, ptr }] [{ i32, ptr, ptr } { i32 65535, ptr @__blood_register_handlers, ptr null }, { i32, ptr, ptr } { i32 65535, ptr @__blood_vft_init, ptr null }]\n");

    ir
}

/// Emits resume logic for a handler op wrapper.
/// If cont == 0, returns resume_val directly (tail-resumptive).
/// Otherwise, calls blood_continuation_resume_with_regions and returns its result.
fn emit_resume_logic(ir: &mut String, resume_val: &str) {
    ir.push_str("  %is_tail = icmp eq i64 %cont, 0\n");
    ir.push_str("  br i1 %is_tail, label %tail_resume, label %cont_resume\n");
    ir.push_str("tail_resume:\n");
    ir.push_str("  ret i64 ");
    ir.push_str(resume_val);
    ir.push_str("\n");
    ir.push_str("cont_resume:\n");
    ir.push_str("  %cont_result = call i64 @blood_continuation_resume_with_regions(i64 %cont, i64 ");
    ir.push_str(resume_val);
    ir.push_str(")\n");
    ir.push_str("  ret i64 %cont_result\n");
}

/// Widens a value to i64, returning the name of the widened value.
fn widen_to_i64(ir: &mut String, val_name: &str, ty: &str) -> String {
    if str_eq(ty, "i64") {
        let mut s = common.make_string("%");
        s.push_str(val_name);
        return s;
    }
    if str_eq(ty, "i32") || str_eq(ty, "i16") || str_eq(ty, "i8") || str_eq(ty, "i1") {
        ir.push_str("  %");
        ir.push_str(val_name);
        ir.push_str("_wide = zext ");
        ir.push_str(ty);
        ir.push_str(" %");
        ir.push_str(val_name);
        ir.push_str(" to i64\n");
        let mut s = common.make_string("%");
        s.push_str(val_name);
        s.push_str("_wide");
        return s;
    }
    if str_eq(ty, "ptr") {
        ir.push_str("  %");
        ir.push_str(val_name);
        ir.push_str("_wide = ptrtoint ptr %");
        ir.push_str(val_name);
        ir.push_str(" to i64\n");
        let mut s = common.make_string("%");
        s.push_str(val_name);
        s.push_str("_wide");
        return s;
    }
    if str_eq(ty, "double") {
        ir.push_str("  %");
        ir.push_str(val_name);
        ir.push_str("_wide = bitcast double %");
        ir.push_str(val_name);
        ir.push_str(" to i64\n");
        let mut s = common.make_string("%");
        s.push_str(val_name);
        s.push_str("_wide");
        return s;
    }
    if str_eq(ty, "{}") || str_eq(ty, "void") {
        return common.make_string("0");
    }
    // For aggregate types (struct, tuple, etc.): reinterpret bits as i64.
    // Store the struct to an i64-sized alloca, then load as i64.
    ir.push_str("  %");
    ir.push_str(val_name);
    ir.push_str("_alloca = alloca i64\n");
    ir.push_str("  store ");
    ir.push_str(ty);
    ir.push_str(" %");
    ir.push_str(val_name);
    ir.push_str(", ptr %");
    ir.push_str(val_name);
    ir.push_str("_alloca, align 8\n");
    ir.push_str("  %");
    ir.push_str(val_name);
    ir.push_str("_wide = load i64, ptr %");
    ir.push_str(val_name);
    ir.push_str("_alloca, align 8\n");
    let mut s = common.make_string("%");
    s.push_str(val_name);
    s.push_str("_wide");
    s
}

/// Emits call arguments for the inner handler op body function.
/// For i64 params, uses %arg_i64_{N} directly (no narrowing was done).
/// For other types, uses %arg_{N} (narrowing creates this name).
/// sig_offset: offset into fn_signatures params (1 to skip state ptr, 0 for no offset).
fn emit_call_args(ir: &mut String, ctx: &mut codegen_ctx.CodegenCtx, body_def_id: u32, param_count: usize, sig_offset: usize) {
    for pi in 0usize..param_count {
        if pi > 0 {
            ir.push_str(", ");
        }
        let param_ty = match ctx.lookup_fn_param_type(body_def_id, pi + sig_offset) {
            Option.Some(ty) => ty,
            Option.None => common.make_string("i64"),
        };
        ir.push_str(param_ty.as_str());
        if str_eq(param_ty.as_str(), "i64") {
            // For i64 params, the loaded value is directly %arg_i64_{N}
            ir.push_str(" %arg_i64_");
        } else {
            // For narrowed types, the narrowed value is %arg_{N}
            ir.push_str(" %arg_");
        }
        push_usize(ir, pi);
    }
}

// ============================================================
// Codegen Work List
// ============================================================

/// A single unit of codegen work: one function body to lower and emit.
struct CodegenWorkItem {
    /// Index into lower_result.bodies.
    body_idx: usize,
    /// The mangled function name for LLVM IR.
    fn_name: String,
    /// The DefId of this function (used for naming and dedup).
    def_id: hir_def.DefId,
    /// The DefId used for typeck resolution lookups (method/field/coercion).
    /// For handler op bodies, this is the shared effect op DefId (matches typeck),
    /// while def_id is a unique synthetic ID for naming.
    typeck_def_id: hir_def.DefId,
    /// The function's return type.
    return_ty: type_intern.TyId,
    /// The function's source span.
    span: common.Span,
    /// Source module index (0 = main, 1..N = external modules).
    module_index: u32,
}

/// Result of scanning bodies to build the work list.
struct CodegenWorkList {
    /// The work items to process.
    items: Vec<CodegenWorkItem>,
    /// Function names that were defined (for stub generation).
    defined_names: Vec<String>,
    /// DefIds that were defined (for duplicate detection — already embedded in items).
    defined_def_ids: Vec<u32>,
    /// Mapping from body_id to fn_name for handler clause bodies.
    /// Used by generate_handler_wrappers to find the correct function name
    /// for kind=2 return clause body calls (avoids def_name collision with
    /// register_all_item_names).
    body_id_to_name: Vec<BodyIdNameEntry>,
}

struct BodyIdNameEntry {
    body_id: u32,
    fn_name: String,
}

/// Scans all HIR bodies and builds a work list of functions to codegen.
/// Finds the FnSig for a body by scanning items for a matching body_id.
fn find_fn_sig_for_body(items: &Vec<hir_lower_ctx.ItemEntry>, body_id: hir_def.BodyId) -> Option<hir_item.FnSig> {
    for j in 0usize..items.len() {
        match &items[j].item.kind {
            &hir_item.ItemKind.Fn(ref fn_def) => {
                match &fn_def.body_id {
                    &Option.Some(ref bid) => {
                        if bid.index == body_id.index {
                            return Option.Some(fn_def.sig);
                        }
                    }
                    &Option.None => {}
                }
            }
            _ => {}
        }
    }
    Option.None
}

/// For handler op bodies, finds the original effect operation DefId from the HIR.
/// Handler op bodies have synthetic def_ids (0x80000000 + body_id) for unique naming,
/// but typeck resolutions are keyed by the original op_def_id.
fn find_handler_op_typeck_def_id(
    items: &Vec<hir_lower_ctx.ItemEntry>,
    body_id: hir_def.BodyId,
) -> Option<hir_def.DefId> {
    for i in 0usize..items.len() {
        match &items[i].item.kind {
            &hir_item.ItemKind.Handler(ref handler_def) => {
                for j in 0usize..handler_def.op_impls.len() {
                    if handler_def.op_impls[j].body_id.index == body_id.index {
                        return Option.Some(handler_def.op_impls[j].op_def_id);
                    }
                }
            }
            _ => {}
        }
    }
    Option.None
}

/// Filters out static bodies and duplicates from generic instantiations.
/// This separates work identification from work execution, enabling batching.
fn build_codegen_worklist(
    lower_result: &hir_lower_ctx.LowerResult,
    static_def_ids: &Vec<u32>,
    const_generic_body_ids: &Vec<u32>,
) -> CodegenWorkList {
    let mut items: Vec<CodegenWorkItem> = Vec.new();
    let mut defined_names: Vec<String> = Vec.new();
    let mut defined_def_ids: Vec<u32> = Vec.new();
    let mut body_id_to_name: Vec<BodyIdNameEntry> = Vec.new();

    for body_idx in 0usize..lower_result.bodies.len() {
        let body_entry = &lower_result.bodies[body_idx];
        let body_id = body_entry.body_id;

        let fn_info = driver.find_fn_for_body(&lower_result.items, body_id);

        let return_ty = match &fn_info {
            &Option.Some(ref info) => type_intern.TyId.new(info.return_ty.index),
            &Option.None => type_intern.CommonTypes.unit(),
        };
        let span = match &fn_info {
            &Option.Some(ref info) => info.span,
            &Option.None => common.Span.new(0, 0, 1, 1),
        };
        let fn_name = match &fn_info {
            &Option.Some(ref info) => main_helpers.make_mangled_fn_name(&lower_result.interner, info, &lower_result.no_mangle_def_ids, &lower_result.export_name_entries),
            &Option.None => driver.make_fn_name(body_idx),
        };
        let def_id = match &fn_info {
            &Option.Some(ref info) => info.def_id,
            &Option.None => hir_def.DefId.new(body_idx as u32),
        };

        // For handler op bodies (synthetic def_id with 0x80000000 bit),
        // find the original op_def_id for typeck resolution lookups.
        let typeck_def_id = if def_id.index >= 0x80000000 {
            match find_handler_op_typeck_def_id(&lower_result.items, body_id) {
                Option.Some(orig) => orig,
                Option.None => def_id,
            }
        } else {
            def_id
        };

        // Check if this body belongs to a static variable - skip if so.
        let mut is_static_body = false;
        let mut sbi: usize = 0;
        while sbi < static_def_ids.len() {
            if static_def_ids[sbi] == def_id.index {
                is_static_body = true;
                sbi = static_def_ids.len(); // break
            }
            sbi += 1;
        }
        if is_static_body {
            continue;
        }

        // Skip const-generic function bodies — they'll be monomorphized later.
        if driver.is_const_generic_body(body_id.index, const_generic_body_ids) {
            continue;
        }

        // Check if this DefId was already processed (skip duplicates)
        let mut is_duplicate = false;
        let mut di: usize = 0;
        while di < defined_def_ids.len() {
            if defined_def_ids[di] == def_id.index {
                is_duplicate = true;
                di = defined_def_ids.len(); // break
            }
            di += 1;
        }
        if is_duplicate {
            continue;
        }

        defined_def_ids.push(def_id.index);
        defined_names.push(main_helpers.clone_string(&fn_name));

        // Record body_id → fn_name mapping for handler clause bodies.
        // This is used by generate_handler_wrappers for kind=2 return clause
        // body calls, avoiding the def_name collision with register_all_item_names.
        body_id_to_name.push(BodyIdNameEntry {
            body_id: body_id.index,
            fn_name: main_helpers.clone_string(&fn_name),
        });

        items.push(CodegenWorkItem {
            body_idx,
            fn_name,
            def_id,
            typeck_def_id,
            return_ty,
            span,
            module_index: body_entry.module_index,
        });

    }

    CodegenWorkList {
        items,
        defined_names,
        defined_def_ids,
        body_id_to_name,
    }
}

// ============================================================
// Parallel Codegen Infrastructure
// ============================================================

// Per-worker packed arg: { ctx_addr, lower_addr, typeck_addr, worklist_addr,
//                          chunk_start, chunk_end, output_addr }
// Layout: 7 × i64 at offsets 0, 8, 16, 24, 32, 40, 48.
// Allocated via alloc(56), populated via ptr_write_i64.
fn pack_worker_arg(
    ctx_addr: u64, lower_addr: u64, typeck_addr: u64,
    worklist_addr: u64, start: usize, end: usize, output_addr: u64,
) -> u64 {
    let buf: u64 = alloc(56);
    ptr_write_i64(buf, ctx_addr as i64);
    ptr_write_i64(buf + 8, lower_addr as i64);
    ptr_write_i64(buf + 16, typeck_addr as i64);
    ptr_write_i64(buf + 24, worklist_addr as i64);
    ptr_write_i64(buf + 32, start as i64);
    ptr_write_i64(buf + 40, end as i64);
    ptr_write_i64(buf + 48, output_addr as i64);
    buf
}

/// Worker function for parallel codegen threads.
/// Receives packed args via u64 address (7 × i64), processes its chunk of the
/// worklist (MIR lowering + codegen), and writes IR to its output String.
///
/// Thread safety: alloc bypass must be active before spawning. Workers use
/// heap-only allocation (no regions) — the region system is not thread-safe.
/// The type-to-LLVM cache is disabled (fn_temp_region=0) which adds minor
/// overhead but avoids region stack corruption.
fn codegen_thread_worker(arg: u64) -> u64 {
    // Unpack args from raw memory: 7 × i64 at offsets 0..48.
    let ctx_addr: u64 = ptr_read_i64(arg) as u64;
    let lower_addr: u64 = ptr_read_i64(arg + 8) as u64;
    let typeck_addr: u64 = ptr_read_i64(arg + 16) as u64;
    let wl_addr: u64 = ptr_read_i64(arg + 24) as u64;
    let chunk_start: usize = ptr_read_i64(arg + 32) as usize;
    let chunk_end: usize = ptr_read_i64(arg + 40) as usize;
    let output_addr: u64 = ptr_read_i64(arg + 48) as u64;

    let ctx: &mut codegen_ctx.CodegenCtx = @unsafe { (ctx_addr as usize as *mut codegen_ctx.CodegenCtx) as &mut codegen_ctx.CodegenCtx };
    let lower: &hir_lower_ctx.LowerResult = @unsafe { (lower_addr as usize as *const hir_lower_ctx.LowerResult) as &hir_lower_ctx.LowerResult };
    let typeck: &typeck_driver.TypeCheckResult = @unsafe { (typeck_addr as usize as *const typeck_driver.TypeCheckResult) as &typeck_driver.TypeCheckResult };
    let wl: &CodegenWorkList = @unsafe { (wl_addr as usize as *const CodegenWorkList) as &CodegenWorkList };
    let output: &mut String = @unsafe { (output_addr as usize as *mut String) as &mut String };

    // No regions: bypass flag ensures all allocations go to heap (thread-safe).
    // fn_temp_region = 0 disables the type-to-LLVM cache. Per-function memory
    // is not reclaimed (accumulates on heap) — acceptable for the parallel phase.

    set_alloc_bypass_tracking(1);

    // Per-worker MIR + temp regions. Safe for single-worker mode.
    // For multi-worker, these cause races on the global region stack, but
    // the bypass flag ensures allocations bypass the region dispatch.
    let worker_mir_region = region_create(4194304, 8589934592);
    let worker_fn_temp_region = region_create(2097152, 4294967296);

    let mut i: usize = chunk_start;
    while i < chunk_end {
        if i % 100 == 0 {
            eprint_str("\n  [worker fn ");
            eprint_str(int_to_string(i as i32));
            eprint_str("/");
            eprint_str(int_to_string(chunk_end as i32));
            eprint_str("]");
        }
        let work = &wl.items[i];
        let body_entry = &lower.bodies[work.body_idx];
        let hir_body = &body_entry.body;

        region_activate(worker_mir_region);
        let mut mir_result = mir_lower.lower_body(
            work.typeck_def_id,
            hir_body,
            type_intern.TyId.new(work.return_ty.index),
            work.span,
            &typeck.subst_table,
            &typeck.method_resolutions,
            &typeck.field_resolutions,
            &typeck.coercion_entries,
        );

        if work.def_id.index != work.typeck_def_id.index {
            mir_result.body.def_id = work.def_id;
        }

        // Pop MIR region — codegen reads MIR body (still valid) from here.
        region_deactivate();

        // Set up call remaps for trait default methods
        ctx.call_remaps = find_call_remaps_for_def(
            &typeck.default_method_remaps,
            work.def_id.index,
        );

        let is_hop = ctx.is_handler_op_body(work.def_id.index);
        if is_hop {
            let hop_state_count = ctx.handler_op_state_count(work.def_id.index);
            if hop_state_count > 0 {
                ctx.handler_op_state_local = 1;
                ctx.handler_op_state_field_count = hop_state_count;
            }
            ctx.is_handler_op = true;
        }

        // Activate temp region for codegen temporaries
        region_activate(worker_fn_temp_region);
        ctx.fn_temp_region = worker_fn_temp_region;
        let mc: u32 = lower.module_names.len() as u32;
        let fn_ir = codegen.generate_function_with_ctx(ctx, &mir_result.body, work.fn_name.as_str(), work.module_index, mc);

        // Deactivate temp region before appending to output
        ctx.fn_temp_region = 0 as u64;
        region_deactivate();
        output.push_str(fn_ir.as_str());

        // Closures and inline handler bodies
        let mut cli: usize = 0;
        while cli < mir_result.closure_names.len() && cli < mir_result.closure_mir.len() {
            let cname = &mir_result.closure_names[cli];
            let cbody = &mir_result.closure_mir[cli];

            let is_inline_hop = cli < mir_result.closure_is_handler_op.len()
                && mir_result.closure_is_handler_op[cli];
            if is_inline_hop {
                ctx.is_handler_op = true;
            }

            region_activate(worker_fn_temp_region);
            ctx.fn_temp_region = worker_fn_temp_region;
            let closure_ir = codegen.generate_function_with_ctx(ctx, cbody, cname.as_str(), work.module_index, mc);
            ctx.fn_temp_region = 0 as u64;
            region_deactivate();
            output.push_str(closure_ir.as_str());

            if is_inline_hop {
                ctx.is_handler_op = false;
            }

            cli += 1;
        }

        // Reset regions to reclaim per-function temporaries
        region_reset(worker_fn_temp_region);
        region_reset(worker_mir_region);

        if is_hop {
            ctx.handler_op_state_local = -1;
            ctx.handler_op_state_field_count = 0;
            ctx.is_handler_op = false;
        }
        ctx.call_remaps = Vec.new();

        i += 1;
    }

    region_destroy(worker_fn_temp_region);
    region_destroy(worker_mir_region);
    0
}

// ============================================================
// Pass 2: MIR Lowering + Codegen
// ============================================================

/// Runs Pass 2 codegen, writing each function's IR directly to output_path.
/// Processes functions sequentially with per-function MIR regions for memory efficiency.
/// Returns collected mono_requests and next_mono_def_id for const-generic monomorphization.
fn codegen_pass2(
    ctx: &mut codegen_ctx.CodegenCtx,
    worklist: &CodegenWorkList,
    lower_result: &hir_lower_ctx.LowerResult,
    typeck_result: &typeck_driver.TypeCheckResult,
    output_path: &str,
    args: &Args,
    has_const_generics: bool,
    const_generic_fn_set: &Vec<u32>,
    const_generic_param_counts: &Vec<u32>,
    turbofish_const_args: &Vec<mir_lower_ctx.TurbofishConstArg>,
    next_mono_def_id_in: u32,
    type_generic_fn_set: &Vec<u32>,
    type_generic_calls: &Vec<common.TypeGenericCallInfo>,
    skip_modules: &Vec<bool>,
) -> CodegenPass2Result {
    let mut all_mono_requests: Vec<mir_lower_ctx.MonoRequest> = Vec.new();
    let mut next_mono_def_id: u32 = next_mono_def_id_in;

    let total_items: usize = worklist.items.len();
    if total_items == 0 {
        return CodegenPass2Result {
            mono_requests: all_mono_requests,
            next_mono_def_id: next_mono_def_id,
            fn_temp_region: 0 as u64,
        };
    }

    // ================================================================
    // Parallel codegen path: use worker threads for large, non-incremental
    // builds without const/type generics. Falls through to sequential path
    // when conditions aren't met.
    // ================================================================
    let has_generics = has_const_generics || type_generic_fn_set.len() > 0;
    // Parallel codegen: enabled for non-incremental clean builds without split-modules.
    let use_parallel = total_items > 200 && !has_generics
        && skip_modules.len() == 0 && !args.dump_mir && !args.validate_mir
        && !args.alloc_profile && !args.no_parallel;
    if use_parallel {
        let num_workers: usize = 4;
        let chunk_size: usize = total_items / num_workers;

        eprint_str("\n  [parallel codegen: ");
        eprint_str(int_to_string(num_workers as i32));
        eprint_str(" workers, ");
        eprint_str(int_to_string(total_items as i32));
        eprint_str(" fns]");

        let t_parallel_start = blood_clock_millis();

        // Pre-register fn_signatures for ALL worklist functions via sequential
        // MIR lowering. Workers need cross-worker signatures for call-site fixup
        // (extractvalue+load for ref→value demotion at lines 1201-1213 of
        // codegen_term.blood). Without signatures, the fixup is skipped and
        // fat refs {ptr,i32} are passed where by-value structs are expected.
        // This also warms the global MIR caches (CACHED_METHOD/FIELD_HASH).
        {
            let mir_region_sigs = region_create(4194304, 8589934592);
            for si in 0usize..total_items {
                let work = &worklist.items[si];
                let body_entry = &lower_result.bodies[work.body_idx];
                region_activate(mir_region_sigs);
                let mir_result = mir_lower.lower_body(
                    work.typeck_def_id,
                    &body_entry.body,
                    type_intern.TyId.new(work.return_ty.index),
                    work.span,
                    &typeck_result.subst_table,
                    &typeck_result.method_resolutions,
                    &typeck_result.field_resolutions,
                    &typeck_result.coercion_entries,
                );
                region_deactivate();
                // Extract signature from MIR body locals
                let mir_body = &mir_result.body;
                let param_end: usize = 1 + (mir_body.param_count as usize);
                let mut sig_params: Vec<String> = Vec.new();
                let mut pi: usize = 1;
                while pi < param_end && pi < mir_body.locals.len() {
                    sig_params.push(codegen_size.type_to_llvm_with_ctx_id(ctx, mir_body.locals[pi].ty));
                    pi += 1;
                }
                let mut sig_ret = common.make_string("void");
                if mir_body.locals.len() > 0 {
                    sig_ret = codegen_size.type_to_llvm_with_ctx_id(ctx, mir_body.locals[0].ty);
                    if main_helpers.str_equals(&sig_ret, "{}") {
                        sig_ret = common.make_string("void");
                    }
                }
                ctx.register_fn_signature(work.def_id.index, sig_params, sig_ret);
                region_reset(mir_region_sigs);
            }
            // Don't destroy — MIR cache hash maps allocated inside this region
        }

        // Get addresses of shared read-only data BEFORE deactivating the region.
        let lower_addr: u64 = @unsafe { lower_result as *const hir_lower_ctx.LowerResult as usize } as u64;
        let typeck_addr: u64 = @unsafe { typeck_result as *const typeck_driver.TypeCheckResult as usize } as u64;
        let wl_addr: u64 = @unsafe { worklist as *const CodegenWorkList as usize } as u64;

        // Deactivate codegen_region and enable bypass BEFORE creating worker ctxs.
        // This ensures create_worker_ctx allocates on the HEAP (not the region).
        // Region-allocated buffers cause UB when workers' bypass realloc calls
        // malloc_usable_size on them.
        let saved_codegen_region = region_deactivate_get();
        set_alloc_bypass_tracking(1);

        // Create per-worker CodegenCtx and output buffers.
        // All allocations go to heap (bypass active, no region on stack).
        let mut worker_ctxs: Vec<codegen_ctx.CodegenCtx> = Vec.new();
        let mut worker_outputs: Vec<String> = Vec.new();
        for w in 0usize..num_workers {
            let mut wctx = ctx.create_worker_ctx();
            wctx.string_counter = ctx.string_counter + (w as u32 * 100000);
            worker_ctxs.push(wctx);
            worker_outputs.push(String.new());
        }

        // Pack args and spawn worker threads.
        // Worker ctxs and outputs are in Vecs — get element addresses via &mut vec[i].
        let mut handles: Vec<u64> = Vec.new();
        let mut arg_bufs: Vec<u64> = Vec.new();
        for w in 0usize..num_workers {
            let start = w * chunk_size;
            let end = if w == num_workers - 1 { total_items } else { (w + 1) * chunk_size };
            let ctx_addr: u64 = @unsafe { &mut worker_ctxs[w] as *mut codegen_ctx.CodegenCtx as usize } as u64;
            let out_addr: u64 = @unsafe { &mut worker_outputs[w] as *mut String as usize } as u64;
            let arg_buf = pack_worker_arg(ctx_addr, lower_addr, typeck_addr, wl_addr, start, end, out_addr);
            arg_bufs.push(arg_buf);
            let fn_ptr: u64 = @unsafe { codegen_thread_worker as u64 };
            let handle = thread_spawn(fn_ptr, arg_buf);
            handles.push(handle);
        }

        // Join all workers
        for w in 0usize..num_workers {
            thread_join(handles[w]);
        }

        // Disable alloc bypass, re-activate codegen region, free arg buffers
        set_alloc_bypass_tracking(0);
        region_activate(saved_codegen_region);
        for w in 0usize..num_workers {
            free(arg_bufs[w]);
        }

        let t_parallel_end = blood_clock_millis();
        eprint_str("\n  [parallel codegen done: ");
        eprint_str(int_to_string((t_parallel_end - t_parallel_start) as i32));
        eprint_str("ms]");

        // Merge: write all worker outputs to the main output file (in order)
        for w in 0usize..num_workers {
            file_append_string(output_path, worker_outputs[w].as_str());
        }

        // Merge worker string tables into the main ctx.
        // Each worker has its own string_table with non-overlapping labels.
        for w in 0usize..num_workers {
            let wctx = &worker_ctxs[w];
            for si in 0usize..wctx.string_table.len() {
                let entry = &wctx.string_table[si];
                // Add to main ctx with the worker's label (already unique)
                let idx = ctx.string_table.len() as u32;
                ctx.string_table.push(codegen_ctx.StringConstant {
                    label: main_helpers.clone_string(&entry.label),
                    content: main_helpers.clone_string(&entry.content),
                    length: entry.length,
                });
                // Don't bother updating string_table_hash — it's only used
                // for dedup during codegen, which is done.
            }
        }
        // Update string_counter to be past all worker ranges
        ctx.string_counter = ctx.string_counter + (num_workers as u32 * 100000);

        // Merge fn_ptr_wrapper_defs from workers
        for w in 0usize..num_workers {
            let wctx = &worker_ctxs[w];
            for fi in 0usize..wctx.fn_ptr_wrapper_defs.len() {
                ctx.fn_ptr_wrapper_defs.push(main_helpers.clone_string(&wctx.fn_ptr_wrapper_defs[fi]));
            }
        }

        // Merge inline_stubs from workers
        for w in 0usize..num_workers {
            let wctx = &worker_ctxs[w];
            for si in 0usize..wctx.inline_stubs.len() {
                ctx.inline_stubs.push(main_helpers.clone_string(&wctx.inline_stubs[si]));
            }
        }

        // Merge fn_signatures from workers
        for w in 0usize..num_workers {
            let wctx = &worker_ctxs[w];
            for fi in 0usize..wctx.fn_signatures.len() {
                let sig = &wctx.fn_signatures[fi];
                let mut cloned_params: Vec<String> = Vec.new();
                for pi in 0usize..sig.param_types.len() {
                    cloned_params.push(main_helpers.clone_string(&sig.param_types[pi]));
                }
                ctx.register_fn_signature(
                    sig.def_id,
                    cloned_params,
                    main_helpers.clone_string(&sig.return_type),
                );
            }
        }

        // Print perf summary (parallel replaces the per-phase breakdown)
        eprint_str("\n  [codegen pass2] functions=");
        eprint_str(int_to_string(total_items as i32));
        eprint_str(" parallel=");
        eprint_str(int_to_string(num_workers as i32));
        eprint_str(" wall_ms=");
        eprint_str(int_to_string((t_parallel_end - t_parallel_start) as i32));
        eprint_str("\n");

        return CodegenPass2Result {
            mono_requests: all_mono_requests,
            next_mono_def_id: next_mono_def_id,
            fn_temp_region: 0 as u64,
        };
    }

    // ================================================================
    // Sequential codegen path (original)
    // ================================================================

    // Shared MIR region — created once, reset between functions.
    // Avoids mmap/munmap cycling that causes memory layout instability.
    let mir_region = region_create(4194304, 8589934592);

    // Per-function temp region for codegen temporaries (output buffer, local maps).
    // Reset after each function to reclaim memory that would otherwise leak
    // in the bump allocator. String table allocations bypass this region
    // (see add_string_constant) so they persist across functions.
    let fn_temp_region = region_create(2097152, 4294967296);
    let mut mir_validation_errors: usize = 0;
    // Per-function IR size tracking for --alloc-profile
    let mut fn_ir_sizes: Vec<usize> = Vec.new();
    let mut fn_ir_names: Vec<String> = Vec.new();

    let mut skipped_count: usize = 0;

    // Perf diagnostics (Rev 4 instrumentation — permanent):
    // Sub-phase totals across all functions in codegen pass 2. Printed at
    // end. Lets future regressions in any sub-phase be immediately visible
    // in build output without additional tooling. Overhead: one
    // blood_clock_millis call per sub-phase per function (trivial).
    let mut t_mir_lower_total: u64 = 0;
    let mut t_bc01_scan_total: u64 = 0;
    let mut t_init_lin_total: u64 = 0;
    let mut t_codegen_total: u64 = 0;
    let mut t_cache_check_total: u64 = 0;

    for i in 0usize..total_items {
        let work = &worklist.items[i];

        // Skip unchanged modules — their cached .ll and .o are still valid.
        // Signatures for skipped functions are loaded from the fn_sigs cache.
        if skip_modules.len() > 0 {
            let mi = work.module_index as usize;
            if mi < skip_modules.len() && skip_modules[mi] {
                skipped_count += 1;
                continue;
            }
        }

        if i % 500 == 0 {
            eprint_str("\n  [fn ");
            eprint_str(int_to_string(i as i32));
            eprint_str("/");
            eprint_str(int_to_string(total_items as i32));
            eprint_str("]");
        }

        let body_entry = &lower_result.bodies[work.body_idx];
        let hir_body = &body_entry.body;

        // Per-function content hash skip (in split-modules mode only).
        // If the function's canonical AST hash is unchanged from the cached value,
        // reuse the cached IR fragment instead of re-doing MIR lowering + codegen.
        let t_cache_start = blood_clock_millis();
        if args.split_modules && !args.no_cache {
            let fn_sig_opt = find_fn_sig_for_body(&lower_result.items, body_entry.body_id);
            match &fn_sig_opt {
                &Option.Some(ref sig) => {
                    let hash = content_hash.hash_fn_body(hir_body, sig);
                    let hex = content_hash.hash_to_hex(&hash);
                    let mut cache_dir = main_helpers.strip_filename(output_path);
                    cache_dir.push_str("/.content_hashes");
                    let mut hash_path = common.make_string(cache_dir.as_str());
                    hash_path.push('/');
                    hash_path.push_str(work.fn_name.as_str());
                    hash_path.push_str(".hash");
                    let mut ir_path = common.make_string(cache_dir.as_str());
                    ir_path.push('/');
                    ir_path.push_str(work.fn_name.as_str());
                    ir_path.push_str(".ir");
                    if file_exists(hash_path.as_str()) && file_exists(ir_path.as_str()) {
                        let cached_hex: &str = file_read_to_string(hash_path.as_str());
                        if main_helpers.str_equals_str(cached_hex, hex.as_str()) {
                            let cached_ir: &str = file_read_to_string(ir_path.as_str());
                            file_append_string(output_path, cached_ir);
                            skipped_count += 1;
                            continue;
                        }
                    }
                }
                &Option.None => {}
            }
        }

        t_cache_check_total += blood_clock_millis() - t_cache_start;

        // Activate MIR region ON TOP of the codegen_region stack.
        // MIR lowering allocations go here, then we pop so codegen uses
        // the parent codegen_region (persistent across all functions).
        region_activate(mir_region);

        let t_mir_start = blood_clock_millis();
        let has_generics = has_const_generics || type_generic_fn_set.len() > 0;
        let mir_result = if has_generics {
            mir_lower.lower_body_with_const_info(
                work.typeck_def_id,  // typeck_def_id for correct resolution lookups
                hir_body,
                type_intern.TyId.new(work.return_ty.index),
                work.span,
                &typeck_result.subst_table,
                &typeck_result.method_resolutions,
                &typeck_result.field_resolutions,
                &typeck_result.coercion_entries,
                Vec.new(), // No const_bindings for non-specialized bodies
                driver.clone_u32_vec(const_generic_fn_set),
                driver.clone_turbofish_args(turbofish_const_args),
                driver.clone_u32_vec(const_generic_param_counts),
                next_mono_def_id,
                driver.clone_u32_vec(type_generic_fn_set),
                driver.clone_type_generic_calls(type_generic_calls),
            )
        } else {
            mir_lower.lower_body(
                work.typeck_def_id,
                hir_body,
                type_intern.TyId.new(work.return_ty.index),
                work.span,
                &typeck_result.subst_table,
                &typeck_result.method_resolutions,
                &typeck_result.field_resolutions,
                &typeck_result.coercion_entries,
            )
        };

        t_mir_lower_total += blood_clock_millis() - t_mir_start;

        // For handler op bodies, override the MIR body's def_id with the unique
        // synthetic def_id. The MIR lowering used typeck_def_id for correct
        // method/field resolution, but codegen needs the unique def_id for naming
        // and fn_signature registration.
        if work.def_id.index != work.typeck_def_id.index {
            mir_result.body.def_id = work.def_id;
        }

        // Pop mir_region — codegen_region becomes active again.
        // MIR data remains valid until region_reset below.
        region_deactivate();

        // Update next_mono_def_id counter
        if mir_result.next_mono_def_id > next_mono_def_id {
            next_mono_def_id = mir_result.next_mono_def_id;
        }

        // Collect mono requests and register specialized function names immediately
        // so codegen of the calling function can resolve them.
        {
            for ri in 0usize..mir_result.mono_requests.len() {
                let req_ref = &mir_result.mono_requests[ri];
                // Register the specialized name BEFORE codegen of this function
                ctx.register_def_name(req_ref.specialized_def_id, common.make_string(req_ref.fn_name.as_str()));
                if req_ref.is_type_mono {
                    // Clone type bindings
                    let mut bindings: Vec<common.TypeMonoBinding> = Vec.new();
                    for tbi in 0usize..req_ref.type_bindings.len() {
                        bindings.push(common.TypeMonoBinding.new(
                            req_ref.type_bindings[tbi].ty_var_index,
                            req_ref.type_bindings[tbi].concrete_ty_id,
                        ));
                    }
                    all_mono_requests.push(mir_lower_ctx.MonoRequest.new_type_mono(
                        req_ref.original_def_id,
                        bindings,
                        req_ref.specialized_def_id,
                        common.make_string(req_ref.fn_name.as_str()),
                    ));
                } else {
                    all_mono_requests.push(mir_lower_ctx.MonoRequest.new(
                        req_ref.original_def_id,
                        driver.clone_u64_vec(&req_ref.const_values),
                        req_ref.specialized_def_id,
                        common.make_string(req_ref.fn_name.as_str()),
                    ));
                }
            }
        }

        // Report MIR lowering errors (non-fatal in streaming mode — continue to codegen)
        if mir_result.errors.len() > 0 {
            for mei in 0usize..mir_result.errors.len() {
                eprint_str("MIR lowering error: ");
                eprint_str(mir_result.errors[mei].message.as_str());
                eprint_str("\n");
            }
        }

        // Dump MIR if requested
        if args.dump_mir {
            let fn_name_str = work.fn_name.as_str();
            let should_dump = match &args.dump_mir_filter {
                &Option.Some(ref filter) => main_helpers.str_contains_ref(fn_name_str, filter.as_str()),
                &Option.None => true,
            };
            if should_dump {
                let mir_text = dump_mir.format_mir_body(&mir_result.body, fn_name_str);
                eprint_str("=== MIR: ");
                eprint_str(fn_name_str);
                eprint_str(" ===\n");
                eprint_str(mir_text.as_str());
                eprint_str("\n");
            }
        }

        // BC-01: Reject returning reference to stack-local variable.
        // Only catches direct `_0 = Ref(&local)` where local was assigned from
        // a constant or aggregate (not derived from a parameter).
        let t_bc01_start = blood_clock_millis();
        {
            let mir_ref = &mir_result.body;
            let param_end: u32 = 1 + mir_ref.param_count;
            for dbb in 0usize..mir_ref.basic_blocks.len() {
                let dblk = &mir_ref.basic_blocks[dbb];
                let has_ret = match &dblk.terminator {
                    &Option.Some(ref t) => {
                        match &t.kind { &mir_term.TerminatorKind.Return => true, _ => false, }
                    }
                    &Option.None => false,
                };
                if has_ret {
                    for dsi in 0usize..dblk.statements.len() {
                        match &dblk.statements[dsi].kind {
                            &mir_stmt.StatementKind.Assign { ref place, ref rvalue } => {
                                if place.local.index == 0 {
                                    match rvalue {
                                        &mir_types.Rvalue.Ref { ref place: rp, mutable: _ } => {
                                            if rp.local.index >= param_end && rp.projection.len() == 0 {
                                                // Trace: only reject if local was initialized from
                                                // a constant (not from a parameter access/projection)
                                                let ref_local_idx = rp.local.index;
                                                let mut is_const_init = false;
                                                for tsi in 0usize..dblk.statements.len() {
                                                    match &dblk.statements[tsi].kind {
                                                        &mir_stmt.StatementKind.Assign { ref place: tp, ref rvalue: trv } => {
                                                            if tp.local.index == ref_local_idx && tp.projection.len() == 0 {
                                                                match trv {
                                                                    &mir_types.Rvalue.Use(ref op) => {
                                                                        match op {
                                                                            &mir_types.Operand.Constant(_) => { is_const_init = true; }
                                                                            &mir_types.Operand.Copy(ref src) => {
                                                                                // One-level trace: check if source is also const
                                                                                if src.projection.len() == 0 && src.local.index >= param_end {
                                                                                    for tsi2 in 0usize..dblk.statements.len() {
                                                                                        match &dblk.statements[tsi2].kind {
                                                                                            &mir_stmt.StatementKind.Assign { ref place: tp2, ref rvalue: trv2 } => {
                                                                                                if tp2.local.index == src.local.index && tp2.projection.len() == 0 {
                                                                                                    match trv2 {
                                                                                                        &mir_types.Rvalue.Use(ref op2) => {
                                                                                                            match op2 {
                                                                                                                &mir_types.Operand.Constant(_) => { is_const_init = true; }
                                                                                                                _ => {}
                                                                                                            }
                                                                                                        }
                                                                                                        &mir_types.Rvalue.Aggregate { kind: _, ref operands } => { is_const_init = true; }
                                                                                                        _ => {}
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                            _ => {}
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                            _ => {}
                                                                        }
                                                                    }
                                                                    &mir_types.Rvalue.Aggregate { kind: _, ref operands } => { is_const_init = true; }
                                                                    _ => {}
                                                                }
                                                            }
                                                        }
                                                        _ => {}
                                                    }
                                                }
                                                if is_const_init {
                                                    eprint_str("\nerror[E0503]: cannot return reference to local variable\n");
                                                    eprint_str("  --> in function ");
                                                    eprint_str(work.fn_name.as_str());
                                                    eprint_str("\n  = note: reference to stack-local escapes function scope\n");
                                                    panic("cannot return reference to local variable");
                                                }
                                            }
                                        }
                                        &mir_types.Rvalue.Use(ref ret_op) => {
                                            // Indirect: _0 = Copy(src) — trace src
                                            match ret_op {
                                                &mir_types.Operand.Copy(ref src_place) => {
                                                    if src_place.projection.len() == 0 && src_place.local.index >= param_end {
                                                        // Find src's assignment in same block
                                                        for bsi in 0usize..dblk.statements.len() {
                                                            match &dblk.statements[bsi].kind {
                                                                &mir_stmt.StatementKind.Assign { ref place: bp, ref rvalue: brv } => {
                                                                    if bp.local.index == src_place.local.index && bp.projection.len() == 0 {
                                                                        // Trace one more level for Copy chains
                                                                        match brv {
                                                                            &mir_types.Rvalue.Ref { ref place: ref_p, mutable: _ } => {
                                                                                if ref_p.local.index >= param_end && ref_p.projection.len() == 0 {
                                                                                    eprint_str("\nerror[E0503]: cannot return reference to local variable\n");
                                                                                    eprint_str("  --> in function ");
                                                                                    eprint_str(work.fn_name.as_str());
                                                                                    eprint_str("\n  = note: reference to stack-local escapes function scope\n");
                                                                                    panic("cannot return reference to local variable");
                                                                                }
                                                                            }
                                                                            &mir_types.Rvalue.Use(ref inner_op) => {
                                                                                // Copy chain: trace one more level
                                                                                match inner_op {
                                                                                    &mir_types.Operand.Copy(ref inner_src) => {
                                                                                        if inner_src.projection.len() == 0 && inner_src.local.index >= param_end {
                                                                                            for bsi2 in 0usize..dblk.statements.len() {
                                                                                                match &dblk.statements[bsi2].kind {
                                                                                                    &mir_stmt.StatementKind.Assign { ref place: bp2, ref rvalue: brv2 } => {
                                                                                                        if bp2.local.index == inner_src.local.index && bp2.projection.len() == 0 {
                                                                                                            match brv2 {
                                                                                                                &mir_types.Rvalue.Ref { ref place: rp2, mutable: _ } => {
                                                                                                                    if rp2.local.index >= param_end && rp2.projection.len() == 0 {
                                                                                                                        eprint_str("\nerror[E0503]: cannot return reference to local variable\n");
                                                                                                                        eprint_str("  --> in function ");
                                                                                                                        eprint_str(work.fn_name.as_str());
                                                                                                                        eprint_str("\n  = note: reference to stack-local escapes function scope\n");
                                                                                                                        panic("cannot return reference to local variable");
                                                                                                                    }
                                                                                                                }
                                                                                                                _ => {}
                                                                                                            }
                                                                                                        }
                                                                                                    }
                                                                                                    _ => {}
                                                                                                }
                                                                                            }
                                                                                        }
                                                                                    }
                                                                                    _ => {}
                                                                                }
                                                                            }
                                                                            _ => {}
                                                                        }
                                                                    }
                                                                }
                                                                _ => {}
                                                            }
                                                        }
                                                    }
                                                }
                                                _ => {}
                                            }
                                        }
                                        _ => {}
                                    }
                                }
                            }
                            _ => {}
                        }
                    }
                }
            }
        }
        t_bc01_scan_total += blood_clock_millis() - t_bc01_start;

        // Validate MIR structure if requested
        if args.validate_mir {
            let fn_name_str = work.fn_name.as_str();
            let errors = validate_mir.validate_body(&mir_result.body, fn_name_str);
            if errors.len() > 0 {
                mir_validation_errors += errors.len();
                eprint_str("=== MIR VALIDATION ERRORS: ");
                eprint_str(fn_name_str);
                eprint_str(" ===\n");
                for ei in 0usize..errors.len() {
                    eprint_str("  ");
                    eprint_str(errors[ei].as_str());
                    eprint_str("\n");
                }
            }
        }

        // Definite initialization + linearity analysis — always runs.
        // Skip for functions with MIR lowering errors (incomplete MIR causes
        // false positives from unresolved field accesses).
        let t_init_lin_start = blood_clock_millis();
        if mir_result.errors.len() == 0 {
            let init_result = mir_init.analyze_init(&mir_result.body);
            if init_result.errors.len() > 0 {
                mir_validation_errors += init_result.errors.len();
                eprint_str("=== INIT ERRORS: ");
                eprint_str(work.fn_name.as_str());
                eprint_str(" ===\n");
                for ii in 0usize..init_result.errors.len() {
                    eprint_str("  ");
                    eprint_str(init_result.errors[ii].message.as_str());
                    eprint_str("\n");
                }
            }
            let lin_result = mir_init.analyze_linearity(&mir_result.body);
            if lin_result.errors.len() > 0 {
                mir_validation_errors += lin_result.errors.len();
                eprint_str("=== LINEARITY ERRORS: ");
                eprint_str(work.fn_name.as_str());
                eprint_str(" ===\n");
                for li in 0usize..lin_result.errors.len() {
                    eprint_str("  ");
                    eprint_str(lin_result.errors[li].message.as_str());
                    eprint_str("\n");
                }
            }
        }
        t_init_lin_total += blood_clock_millis() - t_init_lin_start;

        // Set up call remapping for trait default methods.
        ctx.call_remaps = find_call_remaps_for_def(
            &typeck_result.default_method_remaps,
            work.def_id.index,
        );

        // Set handler op state flags if this is a handler op body.
        // Only set handler_op_state_local=1 when the handler has state fields.
        let is_hop = ctx.is_handler_op_body(work.def_id.index);
        if is_hop {
            let hop_state_count = ctx.handler_op_state_count(work.def_id.index);
            if hop_state_count > 0 {
                ctx.handler_op_state_local = 1;
                ctx.handler_op_state_field_count = hop_state_count;
            }
            ctx.is_handler_op = true;
        }

        // Activate temp region for codegen temporaries (output buffer, local maps).
        // add_string_constant deactivates this to allocate in the parent region.
        region_activate(fn_temp_region);
        ctx.fn_temp_region = fn_temp_region;

        // Codegen (fn_temp_region active, mir_region read-only)
        let t_codegen_start = blood_clock_millis();
        let mc2: u32 = lower_result.module_names.len() as u32;
        let fn_ir = codegen.generate_function_with_ctx(ctx, &mir_result.body, work.fn_name.as_str(), work.module_index, mc2);
        if args.alloc_profile {
            fn_ir_sizes.push(fn_ir.len());
            region_deactivate();
            fn_ir_names.push(common.make_string(work.fn_name.as_str()));
            region_activate(fn_temp_region);
        }
        file_append_string(output_path, fn_ir.as_str());

        // Generate closure and inline handler bodies discovered during MIR lowering
        let mut combined_ir = common.make_string(fn_ir.as_str());
        let mut cli: usize = 0;
        while cli < mir_result.closure_names.len() && cli < mir_result.closure_mir.len() {
            let cname = &mir_result.closure_names[cli];
            let cbody = &mir_result.closure_mir[cli];

            // Check if this closure body is an inline handler op
            let is_inline_hop = cli < mir_result.closure_is_handler_op.len()
                && mir_result.closure_is_handler_op[cli];
            if is_inline_hop {
                ctx.is_handler_op = true;
            }

            let closure_ir = codegen.generate_function_with_ctx(ctx, cbody, cname.as_str(), work.module_index, mc2);
            file_append_string(output_path, closure_ir.as_str());
            combined_ir.push_str(closure_ir.as_str());

            if is_inline_hop {
                ctx.is_handler_op = false;
            }

            cli += 1;
        }
        t_codegen_total += blood_clock_millis() - t_codegen_start;

        // Save per-function content hash + IR to cache (for future skip)
        let t_cache_save_start = blood_clock_millis();
        if args.split_modules && !args.no_cache {
            let fn_sig_opt2 = find_fn_sig_for_body(&lower_result.items, body_entry.body_id);
            match &fn_sig_opt2 {
                &Option.Some(ref sig) => {
                    let hash = content_hash.hash_fn_body(hir_body, sig);
                    let hex = content_hash.hash_to_hex(&hash);
                    let mut cache_dir = main_helpers.strip_filename(output_path);
                    cache_dir.push_str("/.content_hashes");
                    main_helpers.ensure_dir(cache_dir.as_str());
                    let mut hash_path = common.make_string(cache_dir.as_str());
                    hash_path.push('/');
                    hash_path.push_str(work.fn_name.as_str());
                    hash_path.push_str(".hash");
                    file_write_string(hash_path.as_str(), hex.as_str());
                    let mut ir_path = common.make_string(cache_dir.as_str());
                    ir_path.push('/');
                    ir_path.push_str(work.fn_name.as_str());
                    ir_path.push_str(".ir");
                    file_write_string(ir_path.as_str(), combined_ir.as_str());
                }
                &Option.None => {}
            }
        }
        t_cache_check_total += blood_clock_millis() - t_cache_save_start;

        // Deactivate and reset temp region — reclaims all per-function temporaries.
        ctx.fn_temp_region = 0 as u64;
        region_deactivate();
        region_reset(fn_temp_region);
        // Reset MIR region — bump pointer back to start, keep virtual mapping
        region_reset(mir_region);

        // Clear handler op state flags
        if is_hop {
            ctx.handler_op_state_local = -1;
            ctx.handler_op_state_field_count = 0;
            ctx.is_handler_op = false;
        }

        // Clear call remaps after generating the function
        ctx.call_remaps = Vec.new();

    }

    // Destroy MIR region after all functions processed.
    // NOTE: fn_temp_region is NOT destroyed here — ctx still holds dangling
    // references into it (local maps, output buffer from last iteration).
    // The caller destroys it after all ctx access is complete.
    region_destroy(mir_region);

    // Perf diagnostics (Rev 4): print sub-phase totals so regressions in
    // any individual phase are immediately visible in build output.
    eprint_str("\n  [codegen pass2] functions=");
    eprint_str(int_to_string(total_items as i32));
    eprint_str(" cache_ms=");
    eprint_str(int_to_string(t_cache_check_total as i32));
    eprint_str(" mir_lower_ms=");
    eprint_str(int_to_string(t_mir_lower_total as i32));
    eprint_str(" bc01_ms=");
    eprint_str(int_to_string(t_bc01_scan_total as i32));
    eprint_str(" init_lin_ms=");
    eprint_str(int_to_string(t_init_lin_total as i32));
    eprint_str(" codegen_ms=");
    eprint_str(int_to_string(t_codegen_total as i32));
    eprint_str("\n");

    // Sub-phase breakdown inside mir_lower itself (populated by
    // mir_lower.lower_body and lower_body_with_const_info). These timers
    // decompose the mir_lower_ms bucket above.
    eprint_str("  [mir_lower] setup_ms=");
    eprint_str(int_to_string(mir_lower.mir_lower_t_setup_ms() as i32));
    eprint_str(" expr_ms=");
    eprint_str(int_to_string(mir_lower.mir_lower_t_expr_ms() as i32));
    eprint_str(" finish_ms=");
    eprint_str(int_to_string(mir_lower.mir_lower_t_finish_ms() as i32));
    eprint_str(" resolve_locals_ms=");
    eprint_str(int_to_string(mir_lower.mir_lower_t_resolve_ms() as i32));
    eprint_str("\n");

    // Sub-phase breakdown inside codegen.generate_function_with_ctx itself.
    // These timers decompose the codegen_ms bucket above.
    eprint_str("  [codegen fn] setup_ms=");
    eprint_str(int_to_string(codegen.codegen_t_setup_ms() as i32));
    eprint_str(" escape_ms=");
    eprint_str(int_to_string(codegen.codegen_t_escape_ms() as i32));
    eprint_str(" allocas_ms=");
    eprint_str(int_to_string(codegen.codegen_t_allocas_ms() as i32));
    eprint_str(" blocks_ms=");
    eprint_str(int_to_string(codegen.codegen_t_blocks_ms() as i32));
    eprint_str(" footer_ms=");
    eprint_str(int_to_string(codegen.codegen_t_footer_ms() as i32));
    eprint_str("\n");

    // Convergence stats for analyze_init's fixed-point dataflow.
    // total/calls = average iterations per fn; max = worst case;
    // hit_cap > 0 means some fn did not converge in 100 iterations.
    eprint_str("  [mir_init] calls=");
    eprint_str(int_to_string(mir_init.init_call_count() as i32));
    eprint_str(" iter_total=");
    eprint_str(int_to_string(mir_init.init_iter_total() as i32));
    eprint_str(" iter_max=");
    eprint_str(int_to_string(mir_init.init_iter_max() as i32));
    eprint_str(" hit_cap=");
    eprint_str(int_to_string(mir_init.init_hit_cap() as i32));
    eprint_str(" setup_ms=");
    eprint_str(int_to_string(mir_init.init_t_setup_ms() as i32));
    eprint_str(" fixpoint_ms=");
    eprint_str(int_to_string(mir_init.init_t_fixpoint_ms() as i32));
    eprint_str(" error_pass_ms=");
    eprint_str(int_to_string(mir_init.init_t_error_pass_ms() as i32));
    eprint_str("\n");

    // Per-arm breakdown of emit_statement (codegen blocks_ms hot path).
    // 100% of selfhost statements are Assign; the place/type/rvalue split
    // identifies which sub-call dominates.
    eprint_str("  [stmt] total_ms=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_total_ms() as i32));
    eprint_str(" assign_ms=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_assign_ms() as i32));
    eprint_str(" calls=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_count_total() as i32));
    eprint_str(" assign_calls=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_count_assign() as i32));
    eprint_str("\n");
    eprint_str("  [stmt assign] place_ms=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_assign_place_ms() as i32));
    eprint_str(" type_ms=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_assign_type_ms() as i32));
    eprint_str(" rvalue_ms=");
    eprint_str(int_to_string(codegen_stmt.stmt_t_assign_rvalue_ms() as i32));
    eprint_str("\n");

    // Per-Rvalue-kind breakdown. The Assign rvalue_ms bucket is the single
    // biggest line in codegen pass2; this decomposes it by kind so future
    // sessions can target the slowest arm directly.
    eprint_str("  [rvalue] use=");
    eprint_str(int_to_string(codegen_expr.rv_t_use_ms() as i32));
    eprint_str("ms/");
    eprint_str(int_to_string(codegen_expr.rv_c_use() as i32));
    eprint_str(" ref=");
    eprint_str(int_to_string(codegen_expr.rv_t_ref_ms() as i32));
    eprint_str("ms/");
    eprint_str(int_to_string(codegen_expr.rv_c_ref() as i32));
    eprint_str(" binop=");
    eprint_str(int_to_string(codegen_expr.rv_t_binop_ms() as i32));
    eprint_str("ms/");
    eprint_str(int_to_string(codegen_expr.rv_c_binop() as i32));
    eprint_str(" agg=");
    eprint_str(int_to_string(codegen_expr.rv_t_agg_ms() as i32));
    eprint_str("ms/");
    eprint_str(int_to_string(codegen_expr.rv_c_agg() as i32));
    eprint_str(" cast=");
    eprint_str(int_to_string(codegen_expr.rv_t_cast_ms() as i32));
    eprint_str("ms/");
    eprint_str(int_to_string(codegen_expr.rv_c_cast() as i32));
    eprint_str("\n");

    if skipped_count > 0 {
        eprint_str("\n  [skipped ");
        eprint_str(int_to_string(skipped_count as i32));
        eprint_str(" cached fns]");
    }

    // Report top functions by IR size if --alloc-profile
    if args.alloc_profile && fn_ir_sizes.len() > 0 {
        eprint_str("\n  === Top 10 functions by IR size ===\n");
        // Simple selection of top 10 by finding max, zeroing, repeat
        for rank in 0usize..10 {
            if rank >= fn_ir_sizes.len() { break; }
            let mut max_idx: usize = 0;
            let mut max_val: usize = 0;
            for j in 0usize..fn_ir_sizes.len() {
                if fn_ir_sizes[j] > max_val {
                    max_val = fn_ir_sizes[j];
                    max_idx = j;
                }
            }
            if max_val == 0 { break; }
            eprint_str("    ");
            eprint_str(int_to_string((rank + 1) as i32));
            eprint_str(". ");
            eprint_str(fn_ir_names[max_idx].as_str());
            eprint_str(" (");
            eprint_str(int_to_string((max_val / 1024) as i32));
            eprint_str(" KB)\n");
            fn_ir_sizes[max_idx] = 0;
        }
    }

    // Abort if MIR validation found errors (--validate-mir makes validation blocking)
    if mir_validation_errors > 0 {
        eprint_str("\n  MIR validation found ");
        eprint_str(int_to_string(mir_validation_errors as i32));
        eprint_str(" error(s). Aborting.\n");
        panic("MIR validation failed — aborting compilation");
    }

    CodegenPass2Result {
        mono_requests: all_mono_requests,
        next_mono_def_id: next_mono_def_id,
        fn_temp_region: fn_temp_region,
    }
}

/// Result of codegen pass 2, containing mono requests for const-generic monomorphization.
struct CodegenPass2Result {
    mono_requests: Vec<mir_lower_ctx.MonoRequest>,
    next_mono_def_id: u32,
    /// Per-function temp region handle. Must be destroyed by the caller after
    /// all CodegenCtx access is complete (ctx holds dangling refs into it).
    fn_temp_region: u64,
}

/// Resolves pending method calls for a type-generic function body being monomorphized.
/// Takes the original method_resolutions, finds pending (unresolved) method calls
/// for the given body, resolves them using the mono_subst and impl_method_table,
/// and returns a new method_resolutions vec with the resolved entries added.
fn resolve_methods_for_type_mono(
    method_resolutions: &Vec<common.MethodResEntry>,
    pending_method_calls: &Vec<common.PendingMethodCall>,
    impl_method_table: &Vec<common.ImplMethodEntry>,
    mono_subst: &unify.SubstTable,
    body_def_id: u32,
    specialized_def_id: u32,
    type_bindings: &Vec<common.TypeMonoBinding>,
) -> Vec<common.MethodResEntry> {
    // Clone method resolutions, remapping entries for this body from
    // original_def_id to specialized_def_id (same pattern as field_resolutions).
    let mut result: Vec<common.MethodResEntry> = Vec.new();
    for i in 0usize..method_resolutions.len() {
        if method_resolutions[i].body_def_id == body_def_id {
            result.push(common.MethodResEntry.new(
                specialized_def_id,
                method_resolutions[i].span_start,
                method_resolutions[i].def_id_index,
            ));
        } else {
            result.push(common.MethodResEntry.new(
                method_resolutions[i].body_def_id,
                method_resolutions[i].span_start,
                method_resolutions[i].def_id_index,
            ));
        }
    }

    // Find pending method calls for this body and resolve them.
    // Use specialized_def_id as the body_def_id in new resolution entries,
    // because MirLowerCtx.body_def_id will be the specialized DefId.
    for pi in 0usize..pending_method_calls.len() {
        let pending = &pending_method_calls[pi];
        if pending.body_def_id != body_def_id {
            continue;
        }

        // Resolve the receiver type through the mono subst table.
        // If the receiver_var's Infer isn't in the subst, the receiver was
        // unresolved during typeck (common for type params). Try all concrete
        // type bindings from the mono request as candidate receiver types.
        let receiver_infer = type_intern.type_interner().mk_infer(hir_def.TyVarId.new(pending.receiver_var));
        let resolved_ty = unify.apply_substs_id(mono_subst, receiver_infer);
        let base_ty = strip_refs(resolved_ty);

        // Check if resolution succeeded (not still an Infer type)
        let mut resolved_ok: bool = false;
        let interner_check = type_intern.type_interner();
        match interner_check.get(base_ty) {
            &type_intern.InternedTypeKind.Infer(_) => {}
            &type_intern.InternedTypeKind.Param(_) => {}
            _ => { resolved_ok = true; }
        }

        // Look up the method in the impl_method_table by self type and method name.
        // If the receiver didn't resolve, try each concrete type binding as a candidate.
        let mut found = false;
        if resolved_ok {
            let mut mi: usize = 0;
            while mi < impl_method_table.len() && !found {
                let entry = &impl_method_table[mi];
                if entry.self_ty_id == base_ty.index && main_helpers.str_equals(&entry.method_name_str, pending.method_name_str.as_str()) {
                    result.push(common.MethodResEntry.new(
                        specialized_def_id,
                        pending.span_start,
                        entry.method_def_id,
                    ));
                    found = true;
                }
                mi += 1;
            }
        }
        // Fallback: receiver didn't resolve — try each type binding's concrete type
        if !found {
            for tbi in 0usize..type_bindings.len() {
                if found { break; }
                let concrete_ty = type_intern.TyId.new(type_bindings[tbi].concrete_ty_id);
                let concrete_base = strip_refs(concrete_ty);
                let mut mi: usize = 0;
                while mi < impl_method_table.len() && !found {
                    let entry = &impl_method_table[mi];
                    if entry.self_ty_id == concrete_base.index && main_helpers.str_equals(&entry.method_name_str, pending.method_name_str.as_str()) {
                        result.push(common.MethodResEntry.new(
                            specialized_def_id,
                            pending.span_start,
                            entry.method_def_id,
                        ));
                        found = true;
                    }
                    mi += 1;
                }
            }
        }
    }

    result
}

/// Strips reference wrappers from a TyId to get the base type.
fn strip_refs(ty_id: type_intern.TyId) -> type_intern.TyId {
    let interner = type_intern.type_interner();
    let mut current = ty_id;
    let mut depth: i32 = 0;
    while depth < 10 {
        match interner.get(current) {
            &type_intern.InternedTypeKind.Ref { inner, mutable: _ } => {
                current = inner;
                depth += 1;
            }
            _ => { return current; }
        }
    }
    current
}

fn find_call_remaps_for_def(
    remaps: &Vec<common.DefaultMethodRemap>,
    def_id: u32,
) -> Vec<common.CallRemapEntry> {
    let mut result: Vec<common.CallRemapEntry> = Vec.new();
    for i in 0usize..remaps.len() {
        if remaps[i].body_def_id == def_id {
            // Copy the remap entries
            for j in 0usize..remaps[i].call_remaps.len() {
                result.push(common.CallRemapEntry.new(
                    remaps[i].call_remaps[j].from_def_id,
                    remaps[i].call_remaps[j].to_def_id,
                ));
            }
            return result;
        }
    }
    result
}

// ============================================================
// Memory Profiling
// ============================================================

/// Reads VmRSS from /proc/self/status and returns the value in KB.
/// Returns 0 if the file cannot be read or parsed.
fn get_rss_kb() -> u64 {
    let status: &str = file_read_to_string("/proc/self/status");
    if status.len() == 0 {
        return 0 as u64;
    }
    // Scan for "VmRSS:" line and parse the number
    let target: &str = "VmRSS:";
    let status_bytes = status.as_bytes();
    let status_len = status.len();
    let mut i: usize = 0;
    while i < status_len {
        // Check if we're at "VmRSS:"
        if i + 6 <= status_len {
            let ch0 = status_bytes[i];
            let ch1 = status_bytes[i + 1];
            let ch2 = status_bytes[i + 2];
            let ch3 = status_bytes[i + 3];
            let ch4 = status_bytes[i + 4];
            let ch5 = status_bytes[i + 5];
            if ch0 == 86 && ch1 == 109 && ch2 == 82 && ch3 == 83 && ch4 == 83 && ch5 == 58 {
                // Found "VmRSS:" — skip whitespace and parse number
                let mut j: usize = i + 6;
                while j < status_len {
                    let c = status_bytes[j];
                    if c == 32 || c == 9 {
                        j += 1;
                    } else {
                        break;
                    }
                }
                // Parse digits
                let mut value: u64 = 0;
                while j < status_len {
                    let c = status_bytes[j];
                    if c >= 48 && c <= 57 {
                        value = value * 10 + (c - 48) as u64;
                        j += 1;
                    } else {
                        break;
                    }
                }
                return value;
            }
        }
        // Skip to next line
        while i < status_len && status_bytes[i] != 10 {
            i += 1;
        }
        i += 1;
    }
    0 as u64
}

/// Formats a byte count as human-readable (e.g., "1234 MB" or "5678 KB").
fn push_bytes_human(s: &mut String, bytes: u64) {
    if bytes >= 1073741824 {
        // GB range
        let gb = bytes / 1073741824;
        let remainder_mb = (bytes % 1073741824) / 10737418;  // two decimal places
        push_u64(s, gb);
        s.push('.');
        if remainder_mb < 10 {
            s.push('0');
        }
        push_u64(s, remainder_mb);
        s.push_str(" GB");
    } else if bytes >= 1048576 {
        // MB range
        let mb = bytes / 1048576;
        let remainder_kb = (bytes % 1048576) / 10485;  // two decimal places
        push_u64(s, mb);
        s.push('.');
        if remainder_kb < 10 {
            s.push('0');
        }
        push_u64(s, remainder_kb);
        s.push_str(" MB");
    } else {
        let kb = bytes / 1024;
        push_u64(s, kb);
        s.push_str(" KB");
    }
}

/// Prints a memory snapshot for a single phase boundary.
/// label: phase name (e.g., "After parse")
/// regions: list of (name, region_id) pairs to report on
fn print_mem_phase(label: &str, parse_region: u64, hir_region: u64, codegen_region: u64) {
    let rss_kb = get_rss_kb();
    let sys_live = system_alloc_live_bytes();

    let mut msg = String.new();
    msg.push_str("\n  [mem] ");
    msg.push_str(label);
    msg.push_str("\n");

    // RSS
    msg.push_str("    RSS:              ");
    push_bytes_human(&mut msg, rss_kb * 1024);
    msg.push('\n');

    // System allocator
    msg.push_str("    System heap:      ");
    push_bytes_human(&mut msg, sys_live);
    msg.push('\n');

    // Parse region
    if parse_region != 0 {
        msg.push_str("    parse_region:     used=");
        push_bytes_human(&mut msg, region_used(parse_region) as u64);
        msg.push_str("  committed=");
        push_bytes_human(&mut msg, region_committed(parse_region) as u64);
        msg.push_str("  allocs=");
        push_u64(&mut msg, region_alloc_count(parse_region));
        msg.push('\n');
    }

    // HIR region
    if hir_region != 0 {
        msg.push_str("    hir_region:       used=");
        push_bytes_human(&mut msg, region_used(hir_region) as u64);
        msg.push_str("  committed=");
        push_bytes_human(&mut msg, region_committed(hir_region) as u64);
        msg.push_str("  allocs=");
        push_u64(&mut msg, region_alloc_count(hir_region));
        msg.push('\n');
    }

    // Codegen region
    if codegen_region != 0 {
        msg.push_str("    codegen_region:   used=");
        push_bytes_human(&mut msg, region_used(codegen_region) as u64);
        msg.push_str("  committed=");
        push_bytes_human(&mut msg, region_committed(codegen_region) as u64);
        msg.push_str("  allocs=");
        push_u64(&mut msg, region_alloc_count(codegen_region));
        msg.push('\n');
    }

    // Realloc diagnostics (cumulative since last reset)
    let ra_count = realloc_diag_count();
    let ra_wasted = realloc_diag_wasted();
    let ra_inplace = realloc_diag_inplace();
    let ra_inplace_bytes = realloc_diag_inplace_bytes();
    msg.push_str("    realloc:          count=");
    push_u64(&mut msg, ra_count);
    msg.push_str("  wasted=");
    push_bytes_human(&mut msg, ra_wasted);
    msg.push_str("  inplace_eligible=");
    push_u64(&mut msg, ra_inplace);
    msg.push_str("  inplace_savings=");
    push_bytes_human(&mut msg, ra_inplace_bytes);
    msg.push('\n');
    msg.push_str("    realloc_delta:    offset_saved=");
    push_bytes_human(&mut msg, realloc_diag_offset_delta());
    msg.push('\n');

    eprint_str(msg.as_str());
    print_alloc_hist();
    realloc_stats_reset();
}

// ============================================================
// Streaming Compilation
// ============================================================

/// Compiles a source file using streaming codegen, writing IR directly to output_path.
/// Returns true on success, false on error (errors are printed directly).
///
/// Uses phase-scoped regions to manage memory:
/// - Parse region: holds AST nodes (destroyed after HIR lowering)
/// - HIR region: holds HIR/typeck data (destroyed after codegen)
/// - Per-function MIR regions: hold MIR bodies (destroyed after each function's IR is written)
fn compile_file_streaming(path: &str, output_path: &str, args: &Args) -> bool {
    let compile_start = blood_clock_millis();

    // Enable aggregate escape analysis when parallel codegen is disabled.
    // This is safe because the heap corruption only occurs under parallel workload.
    mir_escape.set_aggregate_escape_enabled(args.no_parallel);

    // === Build cache check ===
    let base_dir = source.parent_dir(path);
    let cache_dir = build_cache.ensure_cache_dir(base_dir.as_str());
    let exe_path: &str = args_get(0);
    let source_hash: u64 = if args.no_cache { 0 as u64 } else {
        build_cache.try_cache(base_dir.as_str(), path, exe_path)
    };

    if source_hash != 0 {
        let cached_path = build_cache.cache_ll_path(cache_dir.as_str(), source_hash);
        if file_exists(cached_path.as_str()) {
            // Cache hit — copy cached IR to output
            let cached_content: &str = file_read_to_string(cached_path.as_str());
            file_write_string(output_path, cached_content);
            eprint_str("[CACHE HIT] ");
            eprint_str(output_path);
            eprint_str("\n");
            return true;
        }
    }

    // Phase 1: Read source file and compute base_dir (global allocator — small)
    let read_result = source.read_file(path);
    if !read_result.success {
        main_helpers.print_error("Failed to read source file");
        return false;
    }

    let content = match &read_result.content {
        &Option.Some(ref c) => c,
        &Option.None => {
            main_helpers.print_error("No content in file");
            return false;
        }
    };

    // === Parse Phase (parse_region) ===
    // 2 MB initial, 10 GB max — holds AST nodes, tokens, spans.
    // Destroyed after HIR lowering to free AST memory early.
    eprint_str("  Parsing...");
    let parse_start = blood_clock_millis();

    // Preprocess macros BEFORE activating parse_region so expanded_source
    // lands on the global heap.  It is used for error reporting after
    // parse_region is destroyed; allocating it inside the region causes
    // use-after-free on type-check error paths.
    let expanded_source = macro_expand.preprocess_macros(content);

    let parse_region = region_create(2097152, 10737418240);
    region_activate(parse_region);

    let parse_result = parser.parse_file(expanded_source.as_str());
    let parse_elapsed = blood_clock_millis() - parse_start;
    if parse_result.errors.len() > 0 {
        eprint_str(" FAILED\n");
        let error_reporter = reporter.ErrorReporter.new(expanded_source.as_str(), path);
        let parse_errors = driver.convert_parse_errors(&parse_result.errors);
        let formatted = error_reporter.format_errors(&parse_errors);
        eprint_str(formatted.as_str());
        region_deactivate();
        region_destroy(parse_region);
        return false;
    }

    let program = match &parse_result.program {
        &Option.Some(ref p) => p,
        &Option.None => {
            eprint_str(" FAILED\n");
            main_helpers.print_error("No program produced by parser");
            region_deactivate();
            region_destroy(parse_region);
            return false;
        }
    };
    eprint_str(" done\n");

    if args.mem_profile {
        print_mem_phase("After parse", parse_region, 0 as u64, 0 as u64);
    }

    // Deactivate parse_region — AST remains readable for HIR lowering.
    region_deactivate();

    // === HIR Lower Phase (hir_region + ast_region) ===
    // hir_region: 16 MB initial, 50 GB max — holds HIR items, bodies, types, typeck info.
    // ast_region: 2 MB initial, 10 GB max — holds parser output (AST nodes).
    //   AST data is read during HIR lowering then freed before type checking.
    eprint_str("  HIR lowering...");
    let hir_start = blood_clock_millis();

    let hir_region = region_create(16777216, 53687091200);
    region_activate(hir_region);

    // Create a separate region for AST/parse data. External module parsing
    // activates this region so AST nodes don't pollute hir_region.
    let ast_region = region_create(2097152, 10737418240);

    let stdlib_path = resolve_stdlib_path(args);
    let lower_result = hir_lower.lower_program_with_ast_region(program, base_dir, expanded_source.as_str(), stdlib_path, ast_region);
    let hir_elapsed = blood_clock_millis() - hir_start;

    // Check for HIR lowering errors
    let mut has_hir_errors = false;
    for di in 0usize..lower_result.diagnostics.len() {
        let diag = &lower_result.diagnostics[di];
        match &diag.level {
            &hir.DiagnosticLevel.Error => {
                has_hir_errors = true;
            }
            &hir.DiagnosticLevel.Warning => {}
            &hir.DiagnosticLevel.Note => {}
            &hir.DiagnosticLevel.Help => {}
        }
    }
    if has_hir_errors {
        eprint_str(" FAILED\n");
        let error_reporter = reporter.ErrorReporter.new(expanded_source.as_str(), path);
        let hir_errors = driver.convert_hir_diagnostics(&lower_result.diagnostics);
        let formatted = error_reporter.format_errors(&hir_errors);
        eprint_str(formatted.as_str());
        region_deactivate();
        region_destroy(hir_region);
        region_destroy(parse_region);
        return false;
    }
    eprint_str(" done\n");

    if args.mem_profile {
        print_mem_phase("After HIR lowering", parse_region, hir_region, 0 as u64);
    }

    // alloc-profile report is printed from hir_lower.blood (has module name mapping).
    // Tags are reset there too, so nothing to do here.

    // Trim hir_region to release pages used during lowering but no longer needed
    region_trim(hir_region);

    if args.mem_profile {
        print_mem_phase("After HIR trim", parse_region, hir_region, 0 as u64);
    }

    // Deactivate hir_region temporarily to destroy parse/ast regions
    region_deactivate();

    // AST no longer needed — free parse memory early (before type checking)
    region_destroy(parse_region);

    // External module AST data is also no longer needed
    region_destroy(ast_region);

    if args.mem_profile {
        print_mem_phase("After parse+ast_region destroy", 0 as u64, hir_region, 0 as u64);
    }

    // === Incremental: compute skip_modules before typeck ===
    // Per-module hash comparison determines which external modules are unchanged.
    // Unchanged modules can be skipped in both typeck Phase 2b and codegen Pass 2.
    let mut skip_modules: Vec<bool> = Vec.new();
    let module_count = lower_result.module_names.len();
    let inc_build_dir = resolve_build_dir(args);
    let mut hash_dir = common.make_string(inc_build_dir.as_str());
    hash_dir.push_str("/obj/.hashes");

    if args.split_modules && !args.no_cache && module_count > 1 {
        main_helpers.ensure_dir(hash_dir.as_str());
        let mut obj_dir = common.make_string(inc_build_dir.as_str());
        obj_dir.push_str("/obj");
        main_helpers.ensure_dir(obj_dir.as_str());

        let mut changed_count: usize = 0;
        for mi in 0usize..module_count {
            let mod_path = &lower_result.module_names[mi];
            let hash = if mi == 0 {
                build_cache.hash_module_source(path, base_dir.as_str(), exe_path)
            } else {
                build_cache.hash_module_source(mod_path.as_str(), source.parent_dir(mod_path.as_str()).as_str(), exe_path)
            };
            let stem = if mi == 0 {
                common.make_string("main")
            } else {
                main_helpers.file_stem(mod_path)
            };
            let cached = build_cache.read_cached_hash(hash_dir.as_str(), stem.as_str());
            let mut ll_exists = false;
            let mut o_exists = false;
            {
                let mut ll_p = common.make_string(obj_dir.as_str());
                ll_p.push('/');
                ll_p.push_str(stem.as_str());
                ll_p.push_str(".ll");
                ll_exists = file_exists(ll_p.as_str());
                let mut o_p = common.make_string(obj_dir.as_str());
                o_p.push('/');
                o_p.push_str(stem.as_str());
                o_p.push_str(".o");
                o_exists = file_exists(o_p.as_str());
            }
            let is_unchanged = hash != 0 && cached == hash && ll_exists && o_exists;
            skip_modules.push(is_unchanged);
            if !is_unchanged {
                changed_count += 1;
            }
        }
        // If all modules changed, disable incremental
        if changed_count >= module_count {
            for si in 0usize..skip_modules.len() {
                skip_modules[si] = false;
            }
        }
    }

    // === Type Check Phase (typeck_region on top of hir_region) ===
    // Typeck allocations go to a separate region so they can be freed after
    // extracting results. This saves ~8 GB of type checker working data
    // (fn_sigs, structs, enums, impls, unifier state) that codegen doesn't need.
    eprint_str("  Type checking...");
    let typeck_start = blood_clock_millis();

    let typeck_region = region_create(16777216, 53687091200);
    region_activate(hir_region);
    region_activate(typeck_region);

    let typeck_result = typeck_driver.check_lower_result(&lower_result, &skip_modules, expanded_source.as_str());
    let typeck_elapsed = blood_clock_millis() - typeck_start;
    if !typeck_result.success {
        eprint_str(" FAILED\n");
        let error_reporter = reporter.ErrorReporter.new(expanded_source.as_str(), path);
        let type_errors = driver.convert_type_errors(&typeck_result.errors);
        let formatted = error_reporter.format_errors(&type_errors);
        eprint_str(formatted.as_str());
        region_deactivate();
        region_deactivate();
        region_destroy(typeck_region);
        region_destroy(hir_region);
        return false;
    }
    eprint_str(" done\n");

    if args.mem_profile {
        print_mem_phase("After type checking", 0 as u64, hir_region, 0 as u64);
    }

    // Dump type resolutions if requested
    if args.dump_types {
        dump_type_resolutions(&typeck_result);
    }

    // Deactivate typeck_region — results still readable but no new allocations
    region_deactivate();

    // Clone TypeCheckResult data to system heap before destroying typeck_region.
    // These are small (Vecs of integer-indexed structs, total ~few MB).
    // The TypeChecker's working data (~8 GB) stays in typeck_region and is freed.
    region_deactivate(); // deactivate hir_region too — clones go to system heap
    let typeck_result = typeck_driver.clone_typeck_result_to_heap(&typeck_result);
    region_destroy(typeck_region);

    if args.mem_profile {
        print_mem_phase("After typeck_region destroy", 0 as u64, hir_region, 0 as u64);
    }

    // Deactivate hir_region — data remains readable for codegen.
    // New allocations (codegen ctx, def_names) go to global allocator.
    // NOTE: CodegenCtx MUST stay on the system heap, not in a region.
    // Its Vecs/HashMaps grow incrementally — on the system heap, old buffers
    // are freed and reused; in a bump region, they'd leak (~6 GB waste).
    region_deactivate();

    // Emit content hashes if requested
    if args.emit_hashes {
        eprint_str("\n  Content hashes:\n");
        for hi in 0usize..lower_result.bodies.len() {
            let body_entry = &lower_result.bodies[hi];
            // Find matching fn item for this body
            for hj in 0usize..lower_result.items.len() {
                match &lower_result.items[hj].item.kind {
                    &hir_item.ItemKind.Fn(ref fn_def) => {
                        match &fn_def.body_id {
                            &Option.Some(ref bid) => {
                                if bid.index == body_entry.body_id.index {
                                    let hash = content_hash.hash_fn_body(&body_entry.body, &fn_def.sig);
                                    let hex = content_hash.hash_to_hex(&hash);
                                    let def_name = match lower_result.interner.resolve(lower_result.items[hj].item.name.symbol) {
                                        Option.Some(n) => common.make_string(n.as_str()),
                                        Option.None => common.make_string("unknown"),
                                    };
                                    print_str(def_name.as_str());
                                    print_str(": ");
                                    println_str(hex.as_str());
                                    // Save hash to build cache for incremental comparison
                                    {
                                        let mut hash_dir = common.make_string(output_path);
                                        // Strip filename to get build dir
                                        let mut last_slash: usize = 0;
                                        let olen: usize = hash_dir.len();
                                        let mut oi: usize = 0;
                                        while oi < olen { if hash_dir.as_bytes()[oi] == 47 { last_slash = oi; } oi += 1; }
                                        if last_slash > 0 {
                                            let mut build_dir = String.new();
                                            oi = 0;
                                            while oi < last_slash { build_dir.push(hash_dir.as_bytes()[oi] as char); oi += 1; }
                                            build_dir.push_str("/.content_hashes");
                                            if !file_exists(build_dir.as_str()) {
                                                let mut mkdir_cmd = common.make_string("mkdir -p ");
                                                mkdir_cmd.push_str(build_dir.as_str());
                                                system(mkdir_cmd.as_str());
                                            }
                                            let mut hash_file = common.make_string(build_dir.as_str());
                                            hash_file.push('/');
                                            hash_file.push_str(def_name.as_str());
                                            hash_file.push_str(".hash");
                                            file_write_string(hash_file.as_str(), hex.as_str());
                                        }
                                    }
                                    // Store in codebase if requested
                                    if args.store_codebase {
                                        let cb = default_codebase_path();
                                        codebase.init_codebase(cb.as_str());
                                        let fn_name = match lower_result.interner.resolve(lower_result.items[hj].item.name.symbol) {
                                            Option.Some(s) => common.make_string(s.as_str()),
                                            Option.None => common.make_string("unknown"),
                                        };
                                        let deps: Vec<String> = Vec.new();
                                        // Extract function source text from the expanded source using span
                                        let item_span = lower_result.items[hj].item.span;
                                        let src_bytes = expanded_source.as_bytes();
                                        let mut fn_source = String.new();
                                        let end = if item_span.end <= src_bytes.len() { item_span.end } else { src_bytes.len() };
                                        let mut si: usize = item_span.start;
                                        while si < end { fn_source.push(src_bytes[si] as char); si += 1; }
                                        let rec = codebase.DefinitionRecord.new(
                                            common.make_string(hex.as_str()),
                                            fn_name,
                                            common.make_string("fn"),
                                            fn_source,
                                            deps,
                                        );
                                        codebase.store_definition(cb.as_str(), &rec);
                                        codebase.add_name(cb.as_str(), rec.name.as_str(), hex.as_str());
                                    }
                                }
                            }
                            &Option.None => {}
                        }
                    }
                    _ => {}
                }
            }
        }
    }

    // Phase 5: Streaming codegen (global allocator for ctx persistent state)
    eprint_str("  Codegen...");
    let codegen_start = blood_clock_millis();

    eprint_str("[begin_streaming]");
    let source_filename = source.file_name(path);
    let mod_count: u32 = lower_result.module_names.len() as u32;
    let mut ctx = codegen_streaming.begin_streaming_module(source_filename.as_str(), output_path, &lower_result.items, mod_count);
    ctx.trace_codegen = args.trace_codegen;
    eprint_str("[done]");

    // Register builtin ADT types (Vec, String, HashMap, Box, Option, Result) in the ADT registry
    eprint_str("[register_adts]");
    codegen.register_builtin_adts(
        &mut ctx,
        &lower_result.builtin_vec_def,
        &lower_result.builtin_string_def,
        &lower_result.builtin_hashmap_def,
        &lower_result.builtin_box_def,
        &lower_result.builtin_option_def,
        &lower_result.builtin_result_def,
    );
    // Set Frozen DefId for persist/freeze codegen (when stdlib Frozen is used)
    match &lower_result.builtin_frozen_def {
        &Option.Some(ref fid) => { ctx.frozen_def_id = fid.index; }
        &Option.None => {}
    }
    eprint_str("[populate_adt]");
    codegen.populate_adt_registry(&mut ctx, &lower_result.items);
    eprint_str("[done]");

    // Dump ADT layouts if requested (after registry is fully populated)
    if args.dump_layouts {
        dump_adt_layouts(&ctx);
    }

    eprint_str("[statics]");
    // Collect static DefIds first - needed for name registration filtering.
    let mut static_def_ids: Vec<u32> = Vec.new();
    for si in 0usize..lower_result.items.len() {
        let item = &lower_result.items[si].item;
        match &item.kind {
            &hir_item.ItemKind.Static(ref _static_def) => {
                static_def_ids.push(item.def_id.index);
            }
            _ => {}
        }
    }

    // Pass 0: Emit static global variable declarations.
    // This must happen before any functions that reference statics.
    // Also registers static names in ctx using the interner.
    codegen_streaming.emit_static_globals_with_names(&mut ctx, &lower_result.interner, &lower_result.items, &lower_result.bodies, &lower_result.thread_local_def_ids);
    eprint_str("[pass0_done]");

    // Pass 1a: Register def_names for all function bodies (global allocator)
    // SKIP static bodies - their names are already registered by emit_static_globals_with_names
    for body_idx in 0usize..lower_result.bodies.len() {
        let body_entry = &lower_result.bodies[body_idx];
        let body_id = body_entry.body_id;
        let fn_info = driver.find_fn_for_body(&lower_result.items, body_id);
        let def_id = match &fn_info {
            &Option.Some(ref info) => info.def_id.index,
            &Option.None => body_idx as u32,
        };
        // Skip static bodies
        let mut is_static = false;
        let mut sbi: usize = 0;
        while sbi < static_def_ids.len() {
            if static_def_ids[sbi] == def_id {
                is_static = true;
                sbi = static_def_ids.len();
            }
            sbi += 1;
        }
        if !is_static {
            let fn_name = match &fn_info {
                &Option.Some(ref info) => main_helpers.make_mangled_fn_name(&lower_result.interner, info, &lower_result.no_mangle_def_ids, &lower_result.export_name_entries),
                &Option.None => driver.make_fn_name(body_idx),
            };
            ctx.register_def_name(def_id, fn_name);
        }
    }

    // Pass 1b: Register def_names for ALL function-like items (including those without bodies).
    // This ensures that calls to foreign/builtin functions resolve to the correct name.
    main_helpers.register_all_item_names(&mut ctx, &lower_result.interner, &lower_result.items, &lower_result.no_mangle_def_ids, &lower_result.export_name_entries);
    eprint_str("[pass1_done]");

    // Pass 1c: Register def_names for builtin constructors (String.new, Vec.new, etc.).
    // These DefIds are allocated by the HIR lowering and map to runtime function names.
    for bfi in 0usize..lower_result.builtin_fn_defs.len() {
        let entry = &lower_result.builtin_fn_defs[bfi];
        ctx.register_def_name(entry.def_id_index, main_helpers.clone_string(&entry.runtime_name));
    }

    // Pass 1c2: Register bridge constants with inline values.
    for bci in 0usize..lower_result.builtin_const_defs.len() {
        let entry = &lower_result.builtin_const_defs[bci];
        ctx.register_bridge_const(entry.def_id_index, entry.int_value);
    }

    // Pass 1e: Register def_names for enum variant constructors.
    // Enum variants have their own DefIds used when constructing variants (e.g., TokenKind.Ident(...)).
    main_helpers.register_enum_variant_names(&mut ctx, &lower_result.interner, &lower_result.items);

    // Pass 1d: Register def_names for synthetic builtin methods (String.push_str, Vec.push, etc.).
    // These DefIds are allocated by the type checker and map to runtime function names.
    for bi in 0usize..typeck_result.builtin_def_names.len() {
        let entry = &typeck_result.builtin_def_names[bi];
        ctx.register_def_name(entry.def_id_index, main_helpers.clone_string(&entry.runtime_name));
    }

    // Collect handler→effect mappings and handler op info for wrapper generation.
    let handler_info = collect_handler_info(&mut ctx, &lower_result.interner, &lower_result.items, &lower_result.bodies);

    // Register handler op body DefIds with state field counts for conditional state-by-pointer codegen.
    for hop_i in 0usize..handler_info.ops.len() {
        ctx.register_handler_op_body(handler_info.ops[hop_i].body_def_id, handler_info.ops[hop_i].state_field_count);
    }

    // Pre-analysis: identify const-generic functions for monomorphization.
    let mut const_generic_fn_set: Vec<u32> = Vec.new();
    let mut const_generic_param_counts: Vec<u32> = Vec.new();
    let mut const_generic_body_ids: Vec<u32> = Vec.new();
    driver.collect_const_generic_fns(
        &lower_result.items,
        &mut const_generic_fn_set,
        &mut const_generic_param_counts,
        &mut const_generic_body_ids,
    );

    // Convert turbofish entries from HIR to MIR format
    let mut turbofish_const_args: Vec<mir_lower_ctx.TurbofishConstArg> = Vec.new();
    {
        for ti in 0usize..lower_result.turbofish_const_entries.len() {
            let entry = &lower_result.turbofish_const_entries[ti];
            let mut vals: Vec<u64> = Vec.new();
            for vi in 0usize..entry.values.len() {
                vals.push(entry.values[vi]);
            }
            turbofish_const_args.push(mir_lower_ctx.TurbofishConstArg.new(
                entry.span_start,
                vals,
            ));
        }
    }

    let has_const_generics: bool = const_generic_fn_set.len() > 0;

    // Pre-analysis: identify type-generic functions for monomorphization.
    let mut type_generic_fn_set: Vec<u32> = Vec.new();
    driver.collect_type_generic_fns(
        &lower_result.items,
        &mut type_generic_fn_set,
    );

    // Generate vtables for dyn Trait dispatch (after ADT registry and def_names)
    codegen.generate_vtables(&mut ctx, &lower_result.interner, &lower_result.items);
    // Emit vtable global constants to output file
    for vti in 0usize..ctx.vtable_defs.len() {
        ctx.buffer_write(ctx.vtable_defs[vti].as_str());
    }
    // VFT metadata comments (P2-9)
    for vni in 0usize..ctx.vtable_name_entries.len() {
        let vne = &ctx.vtable_name_entries[vni];
        let mut vft_comment = common.make_string("; VFT ");
        vft_comment.push_str(vne.vtable_name.as_str());
        vft_comment.push('\n');
        ctx.buffer_write(vft_comment.as_str());
    }

    // Build work list: scan bodies once to identify which functions to codegen.
    // Filters out static bodies, duplicates, and const-generic bodies.
    // Type-generic bodies are NOT skipped — they're compiled with type erasure as fallback.
    // Monomorphized copies are generated in pass 2b for calls needing concrete types.
    let worklist = build_codegen_worklist(&lower_result, &static_def_ids, &const_generic_body_ids);
    eprint_str("[worklist:");
    eprint_str(int_to_string(worklist.items.len() as i32));
    eprint_str("]");

    if args.mem_profile {
        print_mem_phase("Before codegen pass2", 0 as u64, hir_region, 0 as u64);
    }

    // Codegen region: holds per-function codegen temporaries, string_table growth, etc.
    // Persists across all function compilations. Per-function mir_regions sit
    // on top for MIR lowering, then pop so codegen uses this region.
    // CodegenCtx itself stays on the system heap (see comment above at region_deactivate).
    // 32 MB initial, 16 GB max — codegen produces ~50-100 MB of IR + metadata.
    let codegen_region = region_create(33554432, 17179869184);
    region_activate(codegen_region);

    // === Incremental: load cached fn_sigs for codegen ===
    // skip_modules was computed before typeck (used by both typeck and codegen).
    let mut incremental_active = false;
    let mut sigs_path = common.make_string(inc_build_dir.as_str());
    sigs_path.push_str("/obj/.fn_sigs");

    if skip_modules.len() > 0 {
        let mut changed_count: usize = 0;
        for si in 0usize..skip_modules.len() {
            if !skip_modules[si] {
                changed_count += 1;
            }
        }
        if changed_count < skip_modules.len() && file_exists(sigs_path.as_str()) {
            let sigs_data: &str = file_read_to_string(sigs_path.as_str());
            if sigs_data.len() > 0 {
                ctx.load_fn_signatures(sigs_data);
                incremental_active = true;
                eprint_str("\n  [incremental: ");
                eprint_str(int_to_string(changed_count as i32));
                eprint_str("/");
                eprint_str(int_to_string(module_count as i32));
                eprint_str(" modules changed]");
            }
        }
        if !incremental_active {
            for si in 0usize..skip_modules.len() {
                skip_modules[si] = false;
            }
        }
    }

    // Pass 2: MIR lowering + codegen, writing each function's IR directly to file.
    ctx.flush_write_buffer();
    eprint_str("[pass2_start]");
    let pass2_result = codegen_pass2(
        &mut ctx, &worklist, &lower_result, &typeck_result, output_path, args,
        has_const_generics, &const_generic_fn_set, &const_generic_param_counts,
        &turbofish_const_args, 0,
        &type_generic_fn_set, &typeck_result.type_generic_calls,
        &skip_modules,
    );
    eprint_str("[pass2_done]");

    // Pass 2b: Monomorphization — generate specialized copies of const-generic and type-generic functions.
    if pass2_result.mono_requests.len() > 0 {
        eprint_str("[mono:");
        eprint_str(int_to_string(pass2_result.mono_requests.len() as i32));
        eprint_str("]");

        // Shared MIR region for monomorphization — created once, reset between functions.
        let mono_mir_region = region_create(4194304, 8589934592);

        // Track compiled mono function names to skip duplicates.
        // Multiple call sites can generate MonoRequests for the same function+types;
        // we compile the first and register aliases for the rest.
        let mut compiled_mono_names: Vec<String> = Vec.new();

        for mono_i in 0usize..pass2_result.mono_requests.len() {
            let req = &pass2_result.mono_requests[mono_i];

            // Find the original function's body
            let body_info = driver.find_body_for_def_id(
                &lower_result.bodies,
                &lower_result.items,
                req.original_def_id,
            );
            match &body_info {
                &Option.Some(ref info) => {
                    // Check if this mono function was already compiled (dedup).
                    // Register the def name regardless so call sites resolve correctly.
                    ctx.register_def_name(req.specialized_def_id, common.make_string(req.fn_name.as_str()));
                    let mut already_compiled: bool = false;
                    for ci in 0usize..compiled_mono_names.len() {
                        if main_helpers.str_equals(&compiled_mono_names[ci], req.fn_name.as_str()) {
                            already_compiled = true;
                        }
                    }
                    if already_compiled {
                        // Skip — function already emitted by a previous request
                        region_reset(mono_mir_region);
                    } else {
                    compiled_mono_names.push(common.make_string(req.fn_name.as_str()));

                    let body_entry = &lower_result.bodies[info.body_index];
                    let hir_body = &body_entry.body;

                    // Activate MIR region for lowering
                    region_activate(mono_mir_region);

                    let mono_mir = if req.is_type_mono {
                        // Type-generic monomorphization:
                        // Clone the subst table and inject type bindings so that
                        // body type params resolve to concrete types.
                        let mut mono_subst = unify.clone_subst_table(&typeck_result.subst_table);
                        // Use Phase 4 body TyVarIds (from body_entry.type_param_var_ids)
                        // instead of Phase 3 signature TyVarIds (from req.type_bindings.ty_var_index).
                        // Phase 3 and Phase 4 allocate separate TyVarIds for the same type params;
                        // the body uses Phase 4 IDs, so we must inject those into the subst table.
                        for tbi in 0usize..req.type_bindings.len() {
                            let concrete = type_intern.TyId.new(req.type_bindings[tbi].concrete_ty_id);
                            // Add Phase 3 signature TyVarId binding so that the function
                            // return type (which uses Phase 3 IDs) resolves correctly.
                            let sig_var_id = hir_def.TyVarId.new(req.type_bindings[tbi].ty_var_index);
                            mono_subst.add_ty_subst_id(sig_var_id, concrete);
                            // Also add Phase 4 body TyVarId binding so that body-internal
                            // type references resolve correctly.
                            if tbi < body_entry.type_param_var_ids.len() {
                                let body_var_id = hir_def.TyVarId.new(body_entry.type_param_var_ids[tbi]);
                                mono_subst.add_ty_subst_id(body_var_id, concrete);
                            }
                        }

                        // Resolve method calls for concrete types using impl_method_table.
                        // Clone method_resolutions and inject resolved methods for this body.
                        let mono_method_res = resolve_methods_for_type_mono(
                            &typeck_result.method_resolutions,
                            &typeck_result.pending_method_calls,
                            &typeck_result.impl_method_table,
                            &mono_subst,
                            req.original_def_id,
                            req.specialized_def_id,
                            &req.type_bindings,
                        );

                        // Remap field_resolutions: the originals are keyed by original_def_id
                        // but the mono body uses specialized_def_id for lookups.
                        let mut mono_field_res: Vec<common.FieldResEntry> = Vec.new();
                        for fri in 0usize..typeck_result.field_resolutions.len() {
                            let entry = &typeck_result.field_resolutions[fri];
                            if entry.body_def_id == req.original_def_id {
                                mono_field_res.push(common.FieldResEntry.new(
                                    req.specialized_def_id,
                                    entry.span_start,
                                    entry.field_idx,
                                ));
                            } else {
                                mono_field_res.push(common.FieldResEntry.new(
                                    entry.body_def_id,
                                    entry.span_start,
                                    entry.field_idx,
                                ));
                            }
                        }

                        mir_lower.lower_body_with_const_info(
                            hir_def.DefId.new(req.specialized_def_id),
                            hir_body,
                            info.return_ty,
                            info.span,
                            &mono_subst,
                            &mono_method_res,
                            &mono_field_res,
                            &typeck_result.coercion_entries,
                            Vec.new(), // No const_bindings
                            Vec.new(), // No const_generic_fn_set
                            Vec.new(), // No turbofish
                            Vec.new(), // No param counts
                            pass2_result.next_mono_def_id,
                            Vec.new(), // No type_generic_fn_set
                            Vec.new(), // No type_generic_calls
                        )
                    } else {
                        // Const-generic monomorphization
                        let const_bindings = driver.build_const_bindings_from_body(
                            &body_entry.const_param_def_ids,
                            &req.const_values,
                        );

                        mir_lower.lower_body_with_const_info(
                            hir_def.DefId.new(req.specialized_def_id),
                            hir_body,
                            info.return_ty,
                            info.span,
                            &typeck_result.subst_table,
                            &typeck_result.method_resolutions,
                            &typeck_result.field_resolutions,
                            &typeck_result.coercion_entries,
                            const_bindings,
                            Vec.new(), // No further const-generic interception
                            Vec.new(), // No turbofish
                            Vec.new(), // No param counts
                            pass2_result.next_mono_def_id,
                            Vec.new(), // No type_generic_fn_set
                            Vec.new(), // No type_generic_calls
                        )
                    };

                    region_deactivate();

                    // Codegen the specialized body
                    let mono_ir = codegen.generate_function_with_ctx(&mut ctx, &mono_mir.body, req.fn_name.as_str(), 0, mod_count);
                    file_append_string(output_path, mono_ir.as_str());

                    // Compile closure/inline handler bodies from the mono MIR
                    let mut mcli: usize = 0;
                    while mcli < mono_mir.closure_names.len() && mcli < mono_mir.closure_mir.len() {
                        let mcname = &mono_mir.closure_names[mcli];
                        let mcbody = &mono_mir.closure_mir[mcli];
                        let mc_is_hop = mcli < mono_mir.closure_is_handler_op.len()
                            && mono_mir.closure_is_handler_op[mcli];
                        if mc_is_hop { ctx.is_handler_op = true; }
                        let mc_ir = codegen.generate_function_with_ctx(&mut ctx, mcbody, mcname.as_str(), 0, mod_count);
                        file_append_string(output_path, mc_ir.as_str());
                        if mc_is_hop { ctx.is_handler_op = false; }
                        mcli += 1;
                    }

                    // Reset MIR region for next mono function
                    region_reset(mono_mir_region);
                    } // end else (not already_compiled)
                }
                &Option.None => {
                    eprint_str("[mono_err: body not found for def ");
                    eprint_str(int_to_string(req.original_def_id as i32));
                    eprint_str("]\n");
                }
            }

        }

        // Destroy mono MIR region after all mono functions processed
        region_destroy(mono_mir_region);
    }

    if args.mem_profile {
        print_mem_phase("After codegen pass2", 0 as u64, hir_region, codegen_region);
    }

    // Pass 3: Generate stub functions for registered names without bodies.
    // These are enum variant constructors and other synthetic functions that are
    // referenced as function pointers but don't have HIR bodies.
    main_helpers.generate_missing_stubs(&mut ctx, &worklist.defined_names);

    // Pass 4: Generate handler op wrapper functions and __blood_register_handlers.
    // These wrappers adapt the inner handler op bodies to the standard ABI
    // expected by the evidence API runtime (ptr state, ptr args, i64 arg_count, i64 cont) -> i64.
    let handler_wrapper_ir = generate_handler_wrappers(&handler_info, &mut ctx, &worklist.body_id_to_name);
    ctx.buffer_write(handler_wrapper_ir.as_str());

    // Pass 5: Generate VFT init constructor for trait impl methods.
    let vft_init_ir = generate_vft_init_ir(&lower_result);
    ctx.buffer_write(vft_init_ir.as_str());

    // Emit inline handler stub functions collected during PushInlineHandler codegen.
    for stub_i in 0usize..ctx.inline_stubs.len() {
        let stub_ir = main_helpers.clone_string(&ctx.inline_stubs[stub_i]);
        ctx.buffer_write(stub_ir.as_str());
    }

    // Emit fn pointer wrapper functions (fn_name$fnptr) for named functions
    // used as fn() values.  These are deferred to emit at module scope.
    for wpi in 0usize..ctx.fn_ptr_wrapper_defs.len() {
        let wrapper_ir = main_helpers.clone_string(&ctx.fn_ptr_wrapper_defs[wpi]);
        ctx.buffer_write(wrapper_ir.as_str());
    }

    // Finish: write string constants and intrinsic declarations
    codegen_streaming.finish_streaming_module(&mut ctx);

    // Write foreign function declarations (runtime builtins)
    let foreign_decls = main_helpers.generate_foreign_declarations(&lower_result.interner, &lower_result.items);
    ctx.buffer_write(foreign_decls.as_str());

    // Emit DWARF debug metadata at end of module
    let debug_md = ctx.emit_debug_metadata(&lower_result.module_names);
    if debug_md.len() > 0 {
        ctx.buffer_write(debug_md.as_str());
    }

    // Final flush: write any remaining buffered IR to disk
    ctx.flush_write_buffer();
    let codegen_elapsed = blood_clock_millis() - codegen_start;
    eprint_str(" done\n");

    // Split monolithic IR into per-module files (if requested).
    // Must happen before region destroys — ctx.fn_signatures are in codegen_region.
    if args.split_modules {
        let split_build_dir = resolve_build_dir(args);
        // Only split changed modules when incremental is active
        if incremental_active {
            split_monolithic_to_modules_incremental(
                output_path, &worklist, &lower_result.module_names,
                &ctx, split_build_dir.as_str(), &skip_modules,
            );
        } else {
            split_monolithic_to_modules(output_path, &worklist, &lower_result.module_names, &ctx, split_build_dir.as_str());
        }

        // Save fn_sigs cache (all signatures — fresh + cached)
        let sigs_text = ctx.serialize_fn_signatures();
        file_write_string(sigs_path.as_str(), sigs_text.as_str());

        // Save per-module hashes
        if module_count > 1 {
            for mi in 0usize..module_count {
                let mod_path = &lower_result.module_names[mi];
                let stem = if mi == 0 {
                    common.make_string("main")
                } else {
                    main_helpers.file_stem(mod_path)
                };
                let hash = if mi < skip_modules.len() && skip_modules[mi] {
                    // Unchanged — keep existing hash (it's already correct)
                    build_cache.read_cached_hash(hash_dir.as_str(), stem.as_str())
                } else {
                    // Changed — write new hash
                    // Recompute since module_hashes is out of scope
                    if mi == 0 {
                        build_cache.hash_module_source(path, base_dir.as_str(), exe_path)
                    } else {
                        build_cache.hash_module_source(mod_path.as_str(), source.parent_dir(mod_path.as_str()).as_str(), exe_path)
                    }
                };
                if hash != 0 {
                    build_cache.write_cached_hash(hash_dir.as_str(), stem.as_str(), hash);
                }
            }
        }
    }

    if args.mem_profile {
        print_mem_phase("After codegen complete", 0 as u64, hir_region, codegen_region);
    }

    // Free per-function temp region (deferred from codegen_pass2 — ctx held dangling refs)
    if pass2_result.fn_temp_region != 0 {
        region_destroy(pass2_result.fn_temp_region);
    }

    // Free codegen temporaries and ctx growth
    region_deactivate();
    region_destroy(codegen_region);

    // HIR/typeck data no longer needed — free hir_region
    region_destroy(hir_region);

    if args.mem_profile {
        print_mem_phase("After all regions destroyed", 0 as u64, 0 as u64, 0 as u64);
    }

    // === Store in cache ===
    if source_hash != 0 {
        let cached_path = build_cache.cache_ll_path(cache_dir.as_str(), source_hash);
        let compiled_ir: &str = file_read_to_string(output_path);
        file_write_string(cached_path.as_str(), compiled_ir);
    }

    let compile_elapsed = blood_clock_millis() - compile_start;

    // Print timing summary if requested
    if args.timings {
        print_str("\nTimings:\n");
        print_str("  Parse                ");
        print_timing_ms(parse_elapsed);
        print_str("  HIR lowering         ");
        print_timing_ms(hir_elapsed);
        print_str("  Type checking        ");
        print_timing_ms(typeck_elapsed);
        print_str("  Codegen              ");
        print_timing_ms(codegen_elapsed);
        print_str("  ─────────────────────────\n");
        print_str("  Compiler total       ");
        print_timing_ms(compile_elapsed);
    }

    // Hash table load factor diagnostics.
    if args.hash_stats {
        eprint_str("\n  [hash-stats]\n");
        eprint_str("    type_interner:             ");
        eprint_str(int_to_string(type_intern.type_interner().type_count() as i32));
        eprint_str(" types, ");
        eprint_str(int_to_string(type_intern.type_interner().ty_list_count() as i32));
        eprint_str(" type lists\n");
        eprint_str("    ctx.def_names:             ");
        eprint_str(int_to_string(ctx.def_names.len() as i32));
        eprint_str("/");
        eprint_str(int_to_string(ctx.def_names_hash.entry_count() as i32));
        eprint_str(" (vec/hash)\n");
        eprint_str("    ctx.adt_registry:          ");
        eprint_str(int_to_string(ctx.adt_registry.len() as i32));
        eprint_str(" entries\n");
        eprint_str("    ctx.adt_struct_hash:        ");
        eprint_str(int_to_string(ctx.adt_struct_hash.entry_count() as i32));
        eprint_str("/");
        eprint_str(int_to_string(ctx.adt_struct_hash.bucket_capacity() as i32));
        eprint_str(" (load ");
        if ctx.adt_struct_hash.bucket_capacity() > 0 {
            eprint_str(int_to_string((ctx.adt_struct_hash.entry_count() * 100 / ctx.adt_struct_hash.bucket_capacity()) as i32));
        } else {
            eprint_str("0");
        }
        eprint_str("%)\n");
        eprint_str("    ctx.adt_enum_hash:          ");
        eprint_str(int_to_string(ctx.adt_enum_hash.entry_count() as i32));
        eprint_str("/");
        eprint_str(int_to_string(ctx.adt_enum_hash.bucket_capacity() as i32));
        eprint_str(" (load ");
        if ctx.adt_enum_hash.bucket_capacity() > 0 {
            eprint_str(int_to_string((ctx.adt_enum_hash.entry_count() * 100 / ctx.adt_enum_hash.bucket_capacity()) as i32));
        } else {
            eprint_str("0");
        }
        eprint_str("%)\n");
        eprint_str("    ctx.fn_signatures:         ");
        eprint_str(int_to_string(ctx.fn_signatures.len() as i32));
        eprint_str("/");
        eprint_str(int_to_string(ctx.fn_sigs_hash.entry_count() as i32));
        eprint_str(" (vec/hash)\n");
        eprint_str("    ctx.string_table:          ");
        eprint_str(int_to_string(ctx.string_table.len() as i32));
        eprint_str("/");
        eprint_str(int_to_string(ctx.string_table_hash.entry_count() as i32));
        eprint_str(" (vec/hash)\n");
    }

    // Report peak physical RSS (VmHWM = high water mark) from /proc/self/status.
    // Uses $PPID because system() spawns a child shell — /proc/self/ would
    // report awk's memory, not the compiler's. VmHWM is physical memory only
    // (unlike VmPeak which includes mmap'd virtual address space from regions).
    if args.timings {
        system("awk '/VmHWM/ {printf \"  peak_rss_kb=%d\\n\", $2}' /proc/$PPID/status >&2");
    }

    true
}

// ============================================================
// Per-Module IR Splitting
// ============================================================

/// Splits a monolithic .ll file into per-module .ll files.
/// Each module file contains the shared preamble, the module's function definitions,
/// cross-module forward declarations, and the shared postamble (string constants, metadata).
///
/// The monolithic file is preserved unchanged. Per-module files are written to build/obj/.
fn split_monolithic_to_modules(
    monolithic_path: &str,
    worklist: &CodegenWorkList,
    module_names: &Vec<String>,
    ctx: &codegen_ctx.CodegenCtx,
    build_dir: &str,
) {
    let split_start = blood_clock_millis();

    // Build function name → module_index map from worklist
    let mut name_to_module: hashmap.HashMapU64U32 = hashmap.HashMapU64U32.with_capacity(worklist.items.len());
    for wi in 0usize..worklist.items.len() {
        let name_hash = hashmap.hash_str(worklist.items[wi].fn_name.as_str());
        name_to_module.insert(name_hash, worklist.items[wi].module_index);
    }

    // Read the monolithic file
    let content: &str = file_read_to_string(monolithic_path);
    let bytes = content.as_bytes();
    let len = bytes.len();
    if len == 0 { return; }

    // Determine module count
    let module_count = module_names.len();
    if module_count <= 1 { return; } // No external modules to split

    // Create obj directory
    let mut obj_dir = String.new();
    obj_dir.push_str(build_dir);
    obj_dir.push_str("/obj");
    main_helpers.ensure_dir(obj_dir.as_str());

    // Build per-module output paths (stem from module_names)
    let mut module_paths: Vec<String> = Vec.with_capacity(module_count);
    for mi in 0usize..module_count {
        let stem = if mi == 0 {
            common.make_string("main")
        } else {
            main_helpers.file_stem(&module_names[mi])
        };
        let mut path = common.make_string(obj_dir.as_str());
        path.push('/');
        path.push_str(stem.as_str());
        path.push_str(".ll");
        module_paths.push(path);
    }

    // Scan file to find: preamble end, function blocks, postamble start.
    // Preamble = everything before the first non-internal `define`.
    // Function blocks = `define ... {\n` ... `}\n`.
    // Postamble = everything after the last function block's `}\n`.

    // Phase 1: Find preamble end (first `define ` that isn't `define internal `)
    let mut preamble_end: usize = 0;
    let mut pos: usize = 0;
    while pos < len {
        // Find start of line
        let line_start = pos;
        // Find end of line
        let mut line_end = pos;
        while line_end < len && bytes[line_end] != 10 {
            line_end += 1;
        }
        let line_len = line_end - line_start;

        // Check if line starts with "define " and contains "@def" (user function).
        // Preamble functions (@main wrapper, internal builtins) use names like
        // @thread_spawn, @set_alloc_bypass_tracking. User functions are @defN_name.
        // Workers may not emit !dbg markers, so use @def as the reliable indicator.
        if line_len > 7
            && bytes[line_start] == 100 && bytes[line_start + 1] == 101  // "de"
            && bytes[line_start + 2] == 102 && bytes[line_start + 3] == 105  // "fi"
            && bytes[line_start + 4] == 110 && bytes[line_start + 5] == 101  // "ne"
            && bytes[line_start + 6] == 32  // " "
        {
            // Check if this define line contains "@def" (Blood user function marker)
            let mut has_def_fn = false;
            let mut di: usize = line_start + 7;
            while di + 3 < line_end {
                if bytes[di] == 64 && bytes[di + 1] == 100  // "@d"
                    && bytes[di + 2] == 101 && bytes[di + 3] == 102 // "ef"
                {
                    has_def_fn = true;
                    di = line_end; // break
                }
                di += 1;
            }
            if has_def_fn {
                preamble_end = line_start;
                pos = line_start; // don't advance past this line
                break;
            }
        }
        pos = line_end + 1;
    }
    if preamble_end == 0 { preamble_end = len; }

    // Phase 2: Collect function blocks with their names and byte ranges.
    // Each function: (name_hash, block_start, block_end)
    let mut fn_blocks: Vec<(u64, usize, usize)> = Vec.with_capacity(5000);
    pos = preamble_end;
    while pos < len {
        let line_start = pos;
        let mut line_end = pos;
        while line_end < len && bytes[line_end] != 10 {
            line_end += 1;
        }
        let line_len = line_end - line_start;

        // Check for "define "
        if line_len > 7
            && bytes[line_start] == 100 && bytes[line_start + 1] == 101
            && bytes[line_start + 2] == 102 && bytes[line_start + 3] == 105
            && bytes[line_start + 4] == 110 && bytes[line_start + 5] == 101
            && bytes[line_start + 6] == 32
        {
            let block_start = line_start;
            // Extract function name: find '@' then read until '('
            let mut at_pos = line_start + 7;
            while at_pos < line_end && bytes[at_pos] != 64 { // '@'
                at_pos += 1;
            }
            let name_start = at_pos + 1;
            let mut name_end_pos = name_start;
            while name_end_pos < line_end && bytes[name_end_pos] != 40 { // '('
                name_end_pos += 1;
            }
            // Hash the function name
            let name_hash = hashmap.hash_bytes_range(bytes, name_start, name_end_pos);

            // Check for single-line define: `define ... { ... }` all on one line
            // Look for `}` at end of this line (before newline)
            let mut last_char_pos = line_end;
            while last_char_pos > line_start && (bytes[last_char_pos - 1] == 32 || bytes[last_char_pos - 1] == 13) {
                last_char_pos -= 1;
            }
            if last_char_pos > line_start && bytes[last_char_pos - 1] == 125 { // '}' at end of line
                // Single-line function — the block is just this one line
                let block_end = line_end + 1;
                fn_blocks.push((name_hash, block_start, if block_end > len { len } else { block_end }));
                pos = block_end;
                continue;
            }

            // Multi-line function: find end of function block (line starting with '}')
            pos = line_end + 1;
            while pos < len {
                if bytes[pos] == 125 { // '}'
                    // Check if it's a line that's just '}'
                    let mut eol = pos + 1;
                    while eol < len && bytes[eol] != 10 { eol += 1; }
                    let after_brace_len = eol - pos - 1;
                    if after_brace_len == 0 || (after_brace_len == 1 && bytes[pos + 1] == 13) {
                        // Found function end
                        let block_end = eol + 1; // include the newline
                        fn_blocks.push((name_hash, block_start, if block_end > len { len } else { block_end }));
                        pos = block_end;
                        break;
                    }
                }
                // Advance to next line
                while pos < len && bytes[pos] != 10 { pos += 1; }
                pos += 1;
            }
            continue;
        }

        // Non-define line after preamble but before/between functions (e.g., blank lines)
        // will be captured as part of the postamble or inter-function gap
        pos = line_end + 1;
    }

    // Postamble starts after the last function block
    let postamble_start = if fn_blocks.len() > 0 {
        fn_blocks[fn_blocks.len() - 1].2
    } else {
        preamble_end
    };

    // Phase 3: Generate cross-module declares from ctx.fn_signatures
    let all_declares = ctx.generate_all_declares();

    // Build def_id → module_index map from worklist
    let mut defid_to_module: hashmap.HashMapU64U32 = hashmap.HashMapU64U32.with_capacity(worklist.items.len());
    for wi in 0usize..worklist.items.len() {
        defid_to_module.insert(worklist.items[wi].def_id.index as u64, worklist.items[wi].module_index);
    }

    // Phase 4: Write per-module files
    // Each file = preamble + cross-module declares + module's functions + postamble
    for mi in 0usize..module_count {
        let module_idx = mi as u32;
        let path = &module_paths[mi];

        // Write preamble. For non-module-0, strip the @main define (replace with declare)
        // and convert static globals to external declarations.
        let mut preamble = String.new();
        let mut pi: usize = 0;
        let mut skip_until_brace_line = false;
        while pi < preamble_end {
            // Find the current line
            let line_start = pi;
            let mut line_end = pi;
            while line_end < preamble_end && bytes[line_end] != 10 {
                line_end += 1;
            }
            let line_len = line_end - line_start;

            if module_idx != 0 {
                // Skip @main function block in non-module-0 files
                if skip_until_brace_line {
                    // Check if line is just '}'
                    if line_len >= 1 && bytes[line_start] == 125 { // '}'
                        skip_until_brace_line = false;
                    }
                    pi = line_end + 1;
                    continue;
                }
                // Detect "define i32 @main("
                if line_len > 18
                    && bytes[line_start] == 100 && bytes[line_start + 1] == 101  // "de"
                    && bytes[line_start + 2] == 102 && bytes[line_start + 3] == 105  // "fi"
                    && bytes[line_start + 4] == 110 && bytes[line_start + 5] == 101  // "ne"
                    && bytes[line_start + 6] == 32  // " "
                    && bytes[line_start + 7] == 105 && bytes[line_start + 8] == 51  // "i3"
                    && bytes[line_start + 9] == 50 && bytes[line_start + 10] == 32 // "2 "
                    && bytes[line_start + 11] == 64 // "@"
                    && bytes[line_start + 12] == 109 // "m"
                    && bytes[line_start + 13] == 97  // "a"
                    && bytes[line_start + 14] == 105 // "i"
                    && bytes[line_start + 15] == 110 // "n"
                {
                    skip_until_brace_line = true;
                    pi = line_end + 1;
                    continue;
                }
                // Convert "= global " to "= external global " for statics
                if line_len > 2 && bytes[line_start] == 64 { // '@' at start
                    let mut has_global = false;
                    let mut global_pos: usize = 0;
                    let mut gi = line_start;
                    while gi + 8 < line_end {
                        if bytes[gi] == 61 && bytes[gi + 1] == 32  // "= "
                            && bytes[gi + 2] == 103 && bytes[gi + 3] == 108 // "gl"
                            && bytes[gi + 4] == 111 && bytes[gi + 5] == 98  // "ob"
                            && bytes[gi + 6] == 97 && bytes[gi + 7] == 108  // "al"
                            && bytes[gi + 8] == 32 // " "
                        {
                            has_global = true;
                            global_pos = gi;
                            gi = line_end; // break
                        }
                        gi += 1;
                    }
                    // Skip string constant definitions: they use "constant" not "global"
                    // and their content may contain "= global " which would be
                    // incorrectly transformed (the root cause of the splitter bug).
                    if has_global {
                        let mut has_constant = false;
                        let mut ci2 = line_start;
                        while ci2 + 8 < line_end {
                            if bytes[ci2] == 99 && bytes[ci2 + 1] == 111  // "co"
                                && bytes[ci2 + 2] == 110 && bytes[ci2 + 3] == 115  // "ns"
                                && bytes[ci2 + 4] == 116 && bytes[ci2 + 5] == 97  // "ta"
                                && bytes[ci2 + 6] == 110 && bytes[ci2 + 7] == 116  // "nt"
                            {
                                has_constant = true;
                                ci2 = line_end;
                            }
                            ci2 += 1;
                        }
                        if has_constant {
                            has_global = false;
                        }
                    }
                    if has_global {
                        // Copy up to "= " then insert "external " before "global "
                        let mut ci = line_start;
                        while ci < global_pos + 2 { // include "= "
                            preamble.push(bytes[ci] as char);
                            ci += 1;
                        }
                        preamble.push_str("external global ");
                        // Skip to after "global " in the original — find the type
                        ci = global_pos + 9; // past "= global "
                        // Copy the type (up to space before initializer or end of line)
                        // Find " zeroinitializer" or " {" or end
                        let mut type_end = ci;
                        let mut brace_depth: i32 = 0;
                        while type_end < line_end {
                            if bytes[type_end] == 123 { brace_depth += 1; } // '{'
                            if bytes[type_end] == 125 { brace_depth -= 1; } // '}'
                            if brace_depth == 0 && bytes[type_end] == 32 { // space at depth 0
                                break;
                            }
                            type_end += 1;
                        }
                        while ci < type_end {
                            preamble.push(bytes[ci] as char);
                            ci += 1;
                        }
                        preamble.push('\n');
                        pi = line_end + 1;
                        continue;
                    }
                }
            }
            // Copy line as-is
            while pi < line_end {
                preamble.push(bytes[pi] as char);
                pi += 1;
            }
            if pi < preamble_end {
                preamble.push('\n');
                pi += 1;
            }
        }
        file_write_string(path.as_str(), preamble.as_str());

        // Write cross-module declares (for worklist functions NOT in this module).
        // Skip functions not in the worklist (stubs, handler wrappers) — they only
        // exist as defines in module 0 and are not called cross-module.
        for di in 0usize..all_declares.len() {
            let decl_def_id = all_declares[di].0;
            match defid_to_module.get(decl_def_id as u64) {
                Option.Some(decl_module) => {
                    if decl_module != module_idx {
                        file_append_string(path.as_str(), all_declares[di].1.as_str());
                    }
                }
                Option.None => {} // Not in worklist — skip
            }
        }

        // Write this module's function blocks
        for fi in 0usize..fn_blocks.len() {
            let fn_module = match name_to_module.get(fn_blocks[fi].0) {
                Option.Some(m) => m,
                Option.None => 0, // unmatched functions (closures, stubs) → module 0
            };
            if fn_module == module_idx {
                let block_start = fn_blocks[fi].1;
                let block_end = fn_blocks[fi].2;
                let mut block = String.new();
                let mut bi: usize = block_start;
                while bi < block_end {
                    block.push(bytes[bi] as char);
                    bi += 1;
                }
                file_append_string(path.as_str(), block.as_str());
            }
        }

        // Write postamble (string constants, metadata, etc.)
        if postamble_start < len {
            let mut postamble = String.new();
            let mut oi: usize = postamble_start;
            while oi < len {
                postamble.push(bytes[oi] as char);
                oi += 1;
            }
            file_append_string(path.as_str(), postamble.as_str());
        }
    }

    let split_elapsed = blood_clock_millis() - split_start;
    eprint_str("\n  Module split: ");
    eprint_str(int_to_string(module_count as i32));
    eprint_str(" modules in ");
    eprint_str(int_to_string(split_elapsed as i32));
    eprint_str("ms\n");
}

/// Incremental variant of split_monolithic_to_modules.
/// Only regenerates .ll files for changed modules. Unchanged modules keep their cached files.
/// The monolithic .ll only contains functions from changed modules, so unchanged modules
/// are simply skipped during the split.
fn split_monolithic_to_modules_incremental(
    monolithic_path: &str,
    worklist: &CodegenWorkList,
    module_names: &Vec<String>,
    ctx: &codegen_ctx.CodegenCtx,
    build_dir: &str,
    skip_modules: &Vec<bool>,
) {
    let split_start = blood_clock_millis();
    let module_count = module_names.len();
    if module_count <= 1 { return; }

    // Build function name → module_index map from worklist (only changed modules)
    let mut name_to_module: hashmap.HashMapU64U32 = hashmap.HashMapU64U32.with_capacity(worklist.items.len());
    for wi in 0usize..worklist.items.len() {
        let mi = worklist.items[wi].module_index as usize;
        if mi < skip_modules.len() && skip_modules[mi] {
            continue; // Skip unchanged modules' functions
        }
        let name_hash = hashmap.hash_str(worklist.items[wi].fn_name.as_str());
        name_to_module.insert(name_hash, worklist.items[wi].module_index);
    }

    // Read the monolithic file (contains only changed modules' functions)
    let content: &str = file_read_to_string(monolithic_path);
    let bytes = content.as_bytes();
    let len = bytes.len();
    if len == 0 { return; }

    let mut obj_dir = String.new();
    obj_dir.push_str(build_dir);
    obj_dir.push_str("/obj");
    main_helpers.ensure_dir(obj_dir.as_str());

    // Build per-module output paths
    let mut module_paths: Vec<String> = Vec.with_capacity(module_count);
    for mi in 0usize..module_count {
        let stem = if mi == 0 {
            common.make_string("main")
        } else {
            main_helpers.file_stem(&module_names[mi])
        };
        let mut mpath = common.make_string(obj_dir.as_str());
        mpath.push('/');
        mpath.push_str(stem.as_str());
        mpath.push_str(".ll");
        module_paths.push(mpath);
    }

    // Find preamble end (first define with !dbg)
    let mut preamble_end: usize = 0;
    let mut pos: usize = 0;
    while pos < len {
        let line_start = pos;
        let mut line_end = pos;
        while line_end < len && bytes[line_end] != 10 { line_end += 1; }
        let line_len = line_end - line_start;
        if line_len > 7
            && bytes[line_start] == 100 && bytes[line_start + 1] == 101
            && bytes[line_start + 2] == 102 && bytes[line_start + 3] == 105
            && bytes[line_start + 4] == 110 && bytes[line_start + 5] == 101
            && bytes[line_start + 6] == 32
        {
            let mut has_dbg = false;
            let mut di: usize = line_start + 7;
            while di + 3 < line_end {
                if bytes[di] == 33 && bytes[di + 1] == 100
                    && bytes[di + 2] == 98 && bytes[di + 3] == 103 {
                    has_dbg = true;
                    di = line_end;
                }
                di += 1;
            }
            if has_dbg {
                preamble_end = line_start;
                pos = line_start;
                break;
            }
        }
        pos = line_end + 1;
    }
    if preamble_end == 0 { preamble_end = len; }

    // Collect function blocks
    let mut fn_blocks: Vec<(u64, usize, usize)> = Vec.with_capacity(3000);
    pos = preamble_end;
    while pos < len {
        let line_start = pos;
        let mut line_end = pos;
        while line_end < len && bytes[line_end] != 10 { line_end += 1; }
        let line_len = line_end - line_start;
        if line_len > 7
            && bytes[line_start] == 100 && bytes[line_start + 1] == 101
            && bytes[line_start + 2] == 102 && bytes[line_start + 3] == 105
            && bytes[line_start + 4] == 110 && bytes[line_start + 5] == 101
            && bytes[line_start + 6] == 32
        {
            let block_start = line_start;
            let mut at_pos = line_start + 7;
            while at_pos < line_end && bytes[at_pos] != 64 { at_pos += 1; }
            let name_start = at_pos + 1;
            let mut name_end_pos = name_start;
            while name_end_pos < line_end && bytes[name_end_pos] != 40 { name_end_pos += 1; }
            let name_hash = hashmap.hash_bytes_range(bytes, name_start, name_end_pos);

            // Single-line function check
            let mut last_char_pos = line_end;
            while last_char_pos > line_start && (bytes[last_char_pos - 1] == 32 || bytes[last_char_pos - 1] == 13) {
                last_char_pos -= 1;
            }
            if last_char_pos > line_start && bytes[last_char_pos - 1] == 125 {
                let block_end = line_end + 1;
                fn_blocks.push((name_hash, block_start, if block_end > len { len } else { block_end }));
                pos = block_end;
                continue;
            }
            // Multi-line function
            pos = line_end + 1;
            while pos < len {
                if bytes[pos] == 125 {
                    let mut eol = pos + 1;
                    while eol < len && bytes[eol] != 10 { eol += 1; }
                    let after = eol - pos - 1;
                    if after == 0 || (after == 1 && bytes[pos + 1] == 13) {
                        let block_end = eol + 1;
                        fn_blocks.push((name_hash, block_start, if block_end > len { len } else { block_end }));
                        pos = block_end;
                        break;
                    }
                }
                while pos < len && bytes[pos] != 10 { pos += 1; }
                pos += 1;
            }
            continue;
        }
        pos = line_end + 1;
    }

    let postamble_start = if fn_blocks.len() > 0 {
        fn_blocks[fn_blocks.len() - 1].2
    } else { preamble_end };

    // Generate cross-module declares (includes both fresh + cached signatures)
    let all_declares = ctx.generate_all_declares();
    let mut defid_to_module: hashmap.HashMapU64U32 = hashmap.HashMapU64U32.with_capacity(worklist.items.len());
    for wi in 0usize..worklist.items.len() {
        defid_to_module.insert(worklist.items[wi].def_id.index as u64, worklist.items[wi].module_index);
    }

    // Write ONLY changed modules' .ll files
    let mut changed_written: usize = 0;
    for mi in 0usize..module_count {
        let module_idx = mi as u32;
        if mi < skip_modules.len() && skip_modules[mi] {
            continue; // Unchanged — keep cached .ll
        }
        changed_written += 1;
        let mpath = &module_paths[mi];

        // Write preamble (with @main / static fixups for non-module-0)
        let mut preamble = String.new();
        let mut pi: usize = 0;
        let mut skip_until_brace = false;
        while pi < preamble_end {
            let ls = pi;
            let mut le = pi;
            while le < preamble_end && bytes[le] != 10 { le += 1; }
            let ll = le - ls;
            if module_idx != 0 {
                if skip_until_brace {
                    if ll >= 1 && bytes[ls] == 125 { skip_until_brace = false; }
                    pi = le + 1;
                    continue;
                }
                if ll > 18
                    && bytes[ls] == 100 && bytes[ls+1] == 101 && bytes[ls+2] == 102
                    && bytes[ls+3] == 105 && bytes[ls+4] == 110 && bytes[ls+5] == 101
                    && bytes[ls+6] == 32 && bytes[ls+7] == 105 && bytes[ls+8] == 51
                    && bytes[ls+9] == 50 && bytes[ls+10] == 32 && bytes[ls+11] == 64
                    && bytes[ls+12] == 109 && bytes[ls+13] == 97 && bytes[ls+14] == 105
                    && bytes[ls+15] == 110
                {
                    skip_until_brace = true;
                    pi = le + 1;
                    continue;
                }
                if ll > 2 && bytes[ls] == 64 {
                    let mut has_global = false;
                    let mut gp: usize = 0;
                    let mut gi = ls;
                    while gi + 8 < le {
                        if bytes[gi] == 61 && bytes[gi+1] == 32 && bytes[gi+2] == 103
                            && bytes[gi+3] == 108 && bytes[gi+4] == 111 && bytes[gi+5] == 98
                            && bytes[gi+6] == 97 && bytes[gi+7] == 108 && bytes[gi+8] == 32 {
                            has_global = true; gp = gi; gi = le;
                        }
                        gi += 1;
                    }
                    if has_global {
                        let mut ci = ls;
                        while ci < gp + 2 { preamble.push(bytes[ci] as char); ci += 1; }
                        preamble.push_str("external global ");
                        ci = gp + 9;
                        let mut bd: i32 = 0;
                        let mut te = ci;
                        while te < le {
                            if bytes[te] == 123 { bd += 1; }
                            if bytes[te] == 125 { bd -= 1; }
                            if bd == 0 && bytes[te] == 32 { break; }
                            te += 1;
                        }
                        while ci < te { preamble.push(bytes[ci] as char); ci += 1; }
                        preamble.push('\n');
                        pi = le + 1;
                        continue;
                    }
                }
            }
            while pi < le { preamble.push(bytes[pi] as char); pi += 1; }
            if pi < preamble_end { preamble.push('\n'); pi += 1; }
        }
        file_write_string(mpath.as_str(), preamble.as_str());

        // Cross-module declares
        for di in 0usize..all_declares.len() {
            let did = all_declares[di].0;
            match defid_to_module.get(did as u64) {
                Option.Some(dm) => {
                    if dm != module_idx {
                        file_append_string(mpath.as_str(), all_declares[di].1.as_str());
                    }
                }
                Option.None => {}
            }
        }

        // This module's function blocks
        for fi in 0usize..fn_blocks.len() {
            let fm = match name_to_module.get(fn_blocks[fi].0) {
                Option.Some(m) => m,
                Option.None => 0,
            };
            if fm == module_idx {
                let bs = fn_blocks[fi].1;
                let be = fn_blocks[fi].2;
                let mut block = String.new();
                let mut bi = bs;
                while bi < be { block.push(bytes[bi] as char); bi += 1; }
                file_append_string(mpath.as_str(), block.as_str());
            }
        }

        // Postamble
        if postamble_start < len {
            let mut post = String.new();
            let mut oi = postamble_start;
            while oi < len { post.push(bytes[oi] as char); oi += 1; }
            file_append_string(mpath.as_str(), post.as_str());
        }
    }

    let split_elapsed = blood_clock_millis() - split_start;
    eprint_str("\n  Incremental split: ");
    eprint_str(int_to_string(changed_written as i32));
    eprint_str(" changed modules in ");
    eprint_str(int_to_string(split_elapsed as i32));
    eprint_str("ms\n");
}

// ============================================================
// Debug Dump: Type Resolutions
// ============================================================

/// Dumps type/field/method resolution tables to stderr.
fn dump_type_resolutions(typeck_result: &typeck_driver.TypeCheckResult) {
    // Field resolutions
    eprint_str("=== Field Resolutions (");
    let mut field_count_str = String.new();
    push_usize(&mut field_count_str, typeck_result.field_resolutions.len());
    eprint_str(field_count_str.as_str());
    eprint_str(" entries) ===\n");
    for fi in 0usize..typeck_result.field_resolutions.len() {
        let entry = &typeck_result.field_resolutions[fi];
        let mut line = String.new();
        line.push_str("  field[body=d");
        push_usize(&mut line, entry.body_def_id as usize);
        line.push_str(", span=");
        push_usize(&mut line, entry.span_start);
        line.push_str("] -> idx ");
        push_usize(&mut line, entry.field_idx as usize);
        line.push('\n');
        eprint_str(line.as_str());
    }

    // Method resolutions
    eprint_str("=== Method Resolutions (");
    let mut meth_count_str = String.new();
    push_usize(&mut meth_count_str, typeck_result.method_resolutions.len());
    eprint_str(meth_count_str.as_str());
    eprint_str(" entries) ===\n");
    for mi in 0usize..typeck_result.method_resolutions.len() {
        let entry = &typeck_result.method_resolutions[mi];
        let mut line = String.new();
        line.push_str("  method[body=d");
        push_usize(&mut line, entry.body_def_id as usize);
        line.push_str(", span=");
        push_usize(&mut line, entry.span_start);
        line.push_str("] -> def");
        push_usize(&mut line, entry.def_id_index as usize);
        line.push('\n');
        eprint_str(line.as_str());
    }

    // Type variable substitutions
    eprint_str("=== Type Variable Substitutions (");
    let mut tv_count_str = String.new();
    push_usize(&mut tv_count_str, typeck_result.subst_table.ty_substs.len());
    eprint_str(tv_count_str.as_str());
    eprint_str(" entries) ===\n");
    for ti in 0usize..typeck_result.subst_table.ty_substs.len() {
        let subst = &typeck_result.subst_table.ty_substs[ti];
        let mut line = String.new();
        line.push_str("  ?");
        push_usize(&mut line, subst.var_id.index as usize);
        line.push_str(" -> ");
        let type_ty = type_intern.ty_id_to_type(subst.ty);
        let type_str = dump_mir.format_type(&type_ty);
        line.push_str(type_str.as_str());
        line.push('\n');
        eprint_str(line.as_str());
    }

    // Builtin def names
    eprint_str("=== Builtin Def Names (");
    let mut bdn_count_str = String.new();
    push_usize(&mut bdn_count_str, typeck_result.builtin_def_names.len());
    eprint_str(bdn_count_str.as_str());
    eprint_str(" entries) ===\n");
    for bi in 0usize..typeck_result.builtin_def_names.len() {
        let entry = &typeck_result.builtin_def_names[bi];
        let mut line = String.new();
        line.push_str("  def");
        push_usize(&mut line, entry.def_id_index as usize);
        line.push_str(" -> ");
        line.push_str(entry.runtime_name.as_str());
        line.push('\n');
        eprint_str(line.as_str());
    }
}

/// Dumps ADT layouts (struct/enum sizes, fields, variant layouts) to stderr.
fn dump_adt_layouts(ctx: &codegen_ctx.CodegenCtx) {
    eprint_str("=== ADT Layouts (");
    let mut count_str = String.new();
    push_usize(&mut count_str, ctx.adt_registry.len());
    eprint_str(count_str.as_str());
    eprint_str(" entries) ===\n");

    for i in 0usize..ctx.adt_registry.len() {
        match &ctx.adt_registry[i] {
            &codegen_ctx.AdtEntry.Struct(ref layout) => {
                let total_size = codegen_size.llvm_type_size(layout.llvm_type.as_str());
                // Header: struct defN: SIZE bytes
                let mut line = String.new();
                line.push_str("  struct def");
                push_usize(&mut line, layout.def_id as usize);
                // Try to resolve the name
                match ctx.lookup_def_name(layout.def_id) {
                    Option.Some(ref name) => {
                        line.push_str(" (");
                        line.push_str(name.as_str());
                        line.push(')');
                    }
                    Option.None => {}
                }
                line.push_str(": ");
                push_u64(&mut line, total_size);
                line.push_str(" bytes, llvm ");
                line.push_str(layout.llvm_type.as_str());
                line.push('\n');
                eprint_str(line.as_str());

                // Fields
                for fi in 0usize..layout.fields.len() {
                    let field = &layout.fields[fi];
                    let field_size = codegen_size.llvm_type_size(field.llvm_type.as_str());
                    let mut fline = String.new();
                    fline.push_str("      field ");
                    push_usize(&mut fline, fi);
                    fline.push_str(": ");
                    fline.push_str(field.llvm_type.as_str());
                    fline.push_str(" (");
                    push_u64(&mut fline, field_size);
                    fline.push_str(" bytes)");
                    match &field.hir_type {
                        &Option.Some(ty_id) => {
                            let ty = type_intern.ty_id_to_type(ty_id);
                            fline.push_str("  // ");
                            let type_str = dump_mir.format_type(&ty);
                            fline.push_str(type_str.as_str());
                        }
                        &Option.None => {}
                    }
                    fline.push('\n');
                    eprint_str(fline.as_str());
                }
            }
            &codegen_ctx.AdtEntry.Enum(ref layout) => {
                let total_size = codegen_size.llvm_type_size(layout.llvm_type.as_str());
                let disc_size = codegen_size.llvm_type_size(layout.discriminant_type.as_str());
                // Header: enum defN: SIZE bytes
                let mut line = String.new();
                line.push_str("  enum def");
                push_usize(&mut line, layout.def_id as usize);
                match ctx.lookup_def_name(layout.def_id) {
                    Option.Some(ref name) => {
                        line.push_str(" (");
                        line.push_str(name.as_str());
                        line.push(')');
                    }
                    Option.None => {}
                }
                line.push_str(": ");
                push_u64(&mut line, total_size);
                line.push_str(" bytes, llvm ");
                line.push_str(layout.llvm_type.as_str());
                line.push('\n');
                eprint_str(line.as_str());

                // Discriminant
                let mut dline = String.new();
                dline.push_str("      discriminant: ");
                dline.push_str(layout.discriminant_type.as_str());
                dline.push_str(" (");
                push_u64(&mut dline, disc_size);
                dline.push_str(" bytes)\n");
                eprint_str(dline.as_str());

                // Max payload
                let mut pline = String.new();
                pline.push_str("      max_payload: ");
                push_u64(&mut pline, layout.max_payload_size);
                pline.push_str(" bytes\n");
                eprint_str(pline.as_str());

                // Variants
                for vi in 0usize..layout.variants.len() {
                    let variant = &layout.variants[vi];
                    let mut vline = String.new();
                    vline.push_str("      variant ");
                    push_usize(&mut vline, variant.variant_idx as usize);
                    vline.push_str(": payload ");
                    vline.push_str(variant.payload_llvm_type.as_str());
                    let vsize = codegen_size.llvm_type_size(variant.payload_llvm_type.as_str());
                    vline.push_str(" (");
                    push_u64(&mut vline, vsize);
                    vline.push_str(" bytes)\n");
                    eprint_str(vline.as_str());

                    // Variant fields
                    for vfi in 0usize..variant.fields.len() {
                        let field = &variant.fields[vfi];
                        let field_size = codegen_size.llvm_type_size(field.llvm_type.as_str());
                        let mut fline = String.new();
                        fline.push_str("          field ");
                        push_usize(&mut fline, vfi);
                        fline.push_str(": ");
                        fline.push_str(field.llvm_type.as_str());
                        fline.push_str(" (");
                        push_u64(&mut fline, field_size);
                        fline.push_str(" bytes)");
                        match &field.hir_type {
                            &Option.Some(ty_id) => {
                                let ty = type_intern.ty_id_to_type(ty_id);
                                fline.push_str("  // ");
                                let type_str = dump_mir.format_type(&ty);
                                fline.push_str(type_str.as_str());
                            }
                            &Option.None => {}
                        }
                        fline.push('\n');
                        eprint_str(fline.as_str());
                    }
                }
            }
        }
    }
}

/// Formats and prints a millisecond timing value with right-aligned ms suffix.
fn print_timing_ms(ms: u64) {
    let mut buf = String.new();
    push_u64(&mut buf, ms);
    buf.push_str("ms\n");
    print_str(buf.as_str());
}

/// Pushes a u64 value with comma separators into a string.
fn push_u64(s: &mut String, val: u64) {
    if val == 0 {
        s.push('0');
        return;
    }
    // Build digits in reverse
    let mut digits: Vec<u8> = Vec.new();
    let mut n = val;
    while n > 0 {
        let digit = (n % 10) as u8;
        digits.push(digit + 48);
        n /= 10;
    }
    // Push in reverse order with comma separators
    let len = digits.len();
    let mut i = len;
    while i > 0 {
        i -= 1;
        s.push(digits[i] as char);
        let pos_from_right = i;
        if pos_from_right > 0 && pos_from_right % 3 == 0 {
            s.push(',');
        }
    }
}

/// Pushes a usize as decimal digits into a string.
fn push_usize(s: &mut String, val: usize) {
    if val == 0 {
        s.push('0');
        return;
    }
    // Build digits in reverse
    let mut digits: Vec<u8> = Vec.new();
    let mut n = val;
    while n > 0 {
        let digit = (n % 10) as u8;
        digits.push(digit + 48);
        n /= 10;
    }
    // Push in reverse order
    let mut i = digits.len();
    while i > 0 {
        i -= 1;
        s.push(digits[i] as char);
    }
}
